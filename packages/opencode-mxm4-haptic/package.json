{
  "name": "@h82/opencode-mxm4-haptic",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "OpenCode plugin that pulses MX Master 4 haptics on OpenCode events via the mxm4-hapticd daemon.",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=20"
  },
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.mts"
    }
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "@h82/mxm4-haptic": "workspace:*",
    "ts-pattern": "5.9.0"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@opencode-ai/plugin": "1.16.2",
    "@types/node": "25.9.2",
    "eslint": "10.4.1",
    "eslint-config-prettier": "10.1.8",
    "prettier": "3.8.3",
    "tsdown": "0.22.2",
    "typescript": "6.0.3",
    "typescript-eslint": "8.61.0"
  },
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --test",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  }
}
