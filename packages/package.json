{
  "name": "@h82/dotfiles",
  "version": "0.0.0",
  "private": true,
  "packageManager": "bun@1.3.14",
  "workspaces": [
    "*"
  ],
  "scripts": {
    "build": "vp run -r build",
    "typecheck": "vp run -r typecheck",
    "test": "vp run -r test",
    "check": "vp check",
    "lint": "vp lint",
    "format": "vp fmt .",
    "format:check": "vp fmt --check ."
  },
  "devDependencies": {
    "vite": "catalog:",
    "vite-plus": "catalog:"
  },
  "catalog": {
    "vite": "npm:@voidzero-dev/vite-plus-core@0.2.3",
    "vite-plus": "0.2.3",
    "vitest": "4.1.9"
  },
  "overrides": {
    "vite": "catalog:",
    "vitest": "catalog:"
  }
}
