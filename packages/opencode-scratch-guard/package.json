{
  "name": "@h82/opencode-scratch-guard",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "OpenCode plugin that injects a per-user scratch dir as $TMPDIR and denies the shared system temp (/tmp, /var/tmp, /dev/shm) per AGENTS.md.",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=24"
  },
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.mts"
    }
  },
  "files": [
    "dist"
  ],
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@opencode-ai/plugin": "1.16.2",
    "@types/node": "24.13.2",
    "eslint": "10.4.1",
    "eslint-config-prettier": "10.1.8",
    "prettier": "3.8.3",
    "tsdown": "0.22.2",
    "typescript": "6.0.3",
    "typescript-eslint": "8.61.0"
  },
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "bun test",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  }
}
