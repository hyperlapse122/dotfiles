{
  "name": "@h82/mxm4-haptic",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "TypeScript client for the mxm4-hapticd AF_UNIX daemon (MX Master 4 haptics).",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=20"
  },
  "exports": {
