#!/usr/bin/env bash
# import-wifi-1password — provision NetworkManager Wi-Fi connections declaratively
# from .chezmoidata/networking.yaml (`networking.wifi`).
#
#   import-wifi-1password              # add/overwrite every network in the manifest
#   import-wifi-1password --dry-run    # show what would change; change nothing
#   import-wifi-1password --force      # delete + recreate existing connections
#
# MODEL: the set of networks is defined in .chezmoidata/networking.yaml (single
# source of truth) — NOT discovered by listing 1Password items (the previous
# design). Each run converges NetworkManager to the file: a network with no
# matching connection is ADDED; one that already exists is OVERWRITTEN in place
# (its PSK, per-family DNS, and autoconnect priority re-applied via
# `nmcli connection modify`, which does NOT drop an active link — new settings
# take effect on the next (re)connect). --force instead deletes and recreates
# each existing connection for a guaranteed-clean slate (which does reconnect
# it).
#
# SECRETS: ssid/psk in the manifest may each be a literal OR a 1Password `op://`
# reference. References are resolved at chezmoi RENDER time (onepasswordRead) and
# baked into the JSON manifest embedded below — which is why this tool's source
# is `private_` (deployed 0700, owner-only) rather than a world-readable 0755
# ~/.local/bin script, and why it is Linux-gated in dot_local/bin/.chezmoiignore.
# There is NO 1Password / `op` dependency at runtime.
#
# USER-SPACE (no root): connections are created/modified with `nmcli` as the
# running user; NetworkManager authorizes via polkit and writes the root-owned
# 0600 keyfile itself — exactly how plasma-nm creates connections. The PSK
# travels through nmcli's argv for the lifetime of the call (visible in
# /proc/<pid>/cmdline); low-risk on a single-user desktop, and the only way to
# create connections as a non-root user without root-owned keyfile writes.
#
# DNS is split BY FAMILY at the schema level (defaults.ipv4.dns / ipv6.dns; same
# shape per-network to override). v4 entries write to ipv4.dns, v6 entries write
# to ipv6.dns. A single `ignoreAutoDns` flag applies to WHICHEVER family(ies)
# received manual entries — set it true and both families with manual DNS get
# `ignore-auto-dns yes`; the OTHER family is untouched. On modify, a family
# whose merged dns list is empty is CLEARED back to DHCP/RA (ipv{4,6}.dns "" +
# ignore-auto-dns no) — the declarative model.
#
# APPLY INTEGRATION: run_onchange_after_import-wifi-1password.sh.tmpl runs this
# with --from-apply (on a fingerprint change of networking.yaml or this tool,
# not every apply) — quieter, and every "environment not ready" condition (no
# NetworkManager, not running) exits 0 so it can never abort an apply.
#
# Linux-only BY DESIGN (NetworkManager is Linux-only): gated out on non-Linux via
# dot_local/bin/.chezmoiignore, so op:// secrets are never resolved into a
# macOS/Windows copy. Per the script-parity exception in AGENTS.md there is no
# .ps1 counterpart.

set -euo pipefail

# Configuration / counters (globals; set from argv).
DRY_RUN=false
FORCE=false
FROM_APPLY=false
ADDED=0
UPDATED=0
SKIPPED=0
FAILED=0

# Network manifest, rendered from .chezmoidata/networking.yaml with every op://
# ref resolved to its 1Password value (this is why the source is private_ 0700 —
# the JSON below holds the real PSKs). EDIT .chezmoidata/networking.yaml, never
# this deployed copy. `<<'WIFI_CONFIG_EOF'` is a literal heredoc (no shell
# expansion); resolve-op-refs-json.tmpl emits valid JSON (toJson-escaped) parsed
# by jq at runtime.
WIFI_CONFIG_JSON=$(cat <<'WIFI_CONFIG_EOF'
{{ includeTemplate "resolve-op-refs-json.tmpl" (dict "value" .networking.wifi "ctx" $) }}
WIFI_CONFIG_EOF
)

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------
log()  { printf 'import-wifi-1password: %s\n' "$*"; }
# vlog: chatter suppressed under --from-apply to keep `chezmoi apply` quiet.
vlog() { "$FROM_APPLY" || printf 'import-wifi-1password: %s\n' "$*"; }
warn() { printf 'import-wifi-1password: %s\n' "$*" >&2; }

usage() {
  cat <<'EOF'
Usage: import-wifi-1password [--dry-run] [--force]

Provision NetworkManager Wi-Fi connections from .chezmoidata/networking.yaml
(networking.wifi), one per network, as the running user (no sudo). Each network
is added if missing and overwritten in place if it already exists (its PSK,
DNS, and autoconnect priority re-applied). DNS is per-family (ipv4.dns /
ipv6.dns) with a single ignoreAutoDns flag that applies to whichever family(ies)
have manual entries.

Options:
  -n, --dry-run   Show what would change; make no changes.
  -f, --force     Delete and recreate existing connections instead of modifying.
  -h, --help      Show this help and exit.

Wi-Fi passwords come from .chezmoidata/networking.yaml (op:// references
resolved at chezmoi render time), so no 1Password/op access is needed at
runtime. Requires NetworkManager (nmcli) running and jq. Connections are
created via nmcli/polkit; no root needed.
EOF
}

# ---------------------------------------------------------------------------
# Exit helpers
# ---------------------------------------------------------------------------

# bail_env <message> : "environment not ready". Clean skip (exit 0) under
# --from-apply; failure (exit 1) when run by hand.
bail_env() {
  if "$FROM_APPLY"; then
    printf 'import-wifi-1password: skipped (%s)\n' "$1" >&2
    exit 0
  fi
  printf 'import-wifi-1password: %s\n' "$1" >&2
  exit 1
}

# ---------------------------------------------------------------------------
# NetworkManager helpers
# ---------------------------------------------------------------------------

# connection_uuids <ssid> : print the UUID of every NetworkManager connection
# named exactly <ssid>, one per line. NM (and KDE) name Wi-Fi connections after
# their SSID, and so does this tool, so a name match reliably detects an existing
# network — but the NAME is not unique, so every mutation below addresses the
# profile by UUID (nmcli's unique identifier), never by name. UUID column FIRST:
# UUIDs never contain ':', so the first ':' splits reliably even for SSIDs that
# contain colons (`-e no` disables terse escaping, which would otherwise
# backslash-escape the separator).
connection_uuids() {
  local ssid="$1" line
  while IFS= read -r line; do
    [[ "${line#*:}" == "$ssid" ]] && printf '%s\n' "${line%%:*}"
  done < <(nmcli -t -e no -f UUID,NAME connection show 2>/dev/null)
}

# delete_connection <uuid>
delete_connection() {
  nmcli connection delete uuid "$1" >/dev/null 2>&1 || true
}

# append_wifi_args <arrayname> <keymgmt> <psk> <dns4_csv> <dns6_csv> <ignore>
#                  <mode> : append security + per-family DNS nmcli properties
# to the named arg array (nameref). Security is set only for wpa-psk (open
# networks leave any wifi-sec alone; convert a secured connection to open with
# --force). Per family: a non-empty list sets ipv{4,6}.dns + ipv{4,6}.ignore-
# auto-dns (yes iff <ignore> is "true", else no); on `modify` an EMPTY list
# actively resets that family back to DHCP/RA (ipv{4,6}.dns "" +
# ignore-auto-dns no), while on `add` an empty list simply leaves NM's default.
append_wifi_args() {
  local -n _args="$1"
  local keymgmt="$2" psk="$3" dns4="$4" dns6="$5" ignore="$6" mode="$7"
  if [[ "$keymgmt" == "wpa-psk" ]]; then
    _args+=(wifi-sec.key-mgmt wpa-psk wifi-sec.psk "$psk")
  fi
  local ignore_val="no"
  [[ "$ignore" == "true" ]] && ignore_val="yes"
  if [[ -n "$dns4" ]]; then
    _args+=(ipv4.dns "$dns4" ipv4.ignore-auto-dns "$ignore_val")
  elif [[ "$mode" == "modify" ]]; then
    _args+=(ipv4.dns "" ipv4.ignore-auto-dns no)
  fi
  if [[ -n "$dns6" ]]; then
    _args+=(ipv6.dns "$dns6" ipv6.ignore-auto-dns "$ignore_val")
  elif [[ "$mode" == "modify" ]]; then
    _args+=(ipv6.dns "" ipv6.ignore-auto-dns no)
  fi
}

# add_connection <ssid> <psk> <keymgmt> <priority> <dns4> <dns6> <ignore> :
# nmcli connection add as the running user (polkit). nmcli writes the root-owned
# 0600 keyfile itself. Returns nonzero on failure.
add_connection() {
  local ssid="$1" psk="$2" keymgmt="$3" priority="$4" dns4="$5" dns6="$6" ignore="$7"
  local -a args=(connection add type wifi con-name "$ssid" ssid "$ssid"
    connection.autoconnect yes save yes)
  [[ -n "$priority" ]] && args+=(connection.autoconnect-priority "$priority")
  append_wifi_args args "$keymgmt" "$psk" "$dns4" "$dns6" "$ignore" add
  nmcli "${args[@]}" >/dev/null
}

# modify_connection <uuid> <psk> <keymgmt> <priority> <dns4> <dns6> <ignore> :
# converge an EXISTING connection to the manifest in place, without deleting it
# (so an active link is not dropped; new settings apply on the next connect).
# Priority is applied only when the manifest gives one — an absent priority is
# never synced back, so a value set by hand in NM is preserved. Returns nonzero
# on failure.
modify_connection() {
  local uuid="$1" psk="$2" keymgmt="$3" priority="$4" dns4="$5" dns6="$6" ignore="$7"
  local -a args=(connection modify uuid "$uuid" connection.autoconnect yes)
  [[ -n "$priority" ]] && args+=(connection.autoconnect-priority "$priority")
  append_wifi_args args "$keymgmt" "$psk" "$dns4" "$dns6" "$ignore" modify
  nmcli "${args[@]}" >/dev/null
}

# ---------------------------------------------------------------------------
# Per-network processing
# ---------------------------------------------------------------------------

# process_network <network-json> : one manifest network (defaults already merged
# in by the jq pass in main), updating ADDED/UPDATED/SKIPPED/FAILED.
process_network() {
  local net_json="$1" ssid psk prio dns4 dns6 ignore keymgmt desc
  ssid="$(jq -r '.ssid // ""' <<<"$net_json")"
  psk="$(jq -r '.psk // ""' <<<"$net_json")"
  prio="$(jq -r 'if .priority == null then "" else (.priority | tostring) end' <<<"$net_json")"
  dns4="$(jq -r '(.dns4 // []) | join(",")' <<<"$net_json")"
  dns6="$(jq -r '(.dns6 // []) | join(",")' <<<"$net_json")"
  ignore="$(jq -r 'if .ignoreAutoDns then "true" else "false" end' <<<"$net_json")"

  if [[ -z "$ssid" ]]; then
    warn "a network entry has no ssid (empty after op:// resolution); skipping"
    FAILED=$((FAILED + 1))
    return 0
  fi
  # NM documents connection.autoconnect-priority as valid in -999..999; an
  # out-of-range value would make the nmcli add/modify fail outright, so it is
  # warned-and-ignored ([[ ]] short-circuits, so the arithmetic tests only run
  # once the regex has proven integer-ness).
  if [[ -n "$prio" ]] \
    && ! [[ "$prio" =~ ^-?[0-9]+$ && "$prio" -ge -999 && "$prio" -le 999 ]]; then
    warn "network \"$ssid\": priority \"$prio\" is not an integer in -999..999; ignoring"
    prio=""
  fi
  if [[ -n "$psk" ]]; then keymgmt="wpa-psk"; else keymgmt="none"; fi

  desc="$keymgmt"
  if [[ -z "$dns4" && -z "$dns6" ]]; then
    desc="$desc, dns DHCP"
  else
    local dns_desc=""
    [[ -n "$dns4" ]] && dns_desc="dns4 $dns4"
    if [[ -n "$dns6" ]]; then
      [[ -n "$dns_desc" ]] && dns_desc="$dns_desc + "
      dns_desc="${dns_desc}dns6 $dns6"
    fi
    [[ "$ignore" == "true" ]] && dns_desc="$dns_desc (only)"
    desc="$desc, $dns_desc"
  fi
  [[ -n "$prio" ]] && desc="$desc, prio $prio"

  local -a uuids=()
  mapfile -t uuids < <(connection_uuids "$ssid")

  # No existing connection -> ADD.
  if ((${#uuids[@]} == 0)); then
    if "$DRY_RUN"; then
      log "would add \"$ssid\" ($desc)"
      ADDED=$((ADDED + 1))
      return 0
    fi
    if add_connection "$ssid" "$psk" "$keymgmt" "$prio" "$dns4" "$dns6" "$ignore"; then
      log "added \"$ssid\" ($desc)"
      ADDED=$((ADDED + 1))
    else
      warn "failed to add \"$ssid\""
      FAILED=$((FAILED + 1))
    fi
    return 0
  fi

  # --force -> delete every match and recreate one fresh (clean slate).
  if "$FORCE"; then
    if "$DRY_RUN"; then
      log "would replace \"$ssid\" ($desc)"
      ADDED=$((ADDED + 1))
      return 0
    fi
    local uuid
    for uuid in "${uuids[@]}"; do
      delete_connection "$uuid"
    done
    if add_connection "$ssid" "$psk" "$keymgmt" "$prio" "$dns4" "$dns6" "$ignore"; then
      log "replaced \"$ssid\" ($desc)"
      ADDED=$((ADDED + 1))
    else
      warn "failed to recreate \"$ssid\""
      FAILED=$((FAILED + 1))
    fi
    return 0
  fi

  # Existing, no --force -> overwrite in place. Several profiles sharing the SSID
  # make the target ambiguous, so warn and leave them all alone (use --force to
  # collapse them into one).
  if ((${#uuids[@]} > 1)); then
    warn "${#uuids[@]} connections are named \"$ssid\"; skipping (ambiguous target — use --force to replace)"
    SKIPPED=$((SKIPPED + 1))
    return 0
  fi
  if "$DRY_RUN"; then
    log "would update \"$ssid\" ($desc)"
    UPDATED=$((UPDATED + 1))
    return 0
  fi
  if modify_connection "${uuids[0]}" "$psk" "$keymgmt" "$prio" "$dns4" "$dns6" "$ignore"; then
    vlog "updated \"$ssid\" ($desc)"
    UPDATED=$((UPDATED + 1))
  else
    warn "failed to update \"$ssid\""
    FAILED=$((FAILED + 1))
  fi
  return 0
}

main() {
  while [[ $# -gt 0 ]]; do
    case "$1" in
      -n | --dry-run) DRY_RUN=true ;;
      -f | --force)   FORCE=true ;;
      --from-apply)   FROM_APPLY=true ;;
      -h | --help)    usage; exit 0 ;;
      *)
        printf 'import-wifi-1password: unknown option: %s\n\n' "$1" >&2
        usage >&2
        exit 2
        ;;
    esac
    shift
  done

  # Preflight — all "environment not ready" -> clean skip under apply.
  command -v nmcli >/dev/null 2>&1 || bail_env "NetworkManager (nmcli) not found"
  [[ "$(nmcli -t -e no -f RUNNING general status 2>/dev/null)" == "running" ]] \
    || bail_env "NetworkManager is not running"
  command -v jq >/dev/null 2>&1 || bail_env "jq not found"

  local total
  total="$(jq '.networks | length' <<<"$WIFI_CONFIG_JSON" 2>/dev/null || echo 0)"
  if [[ "$total" -eq 0 ]]; then
    vlog "no networks defined in networking.yaml; nothing to do"
    exit 0
  fi

  # Merge defaults into each network per-family, so process_network sees a
  # fully-resolved object (per-network ipv4.dns / ipv6.dns / ignoreAutoDns win
  # over their defaults; `has` is used for boolean fields because jq's // treats
  # false as null-ish and would falsely fall through to defaults).
  local net
  while IFS= read -r net; do
    [[ -z "$net" ]] && continue
    process_network "$net"
  done < <(jq -c '
    (.defaults // {}) as $D
    | ($D.ipv4 // {}) as $d4
    | ($D.ipv6 // {}) as $d6
    | .networks[]
    | {
        ssid: (.ssid // ""),
        psk: (.psk // ""),
        priority: (.priority // null),
        dns4: (if ((.ipv4 // {}) | has("dns")) then .ipv4.dns else ($d4.dns // []) end),
        dns6: (if ((.ipv6 // {}) | has("dns")) then .ipv6.dns else ($d6.dns // []) end),
        ignoreAutoDns: (if has("ignoreAutoDns") then .ignoreAutoDns else ($D.ignoreAutoDns // false) end)
      }' <<<"$WIFI_CONFIG_JSON")

  if "$DRY_RUN"; then
    log "dry run — ${ADDED} would add/replace, ${UPDATED} would update, ${SKIPPED} skipped, ${FAILED} problem(s); no changes made"
    exit 0
  fi
  if "$FROM_APPLY"; then
    [[ "$ADDED" -gt 0 || "$UPDATED" -gt 0 || "$FAILED" -gt 0 ]] \
      && log "${ADDED} added, ${UPDATED} updated, ${SKIPPED} skipped, ${FAILED} failed"
    exit 0
  fi
  log "${ADDED} added, ${UPDATED} updated, ${SKIPPED} skipped, ${FAILED} failed"
  [[ "$FAILED" -gt 0 ]] && exit 1
  exit 0
}

main "$@"
