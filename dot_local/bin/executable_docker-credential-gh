#!/usr/bin/env bash
#
# docker-credential-gh — Docker credential helper for GitHub-hosted registries.
#
# Docker invokes this binary when authenticating to any registry mapped to
# `gh` in ~/.docker/config.json (currently `ghcr.io` and the legacy
# `docker.pkg.github.com`). It implements the four Docker credential-helper
# subcommands (`get`, `store`, `erase`, `list`) and shells out to the `gh`
# CLI to fetch the active GitHub token.
#
# Protocol references:
#   https://docs.docker.com/reference/cli/docker/login/#credential-helper-protocol
#   https://github.com/docker/docker-credential-helpers
#
# Single-platform exception (AGENTS.md "Script parity rule"):
#   Docker on Windows resolves credential helpers via PATHEXT and expects
#   `.exe`/`.bat`/`.cmd`, plus a different helper-name mapping in
#   ~/.docker/config.json. If Windows support is added later, ship
#   `docker-credential-gh.cmd` alongside this file.
#
# Dependencies: `gh` on PATH (system install or mise shim). This script does
# NOT use `mise exec` — the user's shell already exposes `gh`/`glab` directly.

set -euo pipefail

cmd="${1:-}"

# Docker credential-helper protocol dispatch.
case "$cmd" in
  store | erase)
    # `store`: stdin is JSON {ServerURL,Username,Secret}.
    # `erase`: stdin is the server URL.
    # In both cases `gh` is the source of truth — drain stdin and no-op.
    cat - >/dev/null
    exit 0
    ;;
  list)
    # `list` is not in the published protocol but Docker's helper library
    # invokes it for native-store enumeration. Return an empty map; we don't
    # surface stored credentials here.
    printf '{}\n'
    exit 0
    ;;
  get)
    : # fall through
    ;;
  *)
    printf 'docker-credential-gh: unknown command: %s\n' "$cmd" >&2
    exit 1
    ;;
esac

# `get`: stdin is the registry URL on a single line. Normalise it.
host="$(cat -)"
host="${host#https://}"
host="${host#http://}"
host="${host%/}"

case "$host" in
  ghcr.io | docker.pkg.github.com) ;;
  *)
    # Exact sentinel — Docker's helper client trims whitespace and maps this
    # message to ErrCredentialsNotFound, letting the auth flow fall back
    # gracefully instead of hard-erroring.
    printf 'credentials not found in native keychain\n'
    exit 1
    ;;
esac

if ! command -v gh >/dev/null 2>&1; then
  printf 'docker-credential-gh: `gh` CLI not found on PATH\n' >&2
  exit 1
fi

# `gh auth token` is host-scoped. ghcr.io and docker.pkg.github.com both
# authenticate against github.com (or the corresponding GHES hostname when
# applicable).
token="$(gh auth token --hostname github.com 2>/dev/null || true)"
if [[ -z "$token" ]]; then
  printf 'credentials not found in native keychain\n'
  exit 1
fi

# GHCR docs require a real GitHub username for PAT auth. Fall back to
# `oauth2accesstoken` if the API call fails (offline, scope-limited token).
username="$(GH_HOST=github.com gh api user -q '.login' 2>/dev/null || echo oauth2accesstoken)"

printf '{"Username":"%s","Secret":"%s"}\n' "$username" "$token"
