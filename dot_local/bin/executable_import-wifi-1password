#!/usr/bin/env bash
# import-wifi-1password — import 1Password Wi-Fi networks into NetworkManager.
#
# Read every 1Password "Wireless Router" item the signed-in `op` account can see
# and create a matching NetworkManager Wi-Fi connection for each, as the RUNNING
# USER (no sudo) via `nmcli` + polkit — the same path plasma-nm uses, so the
# resulting connections work identically in the KDE applet (no secret-agent
# friction, no password re-prompt).
#
#   import-wifi-1password              # import all missing networks
#   import-wifi-1password --dry-run    # show what would happen; change nothing
#   import-wifi-1password --force      # overwrite existing connections of the same SSID
#   import-wifi-1password --vault Home # only items from the "Home" vault
#
# SOURCE (1Password): items of category "Wireless Router". Field extraction is
# layered so it works whether the user filled the canonical wireless fields or
# the generic router-admin fields (the common case for KT/Korean-ISP home routers
# where the SSID + PSK land in `name`/`password`, labelled 기지국 이름/비밀번호):
#   SSID : `network_name` → `name` → item title
#   PSK  : `wireless_password` → `password`
# A network WITH a passphrase is imported as WPA/WPA2/WPA3-personal (key-mgmt
# wpa-psk); one WITHOUT is imported as open. Enterprise (802.1x) and WPA3-only
# SAE networks are out of scope (a plain PSK cannot express them).
#
# PRIORITY (optional): a field with id or label `priority` (or Korean label
# `우선순위`) holding an integer in NM's documented -999..999 range maps to
# connection.autoconnect-priority — when several known networks are in range,
# NM autoconnects to the highest value (default 0). Use it to prefer the 5GHz
# SSID of a dual-band router: give e.g. KT_GiGA_5G_xxxx priority 10 and leave
# the 2.4GHz sibling unset. Priority is also synced onto an EXISTING connection
# of the same SSID without --force — a priority-only change in 1Password never
# requires recreating the connection (the PSK is untouched); a non-integer or
# out-of-range value is warned about and ignored. An ABSENT/cleared field is
# deliberately NOT synced back to 0: like the exists-skip rule for the
# connection itself, the tool only converges settings 1Password actually
# expresses, so a priority the user set by hand in NM is never clobbered — to
# reset via 1Password, set the field to an explicit 0.
#
# USER-SPACE (no root): connections are created with `nmcli connection add` as
# the running user. NetworkManager authorizes this via polkit for the active
# session and writes the resulting root-owned 0600 keyfile itself — exactly how
# plasma-nm creates connections. The trade-off vs. writing keyfiles directly is
# that the PSK travels through nmcli's argv for the lifetime of the call
# (visible in /proc/<pid>/cmdline); on a single-user desktop this is low-risk,
# and it is the only way to create connections as a non-root user without
# root-owned keyfile writes.
#
# 1PASSWORD CLI AUTH: works with EITHER `op signin` (service/account) OR the
# 1Password desktop app's CLI integration (Settings → Developer → Integrate with
# 1Password CLI). Under desktop integration `op whoami` reports "not signed in"
# even though item access works, so this script does NOT gate on `op whoami`;
# the real `op item list` call is the auth probe.
#
# APPLY INTEGRATION: .chezmoiscripts/30-linux/run_onchange_after_import-wifi-1password.sh.tmpl
# runs this with --from-apply (on a fingerprint change, not every apply) — quieter, and every
# "environment not ready" condition (no NetworkManager, `op` not usable, no
# active polkit session) exits 0 so it can never abort an apply.
#
# Single-platform (Linux) BY DESIGN — NetworkManager is Linux-only — so per the
# script-parity exception in AGENTS.md there is no .ps1 counterpart. It deploys
# to ~/.local/bin on every POSIX host but cleanly no-ops where there is no
# `nmcli` (e.g. macOS).

set -euo pipefail

# Configuration / counters (globals; set from argv).
DRY_RUN=false
FORCE=false
FROM_APPLY=false
VAULT=""
CREATED=0
UPDATED=0
SKIPPED=0
FAILED=0

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------
log()  { printf 'import-wifi-1password: %s\n' "$*"; }
# vlog: chatter suppressed under --from-apply to keep `chezmoi apply` quiet.
vlog() { "$FROM_APPLY" || printf 'import-wifi-1password: %s\n' "$*"; }
warn() { printf 'import-wifi-1password: %s\n' "$*" >&2; }

usage() {
  cat <<'EOF'
Usage: import-wifi-1password [--dry-run] [--force] [--vault NAME]

Import 1Password "Wireless Router" (Wi-Fi) items into NetworkManager, creating
one Wi-Fi connection per network as the running user (no sudo). Idempotent: a
network whose SSID already has a NetworkManager connection is skipped — except
its autoconnect priority, which is kept in sync (see below).

An integer item field with id/label `priority` (or label `우선순위`, valid
range -999..999) sets the connection's connection.autoconnect-priority; NM
autoconnects to the known in-range network with the highest value (default 0),
e.g. to prefer a router's 5GHz SSID over its 2.4GHz one. A priority change is
applied to an existing connection in place, without --force and without
touching its PSK; an absent/cleared field leaves the connection untouched
(set an explicit 0 to reset via 1Password).

Options:
  -n, --dry-run     Show what would be imported; make no changes.
  -f, --force       Overwrite an existing NetworkManager connection of the same SSID.
      --vault NAME  Only import items from the named 1Password vault.
  -h, --help        Show this help and exit.

Requires the 1Password CLI (`op`) usable (signed in OR desktop-app integrated)
and NetworkManager (`nmcli`) running. Connections are created via `nmcli` as the
running user (polkit); no root needed.
EOF
}

# ---------------------------------------------------------------------------
# Exit helpers
# ---------------------------------------------------------------------------

# bail_env <message> : "environment not ready". Clean skip (exit 0) under
# --from-apply; failure (exit 1) when run by hand.
bail_env() {
  if "$FROM_APPLY"; then
    printf 'import-wifi-1password: skipped (%s)\n' "$1" >&2
    exit 0
  fi
  printf 'import-wifi-1password: %s\n' "$1" >&2
  exit 1
}

# bail_op <reason> : 1Password not usable. Same apply/manual split as bail_env.
bail_op() {
  if "$FROM_APPLY"; then
    printf 'import-wifi-1password: skipped (1Password not usable: %s)\n' "$1" >&2
    exit 0
  fi
  printf 'import-wifi-1password: 1Password is not usable (%s).\n' "$1" >&2
  printf '  Unlock the 1Password app and enable Settings → Developer →\n' >&2
  # shellcheck disable=SC2016  # literal help text: the user types this, we don't expand it
  printf '  Integrate with 1Password CLI, or run: eval "$(op signin)"\n' >&2
  exit 1
}

# ---------------------------------------------------------------------------
# 1Password / NetworkManager helpers
# ---------------------------------------------------------------------------

# field_value <item-json> <field-id> : first non-empty value among fields with
# the given id, or "" if none (field missing OR value null/empty).
field_value() {
  jq -r --arg id "$2" \
    '[.fields[]? | select(.id==$id) | .value // ""] | map(select(length>0)) | .[0] // ""' \
    <<<"$1"
}

# field_by_label <item-json> <regex> : first non-empty value among fields whose
# LABEL matches the case-insensitive anchored regex. Custom fields added by the
# user carry a random generated id, so only their label is stable — this is the
# lookup path for the user-authored `priority` field (field_value covers the
# built-in category fields, whose ids are well-known).
field_by_label() {
  jq -r --arg re "$2" \
    '[.fields[]? | select((.label // "") | test($re; "i")) | .value // ""] | map(select(length>0)) | .[0] // ""' \
    <<<"$1"
}

# connection_uuids <ssid> : print the UUID of every NetworkManager connection
# named exactly <ssid>, one per line. NM (and KDE) name Wi-Fi connections after
# their SSID, and so does this tool, so a name match reliably detects an
# existing network — but the NAME is not unique, so every mutation below
# addresses the profile by UUID (nmcli's unique identifier), never by name.
# UUID column FIRST: UUIDs never contain ':', so the first ':' splits reliably
# even for SSIDs that contain colons (`-e no` disables terse escaping, which
# would otherwise backslash-escape the separator).
connection_uuids() {
  local ssid="$1" line
  while IFS= read -r line; do
    [[ "${line#*:}" == "$ssid" ]] && printf '%s\n' "${line%%:*}"
  done < <(nmcli -t -e no -f UUID,NAME connection show 2>/dev/null)
}

# delete_connection <uuid>
delete_connection() {
  nmcli connection delete uuid "$1" >/dev/null 2>&1 || true
}

# create_connection <ssid> <psk> <keymgmt> <priority> : nmcli connection add as
# the running user (polkit). nmcli writes the root-owned 0600 keyfile itself —
# matching how plasma-nm creates connections. Returns nonzero on failure.
create_connection() {
  local ssid="$1" psk="$2" keymgmt="$3" priority="$4"
  local -a args=(connection add type wifi con-name "$ssid" ssid "$ssid"
    connection.autoconnect yes save yes)
  [[ -n "$priority" ]] && args+=(connection.autoconnect-priority "$priority")
  if [[ "$keymgmt" == "wpa-psk" ]]; then
    args+=(wifi-sec.key-mgmt wpa-psk wifi-sec.psk "$psk")
  fi
  nmcli "${args[@]}" >/dev/null
}

# sync_priority <ssid> <priority> <uuid>... : bring an EXISTING connection's
# connection.autoconnect-priority in line with the 1Password field, without
# recreating the connection (PSK and every other setting untouched). No-op when
# the item has no priority or it already matches; with SEVERAL profiles named
# for the SSID the target is ambiguous, so it warns and leaves them all alone
# (matching the exists-skip rule) rather than guessing. An absent field is
# deliberately NOT synced back to 0 — see the PRIORITY header note. Updates
# UPDATED/SKIPPED/FAILED.
sync_priority() {
  local ssid="$1" priority="$2" current
  shift 2
  local -a uuids=("$@")
  if [[ -n "$priority" ]]; then
    if ((${#uuids[@]} > 1)); then
      warn "${#uuids[@]} connections are named \"$ssid\"; skipping priority sync (ambiguous target)"
      SKIPPED=$((SKIPPED + 1))
      return 0
    fi
    current="$(nmcli -g connection.autoconnect-priority connection show uuid "${uuids[0]}" 2>/dev/null || echo "")"
    if [[ "$current" != "$priority" ]]; then
      if "$DRY_RUN"; then
        log "would set priority ${priority} on existing \"$ssid\" (currently ${current:-unset})"
        UPDATED=$((UPDATED + 1))
        return 0
      fi
      if nmcli connection modify uuid "${uuids[0]}" connection.autoconnect-priority "$priority" >/dev/null 2>&1; then
        log "set priority ${priority} on existing \"$ssid\" (was ${current:-unset})"
        UPDATED=$((UPDATED + 1))
      else
        warn "failed to set priority on \"$ssid\""
        FAILED=$((FAILED + 1))
      fi
      return 0
    fi
  fi
  vlog "exists, skipping \"$ssid\""
  SKIPPED=$((SKIPPED + 1))
}

# process_item <item-json> : import a single item, updating CREATED/SKIPPED/FAILED.
process_item() {
  local item="$1" title ssid psk keymgmt priority
  title="$(jq -r '.title // ""' <<<"$item")"
  ssid="$(field_value "$item" network_name)"
  [[ -z "$ssid" ]] && ssid="$(field_value "$item" name)"
  [[ -z "$ssid" ]] && ssid="$title"
  psk="$(field_value "$item" wireless_password)"
  [[ -z "$psk" ]] && psk="$(field_value "$item" password)"
  priority="$(field_value "$item" priority)"
  [[ -z "$priority" ]] && priority="$(field_by_label "$item" '^(priority|우선순위)$')"

  if [[ -z "$ssid" ]]; then
    warn "item \"${title:-?}\": no SSID (network_name/name/title all empty); skipping"
    FAILED=$((FAILED + 1))
    return 0
  fi
  # NM documents connection.autoconnect-priority as valid in -999..999; an
  # out-of-range value would make the nmcli add/modify fail outright, so it is
  # warned-and-ignored exactly like a non-integer ([[ ]] short-circuits, so the
  # arithmetic tests only run once the regex has proven integer-ness).
  if [[ -n "$priority" ]] \
    && ! [[ "$priority" =~ ^-?[0-9]+$ && "$priority" -ge -999 && "$priority" -le 999 ]]; then
    warn "item \"$ssid\": priority \"$priority\" is not an integer in -999..999; ignoring"
    priority=""
  fi
  if [[ -n "$psk" ]]; then keymgmt="wpa-psk"; else keymgmt="none"; fi
  local desc="$keymgmt"
  [[ -n "$priority" ]] && desc="$keymgmt, prio $priority"

  local -a uuids=()
  mapfile -t uuids < <(connection_uuids "$ssid")
  if ((${#uuids[@]} > 0)); then
    if ! "$FORCE"; then
      sync_priority "$ssid" "$priority" "${uuids[@]}"
      return 0
    fi
    if "$DRY_RUN"; then
      log "would REPLACE \"$ssid\" ($desc)"
      CREATED=$((CREATED + 1))
      return 0
    fi
    local uuid
    for uuid in "${uuids[@]}"; do
      delete_connection "$uuid"
    done
    if create_connection "$ssid" "$psk" "$keymgmt" "$priority"; then
      log "replaced \"$ssid\" ($desc)"
      CREATED=$((CREATED + 1))
    else
      warn "failed to create \"$ssid\""
      FAILED=$((FAILED + 1))
    fi
    return 0
  fi

  if "$DRY_RUN"; then
    log "would import \"$ssid\" ($desc)"
    CREATED=$((CREATED + 1))
    return 0
  fi
  if create_connection "$ssid" "$psk" "$keymgmt" "$priority"; then
    log "imported \"$ssid\" ($desc)"
    CREATED=$((CREATED + 1))
  else
    warn "failed to create \"$ssid\""
    FAILED=$((FAILED + 1))
  fi
  return 0
}

main() {
  while [[ $# -gt 0 ]]; do
    case "$1" in
      -n | --dry-run) DRY_RUN=true ;;
      -f | --force)   FORCE=true ;;
      --from-apply)   FROM_APPLY=true ;;
      --vault)
        shift
        [[ $# -gt 0 ]] || { warn "--vault requires a value"; exit 2; }
        VAULT="$1"
        ;;
      --vault=*) VAULT="${1#*=}" ;;
      -h | --help) usage; exit 0 ;;
      *)
        printf 'import-wifi-1password: unknown option: %s\n\n' "$1" >&2
        usage >&2
        exit 2
        ;;
    esac
    shift
  done

  # Preflight — all "environment not ready" → clean skip under apply.
  command -v nmcli >/dev/null 2>&1 || bail_env "NetworkManager (nmcli) not found"
  [[ "$(nmcli -t -e no -f RUNNING general status 2>/dev/null)" == "running" ]] \
    || bail_env "NetworkManager is not running"
  command -v op >/dev/null 2>&1 || bail_env "1Password CLI (op) not found"
  command -v jq >/dev/null 2>&1 || bail_env "jq not found"

  # `op item list` is the real auth probe (op whoami is unreliable under desktop
  # integration). Capture stderr so a failure carries a useful reason.
  local -a list=(item list --categories "Wireless Router" --format json)
  [[ -n "$VAULT" ]] && list+=(--vault "$VAULT")
  local items
  if ! items="$(op "${list[@]}" 2>&1)"; then
    bail_op "${items%%$'\n'*}"
  fi
  local total
  total="$(jq 'length' <<<"$items" 2>/dev/null || echo 0)"
  if [[ "$total" -eq 0 ]]; then
    log "no \"Wireless Router\" items found in 1Password; nothing to import"
    exit 0
  fi

  local id item
  while IFS= read -r id; do
    [[ -z "$id" ]] && continue
    # Item IDs are globally unique, so no --vault on the get (avoids vault-name
    # mismatch on accounts with non-unique vault aliases).
    if item="$(op item get "$id" --format json --reveal 2>/dev/null)"; then
      process_item "$item"
    else
      warn "failed to read 1Password item ${id}"
      FAILED=$((FAILED + 1))
    fi
  done < <(jq -r '.[].id' <<<"$items")

  if "$DRY_RUN"; then
    log "dry run — ${CREATED} would import, ${UPDATED} would update priority, ${SKIPPED} existing, ${FAILED} problem(s); no changes made"
    exit 0
  fi
  if "$FROM_APPLY"; then
    [[ "$CREATED" -gt 0 || "$UPDATED" -gt 0 || "$FAILED" -gt 0 ]] \
      && log "${CREATED} imported, ${UPDATED} priority updated, ${SKIPPED} existing, ${FAILED} failed"
    exit 0
  fi
  log "${CREATED} imported, ${UPDATED} priority updated, ${SKIPPED} existing, ${FAILED} failed"
  [[ "$FAILED" -gt 0 ]] && exit 1
  exit 0
}

main "$@"
