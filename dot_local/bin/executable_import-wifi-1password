#!/usr/bin/env bash
# import-wifi-1password — import 1Password Wi-Fi networks into NetworkManager.
#
# Read every 1Password "Wireless Router" item the signed-in `op` account can see
# and create a matching NetworkManager Wi-Fi connection for each, as the RUNNING
# USER (no sudo) via `nmcli` + polkit — the same path plasma-nm uses, so the
# resulting connections work identically in the KDE applet (no secret-agent
# friction, no password re-prompt).
#
#   import-wifi-1password              # import all missing networks
#   import-wifi-1password --dry-run    # show what would happen; change nothing
#   import-wifi-1password --force      # overwrite existing connections of the same SSID
#   import-wifi-1password --vault Home # only items from the "Home" vault
#
# SOURCE (1Password): items of category "Wireless Router". Field extraction is
# layered so it works whether the user filled the canonical wireless fields or
# the generic router-admin fields (the common case for KT/Korean-ISP home routers
# where the SSID + PSK land in `name`/`password`, labelled 기지국 이름/비밀번호):
#   SSID : `network_name` → `name` → item title
#   PSK  : `wireless_password` → `password`
# A network WITH a passphrase is imported as WPA/WPA2/WPA3-personal (key-mgmt
# wpa-psk); one WITHOUT is imported as open. Enterprise (802.1x) and WPA3-only
# SAE networks are out of scope (a plain PSK cannot express them).
#
# USER-SPACE (no root): connections are created with `nmcli connection add` as
# the running user. NetworkManager authorizes this via polkit for the active
# session and writes the resulting root-owned 0600 keyfile itself — exactly how
# plasma-nm creates connections. The trade-off vs. writing keyfiles directly is
# that the PSK travels through nmcli's argv for the lifetime of the call
# (visible in /proc/<pid>/cmdline); on a single-user desktop this is low-risk,
# and it is the only way to create connections as a non-root user without
# root-owned keyfile writes.
#
# 1PASSWORD CLI AUTH: works with EITHER `op signin` (service/account) OR the
# 1Password desktop app's CLI integration (Settings → Developer → Integrate with
# 1Password CLI). Under desktop integration `op whoami` reports "not signed in"
# even though item access works, so this script does NOT gate on `op whoami`;
# the real `op item list` call is the auth probe.
#
# APPLY INTEGRATION: .chezmoiscripts/30-linux/run_onchange_after_import-wifi-1password.sh.tmpl
# runs this with --from-apply (on a fingerprint change, not every apply) — quieter, and every
# "environment not ready" condition (no NetworkManager, `op` not usable, no
# active polkit session) exits 0 so it can never abort an apply.
#
# Single-platform (Linux) BY DESIGN — NetworkManager is Linux-only — so per the
# script-parity exception in AGENTS.md there is no .ps1 counterpart. It deploys
# to ~/.local/bin on every POSIX host but cleanly no-ops where there is no
# `nmcli` (e.g. macOS).

set -euo pipefail

# Configuration / counters (globals; set from argv).
DRY_RUN=false
FORCE=false
FROM_APPLY=false
VAULT=""
CREATED=0
SKIPPED=0
FAILED=0

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------
log()  { printf 'import-wifi-1password: %s\n' "$*"; }
# vlog: chatter suppressed under --from-apply to keep `chezmoi apply` quiet.
vlog() { "$FROM_APPLY" || printf 'import-wifi-1password: %s\n' "$*"; }
warn() { printf 'import-wifi-1password: %s\n' "$*" >&2; }

usage() {
  cat <<'EOF'
Usage: import-wifi-1password [--dry-run] [--force] [--vault NAME]

Import 1Password "Wireless Router" (Wi-Fi) items into NetworkManager, creating
one Wi-Fi connection per network as the running user (no sudo). Idempotent: a
network whose SSID already has a NetworkManager connection is skipped.

Options:
  -n, --dry-run     Show what would be imported; make no changes.
  -f, --force       Overwrite an existing NetworkManager connection of the same SSID.
      --vault NAME  Only import items from the named 1Password vault.
  -h, --help        Show this help and exit.

Requires the 1Password CLI (`op`) usable (signed in OR desktop-app integrated)
and NetworkManager (`nmcli`) running. Connections are created via `nmcli` as the
running user (polkit); no root needed.
EOF
}

# ---------------------------------------------------------------------------
# Exit helpers
# ---------------------------------------------------------------------------

# bail_env <message> : "environment not ready". Clean skip (exit 0) under
# --from-apply; failure (exit 1) when run by hand.
bail_env() {
  if "$FROM_APPLY"; then
    printf 'import-wifi-1password: skipped (%s)\n' "$1" >&2
    exit 0
  fi
  printf 'import-wifi-1password: %s\n' "$1" >&2
  exit 1
}

# bail_op <reason> : 1Password not usable. Same apply/manual split as bail_env.
bail_op() {
  if "$FROM_APPLY"; then
    printf 'import-wifi-1password: skipped (1Password not usable: %s)\n' "$1" >&2
    exit 0
  fi
  printf 'import-wifi-1password: 1Password is not usable (%s).\n' "$1" >&2
  printf '  Unlock the 1Password app and enable Settings → Developer →\n' >&2
  # shellcheck disable=SC2016  # literal help text: the user types this, we don't expand it
  printf '  Integrate with 1Password CLI, or run: eval "$(op signin)"\n' >&2
  exit 1
}

# ---------------------------------------------------------------------------
# 1Password / NetworkManager helpers
# ---------------------------------------------------------------------------

# field_value <item-json> <field-id> : first non-empty value among fields with
# the given id, or "" if none (field missing OR value null/empty).
field_value() {
  jq -r --arg id "$2" \
    '[.fields[]? | select(.id==$id) | .value // ""] | map(select(length>0)) | .[0] // ""' \
    <<<"$1"
}

# connection_exists <ssid> : true if a NetworkManager connection is named exactly
# <ssid>. NM (and KDE) name Wi-Fi connections after their SSID, and so does this
# tool, so a name match reliably detects an existing network. `-e no` disables
# terse escaping so single-field NAME output is the raw name.
connection_exists() {
  local ssid="$1" name
  while IFS= read -r name; do
    [[ "$name" == "$ssid" ]] && return 0
  done < <(nmcli -t -e no -f NAME connection show 2>/dev/null)
  return 1
}

delete_connection() {
  nmcli connection delete id "$1" >/dev/null 2>&1 || true
}

# create_connection <ssid> <psk> <keymgmt> : nmcli connection add as the running
# user (polkit). nmcli writes the root-owned 0600 keyfile itself — matching how
# plasma-nm creates connections. Returns nonzero on failure.
create_connection() {
  local ssid="$1" psk="$2" keymgmt="$3"
  local -a args=(connection add type wifi con-name "$ssid" ssid "$ssid"
    connection.autoconnect yes save yes)
  if [[ "$keymgmt" == "wpa-psk" ]]; then
    args+=(wifi-sec.key-mgmt wpa-psk wifi-sec.psk "$psk")
  fi
  nmcli "${args[@]}" >/dev/null
}

# process_item <item-json> : import a single item, updating CREATED/SKIPPED/FAILED.
process_item() {
  local item="$1" title ssid psk keymgmt
  title="$(jq -r '.title // ""' <<<"$item")"
  ssid="$(field_value "$item" network_name)"
  [[ -z "$ssid" ]] && ssid="$(field_value "$item" name)"
  [[ -z "$ssid" ]] && ssid="$title"
  psk="$(field_value "$item" wireless_password)"
  [[ -z "$psk" ]] && psk="$(field_value "$item" password)"

  if [[ -z "$ssid" ]]; then
    warn "item \"${title:-?}\": no SSID (network_name/name/title all empty); skipping"
    FAILED=$((FAILED + 1))
    return 0
  fi
  if [[ -n "$psk" ]]; then keymgmt="wpa-psk"; else keymgmt="none"; fi

  if connection_exists "$ssid"; then
    if ! "$FORCE"; then
      vlog "exists, skipping \"$ssid\" ($keymgmt)"
      SKIPPED=$((SKIPPED + 1))
      return 0
    fi
    if "$DRY_RUN"; then
      log "would REPLACE \"$ssid\" ($keymgmt)"
      CREATED=$((CREATED + 1))
      return 0
    fi
    delete_connection "$ssid"
    if create_connection "$ssid" "$psk" "$keymgmt"; then
      log "replaced \"$ssid\" ($keymgmt)"
      CREATED=$((CREATED + 1))
    else
      warn "failed to create \"$ssid\""
      FAILED=$((FAILED + 1))
    fi
    return 0
  fi

  if "$DRY_RUN"; then
    log "would import \"$ssid\" ($keymgmt)"
    CREATED=$((CREATED + 1))
    return 0
  fi
  if create_connection "$ssid" "$psk" "$keymgmt"; then
    log "imported \"$ssid\" ($keymgmt)"
    CREATED=$((CREATED + 1))
  else
    warn "failed to create \"$ssid\""
    FAILED=$((FAILED + 1))
  fi
  return 0
}

main() {
  while [[ $# -gt 0 ]]; do
    case "$1" in
      -n | --dry-run) DRY_RUN=true ;;
      -f | --force)   FORCE=true ;;
      --from-apply)   FROM_APPLY=true ;;
      --vault)
        shift
        [[ $# -gt 0 ]] || { warn "--vault requires a value"; exit 2; }
        VAULT="$1"
        ;;
      --vault=*) VAULT="${1#*=}" ;;
      -h | --help) usage; exit 0 ;;
      *)
        printf 'import-wifi-1password: unknown option: %s\n\n' "$1" >&2
        usage >&2
        exit 2
        ;;
    esac
    shift
  done

  # Preflight — all "environment not ready" → clean skip under apply.
  command -v nmcli >/dev/null 2>&1 || bail_env "NetworkManager (nmcli) not found"
  [[ "$(nmcli -t -e no -f RUNNING general status 2>/dev/null)" == "running" ]] \
    || bail_env "NetworkManager is not running"
  command -v op >/dev/null 2>&1 || bail_env "1Password CLI (op) not found"
  command -v jq >/dev/null 2>&1 || bail_env "jq not found"

  # `op item list` is the real auth probe (op whoami is unreliable under desktop
  # integration). Capture stderr so a failure carries a useful reason.
  local -a list=(item list --categories "Wireless Router" --format json)
  [[ -n "$VAULT" ]] && list+=(--vault "$VAULT")
  local items
  if ! items="$(op "${list[@]}" 2>&1)"; then
    bail_op "${items%%$'\n'*}"
  fi
  local total
  total="$(jq 'length' <<<"$items" 2>/dev/null || echo 0)"
  if [[ "$total" -eq 0 ]]; then
    log "no \"Wireless Router\" items found in 1Password; nothing to import"
    exit 0
  fi

  local id item
  while IFS= read -r id; do
    [[ -z "$id" ]] && continue
    # Item IDs are globally unique, so no --vault on the get (avoids vault-name
    # mismatch on accounts with non-unique vault aliases).
    if item="$(op item get "$id" --format json --reveal 2>/dev/null)"; then
      process_item "$item"
    else
      warn "failed to read 1Password item ${id}"
      FAILED=$((FAILED + 1))
    fi
  done < <(jq -r '.[].id' <<<"$items")

  if "$DRY_RUN"; then
    log "dry run — ${CREATED} would import, ${SKIPPED} existing, ${FAILED} problem(s); no changes made"
    exit 0
  fi
  if "$FROM_APPLY"; then
    [[ "$CREATED" -gt 0 || "$FAILED" -gt 0 ]] \
      && log "${CREATED} imported, ${SKIPPED} existing, ${FAILED} failed"
    exit 0
  fi
  log "${CREATED} imported, ${SKIPPED} existing, ${FAILED} failed"
  [[ "$FAILED" -gt 0 ]] && exit 1
  exit 0
}

main "$@"
