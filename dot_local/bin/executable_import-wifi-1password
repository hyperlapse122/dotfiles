#!/usr/bin/env bash
# import-wifi-1password — import 1Password Wi-Fi networks into NetworkManager.
#
# Read every 1Password "Wireless Router" item (the native Wi-Fi item type) the
# signed-in `op` account can see and create a matching NetworkManager Wi-Fi
# connection for each. Idempotent, add-only: a network whose SSID already has a
# NetworkManager connection is left untouched (use --force to overwrite).
#
#   import-wifi-1password              # import all missing networks
#   import-wifi-1password --dry-run    # show what would happen; change nothing
#   import-wifi-1password --force      # overwrite existing connections of the same SSID
#   import-wifi-1password --vault Home # only items from the "Home" vault
#
# SOURCE (1Password): items of the "Wireless Router" category. The SSID is read
# from the `network_name` field (falling back to the item title); the passphrase
# from `wireless_password`. A network WITH a passphrase is imported as WPA/WPA2/
# WPA3-personal (key-mgmt wpa-psk); one WITHOUT is imported as an open network.
# Items are read with `op item get --reveal`. Enterprise (802.1x) and WPA3-only
# SAE networks are out of scope (a plain PSK cannot express them).
#
# SECRET HANDLING — why keyfiles, not `nmcli ... wifi-sec.psk`: passing the PSK
# to nmcli puts it in the process argv, readable from /proc/<pid>/cmdline (and
# `ps`) for the life of the call. Instead each connection is written as a
# NetworkManager keyfile straight into /etc/NetworkManager/system-connections/:
# the PSK only ever travels through a shell variable and a private, mode-0600
# temp file under $XDG_RUNTIME_DIR, landing in a root-owned 0600 keyfile. The
# SSID is emitted in keyfile byte-array form (b1;b2;...;) so no SSID — spaces,
# UTF-8, ';', '#' — can corrupt the file. This mirrors how this repo already
# installs /etc/NetworkManager/conf.d/*.conf via `sudo install -m`.
#
# ROOT: writing under /etc/NetworkManager/system-connections needs root, so a
# real run uses sudo (skipped when already root). Like install-system-config, a
# non-interactive shell with no cached sudo credentials is a CLEAN SKIP, not a
# failure. --dry-run needs no root.
#
# APPLY INTEGRATION: .chezmoiscripts/linux/run_after_import-wifi-1password.sh.tmpl
# runs this on every `chezmoi apply` with --from-apply — quieter, and every
# "environment not ready" condition (no NetworkManager, `op` not signed in, no
# sudo) exits 0 so it can never abort an apply. The logic lives here (not inline
# in that wrapper) so it stays runnable by hand and supports --dry-run; the
# passphrases are read from `op` at runtime and are never embedded into any
# rendered chezmoi template or state.
#
# Single-platform (Linux) BY DESIGN — NetworkManager is Linux-only — so per the
# script-parity exception in AGENTS.md there is no .ps1 counterpart. It deploys
# to ~/.local/bin on every POSIX host but cleanly no-ops where there is no
# `nmcli` (e.g. macOS).
#
# SOURCEABLE: the pure helpers (ssid_to_bytes, kf_escape, sanitize_filename,
# render_keyfile) have no side effects when the file is sourced (see the
# main-guard at the bottom), so they can be exercised in isolation.

set -euo pipefail

# ---------------------------------------------------------------------------
# Configuration / counters (globals; set by main from argv).
# ---------------------------------------------------------------------------
DRY_RUN=false
FORCE=false
FROM_APPLY=false
VAULT=""
SUDO=()
CREATED=0
SKIPPED=0
FAILED=0
RELOAD_NEEDED=false

SYS_CONN_DIR="/etc/NetworkManager/system-connections"

# ---------------------------------------------------------------------------
# Pure, side-effect-free helpers.
# ---------------------------------------------------------------------------

# ssid_to_bytes <ssid> : print the SSID as a NetworkManager keyfile byte array
# "b1;b2;...;bN;" (decimal, one entry per raw byte). The byte form sidesteps ALL
# keyfile string escaping for the SSID — spaces, UTF-8, ';', '#', leading spaces
# — because NM parses a digits-and-semicolons ssid value as raw bytes.
ssid_to_bytes() {
  local bytes
  # -v defeats od's '*' run-compression; flatten od's multi-line output, then
  # squeeze to single spaces and turn them into ';' separators with a trailing ';'.
  bytes="$(printf '%s' "$1" | od -An -v -tu1 | tr '\n' ' ' | tr -s ' ')"
  bytes="${bytes# }"
  bytes="${bytes% }"
  printf '%s;' "${bytes// /;}"
}

# kf_escape <value> : escape a string for a NetworkManager keyfile (GKeyFile)
# value. Backslash first, then control chars, then leading/trailing spaces
# (GKeyFile strips unescaped surrounding whitespace). ';' and '#' are literal
# inside a value and need no escaping.
kf_escape() {
  local s="$1"
  s="${s//\\/\\\\}"
  s="${s//$'\n'/\\n}"
  s="${s//$'\t'/\\t}"
  s="${s//$'\r'/\\r}"
  [[ "$s" == ' '* ]] && s="\\s${s#?}"
  [[ "$s" == *' ' ]] && s="${s%?}\\s"
  printf '%s' "$s"
}

# sanitize_filename <ssid> : a safe basename for the .nmconnection file. Only '/'
# (and the impossible NUL) are illegal in a filename; everything else is kept so
# the file stays recognizable. The connection's real name lives in `id=` inside.
sanitize_filename() {
  local s="${1//\//_}"
  printf '%s' "${s:-wifi}"
}

# render_keyfile <ssid> <psk> <keymgmt> <uuid> : print a complete .nmconnection
# keyfile to stdout. Pure (uuid is passed in) so it is deterministic + testable.
render_keyfile() {
  local ssid="$1" psk="$2" keymgmt="$3" uuid="$4"
  printf '[connection]\n'
  printf 'id=%s\n' "$(kf_escape "$ssid")"
  printf 'uuid=%s\n' "$uuid"
  printf 'type=wifi\n'
  printf 'autoconnect=true\n'
  printf '\n[wifi]\n'
  printf 'mode=infrastructure\n'
  printf 'ssid=%s\n' "$(ssid_to_bytes "$ssid")"
  if [[ "$keymgmt" == "wpa-psk" ]]; then
    # NetworkManager >= 1.x keys off the [wifi-security] section itself; the
    # legacy `security=` hint in [wifi] is redundant (nmcli's own writer omits it).
    printf '\n[wifi-security]\n'
    printf 'key-mgmt=wpa-psk\n'
    printf 'psk=%s\n' "$(kf_escape "$psk")"
  fi
  printf '\n[ipv4]\nmethod=auto\n'
  printf '\n[ipv6]\nmethod=auto\n'
}

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------
log()  { printf 'import-wifi-1password: %s\n' "$*"; }
# vlog: chatter suppressed under --from-apply to keep `chezmoi apply` quiet.
vlog() { "$FROM_APPLY" || printf 'import-wifi-1password: %s\n' "$*"; }
warn() { printf 'import-wifi-1password: %s\n' "$*" >&2; }

usage() {
  cat <<'EOF'
Usage: import-wifi-1password [--dry-run] [--force] [--vault NAME]

Import 1Password "Wireless Router" (Wi-Fi) items into NetworkManager, creating
one Wi-Fi connection per network. Idempotent: a network whose SSID already has a
NetworkManager connection is skipped.

Options:
  -n, --dry-run     Show what would be imported; make no changes (no root needed).
  -f, --force       Overwrite an existing NetworkManager connection of the same SSID.
      --vault NAME  Only import items from the named 1Password vault.
  -h, --help        Show this help and exit.

Requires the 1Password CLI (`op`) signed in and NetworkManager (`nmcli`) running.
Writing connections needs root (via sudo). Passphrases are read from `op` at
runtime and written only to root-owned 0600 keyfiles under
/etc/NetworkManager/system-connections — never passed on a command line.
EOF
}

# ---------------------------------------------------------------------------
# Side-effecting helpers
# ---------------------------------------------------------------------------

# bail_env <message> : an "environment not ready" exit. Under --from-apply this
# is a clean skip (exit 0) so it never aborts an apply; run by hand it is a
# failure (exit 1).
bail_env() {
  if "$FROM_APPLY"; then
    printf 'import-wifi-1password: skipped (%s)\n' "$1" >&2
    exit 0
  fi
  printf 'import-wifi-1password: %s\n' "$1" >&2
  exit 1
}

bail_signin() {
  if "$FROM_APPLY"; then
    printf 'import-wifi-1password: skipped (1Password not signed in)\n' >&2
    exit 0
  fi
  printf 'import-wifi-1password: 1Password is not signed in.\n' >&2
  printf '  Sign in first (1Password app > Settings > Developer > CLI),\n' >&2
  # shellcheck disable=SC2016  # literal help text: the user types this, we don't expand it
  printf '  or run:  eval "$(op signin)"\n' >&2
  exit 1
}

setup_sudo() {
  if [[ "${EUID:-$(id -u)}" -eq 0 ]]; then
    SUDO=()
    return 0
  fi
  command -v sudo >/dev/null 2>&1 || bail_env "not running as root and sudo is unavailable"
  SUDO=(sudo)
  # Non-interactive shell with no cached credentials: cannot obtain root without
  # a prompt, so skip cleanly (matches install-system-config's behaviour).
  if [[ ! -t 0 ]] && ! sudo -n true 2>/dev/null; then
    bail_env "no cached sudo credentials in a non-interactive shell; run it in a terminal"
  fi
  # Prime the credential cache once so per-network installs don't reprompt.
  sudo -v 2>/dev/null || bail_env "sudo authentication failed"
}

# connection_exists <ssid> : true if a NetworkManager connection is named exactly
# <ssid>. NetworkManager (and KDE) name Wi-Fi connections after their SSID, and
# this tool does the same, so a name match reliably detects an existing network.
# `-e no` disables terse escaping, so single-field NAME output is the raw name.
connection_exists() {
  local ssid="$1" name
  while IFS= read -r name; do
    [[ "$name" == "$ssid" ]] && return 0
  done < <(nmcli -t -e no -f NAME connection show 2>/dev/null)
  return 1
}

delete_connection() {
  "${SUDO[@]}" nmcli connection delete id "$1" >/dev/null 2>&1 || true
}

# write_connection <ssid> <psk> <keymgmt> : render the keyfile and install it
# root-owned 0600 under $SYS_CONN_DIR without the PSK ever hitting argv.
write_connection() {
  local ssid="$1" psk="$2" keymgmt="$3"
  local uuid dst tmpdir tmp
  uuid="$(uuidgen)"
  dst="${SYS_CONN_DIR}/$(sanitize_filename "$ssid").nmconnection"
  tmpdir="${XDG_RUNTIME_DIR:-$HOME/.cache}"
  (umask 077 && mkdir -p "$tmpdir") 2>/dev/null || true
  tmp="$(umask 077 && mktemp "${tmpdir}/import-wifi.XXXXXX")" || return 1
  render_keyfile "$ssid" "$psk" "$keymgmt" "$uuid" >"$tmp"
  if "${SUDO[@]}" install -m 0600 -o root -g root "$tmp" "$dst"; then
    rm -f "$tmp"
    return 0
  fi
  rm -f "$tmp"
  return 1
}

# process_item <item-id> : import a single 1Password item, updating counters.
process_item() {
  local id="$1" item title ssid psk keymgmt
  local -a get=(item get "$id" --format json --reveal)
  [[ -n "$VAULT" ]] && get+=(--vault "$VAULT")
  if ! item="$(op "${get[@]}" 2>/dev/null)"; then
    warn "failed to read 1Password item ${id}"
    FAILED=$((FAILED + 1))
    return 0
  fi
  title="$(jq -r '.title // ""' <<<"$item")"
  ssid="$(jq -r '[.fields[]? | select(.id=="network_name") | .value][0] // ""' <<<"$item")"
  [[ -z "$ssid" ]] && ssid="$title"
  psk="$(jq -r '[.fields[]? | select(.id=="wireless_password") | .value][0] // ""' <<<"$item")"

  if [[ -z "$ssid" ]]; then
    warn "item \"${title:-$id}\": no SSID (network_name and title empty); skipping"
    FAILED=$((FAILED + 1))
    return 0
  fi
  if [[ -n "$psk" ]]; then keymgmt="wpa-psk"; else keymgmt="none"; fi

  if connection_exists "$ssid"; then
    if ! "$FORCE"; then
      vlog "exists, skipping \"$ssid\" (use --force to overwrite)"
      SKIPPED=$((SKIPPED + 1))
      return 0
    fi
    if "$DRY_RUN"; then
      log "would REPLACE \"$ssid\" ($keymgmt)"
      CREATED=$((CREATED + 1))
      return 0
    fi
    delete_connection "$ssid"
    if write_connection "$ssid" "$psk" "$keymgmt"; then
      log "replaced \"$ssid\" ($keymgmt)"
      RELOAD_NEEDED=true
      CREATED=$((CREATED + 1))
    else
      warn "failed to write \"$ssid\""
      FAILED=$((FAILED + 1))
    fi
    return 0
  fi

  if "$DRY_RUN"; then
    log "would import \"$ssid\" ($keymgmt)"
    CREATED=$((CREATED + 1))
    return 0
  fi
  if write_connection "$ssid" "$psk" "$keymgmt"; then
    log "imported \"$ssid\" ($keymgmt)"
    RELOAD_NEEDED=true
    CREATED=$((CREATED + 1))
  else
    warn "failed to write \"$ssid\""
    FAILED=$((FAILED + 1))
  fi
  return 0
}

main() {
  while [[ $# -gt 0 ]]; do
    case "$1" in
      -n | --dry-run) DRY_RUN=true ;;
      -f | --force) FORCE=true ;;
      --from-apply) FROM_APPLY=true ;;
      --vault)
        shift
        [[ $# -gt 0 ]] || { warn "--vault requires a value"; exit 2; }
        VAULT="$1"
        ;;
      --vault=*) VAULT="${1#*=}" ;;
      -h | --help)
        usage
        exit 0
        ;;
      *)
        printf 'import-wifi-1password: unknown option: %s\n\n' "$1" >&2
        usage >&2
        exit 2
        ;;
    esac
    shift
  done

  # Preflight. All of these are "environment not ready" → clean skip under apply.
  command -v nmcli >/dev/null 2>&1 || bail_env "NetworkManager (nmcli) not found"
  [[ "$(nmcli -t -e no -f RUNNING general status 2>/dev/null)" == "running" ]] \
    || bail_env "NetworkManager is not running"
  command -v op >/dev/null 2>&1 || bail_env "1Password CLI (op) not found"
  command -v jq >/dev/null 2>&1 || bail_env "jq not found"
  command -v uuidgen >/dev/null 2>&1 || bail_env "uuidgen not found"
  command -v od >/dev/null 2>&1 || bail_env "od (coreutils) not found"
  op whoami >/dev/null 2>&1 || bail_signin

  # Root is only needed to actually write connections.
  "$DRY_RUN" || setup_sudo

  local -a list=(item list --categories "Wireless Router" --format json)
  [[ -n "$VAULT" ]] && list+=(--vault "$VAULT")
  local items total
  items="$(op "${list[@]}" 2>/dev/null)" || bail_env "failed to list 1Password items"
  total="$(jq 'length' <<<"$items" 2>/dev/null || echo 0)"
  if [[ "$total" -eq 0 ]]; then
    log "no \"Wireless Router\" items found in 1Password; nothing to import"
    exit 0
  fi

  local id
  while IFS= read -r id; do
    [[ -z "$id" ]] && continue
    process_item "$id"
  done < <(jq -r '.[].id' <<<"$items")

  if "$RELOAD_NEEDED" && ! "$DRY_RUN"; then
    "${SUDO[@]}" nmcli connection reload || warn "nmcli connection reload failed"
  fi

  if "$DRY_RUN"; then
    log "dry run — ${CREATED} would import, ${SKIPPED} existing, ${FAILED} problem(s); no changes made"
    exit 0
  fi
  if "$FROM_APPLY"; then
    [[ "$CREATED" -gt 0 || "$FAILED" -gt 0 ]] \
      && log "${CREATED} imported, ${SKIPPED} existing, ${FAILED} failed"
    exit 0
  fi
  log "${CREATED} imported, ${SKIPPED} existing, ${FAILED} failed"
  [[ "$FAILED" -gt 0 ]] && exit 1
  exit 0
}

# Run main only when executed, not when sourced (so the pure helpers above can be
# exercised in isolation).
if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
  main "$@"
fi
