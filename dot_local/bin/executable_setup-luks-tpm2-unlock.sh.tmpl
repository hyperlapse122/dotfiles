#!/usr/bin/env bash
# setup-luks-tpm2-unlock.sh — TPM2-backed automatic LUKS unlock at boot.
#
# Set up TPM2-backed automated unlocking for EVERY LUKS-encrypted block device
# on the currently-running system (the device backing / included). For each
# crypto_LUKS device it:
#
#   1. seals a LUKS keyslot to the TPM2 (bound to PCR 7 = the UEFI Secure Boot
#      policy state), prompting INTERACTIVELY for an existing LUKS passphrase to
#      authorize the change;
#   2. wires the device's crypttab entry / boot config so the initramfs unlocks
#      it from the TPM at boot;
#   3. rebuilds the initramfs so the TPM2 unlock path is present early at boot.
#
# CROSS-DISTRO via a chezmoi-included backend: the mechanism differs per distro,
# so the distro-specific "backend" is factored into a separate fragment that
# chezmoi inlines here at apply time with `{{ "{{ include }}" }}` — the same
# "diverging fragment" pattern dot_config/git/config.tmpl uses to pull in
# .config_<os>. On Fedora the backend is dracut + systemd-cryptenroll (the only
# initramfs generator that wires systemd's `tpm2-device=auto` crypttab unlock);
# on Ubuntu it is clevis + initramfs-tools (Ubuntu's cryptroot scripts ignore
# `tpm2-device=auto`, Launchpad #1980018, so clevis is the native path). Each
# backend defines four hooks the shared core below calls: backend_preflight,
# backend_enroll, backend_crypttab_opts and backend_finalize. On any other host
# (macOS, a non-Fedora/Ubuntu Linux) a no-op backend exits cleanly up front.
#
# PASSPHRASE HANDLING (two modes):
#
#   1. INTERACTIVE (default): the existing passphrase is only ever typed at the
#      enrollment tool's own prompt — this script never reads it from argv/file.
#      It therefore REQUIRES a TTY (except under --dry-run), so run it by hand
#      after a fresh install (deployed via the executable_ prefix to ~/.local/bin,
#      which is on $PATH):
#
#          setup-luks-tpm2-unlock.sh
#
#      In this mode it is deliberately unsuited to a run_once_/run_onchange_
#      chezmoi script — chezmoi runs those non-interactively and could not answer
#      the prompt.
#
#   2. NON-INTERACTIVE (opt-in via env): when SETUP_LUKS_TPM2_PASSPHRASE is set,
#      the existing passphrase is read from it (env ONLY, never argv — argv is
#      world-visible via ps), the TTY requirement is dropped, and each backend
#      feeds it to the enrollment tool instead of prompting. The value is cleared
#      from the environment immediately so child processes never inherit it. The
#      Ubuntu run_after wrapper (.chezmoiscripts/linux/run_after_ubuntu-luks-tpm2)
#      uses exactly this, sourcing the passphrase from chezmoi's promptString so a
#      host can enroll on `chezmoi apply`.
#
# SAFETY: enrollment ADDS a TPM2-sealed keyslot; it does NOT remove the existing
# passphrase keyslot. The current passphrase therefore stays valid as a fallback
# if the TPM is later cleared or the firmware/Secure-Boot state changes. On the
# Fedora backend `--recovery-key` additionally enrolls a printed recovery key.
# Each backend skips a device that already carries its own TPM2 enrollment.
#
# PCR CHOICE: this runs from the INSTALLED system, so PCR 7 measured here equals
# PCR 7 at the next real boot (same Secure Boot policy) — binding is safe.
# Override with --tpm2-pcrs (e.g. `7+0`, or `` for no binding) if you know what
# you want. The value is passed through to the active backend (systemd `+` form;
# clevis maps `+` to its comma-separated pcr_ids).
#
# Single-platform (Linux only) BY DESIGN — LUKS, TPM2 enrollment and initramfs
# regeneration are Linux-only, so per the script-parity exception in AGENTS.md
# there is no .ps1 counterpart.
#
# IDEMPOTENT: a device already enrolled is skipped; /etc/crypttab entries are
# matched by exact device alias (UUID=, PARTUUID=, raw path, or any /dev/disk/*
# symlink) so options are merged into the existing entry and never duplicated;
# initramfs config is only written when missing; the initramfs is rebuilt only
# when something actually changed. /etc/crypttab is backed up before the first
# edit and written atomically (temp file in /etc + rename) so an interrupted run
# cannot truncate this boot-critical file.
#
# --dry-run prints every intended action and mutates NOTHING.

set -euo pipefail

# ---------------------------------------------------------------------------
# Pure, side-effect-free helpers. The file is sourceable (see the main-guard at
# the bottom), so these can be exercised in isolation without the side-effecting
# flow running.
# ---------------------------------------------------------------------------

# merge_crypttab_opts <existing-opts> <wanted-opts>
# Merge comma-separated crypttab option lists. Dedupe by OPTION KEY (the text
# before '='), so an existing `tpm2-device=/dev/tpmrm0` is respected and the
# wanted `tpm2-device=auto` is NOT appended as a second tpm2-device key (which
# systemd-cryptsetup would reject). A `-`/`none`/empty existing field is
# replaced wholesale by the wanted options. Existing order is preserved.
merge_crypttab_opts() {
  local existing="$1" want="$2"
  if [[ -z "$existing" || "$existing" == "-" || "$existing" == "none" ]]; then
    printf '%s' "$want"
    return
  fi
  local -a want_arr exist_arr
  IFS=',' read -ra want_arr <<<"$want"
  IFS=',' read -ra exist_arr <<<"$existing"
  local result="$existing" tok et tkey ekey present
  for tok in "${want_arr[@]}"; do
    tkey="${tok%%=*}"
    present=false
    for et in "${exist_arr[@]}"; do
      ekey="${et%%=*}"
      [[ "$ekey" == "$tkey" ]] && { present=true; break; }
    done
    [[ "$present" == false ]] && result="${result},${tok}"
  done
  printf '%s' "$result"
}

# render_crypttab <name> <canonical-src> <want-opts> [match-alias...]
# Read current /etc/crypttab content on stdin, print the desired content on
# stdout. An entry matches when its name field equals <name> OR its source field
# (field 2) EXACTLY equals <canonical-src> or any <match-alias> (UUID=, PARTUUID=,
# raw device path, /dev/disk/* symlink). Matching is exact — never substring —
# so we never false-match nor append a duplicate entry for a device already
# present under a different source form. Matched entries get <want-opts> merged
# (see merge_crypttab_opts). Comments, blank lines and unrelated entries pass
# through verbatim. When nothing matches, a canonical `<name> <canonical-src> -
# <want-opts>` line is appended.
render_crypttab() {
  local name="$1" canonical="$2" want="$3"
  shift 3
  local -a aliases=("$@")
  local found=false line trimmed f1 f2 f3 f4 a match
  while IFS= read -r line || [[ -n "$line" ]]; do
    trimmed="${line#"${line%%[![:space:]]*}"}"
    if [[ -z "${line//[[:space:]]/}" || "$trimmed" == \#* ]]; then
      printf '%s\n' "$line"
      continue
    fi
    f1=""; f2=""; f3=""; f4=""
    read -r f1 f2 f3 f4 <<<"$line"
    match=false
    if [[ "$f1" == "$name" || "$f2" == "$canonical" ]]; then
      match=true
    else
      for a in "${aliases[@]}"; do
        [[ "$f2" == "$a" ]] && { match=true; break; }
      done
    fi
    if [[ "$match" == true ]]; then
      found=true
      printf '%s %s %s %s\n' "$f1" "$f2" "${f3:--}" "$(merge_crypttab_opts "${f4:-}" "$want")"
    else
      printf '%s\n' "$line"
    fi
  done
  if [[ "$found" != true ]]; then
    printf '%s %s - %s\n' "$name" "$canonical" "$want"
  fi
}

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------
log_act()  { printf '  -> %s\n' "$*"; }
log_skip() { printf '  -- %s\n' "$*"; }
log_info() { printf '%s\n' "$*"; }
err()      { printf '%s\n' "$*" >&2; }

usage() {
  cat <<'EOF'
Usage: setup-luks-tpm2-unlock.sh [OPTIONS]

TPM2-enroll every LUKS device on this running system for automated unlock at
boot. Prompts interactively for each device's existing passphrase. The
distro-specific mechanism (Fedora: dracut + systemd-cryptenroll; Ubuntu: clevis
+ initramfs-tools) is selected at chezmoi apply time.

Options:
  --dry-run            Print intended actions; change nothing.
  --recovery-key       Also enroll a printed recovery key (Fedora backend only).
  --tpm2-pcrs SPEC     PCR binding spec (default: 7). Examples: 7, 7+0, ''(none).
  -h, --help           Show this help and exit.

Notes:
  * Requires a terminal (it must prompt for your passphrase) unless --dry-run,
    or unless the passphrase is supplied via SETUP_LUKS_TPM2_PASSPHRASE (env
    only, never argv), in which case it enrolls non-interactively.
  * Adds a TPM2 keyslot; your existing passphrase keeps working as a fallback.
  * Idempotent: devices already enrolled for TPM2 unlock are skipped.
EOF
}

# ---------------------------------------------------------------------------
# Shared side-effecting state
# ---------------------------------------------------------------------------

DRY_RUN=false
WITH_RECOVERY_KEY=false
TPM2_PCRS=7
SUDO=()
CHANGED=0
CRYPTTAB_BACKED_UP=false
ROOT_KNAME=""
# Non-interactive passphrase (opt-in via SETUP_LUKS_TPM2_PASSPHRASE); see header.
PASSPHRASE=""
PASSPHRASE_FROM_ENV=false

require_cmd() {
  command -v "$1" >/dev/null 2>&1 || { err "ERROR: required command not found: $1"; exit 1; }
}

# device_is_root <dev> : true when <dev> (or any of its device-mapper
# descendants — LUKS, or LUKS->LVM->root) is the block device backing /.
# Compares by kernel name (KNAME) so it is immune to mapper-name vs dm-N vs
# symlink differences.
device_is_root() {
  local dev="$1" kn
  [[ -z "$ROOT_KNAME" ]] && return 1
  while IFS= read -r kn; do
    [[ "$kn" == "$ROOT_KNAME" ]] && return 0
  done < <(lsblk -rno KNAME "$dev" 2>/dev/null)
  return 1
}

# device_aliases <dev> <uuid> : print, one per line, every crypttab source form
# that can reference <dev> — UUID=, PARTUUID=, the raw path, its realpath, and
# every /dev/disk/* symlink (by-uuid/by-partuuid/by-id/by-path) resolving to it.
# Used for EXACT (never substring) matching of an existing crypttab entry.
device_aliases() {
  local dev="$1" uuid="$2" real partuuid link resolved
  real="$(readlink -f "$dev" 2>/dev/null || true)"
  printf '%s\n' "UUID=$uuid" "$dev"
  [[ -n "$real" && "$real" != "$dev" ]] && printf '%s\n' "$real"
  partuuid="$(lsblk -dno PARTUUID "$dev" 2>/dev/null || true)"
  [[ -n "$partuuid" ]] && printf '%s\n' "PARTUUID=$partuuid"
  for link in /dev/disk/*/*; do
    [[ -e "$link" ]] || continue
    resolved="$(readlink -f "$link" 2>/dev/null || true)"
    [[ -n "$real" && "$resolved" == "$real" ]] && printf '%s\n' "$link"
  done
}

# update_crypttab <name> <canonical-src> <want-opts> [alias...]
# Merge <want-opts> into the device's /etc/crypttab entry (or append a canonical
# entry). A backend that needs no crypttab change passes empty <want-opts>, in
# which case the caller skips this entirely.
update_crypttab() {
  local name="$1" canonical="$2" want="$3"
  shift 3
  local -a aliases=("$@")
  local current new tmp
  current="$("${SUDO[@]}" cat /etc/crypttab 2>/dev/null || true)"
  new="$(printf '%s' "$current" | render_crypttab "$name" "$canonical" "$want" "${aliases[@]}")"
  if [[ "$current" == "$new" ]]; then
    log_skip "/etc/crypttab already correct for $name"
    return 0
  fi
  CHANGED=$((CHANGED + 1))
  if [[ "$DRY_RUN" == true ]]; then
    log_act "would update /etc/crypttab entry for $name:"
    printf '%s\n' "$new" | grep -F -e "$canonical" -e "$name" | sed 's/^/        /' || true
    return 0
  fi
  if [[ "$CRYPTTAB_BACKED_UP" != true ]]; then
    if "${SUDO[@]}" test -e /etc/crypttab; then
      local backup
      backup="/etc/crypttab.bak.$(date +%Y%m%d%H%M%S)"
      "${SUDO[@]}" cp -a /etc/crypttab "$backup"
      log_act "backed up /etc/crypttab -> $backup"
    else
      log_skip "no existing /etc/crypttab to back up"
    fi
    CRYPTTAB_BACKED_UP=true
  fi
  # Atomic replace: write a temp file ON THE SAME FILESYSTEM (/etc), match the
  # existing mode/owner (or 0600 root when creating), then rename into place so
  # an interrupted/failed write can never truncate /etc/crypttab.
  tmp="$("${SUDO[@]}" mktemp /etc/crypttab.tmp.XXXXXX)"
  printf '%s\n' "$new" | "${SUDO[@]}" tee "$tmp" >/dev/null
  if "${SUDO[@]}" test -e /etc/crypttab; then
    "${SUDO[@]}" chmod --reference=/etc/crypttab "$tmp"
    "${SUDO[@]}" chown --reference=/etc/crypttab "$tmp"
  else
    "${SUDO[@]}" chmod 0600 "$tmp"
    "${SUDO[@]}" chown 0:0 "$tmp"
  fi
  "${SUDO[@]}" mv -f "$tmp" /etc/crypttab
  log_act "updated /etc/crypttab for $name"
}

# ---------------------------------------------------------------------------
# Distro backend — inlined at chezmoi apply time (see the file header). Each
# backend defines: backend_preflight, backend_enroll <dev> <name> [is_root],
# backend_crypttab_opts <is_root>, backend_finalize. A backend may use any shared
# helper/state above (SUDO, DRY_RUN, CHANGED, TPM2_PCRS, WITH_RECOVERY_KEY,
# log_*, err, require_cmd, update_crypttab, ...).
# ---------------------------------------------------------------------------
{{ if or (eq .chezmoi.osRelease.id "fedora") (eq .chezmoi.osRelease.id "ubuntu") -}}
{{ include (joinPath .chezmoi.sourceFile ".." (printf ".setup-luks-tpm2-unlock_%s.sh" .chezmoi.osRelease.id)) -}}
{{ else -}}
# No supported backend on this host (not Fedora/Ubuntu). Define no-op hooks so
# the shared flow exits cleanly at backend_preflight before any TTY/sudo prompt.
BACKEND_LABEL="unsupported host"
backend_preflight() {
  log_info "setup-luks-tpm2-unlock.sh has no TPM2 auto-unlock backend for this host"
  log_info "(only Fedora and Ubuntu are supported). Nothing to do; exiting."
  exit 0
}
backend_enroll()        { :; }
backend_crypttab_opts() { :; }
backend_finalize()      { :; }
{{ end -}}

# ---------------------------------------------------------------------------
# Shared orchestration
# ---------------------------------------------------------------------------

main() {
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --dry-run)        DRY_RUN=true ;;
      --recovery-key)   WITH_RECOVERY_KEY=true ;;
      --tpm2-pcrs)      shift; [[ $# -gt 0 ]] || { err "ERROR: --tpm2-pcrs requires a value"; exit 2; }; TPM2_PCRS="$1" ;;
      --tpm2-pcrs=*)    TPM2_PCRS="${1#*=}" ;;
      -h|--help)        usage; exit 0 ;;
      *)                err "ERROR: unknown option: $1"; err ""; usage >&2; exit 2 ;;
    esac
    shift
  done

  # Backend gate + prerequisite check FIRST — before any TTY/sudo prompt or state
  # change. It uses no sudo (only tool/module/hook availability) and exits cleanly
  # (0) on an unsupported host or aborts (non-zero) if the backend is unusable.
  backend_preflight

  # Non-interactive passphrase escape hatch (see header): read the existing
  # passphrase from the environment ONLY (never argv), then clear it from the
  # environment so no child process inherits it. When present, we neither prompt
  # nor need a TTY — the backends unlock with this passphrase instead.
  if [[ -n "${SETUP_LUKS_TPM2_PASSPHRASE:-}" ]]; then
    PASSPHRASE="$SETUP_LUKS_TPM2_PASSPHRASE"
    PASSPHRASE_FROM_ENV=true
  fi
  unset SETUP_LUKS_TPM2_PASSPHRASE

  # Interactive passphrase entry needs a terminal. Allow --dry-run without one,
  # and skip the requirement entirely when a passphrase was supplied via env.
  if [[ "$DRY_RUN" != true && "$PASSPHRASE_FROM_ENV" != true && ! -t 0 ]]; then
    err "ERROR: this script needs an interactive terminal to prompt for your LUKS"
    err "       passphrase. Run it directly in a terminal, pass it via the"
    err "       SETUP_LUKS_TPM2_PASSPHRASE environment variable, or use --dry-run."
    exit 1
  fi

  # dry-run uses `sudo -n` so its read-only probes never prompt/hang; a real run
  # primes the credential cache once so the only later prompts are the backend's
  # per-device passphrase prompts.
  if [[ "${EUID}" -eq 0 ]]; then
    SUDO=()
  elif ! command -v sudo >/dev/null 2>&1; then
    err "ERROR: not running as root and sudo is not available; cannot enroll TPM2."
    exit 1
  elif [[ "$DRY_RUN" == true ]]; then
    SUDO=(sudo -n)
  else
    SUDO=(sudo)
  fi
  if [[ "$DRY_RUN" != true && "${#SUDO[@]}" -gt 0 ]]; then
    "${SUDO[@]}" -v || { err "ERROR: sudo authentication failed"; exit 1; }
  fi

  require_cmd cryptsetup
  require_cmd lsblk
  require_cmd findmnt
  require_cmd readlink

  # TPM2 presence: a kernel TPM2 device node (backend-neutral).
  if [[ ! -e /sys/class/tpm/tpm0 && ! -e /dev/tpmrm0 ]]; then
    err "ERROR: no TPM2 device found (no /sys/class/tpm/tpm0 and no /dev/tpmrm0)."
    err "       TPM2 auto-unlock is not possible here."
    exit 1
  fi

  # Enumerate crypto_LUKS devices (lsblk needs no root for this).
  local -a devices=()
  mapfile -t devices < <(lsblk -rno PATH,FSTYPE 2>/dev/null | awk '$2=="crypto_LUKS"{print $1}' | sort -u)
  if [[ "${#devices[@]}" -eq 0 ]]; then
    log_info "No crypto_LUKS devices found; nothing to do."
    exit 0
  fi

  # Kernel name (e.g. dm-0) of the block device backing /, for ancestry-based
  # root detection. A btrfs '[subvol]' suffix is stripped first.
  local root_src
  root_src="$(findmnt -no SOURCE / 2>/dev/null || true)"
  root_src="${root_src%%[*}"
  ROOT_KNAME="$(lsblk -no KNAME "$root_src" 2>/dev/null | head -n1 || true)"

  log_info "Backend: ${BACKEND_LABEL}"
  log_info "Found ${#devices[@]} crypto_LUKS device(s)."
  [[ "$DRY_RUN" == true ]] && log_info "(dry-run: no changes will be made)"

  local dev uuid name is_root canonical opts
  local -a aliases
  for dev in "${devices[@]}"; do
    # -d (--nodeps) is REQUIRED: without it lsblk recurses into the opened
    # mapping and may emit the inner filesystem UUID, not the LUKS header UUID
    # that /etc/crypttab keys by — keying by the wrong UUID breaks boot.
    uuid="$(lsblk -dno UUID "$dev" 2>/dev/null | head -n1 || true)"
    if [[ -z "$uuid" ]]; then
      log_skip "$dev: could not read LUKS UUID; skipping"
      continue
    fi
    name="$(lsblk -rno NAME "$dev" 2>/dev/null | awk 'NR==2{print}')"
    [[ -z "$name" ]] && name="luks-$uuid"

    if device_is_root "$dev"; then
      is_root=true
    else
      is_root=false
    fi
    canonical="UUID=$uuid"
    mapfile -t aliases < <(device_aliases "$dev" "$uuid")

    log_info ""
    log_info "Device $dev (name=$name, uuid=$uuid, root=$is_root)"
    backend_enroll "$dev" "$name" "$is_root"
    opts="$(backend_crypttab_opts "$is_root")"
    if [[ -n "$opts" ]]; then
      update_crypttab "$name" "$canonical" "$opts" "${aliases[@]}"
    else
      log_skip "$name: backend needs no /etc/crypttab change"
    fi
  done

  log_info ""
  backend_finalize

  log_info ""
  if [[ "$DRY_RUN" == true ]]; then
    log_info "Dry run complete. Re-run without --dry-run to apply."
  else
    log_info "Done. Reboot to verify the TPM2 automatically unlocks your disk(s)."
    log_info "Your existing passphrase still works as a fallback."
  fi
}

# Run main only when executed, not when sourced (so the pure helpers above can
# be imported in isolation without triggering the side-effecting flow).
if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
  main "$@"
fi
