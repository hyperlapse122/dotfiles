#!/usr/bin/env bash

set -euo pipefail

# This wrapper and cli-proxy-api both live in ~/.local/bin (the latter from
# .chezmoiexternals/cli-proxy-api.toml). Fall back to that dir when it is not
# already on PATH so the sibling binary resolves even under a restricted PATH.
case ":$PATH:" in
  *":$HOME/.local/bin:"*) ;;
  *) PATH="$PATH:$HOME/.local/bin" ;;
esac
export PATH

if ! command -v cli-proxy-api >/dev/null 2>&1; then
  printf 'cli-proxy-api-codex-login: `cli-proxy-api` not found on PATH\n' >&2
  exit 127
fi

exec cli-proxy-api --config "$HOME/.config/cli-proxy-api/config.yaml" --codex-login --no-browser "$@"
