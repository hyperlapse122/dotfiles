#!/usr/bin/env bash
#
# docker-credential-dockerhub — Cross-platform Docker credential helper that
# stores credentials in the OS-native keychain.
#
# Docker invokes this binary whenever it needs credentials for a registry
# that isn't already mapped to a more specific helper in
# ~/.docker/config.json. We register it as the top-level `credsStore`, so it
# covers Docker Hub (`https://index.docker.io/v1/`) and every other registry
# that doesn't have an explicit `credHelpers` entry. The per-host entries
# (ghcr.io, registry.jpi.app, etc.) still win for their own hosts because
# Docker checks `credHelpers` first.
#
# This script delegates the full Docker credential-helper protocol — `get`,
# `store`, `erase`, `list` — to the platform-native helper from
# docker/docker-credential-helpers:
#
#   macOS → docker-credential-osxkeychain    (Keychain.app)
#   Linux → docker-credential-secretservice  (D-Bus Secret Service:
#                                             KWallet / GNOME Keyring /
#                                             KeePassXC / 1Password etc.)
#
# Both underlying binaries are installed by chezmoi via
# .chezmoiexternals/system.toml from the
# docker/docker-credential-helpers GitHub releases.
#
# Protocol references:
#   https://docs.docker.com/reference/cli/docker/login/#credential-stores
#   https://docs.docker.com/reference/cli/docker/login/#credential-helpers
#   https://github.com/docker/docker-credential-helpers
#
# Single-platform exception (AGENTS.md "Script parity rule"):
#   Docker on Windows resolves credential helpers via PATHEXT and expects
#   `.cmd`/`.exe`. The Windows-side equivalent is
#   `docker-credential-wincred`, which ships with Docker Desktop natively
#   and does not need a wrapper. If a non-Desktop Windows setup is added
#   later, ship `docker-credential-dockerhub.cmd` alongside this file that
#   `exec`s `docker-credential-wincred`.

set -euo pipefail

case "$(uname -s)" in
  Darwin)
    helper=docker-credential-osxkeychain
    ;;
  Linux)
    helper=docker-credential-secretservice
    ;;
  *)
    printf 'docker-credential-dockerhub: unsupported OS: %s\n' "$(uname -s)" >&2
    exit 1
    ;;
esac

if ! command -v "$helper" >/dev/null 2>&1; then
  # Exact sentinel — Docker's helper client trims whitespace and maps this
  # message to ErrCredentialsNotFound, letting the auth flow fall back
  # gracefully instead of hard-erroring during enumeration (e.g. `list`).
  if [[ "${1:-}" == "list" ]]; then
    printf '{}\n'
    exit 0
  fi
  printf 'docker-credential-dockerhub: %s not found on PATH (install via .chezmoiexternals/system.toml)\n' "$helper" >&2
  exit 1
fi

exec "$helper" "$@"
