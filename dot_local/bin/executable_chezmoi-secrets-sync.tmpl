{{ if ne .chezmoi.os "windows" -}}
#!/usr/bin/env bash
# chezmoi-secrets-sync — refresh the committed GPG secrets cache from 1Password.
#
# Reads every render-time op:// ref from the chezmoi source (the .chezmoidata data
# files + the secret-read call sites), fetches each value from 1Password, and writes
# an armored GPG-encrypted JSON bundle to <source>/.chezmoitemplates/secrets-bundle.json.asc
# for you to commit. `chezmoi apply` then decrypts that cache locally (via the
# secret-read / resolve-op-refs shims) instead of making ~100 live `op` reads.
#
# SAFE BY DESIGN:
#   - never writes plaintext to disk — the JSON is assembled in memory with jq and
#     piped straight into gpg over stdin (only the .asc ciphertext touches the tree);
#   - excludes the one ref the render-time shim can never serve, the GPG private-key
#     import, and ABORTS if it ever appears — the private key must never be baked into
#     the public bundle.
#
# Run it whenever you rotate a secret in 1Password or add a new op:// ref, then commit
# + push the updated bundle and `chezmoi apply` on each host.
#
# Usage: chezmoi-secrets-sync [SOURCE_DIR]   (SOURCE_DIR defaults to `chezmoi source-path`)

set -euo pipefail

RECIPIENT="{{ .user.gpgPubKey }}"
SRC="${1:-$(chezmoi source-path)}"
BUNDLE_DIR="$SRC/.chezmoitemplates"
BUNDLE="$BUNDLE_DIR/secrets-bundle.json.asc"
KEY_SCRIPT="$SRC/.chezmoiscripts/80-keys/run_once_before_import-gpg-key.sh.tmpl"

for c in op gpg jq; do
  command -v "$c" >/dev/null 2>&1 || { printf 'chezmoi-secrets-sync: %s not found on PATH\n' "$c" >&2; exit 1; }
done
# No `op whoami` precondition: desktop-app-mediated `op read` works even when
# `op whoami` reports no CLI session (per the repo's op guidance). A genuinely
# unavailable op surfaces as a per-ref `op read` failure below, which aborts the run
# before anything is written.
gpg --list-keys "$RECIPIENT" >/dev/null 2>&1 || { printf 'chezmoi-secrets-sync: recipient %s not in gpg keyring\n' "$RECIPIENT" >&2; exit 1; }
[ -d "$BUNDLE_DIR" ] || { printf 'chezmoi-secrets-sync: source dir not found: %s\n' "$SRC" >&2; exit 1; }

# Collect render-time op:// refs (exact strings, spaces preserved):
#   (A) values in every .chezmoidata/*.yaml data file (active, non-comment lines; quoted
#       or bare) — glob all of them so a ref added to any current or future data file is
#       captured, not just agents.yaml/networking.yaml
#   (B) direct secret-read call refs in templates, excluding the .chezmoitemplates/
#       helpers and this script itself (they carry the pattern in docs/code, not as
#       active refs)
collect_refs() {
  local f
  for f in "$SRC"/.chezmoidata/*.yaml; do
    [ -f "$f" ] || continue
    # `|| true`: most data files have no op:// ref, and grep exiting 1 under pipefail
    # must not abort the scan.
    grep -vE '^[[:space:]]*#' "$f" | grep -oE 'op://[^"]*' | sed -E 's/[[:space:]]+#.*$//; s/[[:space:]]+$//' || true
  done
  grep -rlE '"ref" "op://' --include='*.tmpl' "$SRC" \
    | grep -vE '/\.chezmoitemplates/|chezmoi-secrets-sync' \
    | while IFS= read -r f; do grep -oE '"ref" "op://[^"]*"' "$f"; done \
    | sed -E 's/^"ref" "//; s/"$//'
}

mapfile -t REFS < <(collect_refs | sort -u)
[ "${#REFS[@]}" -gt 0 ] || { printf 'chezmoi-secrets-sync: no op:// refs found under %s\n' "$SRC" >&2; exit 1; }

# Safety: the GPG private-key ref must never enter the public bundle.
KEY_REF="$(grep -oE 'op://[^"]*' "$KEY_SCRIPT" 2>/dev/null | head -n1 || true)"
if [ -n "$KEY_REF" ] && printf '%s\n' "${REFS[@]}" | grep -qxF -- "$KEY_REF"; then
  printf 'chezmoi-secrets-sync: ABORT — the GPG private-key ref would be baked into the bundle\n' >&2
  exit 1
fi

printf 'chezmoi-secrets-sync: fetching %s secrets from 1Password...\n' "${#REFS[@]}" >&2
pairs() {
  local ref val
  for ref in "${REFS[@]}"; do
    val="$(op read -- "$ref")" || { printf 'chezmoi-secrets-sync: op read failed: %s\n' "$ref" >&2; return 1; }
    # value via env, not argv: a secret in jq's argv is world-readable in /proc/<pid>/cmdline
    v="$val" jq -cn --arg k "$ref" '{key: $k, value: env.v}'
  done
}

# Build the object in memory (never a plaintext file on disk), then encrypt via stdin.
bundle_json="$(pairs | jq -s 'map({(.key): .value}) | add')"
trap 'rm -f "$BUNDLE.tmp"' EXIT
umask 077
printf '%s\n' "$bundle_json" | gpg --batch --yes --armor --encrypt --recipient "$RECIPIENT" --output "$BUNDLE.tmp" -
mv -f "$BUNDLE.tmp" "$BUNDLE"
unset bundle_json

printf 'chezmoi-secrets-sync: wrote %s (%s secrets). Review, commit, push, then apply on each host.\n' \
  "${BUNDLE#"$SRC"/}" "${#REFS[@]}" >&2
{{ end -}}
