#!/bin/sh
# virt-manager — system-python wrapper.
#
# Ubuntu's virt-manager/virt-install 5.1.0 ship `#!/usr/bin/env python3`
# entry points (not rewritten to /usr/bin/python3), while this repo's mise
# config installs `python = "latest"` whose python3 shadows the system one on
# PATH. Only the system python carries the distro PyGObject, so the tools die
# with `ModuleNotFoundError: No module named 'gi'` under the mise python.
# ~/.local/bin precedes /usr/bin on PATH, so this wrapper intercepts the
# command and re-runs the real binary with the system bin dirs first — the
# original PATH stays appended for anything it spawns. Fedora mangles the
# shebang to /usr/bin/python3 at rpm build time, so there this is a no-op
# pass-through. Same pattern: virt-install, virt-xml, virt-clone.
PATH="/usr/bin:/bin:$PATH"
export PATH
exec /usr/bin/virt-manager "$@"
