#!/usr/bin/env bash
#
# docker-credential-glab — Docker credential helper for GitLab-hosted registries.
#
# Docker invokes this binary when authenticating to any registry mapped to
# `glab` in ~/.docker/config.json (currently `registry.jpi.app`). We delegate
# the full credential-helper protocol to `glab`'s built-in
# `auth docker-helper` subcommand, which:
#   1. Reads the registry URL from stdin.
#   2. Resolves the matching GitLab host via each host's
#      `container_registry_domains` config entry.
#   3. Refreshes OAuth2 access tokens automatically when expired.
#   4. Returns the {Username, Secret} JSON Docker expects.
#
# Setup: run `scripts/auth-glab.sh` once. That calls `glab auth login` with
# `--container-registry-domains`, recording the registry-host mapping that
# `glab auth docker-helper` reads here.
#
# Single-platform exception (AGENTS.md "Script parity rule"): see the header
# in `docker-credential-gh` for the rationale; same applies here. If Windows
# support is added later, ship `docker-credential-glab.cmd` alongside this
# file.
#
# Dependencies: `glab` on PATH (mise shim, exposed by the shell's
# `eval "$(mise activate ...)"`). This script does NOT use `mise exec`.

set -euo pipefail

if ! command -v glab >/dev/null 2>&1; then
  printf 'docker-credential-glab: `glab` CLI not found on PATH\n' >&2
  exit 1
fi

# `list` is invoked by Docker's native-store enumeration paths but
# `glab auth docker-helper` does not implement it. Short-circuit with an
# empty map so flows like `docker logout` / compose enumeration don't break.
if [[ "${1:-}" == "list" ]]; then
  printf '{}\n'
  exit 0
fi

# `get` / `store` / `erase` (and anything else glab adds later) → delegate.
# Note: `store` and `erase` return a clear user-facing error from glab telling
# the user to remove this credential helper if they want manual login/logout,
# which is the correct UX for a token-managed registry.
exec glab auth docker-helper "$@"
