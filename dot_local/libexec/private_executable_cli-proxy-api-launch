#!/bin/sh
# Internal CLIProxyAPI launcher. Called only by the managed user supervisors.
set -eu
umask 077
unset CDPATH ENV BASH_ENV LD_PRELOAD LD_LIBRARY_PATH LD_AUDIT LD_DEBUG \
  LD_PROFILE GCONV_PATH LOCPATH GLIBC_TUNABLES DYLD_INSERT_LIBRARIES \
  DYLD_LIBRARY_PATH DYLD_FRAMEWORK_PATH DYLD_FALLBACK_LIBRARY_PATH \
  DYLD_FALLBACK_FRAMEWORK_PATH DYLD_VERSIONED_LIBRARY_PATH \
  DYLD_VERSIONED_FRAMEWORK_PATH DYLD_ROOT_PATH DYLD_IMAGE_SUFFIX \
  DYLD_FORCE_FLAT_NAMESPACE \
  DYLD_SHARED_REGION
PATH=/usr/bin:/bin:/usr/sbin:/sbin
export PATH

fail() {
  printf '%s\n' "cli-proxy-api launcher: $*" >&2
  exit 1
}

[ "${1-}" = "--" ] || fail "invalid invocation"
shift
[ "$#" -eq 0 ] || fail "unexpected arguments"

: "${CPA_HOME:?CPA_HOME is required}"
: "${CPA_ACTIVE_BINARY:?CPA_ACTIVE_BINARY is required}"
: "${CPA_CONFIG:?CPA_CONFIG is required}"
: "${CPA_AUTH_DIR:?CPA_AUTH_DIR is required}"
: "${CPA_WORK_DIR:?CPA_WORK_DIR is required}"

case $CPA_HOME in
  /*) ;;
  *) fail "managed home must be absolute" ;;
esac
owner_uid=$(id -u)
stat_uid() {
  if [ "$(uname -s)" = Darwin ]; then
    stat -f '%u' "$1"
  else
    stat -c '%u' "$1"
  fi
}
stat_mode() {
  if [ "$(uname -s)" = Darwin ]; then
    stat -f '%Lp' "$1"
  else
    stat -c '%a' "$1"
  fi
}
validate_private_dir() {
  label=$1
  path=$2
  [ ! -L "$path" ] || fail "$label must not be a symlink"
  if [ ! -e "$path" ]; then
    mkdir -m 700 "$path"
  fi
  [ -d "$path" ] || fail "$label is not a directory"
  [ "$(stat_uid "$path")" = "$owner_uid" ] || fail "$label owner mismatch"
  [ "$(stat_mode "$path")" = 700 ] || fail "$label mode must be 0700"
}
directory_is_empty() {
  for entry in "$1"/* "$1"/.[!.]* "$1"/..?*; do
    [ ! -e "$entry" ] && [ ! -L "$entry" ] || return 1
  done
  return 0
}

[ -d "$CPA_HOME" ] || fail "managed home is not a directory"
[ "$(stat_uid "$CPA_HOME")" = "$owner_uid" ] || fail "managed home owner mismatch"
[ "$CPA_ACTIVE_BINARY" = "$CPA_HOME/.local/share/cli-proxy-api/current/cli-proxy-api" ] || fail "active binary path is unmanaged"
[ "$CPA_CONFIG" = "$CPA_HOME/.config/cli-proxy-api/config.yaml" ] || fail "config path is unmanaged"
[ "$CPA_AUTH_DIR" = "$CPA_HOME/.local/share/cli-proxy-api/auth" ] || fail "auth directory path is unmanaged"
[ "$CPA_WORK_DIR" = "$CPA_HOME/.local/share/cli-proxy-api/work" ] || fail "working directory path is unmanaged"

[ ! -L "$CPA_ACTIVE_BINARY" ] || fail "active binary must not be a symlink"
[ -f "$CPA_ACTIVE_BINARY" ] || fail "active binary is not a regular file"
[ -x "$CPA_ACTIVE_BINARY" ] || fail "active binary is not executable"
[ -f "$CPA_CONFIG" ] && [ ! -L "$CPA_CONFIG" ] || fail "config is not a regular file"
[ -r "$CPA_CONFIG" ] || fail "config is not readable"
[ "$(stat_uid "$CPA_CONFIG")" = "$owner_uid" ] || fail "config owner mismatch"
[ "$(stat_mode "$CPA_CONFIG")" = 444 ] || fail "config mode must be 0444"

validate_private_dir "auth directory" "$CPA_AUTH_DIR"
validate_private_dir "working directory" "$CPA_WORK_DIR"
[ ! -e "$CPA_WORK_DIR/.env" ] || fail "working directory contains forbidden .env"

# Auth state is deliberately sterile. Never delete or print unexpected entries.
directory_is_empty "$CPA_AUTH_DIR" || fail "auth directory is not empty"

validate_private_dir "temporary directory" "$CPA_WORK_DIR/tmp"
cd "$CPA_WORK_DIR"

# Preserve no ambient credential or proxy variables. CLIProxyAPI needs only its
# managed HOME paths, a private temp directory, a fixed system PATH, and locale.
# -local-model disables both mutable remote model-catalog updaters; upstream's
# credential-free Antigravity version metadata refresh remains unavoidable.
exec env -i \
  HOME="$CPA_HOME" \
  PATH=/usr/bin:/bin:/usr/sbin:/sbin \
  TMPDIR="$CPA_WORK_DIR/tmp" \
  LANG=C \
  LC_ALL=C \
  "$CPA_ACTIVE_BINARY" -config "$CPA_CONFIG" -local-model
