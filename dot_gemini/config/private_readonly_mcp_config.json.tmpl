{{- /* gemini (Google Gemini CLI / Antigravity CLI) MCP servers are data-driven
       from .chezmoidata/agents.yaml through agent-mcp-servers-json.tmpl. Add or remove a
       server there and the gemini config picks it up, mirroring pi mcp.json and
       opencode.json. gemini's mcpServers object uses `command`/`args` for stdio
       servers and `serverUrl` (plus optional `headers`) for HTTP servers;
       `auth: oauth` marks a headerless HTTP server whose credentials are
       provisioned on demand by the figma-auth utility — run
       `figma-auth antigravity` for the Antigravity CLI token store — so no
       target-specific field is emitted here. The recursive resolver applies the
       shared op:// -> onepasswordRead / else-as-is rule to each header value.
       toPrettyJson owns the comma/whitespace handling (and emits keys
       alphabetically, like the pi and opencode siblings). */ -}}
{{- $servers := dict -}}
{{- $mcpServers := includeTemplate "agent-mcp-servers-json.tmpl" (dict "ctx" .) | fromJson -}}
{{- range $mcpServers -}}
{{- if hasKey . "auth" -}}
{{- $auth := get . "auth" -}}
{{- if ne $auth "oauth" -}}
{{- fail (printf "gemini mcp: server %q has unknown auth %q; valid values: oauth" .name $auth) -}}
{{- end -}}
{{- if eq .transport "stdio" -}}
{{- fail (printf "gemini mcp: stdio server %q cannot declare auth %q" .name $auth) -}}
{{- end -}}
{{- end -}}
{{- if eq .transport "stdio" -}}
{{- $servers = set $servers .name (dict "command" .command "args" .args) -}}
{{- else -}}
{{- $e := dict "serverUrl" .url -}}
{{- if hasKey . "headers" -}}
{{- $h := dict -}}
{{- range $k, $v := get . "headers" -}}
{{- $resolved := includeTemplate "resolve-op-refs-json.tmpl" (dict "value" $v "ctx" $) | fromJson -}}
{{- $h = set $h $k $resolved -}}
{{- end -}}
{{- $e = set $e "headers" $h -}}
{{- end -}}
{{- $servers = set $servers .name $e -}}
{{- end -}}
{{- end -}}
{{ toPrettyJson "  " (dict "mcpServers" $servers) }}
