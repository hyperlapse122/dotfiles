# The age identity is provisioned only on POSIX hosts (.chezmoiscripts/80-keys/
# is a bash script with no .ps1 counterpart), so Windows can never decrypt the
# encrypted ~/src project registry — skip it there.
{{- if eq .chezmoi.os "windows" }}
src/garden.yaml
{{- end }}

# Vendored source dirs: crates/ + packages/ monorepos are built/used in place,
