# Containerized / CI environments: Podman creates /run/.containerenv, Docker
# creates /.dockerenv (neither exists on a bare-metal host or VM). Inside a
# container, deploy the CLI dotfiles only and skip all host provisioning:
# package installs, /etc system config, GPG/GitHub/Tailscale auth, fonts,
# KDE/GNOME settings, pro-audio realtime provisioning, and the MX Master haptic build. The
# opencode plugin build is deliberately KEPT (opencode is a first-class CLI
# here; that script soft-skips when its toolchain is absent).
#
# distrobox and toolbox are the OPT-OUT: both bind-mount the host $HOME and both
# create /run/.toolboxenv (distrobox touches it for toolbx compatibility), so an
# apply inside one writes to the real host $HOME and must behave like the host —
# provision fully. Skip only a "real" container: a Podman/Docker marker present
# WITHOUT /run/.toolboxenv.
{{- if and (or (stat "/run/.containerenv") (stat "/.dockerenv")) (not (stat "/run/.toolboxenv")) }}
.chezmoiscripts/30-linux/*.sh
.chezmoiscripts/20-linux-fedora/*.sh
.chezmoiscripts/40-linux-ubuntu/*.sh
.chezmoiscripts/50-linux-kde/*.sh
.chezmoiscripts/50-linux-gnome/*.sh
.chezmoiscripts/10-auth/*.sh
.chezmoiscripts/80-gpg/*.sh
.chezmoiscripts/60-build/*mxm4-haptic.sh
{{- end }}
