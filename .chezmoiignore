# The mxm4-haptic Claude Code / Codex / AGY plugins drive the Linux-only
# mxm4-hapticd daemon (it owns Linux hidraw for the MX Master 4), so there is
# nothing to pulse on macOS/Windows — mirrors the Linux-only mxm4-haptic.js
# OpenCode plugin symlink in .chezmoiscripts/60-build/. Skipping the deployed
# trees also strands nothing: the installer rows below are gated on linux too.
{{- if ne .chezmoi.os "linux" }}
.local/share/claude-plugins
.local/share/codex-plugins
.local/share/agy-plugins
{{- end }}

# Pi is provisioned only on POSIX. Its mxm4-haptic extension shells out to the
# cross-platform Linux/macOS client, and settings.json is a managed private 0400
# target. Skip both on Windows, where Pi is not installed. (No installer is
# stranded: Pi auto-discovers the extension/config targets, and the package
# install script gates itself on `pi` being on PATH.)
{{- if eq .chezmoi.os "windows" }}
.pi/agent/extensions/mxm4-haptic.ts
.pi/agent/settings.json
.pi/agent/models.json
{{- end }}

