./crates
./packages

# The mxm4-haptic Claude Code plugin drives the Linux-only mxm4-hapticd daemon
# (it owns Linux hidraw for the MX Master 4), so there is nothing to pulse on
# macOS/Windows — mirrors the Linux-only mxm4-haptic.js OpenCode plugin symlink
# in .chezmoiscripts/60-build/. Skipping the deployed tree also strands
# nothing: the Claude installer script below is gated on linux too.
{{- if ne .chezmoi.os "linux" }}
.local/share/claude-plugins
{{- end }}

# Pi is provisioned only on POSIX. Its mxm4-haptic extension shells out to the
# cross-platform Linux/macOS client, and its settings.json is a managed 0444
# target that pi cannot write. Skip both on Windows, where pi is not installed.
# (No installer is stranded: pi auto-discovers the extension, and the package
# install script gates itself on `pi` being on PATH.)
{{- if eq .chezmoi.os "windows" }}
.pi/agent/extensions/mxm4-haptic.ts
.pi/agent/settings.json
# CLIProxyAPI has no Windows service/reconciler and must not render partial state.
.chezmoiscripts/90-services/*cli-proxy-api*.sh
.config/cli-proxy-api
.local/libexec/cli-proxy-api-launch
{{- end }}

# Advisor improvement plans (repo-meta docs); never linked into $HOME.
./plans

# internal documentations
./docs

# Containerized / CI environments: Podman creates /run/.containerenv, Docker
# creates /.dockerenv (neither exists on a bare-metal host or VM). Inside a
# container, deploy the CLI dotfiles only and skip all host provisioning:
# package installs, /etc system config, GPG/GitHub/Tailscale auth, fonts,
# KDE/GNOME settings, pro-audio realtime provisioning, and the MX Master haptic
# build. The OpenCode workspace build is deliberately KEPT: the agent CLIs are
# first-class here (the OpenCode workspace build soft-skips when its toolchain
# is absent).
#
# distrobox and toolbox are the OPT-OUT: both bind-mount the host $HOME and both
# create /run/.toolboxenv (distrobox touches it for toolbx compatibility), so an
# apply inside one writes to the real host $HOME and must behave like the host —
# provision fully. Skip only a "real" container: a Podman/Docker marker present
# WITHOUT /run/.toolboxenv.
#
# That whole predicate is the `container` fact — declared in .chezmoidata/facts.yaml
# and resolved once in .chezmoitemplates/facts.tmpl, which is also what the guard
# partials and the installers read. The markers are no longer stat'd here: one
# machine, one answer.
{{- $f := includeTemplate "facts.tmpl" . | fromYaml }}
{{- if $f.container }}
.chezmoiscripts/30-linux/*.sh
.chezmoiscripts/20-linux-fedora/*.sh
.chezmoiscripts/40-linux-ubuntu/*.sh
.chezmoiscripts/50-linux-kde/*.sh
.chezmoiscripts/50-linux-gnome/*.sh
.chezmoiscripts/10-auth/*.sh
.chezmoiscripts/80-keys/*.sh
.chezmoiscripts/60-build/*mxm4-haptic.sh
.chezmoiscripts/90-services/*cli-proxy-api*.sh
.config/cli-proxy-api
.config/systemd/user/cli-proxy-api.service
.local/libexec/cli-proxy-api-launch
Library/LaunchAgents/dev.h82.cli-proxy-api.plist
# No MX Master 4 in a container, and the haptic build is skipped just above, so
# the Claude Code haptic plugin and the pi haptic extension have nothing to
# pulse — skip the deployed plugin tree, the `claude plugin install` script, and
# the pi extension. (The dotagents skills install in the same 70-agents dir is
# deliberately KEPT — see below.)
.local/share/claude-plugins
.chezmoiscripts/70-agents/*claude-plugins.sh
.pi/agent/extensions/mxm4-haptic.ts
# CLIProxyAPI infrastructure is deliberately skipped in real containers: no
# external candidate, config, launcher, user service, or reconciliation side effect.
# The 80-keys age-identity import is skipped above, so the encrypted ~/src
# project registry cannot be decrypted in a container — skip it too (the
# ~/src layout is a host concept anyway).
src/garden.yaml
{{- end }}
