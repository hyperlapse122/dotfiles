{{- /* This file declares ONLY the MCP servers, data-driven from
       .chezmoidata/agents.yaml (range over .agents.mcp.servers). Add or remove an
       MCP server in the DATA file, not here. HTTP headers are optional;
       `auth: oauth` marks a headerless server that uses Claude Code/Codex native
       OAuth storage and therefore needs no target-specific TOML field.

       There are NO dotagents path: skills any more; dotagents declares MCP servers
       only. User-scoped skills reach ~/.agents/skills/<name> two ways: chezmoi
       externals (the list is data in .chezmoidata/agents.yaml, agents.skills.external;
       see .chezmoiexternals/ai-agents.toml), and locally-authored personal skills
       managed directly as chezmoi source under dot_agents/skills/<name>/ (e.g.
       daily-report). dotagents still owns the ~/.claude/skills -> ~/.agents/skills
       symlink — through which both reach Claude Code — and its `install` never prunes
       an undeclared dir (prune is sync-only), so they coexist with the symlink.

       NOT here: everyinc/compound-engineering-plugin. It ships a first-class
       plugin for every agent this repo runs, so it is installed through each
       agent's own plugin mechanism instead of being vendored in as dotagents
       skills — see the generic .chezmoiscripts/70-agents/install-agent-plugins
       (Claude Code + Codex) and the `plugin` array of
       dot_config/opencode/readonly_opencode.json.tmpl (OpenCode). */ -}}
version = 1
agents = ["claude", "codex"]

[trust]
git_domains = ["git.jpi.app"]

{{- range .agents.mcp.servers }}
{{- if hasKey . "auth" }}
{{- $auth := get . "auth" }}
{{- if ne $auth "oauth" }}
{{- fail (printf "dotagents mcp: server %q has unknown auth %q; valid values: oauth" .name $auth) }}
{{- end }}
{{- if eq .transport "stdio" }}
{{- fail (printf "dotagents mcp: stdio server %q cannot declare auth %q" .name $auth) }}
{{- end }}
{{- end }}
[[mcp]]
name = {{ .name | quote }}
{{- if eq .transport "stdio" }}
command = {{ .command | quote }}
args = {{ .args | toJson }}
{{- else }}
url = {{ .url | quote }}
{{- if hasKey . "headers" }}

[mcp.headers]
{{- range $k, $v := get . "headers" }}
{{- $resolved := includeTemplate "resolve-op-refs-json.tmpl" (dict "value" $v) | fromJson }}
{{ $k }} = '{{ $resolved }}'
{{- end }}
{{- end }}
{{- end }}
{{- end }}
