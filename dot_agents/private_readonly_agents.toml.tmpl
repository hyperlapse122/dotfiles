{{- /* Remote skills + MCP servers are data-driven from .chezmoidata/agents.yaml
       (range over .agents.skills.remote and .agents.mcp.servers). The twelve
       local path skills below stay literal here — single consumer, pending
       future removal. Add or remove a remote skill or MCP server in the DATA
       file, not here.

       Remote skill `ref`: absent -> newest release via gitHubLatestRelease
       (release-tracking); present -> literal (improve's "main", which publishes
       no tags). These are GitHub API calls: run chezmoi through the zsh wrapper
       (or `zsh -ic 'chezmoi …'`) so GITHUB_TOKEN is injected.

       NOT here: everyinc/compound-engineering-plugin. It ships a first-class
       plugin for every agent this repo runs, so it is installed through each
       agent's own plugin mechanism instead of being vendored in as dotagents
       skills — see .chezmoiscripts/70-agents/install-compound-engineering
       (Claude Code + Codex) and the `plugin` array of
       dot_config/opencode/readonly_opencode.json.tmpl (OpenCode).

       install-dotagents-skills embeds these same refs in its onchange
       fingerprint, so a new upstream release re-triggers the install that
       actually fetches it — keep the two in sync. */ -}}
version = 1
agents = ["claude", "codex"]

[trust]
github_orgs = ["getsentry", "microsoft", "shadcn"]
git_domains = ["git.jpi.app"]

{{- range .agents.skills.remote }}
[[skills]]
name = {{ .name | quote }}
source = {{ .source | quote }}
{{- if hasKey . "ref" }}
ref = {{ .ref | quote }}
{{- else }}
ref = {{ (gitHubLatestRelease .source).TagName | quote }}
{{- end }}
{{- end }}

[[skills]]
name = "ci-cd-monitoring"
source = "path:skills/ci-cd-monitoring"

[[skills]]
name = "daily-report"
source = "path:skills/daily-report"

[[skills]]
name = "git-branch-cleanup"
source = "path:skills/git-branch-cleanup"

[[skills]]
name = "git-workflow"
source = "path:skills/git-workflow"

[[skills]]
name = "gitlab-issues"
source = "path:skills/gitlab-issues"

[[skills]]
name = "glab"
source = "path:skills/glab"

[[skills]]
name = "glab-stack"
source = "path:skills/glab-stack"

[[skills]]
name = "harness-delegation"
source = "path:skills/harness-delegation"

[[skills]]
name = "js-package-managers"
source = "path:skills/js-package-managers"

[[skills]]
name = "pr-mr"
source = "path:skills/pr-mr"

[[skills]]
name = "ship-issue"
source = "path:skills/ship-issue"

[[skills]]
name = "src-layout"
source = "path:skills/src-layout"

{{- range .agents.mcp.servers }}
[[mcp]]
name = {{ .name | quote }}
{{- if eq .transport "stdio" }}
command = {{ .command | quote }}
args = {{ .args | toJson }}
{{- else }}
url = {{ .url | quote }}

[mcp.headers]
{{- range $k, $v := .headers }}
{{ $k }} = '{{ onepasswordRead $v }}'
{{- end }}
{{- end }}
{{- end }}
