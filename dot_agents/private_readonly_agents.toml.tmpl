{{- /* Every remote skill tracks its newest upstream release, resolved HERE at
       render time — there is no hand-maintained pin and no settle window
       (`minimum_release_age` is deliberately absent: it would reject a
       just-published release and fail the whole apply).

       install-dotagents-skills embeds these same refs in its onchange
       fingerprint, so a new upstream release re-triggers the install that
       actually fetches it — keep the two in sync.

       NOT here: everyinc/compound-engineering-plugin. It ships a first-class
       plugin for every agent this repo runs, so it is installed through each
       agent's own plugin mechanism instead of being vendored in as dotagents
       skills — see .chezmoiscripts/70-agents/install-compound-engineering
       (Claude Code + Codex) and the `plugin` array of
       dot_config/opencode/readonly_opencode.json.tmpl (OpenCode).

       These are GitHub API calls: run chezmoi through the zsh wrapper (or
       `zsh -ic 'chezmoi …'`) so GITHUB_TOKEN is injected. */ -}}
version = 1
agents = ["claude", "codex"]

[trust]
github_orgs = ["getsentry", "microsoft", "shadcn"]
git_domains = ["git.jpi.app"]

[[skills]]
name = "playwright-cli"
source = "microsoft/playwright-cli"
ref = {{ (gitHubLatestRelease "microsoft/playwright-cli").TagName | quote }}

[[skills]]
name = "improve"
# shadcn/improve publishes NO releases and NO tags, so its default branch is the
# only "newest" there is — track the branch head rather than a frozen sha.
source = "shadcn/improve"
ref = "main"

[[skills]]
name = "dotagents"
source = "getsentry/dotagents"
ref = {{ (gitHubLatestRelease "getsentry/dotagents").TagName | quote }}

[[skills]]
name = "ci-cd-monitoring"
source = "path:skills/ci-cd-monitoring"

[[skills]]
name = "daily-report"
source = "path:skills/daily-report"

[[skills]]
name = "git-branch-cleanup"
source = "path:skills/git-branch-cleanup"

[[skills]]
name = "git-workflow"
source = "path:skills/git-workflow"

[[skills]]
name = "gitlab-issues"
source = "path:skills/gitlab-issues"

[[skills]]
name = "glab"
source = "path:skills/glab"

[[skills]]
name = "glab-stack"
source = "path:skills/glab-stack"

[[skills]]
name = "js-package-managers"
source = "path:skills/js-package-managers"

[[skills]]
name = "pr-mr"
source = "path:skills/pr-mr"

[[skills]]
name = "ship-issue"
source = "path:skills/ship-issue"

[[skills]]
name = "src-layout"
source = "path:skills/src-layout"

[[mcp]]
name = "codegraph"
command = "codegraph"
args = ["serve", "--mcp"]

[[mcp]]
name = "context7"
url = "https://mcp.context7.com/mcp"

[mcp.headers]
CONTEXT7_API_KEY = '{{ onepasswordRead "op://Private/Context7/API Key" }}'

[[mcp]]
name = "websearch"
url = "https://mcp.exa.ai/mcp"

[mcp.headers]
x-api-key = '{{ onepasswordRead "op://Private/Exa/API Key" }}'
