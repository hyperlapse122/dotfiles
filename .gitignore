*~

# Rust build artifacts
target/

# packages/mxm4-haptic leaf (standalone Yarn Berry node-modules project).
# Leaf-scoped so the rest of the dotfiles repo is unaffected. yarn.lock is
# intentionally TRACKED (lockfile convention, like the Rust Cargo.lock).
packages/mxm4-haptic/node_modules/
packages/mxm4-haptic/dist/
packages/mxm4-haptic/.yarn/
packages/mxm4-haptic/.pnp.*
