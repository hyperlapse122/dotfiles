# Sisyphus / OpenCode session state
.sisyphus/
.omo/

# Generic secret patterns (defense in depth)
*.pem
*.key
*.p12
*.pfx
*.gpg
*.asc
.env
.env.*
!.env.example

# OS junk
.DS_Store
Thumbs.db
desktop.ini

# Editor backup files
*.swp
*.swo
*~

# Rust build artifacts
target/

# packages/ Yarn Berry monorepo (workspace root, node-modules linker).
# Scoped to packages/ so the rest of the dotfiles repo is unaffected. The
# single workspace-root packages/yarn.lock is intentionally TRACKED (lockfile
# convention, like the Rust Cargo.lock); per-member dist/ build output is not.
packages/node_modules/
packages/.yarn/
packages/.pnp.*
packages/*/dist/
.turbo/
packages/.turbo/
packages/*/.turbo/
