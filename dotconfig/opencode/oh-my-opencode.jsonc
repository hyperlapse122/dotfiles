{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-openagent/refs/heads/dev/assets/oh-my-opencode.schema.json",
  // Model Mapping Reference: https://github.com/code-yeongyu/oh-my-openagent/blob/dev/src/shared/model-requirements.ts
  "agents": {
    "sisyphus": {
      // Switch when there is rate limit or capacity issue with anthropic provider.
      "model": "anthropic/claude-opus-4-6",
      // "model": "github-copilot/claude-opus-4.6",
      "variant": "max"
    },
    "hephaestus": {
      "model": "openai/gpt-5.3-codex",
      "variant": "medium"
    },
    "oracle": {
      "model": "openai/gpt-5.4",
      "variant": "high"
    },
    "librarian": {
      "model": "openrouter/minimax/minimax-m2.7"
    },
    "explore": {
      "model": "github-copilot/grok-code-fast-1"
    },
    "multimodal-looker": {
      "model": "openai/gpt-5.4",
      "variant": "medium"
    },
    "prometheus": {
      // Switch when there is rate limit or capacity issue with anthropic provider.
      "model": "anthropic/claude-opus-4-6",
      // "model": "github-copilot/claude-opus-4.6",
      "variant": "max",
      "prompt_append": "After plan is fully generated and reviewed (optional), check the current branch. if the current branch is not main and starts with automatically generated by opencode like `opencode/some-name`, the branch is dedicated for this task and can be used freely without worrying about affecting other tasks. Rename the branch accordingly with the task and project's rules. if there is no rules for branch naming, follow GitHub Flow naming convention like `feature/some-name`."
    },
    "metis": {
      // Switch when there is rate limit or capacity issue with anthropic provider.
      "model": "anthropic/claude-opus-4-6",
      // "model": "github-copilot/claude-opus-4.6",
      "variant": "max"
    },
    "momus": {
      "model": "openai/gpt-5.4",
      "variant": "xhigh"
    },
    "atlas": {
      // Switch when there is rate limit or capacity issue with anthropic provider.
      "model": "anthropic/claude-sonnet-4-6",
      // "model": "github-copilot/claude-sonnet-4.6",
      "prompt_append": "After plan is fully executed, check the current branch. if the current branch is not main, create or update merge request accordingly with the project's rules. if the current branch starts with automatically generated by opencode like `opencode/some-name`, rename the branch accordingly with the task and project's rules. if there is no rules for branch naming, follow GitHub Flow naming convention like `feature/some-name`."
    },
    "sisyphus-junior": {
      // Switch when there is rate limit or capacity issue with anthropic provider.
      "model": "anthropic/claude-sonnet-4-6"
      // "model": "github-copilot/claude-sonnet-4.6"
    }
  },
  "categories": {
    "visual-engineering": {
      "model": "github-copilot/gemini-3.1-pro-preview",
      "variant": "high"
    },
    "ultrabrain": {
      "model": "openai/gpt-5.4",
      "variant": "xhigh"
    },
    "deep": {
      "model": "openai/gpt-5.3-codex",
      "variant": "medium"
    },
    "artistry": {
      "model": "github-copilot/gemini-3.1-pro-preview",
      "variant": "high"
    },
    "quick": {
      "model": "openai/gpt-5.4-mini"
    },
    "unspecified-low": {
      // Switch when there is rate limit or capacity issue with anthropic provider.
      "model": "anthropic/claude-sonnet-4-6"
      // "model": "github-copilot/claude-sonnet-4.6"
    },
    "unspecified-high": {
      // Switch when there is rate limit or capacity issue with anthropic provider.
      "model": "anthropic/claude-opus-4-6",
      // "model": "github-copilot/claude-opus-4.6",
      "variant": "max"
    },
    "writing": {
      "model": "github-copilot/gemini-3-flash-preview"
    }
  },
  "_migrations": [
    "model-version:anthropic/claude-opus-4-5->anthropic/claude-opus-4-6",
    "model-version:github-copilot/gemini-3-pro-preview->github-copilot/gemini-3.1-pro-preview",
    "model-version:openai/gpt-5.3-codex->openai/gpt-5.4",
    "model-version:openai/gpt-5.2->openai/gpt-5.4",
    "model-version:anthropic/claude-sonnet-4-5->anthropic/claude-sonnet-4-6"
  ],
  "disabled_mcps": ["playwright"],
  "disabled_skills": ["playwright"],
  "browser_automation_engine": { "provider": "playwright-cli" },
  "git_master": {
    "commit_footer": true,
    "include_co_authored_by": true,
    "git_env_prefix": "GIT_MASTER=1"
  }
}
