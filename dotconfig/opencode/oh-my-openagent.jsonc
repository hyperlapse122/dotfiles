{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-openagent/refs/heads/dev/assets/oh-my-opencode.schema.json",
  // Model Mapping Reference: https://github.com/code-yeongyu/oh-my-openagent/blob/dev/src/shared/model-requirements.ts
  "agents": {
    "sisyphus": {
      "model": "anthropic/claude-opus-4-6",
      "variant": "max"
      // "model": "opencode-go/kimi-k2.5"
    },
    "hephaestus": {
      "model": "openai/gpt-5.4",
      "variant": "medium"
    },
    "oracle": {
      "model": "openai/gpt-5.4",
      "variant": "high"
      // "model": "github-copilot/gemini-3.1-pro-preview",
      // "variant": "high"
    },
    "librarian": {
      "model": "opencode-go/minimax-m2.7"
    },
    "explore": {
      "model": "github-copilot/grok-code-fast-1"
    },
    "multimodal-looker": {
      "model": "openai/gpt-5.4",
      "variant": "medium"
      // "model": "opencode-go/minimax-m2.5"
    },
    "prometheus": {
      // "model": "anthropic/claude-opus-4-6",
      // "variant": "max",
      "model": "openai/gpt-5.4",
      "variant": "high",
      "prompt_append": "After plan is fully generated and reviewed (optional), check the current branch. if the current branch is not main and starts with automatically generated by opencode like `opencode/some-name`, the branch is dedicated for this task and can be used freely without worrying about affecting other tasks. Rename the branch accordingly with the task and project's rules. if there is no rules for branch naming, follow git flow naming convention like `feature/some-name`."
    },
    "metis": {
      // "model": "anthropic/claude-opus-4-6",
      // "variant": "max"
      "model": "openai/gpt-5.4",
      "variant": "high"
    },
    "momus": {
      "model": "openai/gpt-5.4",
      "variant": "xhigh"
      // "model": "anthropic/claude-opus-4-6",
      // "variant": "max"
    },
    "atlas": {
      "model": "opencode-go/kimi-k2.5",
      // "model": "anthropic/claude-sonnet-4-6",
      "prompt_append": "After plan is fully executed, check the current branch. if the current branch is not main, create or update merge request accordingly with the project's rules after commit and push all changes. if the current branch starts with automatically generated by opencode like `opencode/some-name`, rename the branch accordingly with the task and project's rules. if there is no rules for branch naming, follow git flow naming convention like `feature/some-name`. When there is CI/CD pipeline failure, analyze the failure and try to fix the issue by pushing new commits until pipeline succeeds."
    },
    "sisyphus-junior": {
      "model": "opencode-go/kimi-k2.5"
      // "model": "anthropic/claude-sonnet-4-6"
    }
  },
  "categories": {
    "visual-engineering": {
      "model": "github-copilot/gemini-3.1-pro-preview",
      "variant": "high"
    },
    "ultrabrain": {
      "model": "openai/gpt-5.4",
      "variant": "xhigh"
      // "model": "github-copilot/gemini-3.1-pro-preview",
      // "variant": "high"
    },
    "deep": {
      "model": "openai/gpt-5.4",
      "variant": "medium"
      // "model": "anthropic/claude-opus-4-6",
      // "variant": "max"
    },
    "artistry": {
      "model": "github-copilot/gemini-3.1-pro-preview",
      "variant": "high"
    },
    "quick": {
      "model": "openai/gpt-5.4-mini-fast"
      // "model": "anthropic/claude-haiku-4-5"
    },
    "unspecified-low": {
      // "model": "anthropic/claude-sonnet-4-6"
      "model": "openai/gpt-5.3-codex",
      "variant": "medium"
    },
    "unspecified-high": {
      // "model": "anthropic/claude-opus-4-6",
      // "variant": "max"
      "model": "openai/gpt-5.4",
      "variant": "high"
    },
    "writing": {
      "model": "github-copilot/gemini-3-flash-preview"
      // "model": "opencode-go/kimi-k2.5"
    }
  },
  "disabled_mcps": ["playwright"],
  "disabled_skills": ["playwright"],
  "disabled_hooks": ["session-notification"],
  "browser_automation_engine": { "provider": "playwright-cli" },
  "git_master": {
    "commit_footer": true,
    "include_co_authored_by": true,
    "git_env_prefix": "GIT_MASTER=1"
  },
  "notification": { "force_enable": true }
}
