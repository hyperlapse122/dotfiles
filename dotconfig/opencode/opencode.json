{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "oh-my-openagent@latest",
    "opencode-wakatime@latest",
    "opencode-gemini-auth@latest",
    "@ex-machina/opencode-anthropic-auth@latest",
    "opencode-copilot-auth@latest"
  ],
  "model": "openai/gpt-5.4",
  "small_model": "github-copilot/gpt-5-mini",
  "autoupdate": "notify",
  "lsp": {
    "biome": {
      "command": [
        "mise",
        "exec",
        "npm:@biomejs/biome",
        "--",
        "biome",
        "lsp-proxy"
      ],
      "extensions": [
        ".ts",
        ".tsx",
        ".js",
        ".jsx",
        ".cts",
        ".ctsx",
        ".cjs",
        ".cjsx",
        ".mts",
        ".mtsx",
        ".mjs",
        ".mjsx",
        ".json",
        ".css",
        ".scss",
        ".html",
        ".vue",
        ".svelte",
        ".json",
        ".yaml",
        ".yml"
      ]
    },
    "buf": {
      "command": [
        "mise",
        "exec",
        "npm:@bufbuild/buf@latest",
        "--",
        "buf",
        "lsp",
        "serve"
      ],
      "extensions": [".proto"]
    }
  },
  "permission": {
    "read": {
      "**/.env*.local": "ask",
      "**/.env*": "allow"
    },
    "edit": {
      "**/.env*.local": "ask",
      "**/.env*": "allow"
    }
  },
  "mcp": {
    "figma": {
      "type": "remote",
      "url": "http://127.0.0.1:3845/mcp"
    }
  }
}
