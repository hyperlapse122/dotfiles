{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "oh-my-openagent@3.16.0",
    "opencode-wakatime",
    "opencode-claude-auth",
    "opencode-copilot-auth"
  ],
  "model": "openai/gpt-5.4",
  "small_model": "github-copilot/gpt-5.4-mini",
  "autoupdate": "notify",
  "lsp": {
    "typescript": {
      "command": [
        "mise",
        "exec",
        "npm:typescript-language-server",
        "--",
        "typescript-language-server",
        "--stdio"
      ],
      "extensions": [
        ".ts",
        ".tsx",
        ".js",
        ".jsx",
        ".mts",
        ".mtsx",
        ".mjs",
        ".mjsx",
        ".cts",
        ".ctsx",
        ".cjs",
        ".cjsx"
      ],
      "initialization": {
        "preferences": {
          "importModuleSpecifierPreference": "relative"
        }
      }
    },
    "biome": {
      "command": [
        "mise",
        "exec",
        "npm:@biomejs/biome",
        "--",
        "biome",
        "lsp-proxy"
      ],
      "extensions": [
        ".ts",
        ".tsx",
        ".js",
        ".jsx",
        ".cts",
        ".ctsx",
        ".cjs",
        ".cjsx",
        ".mts",
        ".mtsx",
        ".mjs",
        ".mjsx",
        ".json",
        ".css",
        ".scss",
        ".html",
        ".vue",
        ".svelte",
        ".json",
        ".yaml",
        ".yml"
      ]
    },
    "buf": {
      "command": [
        "mise",
        "exec",
        "npm:@bufbuild/buf@latest",
        "--",
        "buf",
        "lsp",
        "serve"
      ],
      "extensions": [".proto"]
    }
  },
  "permission": {
    "read": {
      "**/.env*.local": "ask",
      "**/.env*": "allow"
    },
    "edit": {
      "**/.env*.local": "ask",
      "**/.env*": "allow"
    }
  },
  "mcp": {
    "figma": {
      "type": "remote",
      "url": "http://127.0.0.1:3845/mcp"
    }
  },
  "provider": {
    "anthropic": {
      "models": {
        "claude-opus-4-6": {
          "limit": {
            "context": 200000,
            "output": 128000,
            "input": 200000
          }
        },
        "claude-sonnet-4-6": {
          "limit": {
            "context": 200000,
            "output": 64000,
            "input": 200000
          }
        }
      }
    }
  }
}
