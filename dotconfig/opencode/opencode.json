{
  "$schema": "https://opencode.ai/config.json",
  "plugin": ["oh-my-openagent@latest", "opencode-wakatime@latest"],
  "model": "openai/gpt-5.4",
  "small_model": "github-copilot/gpt-5-mini",
  "autoupdate": "notify",
  "lsp": {
    "biome": {
      "command": [
        "mise",
        "exec",
        "npm:@biomejs/biome",
        "--",
        "biome",
        "lsp-proxy"
      ],
      "extensions": [
        ".ts",
        ".tsx",
        ".js",
        ".jsx",
        ".cts",
        ".ctsx",
        ".cjs",
        ".cjsx",
        ".mts",
        ".mtsx",
        ".mjs",
        ".mjsx",
        ".json",
        ".css",
        ".scss",
        ".html",
        ".vue",
        ".svelte",
        ".json",
        ".yaml",
        ".yml"
      ]
    }
  },
  "server": {
    "port": 4096,
    "hostname": "0.0.0.0"
  },
  "permission": {
    "read": {
      "**/.env*.local": "ask",
      "**/.env*": "allow"
    },
    "edit": {
      "**/.env*.local": "ask",
      "**/.env*": "allow"
    }
  },
  "experimental": {
    "batch_tool": true
  }
}
