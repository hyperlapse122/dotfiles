// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "prettier": {},
  "agent": {
    "default_model": {
      "provider": "copilot_chat",
      "model": "gpt-5-mini",
      "enable_thinking": false,
      "effort": "high"
    },
    "favorite_models": [],
    "model_parameters": []
  },
  "edit_predictions": {
    "provider": "copilot"
  },
  "telemetry": {
    "diagnostics": false,
    "metrics": false
  },
  "base_keymap": "JetBrains",
  "ui_font_size": 16,
  "ui_font_family": "Pretendard",
  "ui_font_fallbacks": ["Pretendard JP"],
  "buffer_font_size": 12,
  "buffer_font_family": "JetBrainsMono Nerd Font",
  "buffer_font_fallbacks": ["D2CodingLigature Nerd Font"],
  "buffer_font_features": {
    "calt": true
  },
  "theme": {
    "mode": "system",
    "light": "One Light",
    "dark": "One Dark"
  },
  "auto_install_extensions": {
    "biome": true,
    "graphql": true,
    "html": true,
    "dockerfile": true,
    "git-firefly": true,
    "toml": true,
    "wakatime": true
  },
  "lsp": {
    "biome": {
      "settings": {
        "require_config_file": true
      }
    },
    "vtsls": {
      "settings": {
        // For TypeScript:
        "typescript": { "tsserver": { "maxTsServerMemory": 16184 } },
        // For JavaScript:
        "javascript": { "tsserver": { "maxTsServerMemory": 16184 } }
      }
    }
  },
  "autosave": "on_window_change",
  "restore_on_startup": "launchpad",
  "minimap": {
    "show": "auto"
  },
  "agent_servers": {
    "OpenCode": {
      "favorite_config_option_values": {
        "model": [
          "anthropic/claude-opus-4-7/max",
          "anthropic/claude-sonnet-4-6/max",
          "openai/gpt-5.4/high",
          "opencode-go/kimi-k2.5"
        ]
      },
      "type": "custom",
      "command": "opencode",
      "args": ["acp"]
    }
  }
}
