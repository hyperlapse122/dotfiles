{{- /* fcitx5 classic UI — deploys on every Linux desktop target (KDE + GNOME),
   since the unified input-method policy picks fcitx5 everywhere. A .tmpl for
   ONE reason: the three font lines below. The family and size come from
   .chezmoidata/fonts.yaml (`fonts.families.sans`, `fonts.sizes.sans`) — the
   same source the KDE/GNOME font scripts and the VSCodium settings read — so
   changing the sans face is a ONE-FILE edit instead of a four-file hunt.
   Everything else here is fcitx5's own settings surface and stays literal
   (this file IS the data for those). `Bold` on TrayFont is fcitx5's weight
   token, i.e. structure, not a knob. */ -}}
# 세로 후보 목록
Vertical Candidate List=False
# 마우스 휠을 사용하여 이전 또는 다음 페이지로 이동
WheelForPaging=True
# 글꼴
Font="{{ .fonts.families.sans }} {{ .fonts.sizes.sans }}"
# 메뉴 글꼴
MenuFont="{{ .fonts.families.sans }} {{ .fonts.sizes.sans }}"
# 트레이 글꼴
TrayFont="{{ .fonts.families.sans }} Bold {{ .fonts.sizes.sans }}"
# 트레이 라벨 윤곽선 색상
TrayOutlineColor=#000000
# 트레이 레이블 텍스트 색상
TrayTextColor=#ffffff
# 텍스트 아이콘 선호
PreferTextIcon=False
# 아이콘에 자판 이름 표시
ShowLayoutNameInIcon=True
# 텍스트 표시할 때 입력기 언어 사용
UseInputMethodLanguageToDisplayText=True
# 테마
Theme=default
# Dark Theme
DarkTheme=default-dark
# Follow system light/dark color scheme
UseDarkTheme=True
# Follow system accent color if it is supported by theme and desktop
UseAccentColor=True
# Use Per Screen DPI on X11
PerScreenDPI=True
# Force font DPI on Wayland
ForceWaylandDPI=0
# Enable fractional scale under Wayland
EnableFractionalScale=True

