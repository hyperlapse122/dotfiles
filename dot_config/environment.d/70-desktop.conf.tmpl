# PINENTRY_KDE_USE_WALLET lets pinentry-qt offer "remember in KWallet" — KDE
# targets only. A GNOME host uses pinentry-gnome3 (see
# private_dot_gnupg/.gpg-agent.linux.conf), which caches through gnome-keyring on
# its own, so the KWallet knob must not deploy there.
#
# File content cannot branch at runtime, so the desktop is resolved at RENDER time
# from the `desktop` fact (.chezmoidata/facts.yaml, resolved in
# .chezmoitemplates/facts.tmpl) — the same fact the solaar rules and the pinentry
# choice read. `gnome` means gnome-shell on PATH WITHOUT plasmashell (KDE wins when
# both are present); with neither desktop (headless, container, CI) the fact is
# `none`, so the KDE variant renders, as elsewhere — deterministic artifacts, inert
# without a desktop.
{{ $f := includeTemplate "facts.tmpl" . | fromYaml -}}
{{ if ne $f.desktop "gnome" -}}
PINENTRY_KDE_USE_WALLET=1
{{ end -}}
ELECTRON_OZONE_PLATFORM_HINT=auto
