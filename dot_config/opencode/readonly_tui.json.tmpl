{{- $plugins := includeTemplate "opencode-plugins-json.tmpl" (dict "ctx" . "target" "tui") | fromJson -}}
{
  "$schema": "https://opencode.ai/tui.json",
  "keybinds": {
    "app_exit": "none"
  },
  "scroll_speed": 3,
  "scroll_acceleration": {
    "enabled": true
  },
  "diff_style": "auto",
  "plugin": {{ toPrettyJson "  " $plugins | trim | replace "\n" "\n  " }}
}
