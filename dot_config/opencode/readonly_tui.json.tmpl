{{- /* Version resolved at apply time from oh-my-openagent's latest GitHub tag,
       which is pushed on every npm publish and so mirrors the npm version 1:1
       (GitHub *Releases* can lag npm). Install is still from npm. */ -}}
{{- $ohMyOpenagent := (gitHubLatestTag "code-yeongyu/oh-my-openagent").Name | trimPrefix "v" -}}
{
  "$schema": "https://opencode.ai/tui.json",
  "keybinds": {
    "app_exit": "none"
  },
  "scroll_speed": 3,
  "scroll_acceleration": {
    "enabled": true
  },
  "diff_style": "auto",
  "plugin": [
    "oh-my-openagent@{{ $ohMyOpenagent }}/tui",
    "oh-my-openagent@{{ $ohMyOpenagent }}"
  ]
}