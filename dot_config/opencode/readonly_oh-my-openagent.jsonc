{
	"$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-openagent/refs/heads/dev/assets/oh-my-opencode.schema.json",
	"agents": {
		// Model Mapping Reference: https://github.com/code-yeongyu/oh-my-openagent/blob/dev/packages/model-core/src/agent-model-requirements.ts
		"sisyphus": {
		  // Primary
			"model": "anthropic/claude-opus-4-8",
			"variant": "max"

			// // Fallback
			// "model": "zai/glm-5.2"
		},
		"hephaestus": {
			"model": "openai/gpt-5.5-fast",
			"variant": "medium"
		},
		"oracle": {
			"model": "openai/gpt-5.5-fast",
			"variant": "high",
			"fallback_models": [
				{
					"model": "anthropic/claude-opus-4-8",
					"variant": "high"
				},
				"zai/glm-5.2"
			]
		},
		"librarian": {
			"model": "openai/gpt-5.4-mini-fast",
			"fallback_models": [
				"anthropic/claude-haiku-4-5"
			]
		},
		"explore": {
			"model": "openai/gpt-5.4-mini-fast",
			"fallback_models": [
				"anthropic/claude-haiku-4-5"
			]
		},
		"multimodal-looker": {
			"model": "openai/gpt-5.5-fast",
			"variant": "medium",
			"fallback_models": [
				"moonshotai/kimi-k2.7-code",
				"zai/glm-5v-turbo"
			]
		},
		"prometheus": {
		  // Primary
			"model": "anthropic/claude-opus-4-8",
			"variant": "max",

			// // Fallback
			// "model": "openai/gpt-5.5-fast",
			// "variant": "high",

			"fallback_models": [
				{
					"model": "openai/gpt-5.5-fast",
					"variant": "high"
				},
				"zai/glm-5.2"
			]
		},
		"metis": {
		  // Primary
			"model": "anthropic/claude-sonnet-5",

			// // Fallback
			// "model": "openai/gpt-5.5-fast",
			// "variant": "high",
			
			"fallback_models": [
				{
					"model": "anthropic/claude-opus-4-8",
					"variant": "max"
				},
				{
					"model": "openai/gpt-5.5-fast",
					"variant": "high"
				},
				"zai/glm-5.2",
				"moonshotai/kimi-k2.7-code"
			]
		},
		"momus": {
			"model": "openai/gpt-5.5-fast",
			"variant": "xhigh",
			"fallback_models": [
				{
					"model": "anthropic/claude-opus-4-8",
					"variant": "max"
				},
				"zai/glm-5.2"
			]
		},
		"atlas": {
		  // Primary
			"model": "anthropic/claude-sonnet-5",
			"variant": "max",

			// // Fallback
			// "model": "moonshotai/kimi-k2.7-code",

		  "fallback_models": [
				"moonshotai/kimi-k2.7-code",
				{
					"model": "openai/gpt-5.5-fast",
					"variant": "medium"
				}
			]
		},
		"sisyphus-junior": {
		  // Primary
			"model": "anthropic/claude-sonnet-5",
			"variant": "max",

			// // Fallback
			// "model": "moonshotai/kimi-k2.7-code",
			"fallback_models": [
				"moonshotai/kimi-k2.7-code",
				{
					"model": "openai/gpt-5.5-fast",
					"variant": "medium"
				}
			]
		}
	},
	"categories": {
		// Model Mapping Reference: https://github.com/code-yeongyu/oh-my-openagent/blob/dev/packages/model-core/src/category-model-requirements.ts
		"visual-engineering": {
		  // // Primary
			// "model": "zai/glm-5.1",

			// Fallback
			"model": "anthropic/claude-opus-4-8",
			"variant": "max",
			
			"fallback_models": [
				{
					"model": "anthropic/claude-opus-4-8",
					"variant": "max"
				},
				"zai/glm-5.1",
				"moonshotai/kimi-k2.7-code"
			]
		},
		"ultrabrain": {
			"model": "openai/gpt-5.5-fast",
			"variant": "xhigh",
			"fallback_models": [
				{
					"model": "anthropic/claude-opus-4-8",
					"variant": "max"
				},
				"zai/glm-5.2"
			]
		},
		"deep": {
			"model": "openai/gpt-5.5-fast",
			"variant": "medium",
			"fallback_models": [
				{
					"model": "anthropic/claude-opus-4-8",
					"variant": "max"
				},
				"moonshotai/kimi-k2.7-code",
				"zai/glm-5.2"
			]
		},
		"artistry": {
			"model": "zai/glm-5.1",
			"fallback_models": [
				{
					"model": "anthropic/claude-opus-4-8",
					"variant": "max"
				},
				"openai/gpt-5.5-fast",
				"moonshotai/kimi-k2.7-code",
				"zai/glm-5.2"
			]
		},
		"quick": {
			"model": "openai/gpt-5.4-mini-fast",
			"fallback_models": [
				"anthropic/claude-haiku-4-5"
			]
		},
		"unspecified-low": {
		  // Primary
			"model": "anthropic/claude-sonnet-5",
			"variant": "max",

			// // Fallback
			// "model": "openai/gpt-5.5-fast",
			// "variant": "medium",

			"fallback_models": [
				{
					"model": "openai/gpt-5.5-fast",
					"variant": "medium"
				},
				"moonshotai/kimi-k2.7-code"
			]
		},
		"unspecified-high": {
		  // Primary
			"model": "anthropic/claude-opus-4-8",
			"variant": "max",

			// // Fallback
			// "model": "openai/gpt-5.5-fast",
			// "variant": "high",
			
			"fallback_models": [
				{
					"model": "openai/gpt-5.5-fast",
					"variant": "high"
				},
				"zai/glm-5.2",
				"moonshotai/kimi-k2.7-code"
			]
		},
		"writing": {
			"model": "moonshotai/kimi-k2.7-code",
			"fallback_models": [
				"anthropic/claude-sonnet-5"
			]
		}
	},
	"disabled_mcps": ["playwright", "lsp"],
	"disabled_skills": ["playwright"],
	"disabled_hooks": [
		"session-notification",
		"no-sisyphus-gpt",
		"claude-code-hooks"
	],
	"model_fallback": true,
	"runtime_fallback": {
		"enabled": true,
		// "retry_on_errors": [429],
		"max_fallback_attempts": 3,
		"cooldown_seconds": 60,
		"notify_on_fallback": true
	},
	"browser_automation_engine": { "provider": "playwright-cli" },
	"git_master": {
		"commit_footer": false,
		"include_co_authored_by": false,
		"git_env_prefix": "GIT_MASTER=1"
	},
	"notification": { "force_enable": true }
}
