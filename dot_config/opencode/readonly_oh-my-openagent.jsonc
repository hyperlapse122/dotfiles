{
	"$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-openagent/refs/heads/dev/assets/oh-my-opencode.schema.json",
	"agents": {
		// Model Mapping Reference: https://github.com/code-yeongyu/oh-my-openagent/blob/dev/packages/model-core/src/agent-model-requirements.ts
		"sisyphus": {
		  // // Primary
			// "model": "anthropic/claude-opus-4-8",
			// "variant": "max",

			// Fallback
			"model": "kimi-for-coding/k2p7",

			"fallback_models": [
				"kimi-for-coding/k2p7",
				{
					"model": "openai/gpt-5.5-fast",
					"variant": "medium"
				},
				"zai-coding-plan/glm-5.2"
			]
		},
		"hephaestus": {
			"model": "openai/gpt-5.5-fast",
			"variant": "medium"
		},
		"oracle": {
			"model": "openai/gpt-5.5-fast",
			"variant": "high",
			"fallback_models": [
				{
					"model": "google-agy/gemini-3.1-pro",
					"variant": "high"
				},
				{
					"model": "anthropic/claude-opus-4-8",
					"variant": "high"
				},
				"zai-coding-plan/glm-5.2"
			]
		},
		"librarian": {
			"model": "openai/gpt-5.4-mini-fast",
			"fallback_models": [
				"anthropic/claude-haiku-4-5"
			]
		},
		"explore": {
			"model": "openai/gpt-5.4-mini-fast",
			"fallback_models": [
				"anthropic/claude-haiku-4-5"
			]
		},
		"multimodal-looker": {
			"model": "openai/gpt-5.5-fast",
			"variant": "medium",
			"fallback_models": [
				"kimi-for-coding/k2p7",
				"zai-coding-plan/glm-5v-turbo"
			]
		},
		"prometheus": {
		  // // Primary
			// "model": "anthropic/claude-opus-4-8",
			// "variant": "max",

			// Fallback
			"model": "openai/gpt-5.5-fast",
			"variant": "high",

			"fallback_models": [
				{
					"model": "openai/gpt-5.5-fast",
					"variant": "high"
				},
				"zai-coding-plan/glm-5.2",
				"google-agy/gemini-3.1-pro"
			]
		},
		"metis": {
		  // // Primary
			// "model": "anthropic/claude-sonnet-4-6",

			// Fallback
			"model": "openai/gpt-5.5-fast",
			"variant": "high",
			
			"fallback_models": [
				{
					"model": "anthropic/claude-opus-4-8",
					"variant": "max"
				},
				{
					"model": "openai/gpt-5.5-fast",
					"variant": "high"
				},
				"zai-coding-plan/glm-5.2",
				"kimi-for-coding/k2p7"
			]
		},
		"momus": {
			"model": "openai/gpt-5.5-fast",
			"variant": "xhigh",
			"fallback_models": [
				{
					"model": "anthropic/claude-opus-4-8",
					"variant": "max"
				},
				{
					"model": "google-agy/gemini-3.1-pro",
					"variant": "high"
				},
				"zai-coding-plan/glm-5.2"
			]
		},
		"atlas": {
		  // // Primary
			// "model": "anthropic/claude-sonnet-4-6",
			// "variant": "max",

			// Fallback
			"model": "kimi-for-coding/k2p7",

		  "fallback_models": [
				"kimi-for-coding/k2p7",
				{
					"model": "openai/gpt-5.5-fast",
					"variant": "medium"
				}
			]
		},
		"sisyphus-junior": {
		  // // Primary
			// "model": "anthropic/claude-sonnet-4-6",
			// "variant": "max",

			// Fallback
			"model": "kimi-for-coding/k2p7",
			"fallback_models": [
				"kimi-for-coding/k2p7",
				{
					"model": "openai/gpt-5.5-fast",
					"variant": "medium"
				}
			]
		}
	},
	"categories": {
		// Model Mapping Reference: https://github.com/code-yeongyu/oh-my-openagent/blob/dev/packages/model-core/src/category-model-requirements.ts
		"visual-engineering": {
			"model": "google-agy/gemini-3.1-pro",
			"variant": "high",
			"fallback_models": [
				"zai-coding-plan/glm-5.2",
				{
					"model": "anthropic/claude-opus-4-8",
					"variant": "max"
				},
				"zai-coding-plan/glm-5.1",
				"kimi-for-coding/k2p7"
			]
		},
		"ultrabrain": {
			"model": "openai/gpt-5.5-fast",
			"variant": "xhigh",
			"fallback_models": [
				{
					"model": "google-agy/gemini-3.1-pro",
					"variant": "high"
				},
				{
					"model": "anthropic/claude-opus-4-8",
					"variant": "max"
				},
				"zai-coding-plan/glm-5.2"
			]
		},
		"deep": {
			"model": "openai/gpt-5.5-fast",
			"variant": "medium",
			"fallback_models": [
				{
					"model": "anthropic/claude-opus-4-8",
					"variant": "max"
				},
				{
					"model": "google-agy/gemini-3.1-pro",
					"variant": "high"
				},
				"kimi-for-coding/k2p7",
				"zai-coding-plan/glm-5.2"
			]
		},
		"artistry": {
			"model": "google-agy/gemini-3.1-pro",
			"variant": "high",
			"fallback_models": [
				{
					"model": "anthropic/claude-opus-4-8",
					"variant": "max"
				},
				"openai/gpt-5.5-fast",
				"kimi-for-coding/k2p7",
				"zai-coding-plan/glm-5.2"
			]
		},
		"quick": {
			"model": "openai/gpt-5.4-mini-fast",
			"fallback_models": [
				"anthropic/claude-haiku-4-5",
				"google-agy/gemini-3.5-flash"
			]
		},
		"unspecified-low": {
		  // // Primary
			// "model": "anthropic/claude-sonnet-4-6",
			// "variant": "max",

			// Fallback
			"model": "openai/gpt-5.5-fast",
			"variant": "medium",

			"fallback_models": [
				{
					"model": "openai/gpt-5.5-fast",
					"variant": "medium"
				},
				"kimi-for-coding/k2p7",
				"google-agy/gemini-3.5-flash"
			]
		},
		"unspecified-high": {
		  // // Primary
			// "model": "anthropic/claude-opus-4-8",
			// "variant": "max",

			// Fallback
			"model": "openai/gpt-5.5-fast",
			"variant": "high",
			
			"fallback_models": [
				{
					"model": "openai/gpt-5.5-fast",
					"variant": "high"
				},
				"zai-coding-plan/glm-5.2",
				"kimi-for-coding/k2p7"
			]
		},
		"writing": {
			"model": "google-agy/gemini-3.5-flash",
			"fallback_models": [
				"kimi-for-coding/k2p7",
				"anthropic/claude-sonnet-4-6"
			]
		}
	},
	"model_fallback": true,
  "runtime_fallback": {
    "enabled": true
  },
	"disabled_mcps": ["playwright", "lsp"],
	"disabled_skills": ["playwright"],
	"disabled_hooks": [
		"session-notification",
		"no-sisyphus-gpt",
		"claude-code-hooks"
	],
	"browser_automation_engine": { "provider": "playwright-cli" },
	"git_master": {
		"commit_footer": false,
		"include_co_authored_by": false,
		"git_env_prefix": "GIT_MASTER=1"
	},
	"notification": { "force_enable": true }
}
