{
	"$schema": "https://opencode.ai/config.json",
	"autoupdate": "notify",
	"plugin": [
		"oh-my-openagent@4.15.1",
		"@ex-machina/opencode-anthropic-auth@1.8.1"
	],
	"lsp": {
		"buf": {
			"command": [
				"mise",
				"--no-config",
				"exec",
				"-yq",
				"npm:@bufbuild/buf@latest",
				"--",
				"buf",
				"lsp",
				"serve"
			],
			"extensions": [
				".proto"
			]
		},
		"eslint": {
			"command": [
				"mise",
				"--no-config",
				"exec",
				"-yq",
				"npm:vscode-langservers-extracted",
				"--",
				"vscode-eslint-language-server",
				"--stdio"
			],
			"extensions": [
				".js",
				".jsx",
				".ts",
				".tsx",
				".mjs",
				".mts",
				".cjs",
				".cts",
				".vue"
			],
			"initialization": {
				"validate": "on",
				"workingDirectories": [
					{
						"mode": "auto"
					}
				]
			}
		},
		"marksman": {
			"command": [
				"mise",
				"--no-config",
				"exec",
				"-yq",
				"marksman",
				"--",
				"marksman"
			],
			"extensions": [
				".md"
			]
		}
	},
	"mcp": {
		"context7": {
			"type": "remote",
			"enabled": true,
			"url": "https://mcp.context7.com/mcp",
			"headers": {
				"CONTEXT7_API_KEY": "{file:./secrets/context7-api-key}"
			}
		},
		"websearch": {
			"type": "remote",
			"enabled": true,
			"url": "https://mcp.exa.ai/mcp",
			"headers": {
				"x-api-key": "{file:./secrets/exa-api-key}"
			}
		},
		"codegraph": {
			"type": "local",
			"command": [
				"mise",
				"--no-config",
				"exec",
				"-yq",
				"npm:@colbymchenry/codegraph",
				"node",
				"--",
				"codegraph",
				"serve",
				"--mcp"
			]
		},
		"zai-mcp-server": {
			"type": "local",
			"command": [
				"mise",
				"--no-config",
				"exec",
				"-yq",
				"node",
				"-c",
				"npx -y \"@z_ai/mcp-server\""
			],
			"environment": {
				"Z_AI_API_KEY": "{file:./secrets/zai-coding-plan-api-key}",
				"Z_AI_MODE": "ZAI"
			}
		},
		"web-search-prime": {
			"type": "remote",
			"url": "https://api.z.ai/api/mcp/web_search_prime/mcp",
			"headers": {
				"Authorization": "Bearer {file:./secrets/zai-coding-plan-api-key}"
			}
		},
		"web-reader": {
			"type": "remote",
			"url": "https://api.z.ai/api/mcp/web_reader/mcp",
			"headers": {
				"Authorization": "Bearer {file:./secrets/zai-coding-plan-api-key}"
			}
		},
		"zread": {
			"type": "remote",
			"url": "https://api.z.ai/api/mcp/zread/mcp",
			"headers": {
				"Authorization": "Bearer {file:./secrets/zai-coding-plan-api-key}"
			}
		}
	},
	"permission": {
		"read": {
			"**": "allow",
			"~/.secrets/**": "deny",
			"/home/h82/.secrets/**": "deny",
			"~/.local/share/opencode/auth*": "deny",
			"/home/h82/.local/share/opencode/auth*": "deny",
			"~/.config/glab-cli/config.yml": "deny",
			"/home/h82/.config/glab-cli/config.yml": "deny",
			"~/.config/opencode/opencode.json": "deny",
			"/home/h82/.config/opencode/opencode.json": "deny",
			"/tmp/**": "deny",
			"/var/tmp/**": "deny",
			"/dev/shm/**": "deny"
		},
		"edit": {
			"~/.secrets/**": "deny",
			"/home/h82/.secrets/**": "deny",
			"~/.local/share/opencode/auth*": "deny",
			"/home/h82/.local/share/opencode/auth*": "deny",
			"~/.config/glab-cli/config.yml": "deny",
			"/home/h82/.config/glab-cli/config.yml": "deny",
			"~/.config/opencode/opencode.json": "deny",
			"/home/h82/.config/opencode/opencode.json": "deny",
			"/tmp/**": "deny",
			"/var/tmp/**": "deny",
			"/dev/shm/**": "deny"
		},
		"glob": {
			"~/.secrets/**": "deny",
			"/home/h82/.secrets/**": "deny",
			"~/.local/share/opencode/auth*": "deny",
			"/home/h82/.local/share/opencode/auth*": "deny",
			"~/.config/glab-cli/config.yml": "deny",
			"/home/h82/.config/glab-cli/config.yml": "deny",
			"~/.config/opencode/opencode.json": "deny",
			"/home/h82/.config/opencode/opencode.json": "deny",
			"/tmp/**": "deny",
			"/var/tmp/**": "deny",
			"/dev/shm/**": "deny"
		},
		"bash": {
			"*": "allow",
			"cat ~/.secrets/*": "deny",
			"cat /home/h82/.secrets/*": "deny",
			"cat ~/.local/share/opencode/auth*": "deny",
			"cat /home/h82/.local/share/opencode/auth*": "deny",
			"cat ~/.config/glab-cli/config.yml": "deny",
			"cat /home/h82/.config/glab-cli/config.yml": "deny",
			"cat ~/.config/opencode/opencode.json": "deny",
			"cat /home/h82/.config/opencode/opencode.json": "deny",
			"glab auth status -t": "deny",
			"glab auth status --show-token": "deny"
		}
	},
	"provider": {
		"opencode": {
			"options": {
				"apiKey": "{file:./secrets/opencode-api-key}"
			},
			"whitelist": [
				"deepseek-v4-flash-free",
				"mimo-v2.5-free",
				"nemotron-3-ultra-free",
				"north-mini-code-free"
			]
		},
		"kimi-for-coding": {
			"options": {
				"apiKey": "{file:./secrets/kimi-for-coding-api-key}"
			}
		},
		"zai-coding-plan": {
			"options": {
				"apiKey": "{file:./secrets/zai-coding-plan-api-key}"
			}
		},
		"cerebras": {
			"options": {
				"apiKey": "{file:./secrets/cerebras-api-key}"
			},
			"models": {
				"gemma-4-31b": {
					"limit": {
						"context": 65536,
						"output": 32768
					},
					"modalities": {
						"input": [
							"image",
							"text"
						],
						"output": [
							"text"
						]
					},
					"cost": {
						"input": 0.99,
						"output": 1.49
					}
				}
			}
		},
		"openrouter": {
			"options": {
				"apiKey": "{file:./secrets/openrouter-api-key}",
				"headers": {
					"HTTP-Referer": "https://opencode.ai/",
					"X-OpenRouter-Title": "OpenCode",
					"X-OpenRouter-Categories": "cli-agent"
				}
			},
			"models": {
				"openrouter/free": {
					"name": "Free Models Router",
					"cost": {
						"input": 0,
						"output": 0,
						"cache_read": 0,
						"cache_write": 0
					}
				}
			},
			"whitelist": [
				"openrouter/free"
			]
		},
		"anthropic": {
			"whitelist": []
		}
	},
	"model": "openai/gpt-5.5",
	"small_model": "openrouter/openrouter/free",
	"experimental": {
		"continue_loop_on_deny": true
	}
}