{{- /* Plugin versions are resolved at apply time from each plugin's GitHub
       tags, so no version is pinned in source. A tag is pushed on every npm
       publish, so tags mirror the published npm versions 1:1 — whereas GitHub
       *Releases* can lag npm (e.g. a version published to npm before its
       Release is cut), which would silently downgrade an npm-installed plugin.
       Install still happens from npm via "<name>@<version>".

       compound-engineering is the exception: it is NOT published to npm, so it
       installs straight from git ("<name>@git+<url>#<tag>", the pinned form
       upstream documents in .opencode/INSTALL.md). It is the OpenCode half of
       the same plugin .chezmoiscripts/70-agents/install-compound-engineering
       installs into Claude Code and Codex — all three resolve the SAME release
       tag through .chezmoitemplates/compound-engineering-ref.tmpl, so they can
       never drift. It used to arrive as dotagents skills (the `[[skills]]` "*"
       wildcard entry, now gone from dot_agents/private_readonly_agents.toml.tmpl).
       Its release train is compound-engineering-*, NOT the repo's other tag
       trains — hence the shared lookup rather than a plain gitHubLatestTag. */ -}}
{{- $ohMyOpenagent := (gitHubLatestTag "code-yeongyu/oh-my-openagent").Name | trimPrefix "v" -}}
{{- $wakatime := (gitHubLatestTag "angristan/opencode-wakatime").Name | trimPrefix "v" -}}
{{- $compoundEngineering := includeTemplate "compound-engineering-ref.tmpl" . -}}
{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": "notify",
  "plugin": [
    "oh-my-openagent@{{ $ohMyOpenagent }}",
    "opencode-wakatime@{{ $wakatime }}",
    "compound-engineering@git+https://github.com/EveryInc/compound-engineering-plugin.git#{{ $compoundEngineering }}"{{ if ne .chezmoi.os "windows" }},
    {{ joinPath .chezmoi.homeDir ".local/share/meridian/current/plugin/meridian.ts" | toJson }}{{ end }}
  ],
  "lsp": {
    "buf": {
      "command": [
        "buf",
        "lsp",
        "serve"
      ],
      "extensions": [
        ".proto"
      ]
    },
    "eslint": {
      "command": [
        "mise",
        "--no-config",
        "exec",
        "-yq",
        "npm:vscode-langservers-extracted",
        "--",
        "vscode-eslint-language-server",
        "--stdio"
      ],
      "extensions": [
        ".js",
        ".jsx",
        ".ts",
        ".tsx",
        ".mjs",
        ".mts",
        ".cjs",
        ".cts",
        ".vue"
      ],
      "initialization": {
        "validate": "on",
        "workingDirectories": [
          {
            "mode": "auto"
          }
        ]
      }
    },
    "marksman": {
      "command": [
        "marksman"
      ],
      "extensions": [
        ".md"
      ]
    }
  },
{{- /* MCP servers are data-driven from .chezmoidata/agents.yaml
       (.agents.mcp.servers). Header values are onepasswordRead-resolved at
       render from the op:// refs in the data file; the toPrettyJson|replace
       pattern mirrors oh-my-openagent.jsonc.tmpl (shift the block one indent
       level to nest inside this 2-space object). */ -}}
{{- $mcp := dict -}}
{{- range .agents.mcp.servers -}}
{{- if eq .transport "stdio" -}}
{{- $mcp = set $mcp .name (dict "type" "local" "command" (concat (list .command) .args)) -}}
{{- else -}}
{{- $h := dict -}}
{{- range $k, $v := .headers -}}
{{- $h = set $h $k (onepasswordRead $v) -}}
{{- end -}}
{{- $mcp = set $mcp .name (dict "type" "remote" "enabled" true "url" .url "headers" $h) -}}
{{- end -}}
{{- end -}}
  "mcp": {{ toPrettyJson "  " $mcp | trim | replace "\n" "\n  " }},
  "permission": {
    "read": {
      "**": "allow",
      "~/.local/share/opencode/auth*": "deny",
      "/home/h82/.local/share/opencode/auth*": "deny",
      "~/.config/glab-cli/config.yml": "deny",
      "/home/h82/.config/glab-cli/config.yml": "deny",
      "~/.config/opencode/opencode.json": "deny",
      "/home/h82/.config/opencode/opencode.json": "deny",
      "/tmp/**": "deny",
      "/var/tmp/**": "deny",
      "/dev/shm/**": "deny"
    },
    "edit": {
      "~/.local/share/opencode/auth*": "deny",
      "/home/h82/.local/share/opencode/auth*": "deny",
      "~/.config/glab-cli/config.yml": "deny",
      "/home/h82/.config/glab-cli/config.yml": "deny",
      "~/.config/opencode/opencode.json": "deny",
      "/home/h82/.config/opencode/opencode.json": "deny",
      "/tmp/**": "deny",
      "/var/tmp/**": "deny",
      "/dev/shm/**": "deny"
    },
    "glob": {
      "~/.local/share/opencode/auth*": "deny",
      "/home/h82/.local/share/opencode/auth*": "deny",
      "~/.config/glab-cli/config.yml": "deny",
      "/home/h82/.config/glab-cli/config.yml": "deny",
      "~/.config/opencode/opencode.json": "deny",
      "/home/h82/.config/opencode/opencode.json": "deny",
      "/tmp/**": "deny",
      "/var/tmp/**": "deny",
      "/dev/shm/**": "deny"
    },
    "bash": {
      "*": "allow",
      "cat ~/.local/share/opencode/auth*": "deny",
      "cat /home/h82/.local/share/opencode/auth*": "deny",
      "cat ~/.config/glab-cli/config.yml": "deny",
      "cat /home/h82/.config/glab-cli/config.yml": "deny",
      "cat ~/.config/opencode/opencode.json": "deny",
      "cat /home/h82/.config/opencode/opencode.json": "deny",
      "glab auth status -t": "deny",
      "glab auth status --show-token": "deny"
    }
  },
  "model": {{ .models.opencode.model | toJson }},
  "small_model": {{ .models.opencode.smallModel | toJson }},
  "experimental": {
    "continue_loop_on_deny": true
  },
  "provider": {
    "opencode": {
      "options": {
        "apiKey": "{{ onepasswordRead "op://Private/Opencode/API Key" }}"
      },
      "whitelist": [
        "deepseek-v4-flash-free",
        "mimo-v2.5-free",
        "nemotron-3-ultra-free",
        "north-mini-code-free"
      ]
    },
    "openrouter": {
      "options": {
        "apiKey": "{{ onepasswordRead "op://Private/OpenRouter/API Key" }}",
        "headers": {
          "HTTP-Referer": "https://opencode.ai/",
          "X-OpenRouter-Title": "OpenCode",
          "X-OpenRouter-Categories": "cli-agent"
        }
      },
      "models": {
        "openrouter/free": {
          "name": "Free Models Router",
          "cost": {
            "input": 0,
            "output": 0,
            "cache_read": 0,
            "cache_write": 0
          }
        },
        "openrouter/auto": {},
        "openrouter/fusion": {}
      },
      "whitelist": [
        "openrouter/free",
        "openrouter/auto",
        "openrouter/fusion"
      ]
    }{{ if ne .chezmoi.os "windows" }},
    "anthropic": {
      "options": {
        "baseURL": "http://127.0.0.1:3456",
        "apiKey": "x"
      }
    }{{ end }}
  }
}
