{{- /* Plugin versions are resolved at apply time from each plugin's GitHub
       tags, so no version is pinned in source. A tag is pushed on every npm
       publish, so tags mirror the published npm versions 1:1 — whereas GitHub
       *Releases* can lag npm (e.g. a version published to npm before its
       Release is cut), which would silently downgrade an npm-installed plugin.
       Install still happens from npm via "<name>@<version>". */ -}}
{{- $ohMyOpenagent := (gitHubLatestTag "code-yeongyu/oh-my-openagent").Name | trimPrefix "v" -}}
{{- $anthropicAuth := (gitHubLatestTag "ex-machina-co/opencode-anthropic-auth").Name | trimPrefix "v" -}}
{{- $wakatime := (gitHubLatestTag "angristan/opencode-wakatime").Name | trimPrefix "v" -}}
{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": "notify",
  "plugin": [
    "oh-my-openagent@{{ $ohMyOpenagent }}",
    "@ex-machina/opencode-anthropic-auth@{{ $anthropicAuth }}",
    "opencode-wakatime@{{ $wakatime }}"
  ],
  "lsp": {
    "buf": {
      "command": [
        "buf",
        "lsp",
        "serve"
      ],
      "extensions": [
        ".proto"
      ]
    },
    "eslint": {
      "command": [
        "mise",
        "--no-config",
        "exec",
        "-yq",
        "npm:vscode-langservers-extracted",
        "--",
        "vscode-eslint-language-server",
        "--stdio"
      ],
      "extensions": [
        ".js",
        ".jsx",
        ".ts",
        ".tsx",
        ".mjs",
        ".mts",
        ".cjs",
        ".cts",
        ".vue"
      ],
      "initialization": {
        "validate": "on",
        "workingDirectories": [
          {
            "mode": "auto"
          }
        ]
      }
    },
    "marksman": {
      "command": [
        "marksman"
      ],
      "extensions": [
        ".md"
      ]
    }
  },
  "mcp": {
    "context7": {
      "type": "remote",
      "enabled": true,
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "{file:./secrets/context7-api-key}"
      }
    },
    "websearch": {
      "type": "remote",
      "enabled": true,
      "url": "https://mcp.exa.ai/mcp",
      "headers": {
        "x-api-key": "{file:./secrets/exa-api-key}"
      }
    },
    "codegraph": {
      "type": "local",
      "command": [
        "codegraph",
        "serve",
        "--mcp"
      ]
    },
    "zai-mcp-server": {
      "type": "local",
      "command": [
        "mise",
        "--no-config",
        "--no-env",
        "--no-hooks",
        "exec",
        "-yq",
        "npm:@z_ai/mcp-server",
        "node",
        "--",
        "zai-mcp-server"
      ],
      "environment": {
        "Z_AI_API_KEY": "{file:./secrets/zai-coding-plan-api-key}",
        "Z_AI_MODE": "ZAI"
      }
    },
    "web-search-prime": {
      "type": "remote",
      "url": "https://api.z.ai/api/mcp/web_search_prime/mcp",
      "headers": {
        "Authorization": "Bearer {file:./secrets/zai-coding-plan-api-key}"
      }
    },
    "web-reader": {
      "type": "remote",
      "url": "https://api.z.ai/api/mcp/web_reader/mcp",
      "headers": {
        "Authorization": "Bearer {file:./secrets/zai-coding-plan-api-key}"
      }
    },
    "zread": {
      "type": "remote",
      "url": "https://api.z.ai/api/mcp/zread/mcp",
      "headers": {
        "Authorization": "Bearer {file:./secrets/zai-coding-plan-api-key}"
      }
    }
  },
