{{- $plugins := includeTemplate "opencode-plugins-json.tmpl" (dict "ctx" . "target" "opencode") | fromJson -}}
{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": "notify",
  "plugin": {{ toPrettyJson "  " $plugins | trim | replace "\n" "\n  " }},
  "lsp": {
    "buf": {
      "command": [
        "buf",
        "lsp",
        "serve"
      ],
      "extensions": [
        ".proto"
      ]
    },
    "eslint": {
      "command": [
        "mise",
        "--no-config",
        "exec",
        "-yq",
        "npm:vscode-langservers-extracted",
        "--",
        "vscode-eslint-language-server",
        "--stdio"
      ],
      "extensions": [
        ".js",
        ".jsx",
        ".ts",
        ".tsx",
        ".mjs",
        ".mts",
        ".cjs",
        ".cts",
        ".vue"
      ],
      "initialization": {
        "validate": "on",
        "workingDirectories": [
          {
            "mode": "auto"
          }
        ]
      }
    },
    "marksman": {
      "command": [
        "marksman"
      ],
      "extensions": [
        ".md"
      ]
    }
  },
{{- /* MCP servers are data-driven from .chezmoidata/agents.yaml
       (.agents.mcp.servers). The recursive resolver applies the shared
       op:// -> onepasswordRead / else-as-is rule to every header value; the
       toPrettyJson|replace pattern mirrors oh-my-openagent.jsonc.tmpl (shift
       the block one indent level to nest inside this 2-space object). */ -}}
{{- $mcp := dict -}}
{{- range .agents.mcp.servers -}}
{{- if eq .transport "stdio" -}}
{{- $mcp = set $mcp .name (dict "type" "local" "command" (concat (list .command) .args)) -}}
{{- else -}}
{{- $h := dict -}}
{{- range $k, $v := .headers -}}
{{- $resolved := includeTemplate "resolve-op-refs-json.tmpl" (dict "value" $v) | fromJson -}}
{{- $h = set $h $k $resolved -}}
{{- end -}}
{{- $mcp = set $mcp .name (dict "type" "remote" "enabled" true "url" .url "headers" $h) -}}
{{- end -}}
{{- end -}}
  "mcp": {{ toPrettyJson "  " $mcp | trim | replace "\n" "\n  " }},
  "permission": {
    "read": {
      "**": "allow",
      "~/.local/share/opencode/auth*": "deny",
      "/home/h82/.local/share/opencode/auth*": "deny",
      "~/.config/glab-cli/config.yml": "deny",
      "/home/h82/.config/glab-cli/config.yml": "deny",
      "~/.config/opencode/opencode.json": "deny",
      "/home/h82/.config/opencode/opencode.json": "deny",
      "/tmp/**": "deny",
      "/var/tmp/**": "deny",
      "/dev/shm/**": "deny"
    },
    "edit": {
      "~/.local/share/opencode/auth*": "deny",
      "/home/h82/.local/share/opencode/auth*": "deny",
      "~/.config/glab-cli/config.yml": "deny",
      "/home/h82/.config/glab-cli/config.yml": "deny",
      "~/.config/opencode/opencode.json": "deny",
      "/home/h82/.config/opencode/opencode.json": "deny",
      "/tmp/**": "deny",
      "/var/tmp/**": "deny",
      "/dev/shm/**": "deny"
    },
    "glob": {
      "~/.local/share/opencode/auth*": "deny",
      "/home/h82/.local/share/opencode/auth*": "deny",
      "~/.config/glab-cli/config.yml": "deny",
      "/home/h82/.config/glab-cli/config.yml": "deny",
      "~/.config/opencode/opencode.json": "deny",
      "/home/h82/.config/opencode/opencode.json": "deny",
      "/tmp/**": "deny",
      "/var/tmp/**": "deny",
      "/dev/shm/**": "deny"
    },
    "bash": {
      "*": "allow",
      "cat ~/.local/share/opencode/auth*": "deny",
      "cat /home/h82/.local/share/opencode/auth*": "deny",
      "cat ~/.config/glab-cli/config.yml": "deny",
      "cat /home/h82/.config/glab-cli/config.yml": "deny",
      "cat ~/.config/opencode/opencode.json": "deny",
      "cat /home/h82/.config/opencode/opencode.json": "deny",
      "glab auth status -t": "deny",
      "glab auth status --show-token": "deny"
    }
  },
  "model": {{ .agents.opencode.model | toJson }},
  "small_model": {{ .agents.opencode.smallModel | toJson }},
  "experimental": {
    "continue_loop_on_deny": true
  },
  "provider": {{ includeTemplate "resolve-op-refs-json.tmpl" (dict "value" .agents.opencode.providers "indent" "  ") }}
}
