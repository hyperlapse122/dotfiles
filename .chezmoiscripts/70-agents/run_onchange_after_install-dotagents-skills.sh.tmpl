{{ if or (eq .chezmoi.os "linux") (eq .chezmoi.os "darwin") -}}
{{ $sourceDir := .chezmoi.sourceDir -}}
#!/usr/bin/env bash
# .chezmoiscripts/70-agents/run_onchange_after_install-dotagents-skills.sh.tmpl
#
# Provisions user-scoped agent skills + MCP servers with `dotagents --user
# install`, driven by the deployed ~/.agents/agents.toml (source:
# dot_agents/private_readonly_agents.toml.tmpl).
#
# onchange trigger: THREE relevant inputs, because agents.yaml also contains
# unrelated pi/OpenCode data and remote skills track upstream releases.
#   1. The fingerprint block embeds a sha256 of the RAW agents.toml source
#      template, catching target-format/local-skill edits without resolving any
#      onepasswordRead value.
#   2. A comment-only selective hash covers ONLY unresolved agents.mcp +
#      agents.skills.remote data. An MCP/remote-skill edit re-triggers the
#      install, while pi/OpenCode-only edits in the same data file do not.
#   3. Raw data is byte-identical across an upstream release (refs are template
#      lookups, not literals), so resolved refs are ALSO rendered below. Without
#      them a new release would land in ~/.agents/agents.toml while this script —
#      the thing that actually fetches the skill — never re-ran. Refs are tags,
#      not secrets, so embedding them is safe.
# Caveat: shadcn/improve pins a BRANCH (it publishes no releases/tags), and a
# branch head cannot be resolved by a chezmoi template function — new commits
# there do not re-trigger this script. They are picked up whenever the install
# does run (a config edit, another skill's release, or `chezmoi apply --force`).
#
# This replaces the former `run_after_` + internal stamp-guard design, whose
# every-apply execution existed to (a) refresh the then-UNPINNED remote skills
# past their `minimum_release_age` settle and (b) retry soft-skipped first
# applies; (a) is obsolete — the settle window is gone and the rendered refs
# above re-trigger this script on their own — and (b) is accepted as the
# standard onchange trade-off:
#   - chezmoi records a clean exit-0 run as done, so a soft-skipped or failed
#     install (mise/git absent, network down) is NOT retried on the next apply
#     until the fingerprint changes — after fixing the cause, re-run by hand
#     (the mise exec command below) or with `chezmoi apply --force`;
#   - a rotated 1Password MCP-header secret no longer re-triggers the install
#     by itself (the raw source is byte-identical) — re-provision the same way.
#
# Soft-skip: this script must never fail apply; missing tools and install
# errors all exit 0 after a diagnostic message. Container-kept: intentionally
# not excluded from containers; it soft-skips when mise/git are absent instead
# of bootstrapping anything.

set -euo pipefail

# Raw agents.toml source fingerprint — target-format and local-skill changes.
# Comment-only; never executed.
{{- includeTemplate "fingerprint.tmpl" (dict "sourceDir" $sourceDir "globs" (list "dot_agents/private_readonly_agents.toml.tmpl")) }}
#
# Selective unresolved DATA trigger. toJson is deterministic, and these values
# contain op:// references rather than resolved secrets. Keeping this separate
# from the raw-file fingerprint prevents unrelated pi/OpenCode data centralized
# in agents.yaml from re-running dotagents.
{{ $dotagentsData := dict "mcp" .agents.mcp "remoteSkills" .agents.skills.remote -}}
# dotagents-data-sha256: {{ $dotagentsData | toJson | sha256sum }}
#
# Resolved remote skill refs (see header note 3) — these move on an upstream
# release, changing this script's content and re-triggering the install that
# fetches them. Ranged from .chezmoidata/agents.yaml (skills.remote); keep the
# data and this block in lockstep. A literal `ref` (e.g. improve's branch head)
# prints verbatim. Comment-only; never executed.
{{- range .agents.skills.remote }}
{{- if hasKey . "ref" }}
#   {{ .source }}@{{ .ref }}
{{- else }}
#   {{ .source }}@{{ (gitHubLatestRelease .source).TagName }}
{{- end }}
{{- end }}
#
# NOT provisioned here: everyinc/compound-engineering-plugin. It is installed
# through each agent's native plugin mechanism instead — see the sibling
# install-compound-engineering script (Claude Code + Codex) and the opencode.json
# `plugin` array (OpenCode).

skip() { exit 0; }

if ! command -v mise >/dev/null 2>&1; then
  echo "install-dotagents-skills: skipped (mise not installed)" >&2
  skip
fi

if ! command -v git >/dev/null 2>&1; then
  echo "install-dotagents-skills: skipped (git not installed)" >&2
  skip
fi

# First-apply fix: `dotagents --user install` iterates agents.toml's
# `agents = ["claude", "codex"]` and drops a `skills` symlink into each agent's
# config dir (~/.claude/skills, ~/.codex/skills) via ensureSkillsSymlink, which
# does NOT create the parent. On a fresh machine ~/.codex is provided by the
# codex external, but nothing creates ~/.claude until Claude Code is first run —
# so the symlink fails with ENOENT and the whole install exits non-zero, which
# the soft-skip below then swallows, leaving skills/MCPs unconfigured on the
# very first apply. Pre-create the agent config dirs so the initial apply
# provisions fully; mkdir -p is idempotent and harmless if the dirs already
# exist.
mkdir -p "$HOME/.claude" "$HOME/.codex" || true

set +e
install_output="$(mise --no-env --no-hooks exec -y npm:@sentry/dotagents@latest node -- dotagents --user install 2>&1)"
install_rc=$?
set -e
if [[ $install_rc -ne 0 ]]; then
  reason="${install_output//$'\n'/; }"
  echo "install-dotagents-skills: skipped (install failed: ${reason})" >&2
  skip
fi
{{ end -}}
