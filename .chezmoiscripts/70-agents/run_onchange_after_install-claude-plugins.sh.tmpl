{{ if eq .chezmoi.os "linux" -}}
{{ $sourceDir := .chezmoi.sourceDir -}}
#!/usr/bin/env bash
# .chezmoiscripts/70-agents/run_onchange_after_install-claude-plugins.sh.tmpl
#
# Registers the deployed ~/.local/share/claude-plugins tree as a local Claude
# Code marketplace and installs the plugins it declares — currently just
# `mxm4-haptic`, which pulses the MX Master 4's haptics on Claude Code
# lifecycle events (source: dot_local/share/claude-plugins/, event->waveform
# map: .chezmoidata/haptic.yaml -> haptic.claude).
#
# WHY a plugin, and not hooks in ~/.claude/settings.json: that file is NOT
# chezmoi-manageable. Claude Code live-writes it (theme, effortLevel, tui,
# permissions.defaultMode) and `aoe` injects its own session-tracking hooks into
# its `hooks` key — a chezmoi-managed (let alone readonly_) target would fight
# both. `claude plugin install` writes only `enabledPlugins` and
# `extraKnownMarketplaces`, never `hooks`, and plugin hooks are MERGED with the
# settings ones at load time. So aoe's hooks and ours coexist untouched.
# (dotagents' [[hooks]] cannot do this job either: it hard-gates hook writing to
# PROJECT scope — `dotagents --user install` writes zero hooks — and its event
# enum has only PreToolUse/PostToolUse/UserPromptSubmit/Stop, so it cannot even
# express the Notification and StopFailure buzzes.)
#
# A local-DIRECTORY marketplace is referenced in place, never copied
# (known_marketplaces.json records installLocation == the source path), so the
# plugin is read live out of ~/.local/share/claude-plugins. A `chezmoi apply`
# that re-renders hooks.json therefore takes effect on the next Claude Code
# session with no re-install — the file phase does the real work, and this
# script only has to have registered the marketplace once.
#
# onchange trigger: the fingerprint block below hashes BOTH the plugin source
# tree AND .chezmoidata/haptic.yaml. Both are needed — the tree's hooks.json is
# a TEMPLATE whose raw text is byte-identical when only a waveform value
# changes, so hashing the tree alone would miss a retune (the same reason
# config-solaar fingerprints solaar.yaml alongside rules.yaml.tmpl).
#
# Idempotent: `marketplace add` on an already-known marketplace and `install` on
# an already-installed plugin both no-op and exit 0, so re-running is harmless.
#
# Soft-skip: this script must never fail an apply — a missing `claude` binary or
# a failed install exits 0 after a diagnostic. NOTE the standard onchange
# trade-off: chezmoi records that clean exit-0 as a successful run, so a skipped
# install is NOT retried on the next apply until the fingerprint changes — after
# fixing the cause, re-run the two commands by hand or `chezmoi apply --force`.
#
# Linux-only (the mxm4-hapticd daemon owns Linux hidraw for the MX Master 4, so
# there is nothing to pulse elsewhere), and container-skipped via the root
# .chezmoiignore, which also skips the deployed plugin tree there.

set -euo pipefail

# Plugin-source fingerprint: the deployed tree's SOURCE plus the data file that
# feeds its hooks.json template. Comment-only; never executed.
{{- includeTemplate "fingerprint.tmpl" (dict "sourceDir" $sourceDir "globs" (list "dot_local/share/claude-plugins/**" ".chezmoidata/haptic.yaml")) }}

MARKETPLACE_DIR="$HOME/.local/share/claude-plugins"
MARKETPLACE_NAME="dotfiles"
PLUGINS=("mxm4-haptic")

skip() { exit 0; }

# `claude` is fetched by .chezmoiexternals/ during the file phase and re-linked
# by .chezmoiscripts/00-tools/, so it exists by this after-phase script on a
# normal apply. Absent (first bootstrap, fetch failed) → nothing to install.
if ! command -v claude >/dev/null 2>&1; then
  echo "install-claude-plugins: skipped (claude not on PATH)" >&2
  skip
fi

# The tree is chezmoi-deployed in the file phase that precedes this script. If
# it is missing, the target was ignored (non-Linux, container) or the apply is
# partial — either way there is nothing to register.
if [[ ! -f "$MARKETPLACE_DIR/.claude-plugin/marketplace.json" ]]; then
  echo "install-claude-plugins: skipped (no marketplace at $MARKETPLACE_DIR)" >&2
  skip
fi

# `claude plugin install` records the plugin in ~/.claude/settings.json; on a
# fresh machine nothing has created ~/.claude yet (same first-apply hazard the
# dotagents script guards against). mkdir -p is idempotent.
mkdir -p "$HOME/.claude" || true

if ! claude plugin marketplace add "$MARKETPLACE_DIR" --scope user; then
  echo "install-claude-plugins: skipped (marketplace add failed)" >&2
  skip
fi

for plugin in "${PLUGINS[@]}"; do
  if ! claude plugin install "${plugin}@${MARKETPLACE_NAME}" --scope user; then
    echo "install-claude-plugins: skipped (install of ${plugin} failed)" >&2
    skip
  fi
done
{{ end -}}
