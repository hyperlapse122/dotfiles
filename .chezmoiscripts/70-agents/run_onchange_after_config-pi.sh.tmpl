{{ if ne .chezmoi.os "windows" -}}
#!/usr/bin/env bash
# .chezmoiscripts/70-agents/run_onchange_after_config-pi.sh.tmpl
#
# Merges pi's model defaults — defaultProvider / defaultModel / defaultThinkingLevel
# (source: .chezmoidata/agents.yaml, .agents.pi.defaults) — into
# ~/.pi/agent/settings.json, the file pi
# LIVE-WRITES (theme, packages, lastChangelogVersion, …).
#
# settings.json CANNOT be a chezmoi-managed target: pi read-merge-writes it on
# every session, so a managed file — let alone a readonly_ 0444 one — would fight
# pi for the same file, exactly the way a managed ~/.claude/settings.json would
# fight Claude Code and aoe (see install-claude-plugins). This script instead
# read-merge-WRITES only the three default keys, preserving every key pi owns —
# the same shape config-solaar and config-biopass use for other apps'
# live-written config files.
#
# Why not the alternatives:
#   - `pi config` is a TUI (no non-interactive setter);
#   - `/settings` is interactive-only;
#   - CLI flags (--provider/--model/--thinking) are per-invocation and would
#     fight pi's Ctrl+P model cycling;
#   - there is NO env var for these defaults (pi's env vars cover only API keys).
# Merging into the live file is the only reproducible, non-conflicting route.
#
# The merge is a plain JSON read-modify-write via /usr/bin/python3 (stdlib json —
# no PyYAML, no jq dependency; NOT bare `python3`, which mise may shadow — see
# config-solaar). It reads settings.json (or starts from {}), sets the three
# keys, and writes back at a WRITABLE mode (0644) so pi can keep writing it. If
# settings.json does not yet exist (pi never run), this CREATES it with the three
# defaults + an empty packages array, so pi's later `pi install`
# (run_onchange_after_install-pi-packages, alphabetically AFTER this script)
# merges packages into a file that already carries the defaults — and pi's own
# read-merge-write from then on preserves them. Atomic write via a temp + rename.
#
# onchange trigger: the rendered values below ARE the trigger. There is no
# source-dir dependency to hash beyond .chezmoidata/agents.yaml (whose values
# render into this body), so there is deliberately NO fingerprint block — editing
# the data changes this script's rendered content and re-runs it (the same shape as
# install-pi-packages and install-vscodium-extensions).
#
# Soft-skip: this script must never fail an apply — a missing `pi` binary or a
# missing python3 exits 0 after a diagnostic. NOTE the standard onchange
# trade-off: chezmoi records that clean exit-0 as a successful run, so a skipped
# merge is NOT retried on the next apply until the rendered content changes —
# re-run by hand or `chezmoi apply --force`.
#
# POSIX-only (`ne windows`) and KEPT in containers, like its sibling
# install-pi-packages: pi is a first-class CLI here, its config is wanted in a
# devbox, and every failure path soft-skips.

set -euo pipefail

SETTINGS="${PI_AGENT_SETTINGS:-$HOME/.pi/agent/settings.json}"

skip() { exit 0; }

# `pi` is fetched by .chezmoiexternals/ai-agents.toml during the file phase and
# symlinked into ~/.local/bin by .chezmoiscripts/00-tools/run_onchange_after_pi,
# so it exists by this after-phase script on a normal apply. Absent (first
# bootstrap, fetch failed) → nothing to configure.
if ! command -v pi >/dev/null 2>&1; then
  echo "config-pi: skipped (pi not on PATH)" >&2
  skip
fi

# /usr/bin/python3 carries the stdlib json module everywhere pi runs. Defensive
# guard for a stripped host.
if ! [ -x /usr/bin/python3 ]; then
  echo "config-pi: skipped (/usr/bin/python3 not found)" >&2
  skip
fi

mkdir -p "$(dirname "$SETTINGS")"

# Rendered defaults from .chezmoidata/agents.yaml — the onchange trigger.
/usr/bin/python3 - "$SETTINGS" \
  "{{ .agents.pi.defaults.provider }}" \
  "{{ .agents.pi.defaults.model }}" \
  "{{ .agents.pi.defaults.thinkingLevel }}" \
  <<'PYEOF'
import json, os, sys
path, provider, model, thinking = sys.argv[1:5]
data = {}
if os.path.exists(path):
    try:
        with open(path, "r", encoding="utf-8") as f:
            data = json.load(f)
    except (ValueError, OSError):
        data = {}
data.setdefault("packages", [])
data["defaultProvider"] = provider
data["defaultModel"] = model
data["defaultThinkingLevel"] = thinking
tmp = path + ".tmp"
with open(tmp, "w", encoding="utf-8") as f:
    json.dump(data, f, indent=2)
    f.write("\n")
os.replace(tmp, path)
os.chmod(path, 0o644)
PYEOF

echo "config-pi: set defaultProvider={{ .agents.pi.defaults.provider }} defaultModel={{ .agents.pi.defaults.model }} defaultThinkingLevel={{ .agents.pi.defaults.thinkingLevel }}"
{{ end -}}
