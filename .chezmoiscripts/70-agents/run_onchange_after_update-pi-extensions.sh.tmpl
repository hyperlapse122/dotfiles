{{ if ne .chezmoi.os "windows" -}}
#!/usr/bin/env bash
# .chezmoiscripts/70-agents/run_onchange_after_update-pi-extensions.sh.tmpl
#
# Reconciles pi's installed extensions with the MANAGED, READONLY
# ~/.pi/agent/settings.json via `pi update --extensions`. settings.json is
# deployed 0400 (private_readonly_) by dot_pi/agent/private_readonly_settings
# .json.tmpl, so pi CANNOT write it — which rules out `pi install` (that command
# appends the source to the settings packages array AND installs deps, so its
# settings step would fail against a readonly file). `pi update --extensions`
# instead reads the declared package list FROM settings and updates the npm deps
# under ~/.pi/agent/npm/ WITHOUT writing settings, so it is the one command that
# works against the managed readonly file. This script is just the apply-time
# trigger for it — formerly run_onchange_after_install-pi-packages, which looped
# `pi install` behind a snapshot/chmod/restore dance; `pi update --extensions`
# makes all of that unnecessary.
#
# ONCHANGE TRIGGER — resolved versions/references, NOT the static list. Each
# declared package in .agents.pi.settings.packages is resolved to its latest
# version (npm: the registry /latest endpoint via curl — the same resolution
# opencode-plugins-json.tmpl uses) or reference (git: the default-branch HEAD
# via `git ls-remote` — the same resolution the `improve` skill external uses)
# and baked into the comment block below. A new upstream release changes one of
# those lines, which changes this script's rendered hash, which re-runs the
# script so `pi update --extensions` fetches the new version. This is what
# actually advances the UNPINNED packages (npm: and git: both track latest): the
# former trigger — the static PACKAGES array — only re-ran when the LIST
# changed, so versions went stale between edits. The resolve-and-bake pattern
# matches compound-engineering-ref.tmpl and cli-proxy-api-ref.tmpl; like them, a
# render-time resolution failure aborts the apply loudly rather than silently
# degrading — the repo is already network-dependent at render (every external
# and opencode.json resolve upstream state the same way), so this adds no new
# failure mode. pi reads the package list straight from settings.json; the lines
# below are the trigger ONLY, never passed to the command.
#
# Packages are UNPINNED by design (npm: and git: both track latest) — the same
# unsettled trade-off the dotagents remote skills make by tracking their newest
# upstream release: a bad upstream publish reaches the host on the next update.
#
# Soft-skip: a missing `pi` binary or a missing settings.json exits 0 after a
# diagnostic. NOTE the standard onchange trade-off: chezmoi records that clean
# exit-0 as a successful run, so a skipped update is NOT retried on the next
# apply until the rendered content changes — after fixing the cause, re-run
# `pi update --extensions` by hand or `chezmoi apply --force`.
#
# POSIX-only (`ne windows`): pi is fetched per-version by .chezmoiexternals/
# ai-agents.toml, whose pi block skips Windows. Deliberately KEPT in containers,
# like the dotagents and compound-engineering installs beside it: pi is a
# first-class CLI here and is wanted in a devbox.

set -euo pipefail

SETTINGS="${PI_AGENT_SETTINGS:-$HOME/.pi/agent/settings.json}"

# chezmoi's non-interactive script environment may omit the user-local bin dir,
# even though the file phase linked pi there earlier in the same apply.
PATH="$HOME/.local/bin${PATH:+:$PATH}"
export PATH

skip() { exit 0; }

if ! command -v pi >/dev/null 2>&1; then
  echo "update-pi-extensions: skipped (pi not on PATH)" >&2
  skip
fi

if [[ ! -f "$SETTINGS" ]]; then
  echo "update-pi-extensions: skipped ($SETTINGS absent — file phase did not deploy it)" >&2
  skip
fi

# `pi update --extensions` shells out to `npm` to fetch/update the declared
# extensions under ~/.pi/agent/npm/. On hosts where node/npm are provided by
# mise, this non-interactive chezmoi script environment never runs
# `mise activate`, so mise-managed npm is NOT on PATH and pi would die with
# "npm: command not found". Resolve npm the same way the sibling dotagents
# install does: prefer an already-visible npm, otherwise run pi INSIDE the mise
# environment (`mise exec -y node` puts mise-managed node — which bundles npm —
# on PATH for the duration of the pi run, while the ~/.local/bin entry above
# keeps pi itself resolvable). The `--no-config --no-env --no-hooks` flags make
# it independent of whatever mise config happens to sit in the script's cwd,
# matching the dotagents invocation.
if command -v npm >/dev/null 2>&1; then
  npm_via_mise=0
elif command -v mise >/dev/null 2>&1; then
  npm_via_mise=1
else
  echo "update-pi-extensions: skipped (no npm on PATH and mise unavailable to provide one)" >&2
  skip
fi

# Resolved latest versions/references (render-time) — the onchange trigger.
# Generated from .agents.pi.settings.packages; pi reads the list from
# settings.json, NOT from here. See the header for the resolve-and-bake rationale.
{{ range .agents.pi.settings.packages }}
{{-   if hasPrefix "npm:" . }}
{{-     $pkg := trimPrefix "npm:" . -}}
{{-     $obj := output "curl" "-fsSL" (printf "https://registry.npmjs.org/%s/latest" $pkg) | toString | fromJson -}}
{{-     $ref := "unknown" -}}
{{-     if hasKey $obj "version" -}}{{- $ref = $obj.version | toString -}}{{- end -}}
#   {{ . }} -> {{ $ref }}
{{-   else if hasPrefix "git:" . -}}
{{-     $repo := trimPrefix "git:" . -}}
{{-     $ref := output "sh" "-c" (printf "git ls-remote https://%s.git HEAD 2>/dev/null || true" $repo) | regexFind "^[0-9a-f]{40}" -}}
{{-     if not (regexMatch "^[0-9a-f]{40}$" $ref) -}}{{- fail (printf "update-pi-extensions: could not resolve %s default-branch HEAD to a 40-character commit sha" .) -}}{{- end -}}
#   {{ . }} -> {{ $ref }}
{{-   else -}}
#   {{ . }} -> (unmanaged source kind — no resolution)
{{-   end }}
{{ end }}

if [[ "$npm_via_mise" -eq 1 ]]; then
  mise --no-config --no-env --no-hooks exec -y node -- pi update --extensions
else
  pi update --extensions
fi
{{ end -}}
