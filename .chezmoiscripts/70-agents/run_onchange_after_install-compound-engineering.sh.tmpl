{{ if or (eq .chezmoi.os "linux") (eq .chezmoi.os "darwin") -}}

{{- $ctx := . -}}
{{- $cePlugin := "" -}}
{{- range .agents.opencode.plugins -}}
{{-   if and (eq .install "localArchive") (eq .versionSource "compoundEngineeringRelease") -}}
{{-     $cePlugin = . -}}
{{-   end -}}
{{- end -}}
{{- if $cePlugin -}}
{{- $ceRef := includeTemplate "compound-engineering-ref.tmpl" $ctx -}}
{{- $ceVersion := printf "v%s" (trimPrefix "compound-engineering-v" $ceRef) -}}

#!/usr/bin/env bash
# .chezmoiscripts/70-agents/run_onchange_after_install-compound-engineering.sh.tmpl
#
# Registers everyinc/compound-engineering-plugin (the ce-* + lfg workflow skills)
# with Claude Code and Codex, all sourcing the plugin from the SAME versioned
# local path where .chezmoiexternals/ai-agents.toml extracts the release
# tarball. OpenCode reads the same path directly from
# dot_config/opencode/readonly_opencode.json.tmpl, and pi loads it from its
# MANAGED ~/.pi/agent/settings.json (dot_pi/agent/readonly_settings.json.tmpl,
# which deepCopies .agents.pi.settings) — both file-phase, no script for those
# two agents.
#
# WHY a plugin, and not dotagents skills: upstream ships a first-class plugin
# for every agent this repo runs, so each agent loads the skill set natively
# (`claude plugin list` / `codex plugin list` / `pi list`) instead of being
# vendored in as 29 loose skill directories under ~/.agents/skills. The former
# `[[skills]] name = "*"` wildcard entry in dot_agents/private_readonly_agents
# .toml.tmpl is therefore gone; dotagents still owns every OTHER skill and all
# the MCP servers.
#
# WHY a versioned LOCAL PATH marketplace source, and not the GitHub URL:
#   1. UNIFIED pinning across all four agents, including Claude — whose
#      `plugin marketplace add` takes NO `--ref` and would otherwise track the
#      upstream default branch.
#   2. The path CHANGES on every ref bump (`.local/share/compound-engineering/
#      v<ver>/`), so agents re-register at a NEW absolute path rather than the
#      CLIs having to notice new content behind an unchanged path.
#   3. `.chezmoiscripts/00-tools/run_onchange_after_compound-engineering`
#      prunes older sibling versions after the file phase, so disk usage stays
#      bounded.
#   4. OpenCode reads the SAME on-disk tree through a `<pkg>@file:<abs-path>`
#      NPM spec (see opencode-plugins-json.tmpl), so all four agents point at
#      the identical extracted release rather than a per-agent cache. NOTE:
#      OpenCode's plugin installer accepts a BARE absolute path as "already
#      configured" but never actually installs/imports it — the `file:`
#      protocol is what triggers the real bun install step.
#
# Pinning is now UNIFIED: all four agents load the SAME extracted tag through
# .chezmoitemplates/compound-engineering-ref.tmpl — the ai-agents.toml external
# picks a tarball, chezmoi extracts it under a versioned dir, and
# Claude/Codex/OpenCode/pi all read that path.
#
# onchange trigger: the rendered CE_VERSION below IS the trigger — it moves on
# every upstream compound-engineering-* release, changing this script's content
# and re-running it after the file phase has extracted the new version.
#
# Ref-bump semantics per agent:
#   - Claude / Codex: the marketplace source PATH changed. Their CLIs do NOT
#     move a configured marketplace in place, so this script removes the
#     old-path marketplace registration (identified by the stable marketplace
#     NAME from .claude-plugin/marketplace.json) before re-adding at the new
#     path, then re-installs the plugin.
#   - pi / OpenCode: NO ref-bump handling here. pi's packages array is the
#     MANAGED settings.json (only the current version's absolute path is ever
#     declared), and the 00-tools sibling-version pruner keeps disk bounded,
#     so there is no stale registration to scrub. OpenCode likewise reads the
#     current path straight from its readonly config.
#
# Idempotent (unchanged version): a re-run at the same CE_VERSION exits 0 —
# the marketplace remove no-ops (nothing at the old path), the add hits the
# already-registered current path and no-ops, and the plugin install no-ops.
#
# Both CLIs write only their plugin registries — `claude plugin install`
# touches just `enabledPlugins` + `extraKnownMarketplaces` in
# ~/.claude/settings.json and never its `hooks` key, so aoe's session hooks
# and the mxm4-haptic plugin's hooks are left untouched (same contract as
# install-claude-plugins).
#
# Soft-skip: this script must never fail an apply — a missing CLI or a failed
# install warns and exits 0, and one agent failing never blocks the others.
# NOTE the standard onchange trade-off: chezmoi records that clean exit-0 as
# a successful run, so a skipped install is NOT retried on the next apply
# until the fingerprint changes — after fixing the cause, re-run the commands
# by hand or `chezmoi apply --force`.
#
# Container-kept (like the sibling dotagents skills install, and unlike
# install-claude-plugins): these are agent skills, wanted in a devbox too,
# and the script soft-skips when the CLIs are absent.

set -euo pipefail

BASE_DIR="$HOME/{{ $cePlugin.externalPath }}"
CE_VERSION="{{ $ceVersion }}"
MARKETPLACE_PATH="$BASE_DIR/$CE_VERSION"
MARKETPLACE_NAME="compound-engineering-plugin"
PLUGIN="compound-engineering"

warn() { echo "install-compound-engineering: $*" >&2; }

# Neither ~/.claude nor ~/.codex is guaranteed on a fresh machine: Claude Code
# and Codex only create their own config dir on first run, so the CLIs' scope=user
# writes fail with ENOENT otherwise. Same first-apply hazard the sibling
# install-dotagents-skills script guards against.
mkdir -p "$HOME/.claude" "$HOME/.codex" || true

if [[ ! -d "$MARKETPLACE_PATH" ]]; then
  warn "skipped: $MARKETPLACE_PATH is absent (chezmoi external missing?)"
  exit 0
fi

install_claude() {
  if ! command -v claude >/dev/null 2>&1; then
    warn "claude: skipped (not on PATH)"
    return 0
  fi

  claude plugin marketplace remove "$MARKETPLACE_NAME" --scope user >/dev/null 2>&1 || true

  if ! claude plugin marketplace add "$MARKETPLACE_PATH" --scope user; then
    warn "claude: skipped (marketplace add failed)"
    return 0
  fi

  if ! claude plugin install "${PLUGIN}@${MARKETPLACE_NAME}" --scope user; then
    warn "claude: skipped (plugin install failed)"
    return 0
  fi
}

install_codex() {
  if ! command -v codex >/dev/null 2>&1; then
    warn "codex: skipped (not on PATH)"
    return 0
  fi

  codex plugin marketplace remove "$MARKETPLACE_NAME" >/dev/null 2>&1 || true

  if ! codex plugin marketplace add "$MARKETPLACE_PATH"; then
    warn "codex: skipped (marketplace add failed)"
    return 0
  fi

  if ! codex plugin add "${PLUGIN}@${MARKETPLACE_NAME}"; then
    warn "codex: skipped (plugin add failed)"
    return 0
  fi
}

install_claude
install_codex
{{ end -}}
{{ end -}}
