{{- includeTemplate "fingerprint.tmpl" (dict "sourceDir" .chezmoi.sourceDir "globs" (list "dot_config/cli-proxy-api/readonly_config.yaml" "dot_local/libexec/private_executable_cli-proxy-api-launch" ".ci/smoke-cli-proxy-api.sh" "dot_config/systemd/user/readonly_cli-proxy-api.service")) -}}
{{- else -}}
{{- includeTemplate "fingerprint.tmpl" (dict "sourceDir" .chezmoi.sourceDir "globs" (list "dot_config/cli-proxy-api/readonly_config.yaml" "dot_local/libexec/private_executable_cli-proxy-api-launch" ".ci/smoke-cli-proxy-api.sh" "Library/LaunchAgents/readonly_dev.h82.cli-proxy-api.plist.tmpl")) -}}
{{- end -}}
