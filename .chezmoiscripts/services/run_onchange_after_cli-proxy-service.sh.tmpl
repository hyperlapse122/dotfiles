{{ if or (eq .chezmoi.os "linux") (eq .chezmoi.os "darwin") -}}
{{ $sourceDir := .chezmoi.sourceDir -}}
#!/usr/bin/env bash

set -euo pipefail

SRC="{{ $sourceDir }}"

{{ if eq .chezmoi.os "darwin" -}}
launchctl bootout "gui/$UID/dev.h82.cli-proxy-api" 2>/dev/null || true

if [ -x "$HOME/.local/bin/cli-proxy-api" ]; then
  if launchctl bootstrap "gui/$UID" "$HOME/Library/LaunchAgents/dev.h82.cli-proxy-api.plist" 2>/dev/null; then
    echo "cli-proxy-api: launchd agent loaded (gui/$UID/dev.h82.cli-proxy-api)"
  else
    echo "cli-proxy-api: skipping launchd load (no GUI session?); load manually once logged in, see Library/LaunchAgents/README.md" >&2
  fi
else
  echo "cli-proxy-api: skipping launchd bootstrap (daemon binary not built)" >&2
fi
{{ else -}}
if systemctl --user daemon-reload >/dev/null 2>&1; then
  systemctl --user enable --now cli-proxy-api.service >/dev/null 2>&1 || true
  echo "cli-proxy-api: services enabled and started (cli-proxy-api)"

  # Note: cli-proxy-api supports hot reload so restart is does not required
  # for unit in cli-proxy-api.service; do
  #   if systemctl --user is-active --quiet "$unit" 2>/dev/null; then
  #     systemctl --user restart "$unit" 2>/dev/null || true
  #     echo "cli-proxy-api: restarted $unit (picked up rebuilt binary)"
  #   fi
  # done
else
  echo "cli-proxy-api: skipping enable (no user session bus); enable manually once logged in: systemctl --user enable cli-proxy-api.service" >&2
fi
{{ end -}}

exit 0
{{ end -}}
