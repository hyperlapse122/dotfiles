{{- /* Validate this distro's `gates:` map against the fact registry. Emits
   nothing, and deliberately sits OUTSIDE the OS gate below: a typo in
   packages.yaml's fedora gates must abort the apply on EVERY host, not only on
   the one distro whose installer body renders — otherwise a bad gate name would
   sit unnoticed on the maintainer's Ubuntu machine until CI rendered the Fedora
   container. `values` hands the partial the gate expressions; the keys are the
   package-group names, which it has no opinion about. */ -}}
{{- includeTemplate "facts-validate.tmpl" (dict
      "ctx"    .
      "source" ".chezmoidata/packages.yaml (packages.linux.fedora.gates)"
      "gates"  (values .packages.linux.fedora.gates)) -}}
{{ if eq (printf "%s-%s" .chezmoi.os .chezmoi.osRelease.id) "linux-fedora" -}}
#!/usr/bin/env bash

set -euo pipefail

# Consolidated Fedora provisioning, migrated from the legacy
# scripts/linux/install-packages.sh: repositories, dnf/flatpak/dotnet packages,
# direct-URL RPMs, DKMS module signing, system services + MOK enrollment,
# RTC/NTP time, the NVIDIA container runtime, and user groups. Serves both Fedora
# editions — Workstation (GNOME) and the KDE Plasma Spin — with the per-desktop
# package sets (kdePackages/gnomePackages) gated on the named `desktop` host
# fact; packages.yaml's `gates:` map says which fact gates which group.
#
# Structured to parallel the Ubuntu installer (.chezmoiscripts/40-linux-ubuntu/
# run_onchange_before_ubuntu.sh.tmpl): a single command wrapper (DNF, mirroring
# APT), dedicated setup_*_repos() functions split out from the install
# orchestration, an enable_unit() helper that skips absent units, MOK enrollment
# kept in its own function rather than folded into enable_services(), and a main
# flow whose ordering matches Ubuntu's (repos+packages → NVIDIA support → direct
# installs → flatpak/dotnet → time → module signing/MOK/services → groups). The
# genuinely Fedora-specific pieces have no Ubuntu counterpart and stay
# (KR mirrorlists, COPRs, RPM Fusion, the /var/lib/dkms MOK + VirtualBox module
# signing, and the KR firewall/ufw split, which for Fedora lives in
# 30-linux/install-system-30-network — firewalld, not ufw — so this folder needs
# no `after_` companion to Ubuntu's tailscale-ufw script).
#
# The gates are resolved at RENDER time, not at runtime: the fact values are
# baked into this script by facts-sh.tmpl below. That is the point — one probe
# per chezmoi command, one answer everywhere — and it means a host that becomes
# a different host (a GPU added, a desktop swapped) changes this script's
# rendered content, which is exactly what makes run_onchange re-run it.
#
# chezmoi re-runs this run_onchange script on every rendered-content change (e.g.
# a single packages.yaml edit), so every step is idempotent and guarded:
# install_fedora_packages short-circuits when all packages are present, and the
# remaining functions skip cleanly when their prerequisites are absent.

{{ includeTemplate "facts-sh.tmpl" . }}
{{ includeTemplate "facts-gate.sh.tmpl" . }}
{{- $gates := .packages.linux.fedora.gates }}

# Host capabilities — SEEDED FROM packages.yaml's `gates:` map via the shared
# fact_gate() dispatcher (.chezmoitemplates/facts-gate.sh.tmpl), not hand-wired
# to a FACT_* variable here. This script used to carry its own probes (a sysfs
# 0x10de scan for the NVIDIA GPU, systemd-detect-virt, and a pair of
# `command -v` desktop checks), then — once those became registry facts — a
# stage that still hand-picked which FACT_* answered each flag, bypassing
# whatever the map itself said. Now the map drives the flag directly: change
# `gates.kdePackages` from `desktop.kde` to something else and this flag
# follows it, no script edit required. See the file header in
# .chezmoidata/packages.yaml.
#
# HAS_BARE_METAL is seeded from bareMetalPackages' `!virt` gate — the BARE
# systemd-detect-virt, true for a container as well as a VM. That is
# deliberately not the manifest's `vm` fact (systemd-detect-virt --vm), which
# gates password-less sudo and must stay false in a container.
HAS_NVIDIA=0; fact_gate {{ index $gates "nvidiaPackages" | quote }} && HAS_NVIDIA=1
[[ "${FORCE_NVIDIA:-0}" == 1 ]] && HAS_NVIDIA=1
HAS_BARE_METAL=0; fact_gate {{ index $gates "bareMetalPackages" | quote }} && HAS_BARE_METAL=1

# The desktop is ONE fact with ONE value (kde | gnome | none), so the two flags
# are mutually exclusive by construction — where the old pair of independent
# `command -v` probes would have set both on a host that happened to carry both
# shells. KDE wins that tie (the precedence facts.yaml declares); `none` (a
# server, a container) installs neither set, as before.
HAS_KDE=0; fact_gate {{ index $gates "kdePackages" | quote }} && HAS_KDE=1
HAS_GNOME=0; fact_gate {{ index $gates "gnomePackages" | quote }} && HAS_GNOME=1

{{ includeTemplate "sudo-require-guard.sh.tmpl" "install-fedora.sh" -}}

# All dnf invocations go through one sudo wrapper, mirroring the Ubuntu
# installer's APT array. Fedora needs no env-var payload (there is no
# DEBIAN_FRONTEND equivalent), so this is a thin ("${SUDO[@]}" dnf) alias kept
# for symmetry with that script; every other command (rpm, flatpak, systemctl,
# mokutil, openssl, ...) still calls "${SUDO[@]}" directly.
DNF=("${SUDO[@]}" dnf)

# Package sets rendered from .chezmoidata/packages.yaml.
core_packages=(
  {{ range .packages.linux.fedora.corePackages -}}
  {{ . | quote }}
  {{ end -}}
)
dnf_groups=(
  {{ range .packages.linux.fedora.groups -}}
  {{ . | quote }}
  {{ end -}}
)
packages=(
  {{ range .packages.linux.fedora.packages -}}
  {{ . | quote }}
  {{ end -}}
)
if [[ "${HAS_BARE_METAL}" -eq 1 ]]; then
  packages+=(
    {{ range .packages.linux.fedora.bareMetalPackages -}}
    {{ . | quote }}
    {{ end -}}
  )
fi
if [[ "${HAS_NVIDIA}" -eq 1 ]]; then
  packages+=(
    {{ range .packages.linux.fedora.nvidiaPackages -}}
    {{ . | quote }}
    {{ end -}}
  )
fi
if [[ "${HAS_KDE}" -eq 1 ]]; then
  packages+=(
    {{ range .packages.linux.fedora.kdePackages -}}
    {{ . | quote }}
    {{ end -}}
  )
fi
if [[ "${HAS_GNOME}" -eq 1 ]]; then
  packages+=(
    {{ range .packages.linux.fedora.gnomePackages -}}
    {{ . | quote }}
    {{ end -}}
  )
fi
flatpaks=(
  {{ range .packages.linux.fedora.flatpaks -}}
  {{ . | quote }}
  {{ end -}}
)
dotnet_tools=(
  {{ range .packages.linux.fedora.dotnetTools -}}
  {{ . | quote }}
  {{ end -}}
)
nvidia_rpmfusion_excludes=(
  {{ range .packages.linux.fedora.nvidiaRpmFusionExcludes -}}
  {{ . | quote }}
  {{ end -}}
)

# Point Fedora's base repos at Korea-country metalinks, but only on desktop-class
# hardware (SMBIOS chassis type). Laptops/servers/VMs keep upstream defaults so a
# portable machine is not pinned to KR mirrors. Fedora-only; there is no Ubuntu
# counterpart.
configure_kr_mirrorlists() {
  local chassis_type=''
  if [[ -r /sys/class/dmi/id/chassis_type ]]; then
    chassis_type="$(</sys/class/dmi/id/chassis_type)"
  fi

  case "${chassis_type}" in
    3|4|5|6|7|13|15|16|35) ;;
    *)
      printf 'install-fedora.sh: chassis type "%s" is not desktop-class; leaving Fedora mirrorlists unchanged.\n' "${chassis_type:-unknown}"
      return 0
      ;;
  esac

  local -a repo_options=(
    "fedora.metalink=https://mirrors.fedoraproject.org/metalink?repo=fedora-\$releasever&arch=\$basearch&country=KR"
    'fedora.mirrorlist='
    "updates.metalink=https://mirrors.fedoraproject.org/metalink?repo=updates-released-f\$releasever&arch=\$basearch&country=KR"
    'updates.mirrorlist='
    "updates-testing.metalink=https://mirrors.fedoraproject.org/metalink?repo=updates-testing-f\$releasever&arch=\$basearch&country=KR"
    'updates-testing.mirrorlist='
  )

  "${DNF[@]}" config-manager setopt "${repo_options[@]}"
}

# Keep NVIDIA's CUDA repository as the sole driver authority while RPM Fusion
# remains available for Steam and other nonfree packages. RPM Fusion's NVIDIA
# packages use a conflicting layout (for example xorg-x11-drv-nvidia-cuda
# conflicts with the CUDA repository's nvidia-driver-cuda), so exclude that
# complete package family from every RPM Fusion nonfree repository. The DNF 5
# override is persistent and idempotent. Guarding repo discovery lets this run
# both before the package fast path on existing hosts and again after RPM Fusion
# is first installed on a fresh host.
configure_nvidia_repo_policy() {
  [[ "${HAS_NVIDIA}" -eq 1 ]] || return 0

  if ! "${DNF[@]}" -q repo list --all 'rpmfusion-nonfree*' | grep -q '^rpmfusion-nonfree'; then
    printf 'install-fedora.sh: RPM Fusion nonfree repos not present; skipping NVIDIA package exclusions.\n'
    return 0
  fi

  local IFS=,
  "${DNF[@]}" config-manager setopt \
    "rpmfusion-nonfree*.excludepkgs=${nvidia_rpmfusion_excludes[*]}"
}

# Add the NVIDIA CUDA + container-toolkit repositories. Split out so it reads as
# one NVIDIA unit — mirrors the Ubuntu installer's setup_nvidia_repos — and
# called from setup_fedora_repos under the HAS_NVIDIA gate; the driver/container
# packages are appended to the install set under the same gate.
setup_nvidia_repos() {
  "${DNF[@]}" config-manager addrepo --from-repofile https://developer.download.nvidia.com/compute/cuda/repos/fedora"$(rpm -E %fedora)"/x86_64/cuda-fedora"$(rpm -E %fedora)".repo --overwrite
  "${DNF[@]}" config-manager addrepo --from-repofile https://nvidia.github.io/libnvidia-container/stable/rpm/nvidia-container-toolkit.repo --overwrite
}

# Configure every third-party repository this host needs, mirroring the Ubuntu
# installer's setup_apt_repos. Called from install_fedora_packages ONLY on the
# install path (when a package is actually missing), so a no-op apply where
# everything is already present never touches the network or the repo config —
# an optimization Fedora keeps, that the Ubuntu installer (whose per-repo .list
# writes are individually change-guarded) does not need.
setup_fedora_repos() {
  # Install the repository manager only when missing — dnf would otherwise hit
  # the network just to discover the package is already installed.
  if ! rpm -q fedora-workstation-repositories >/dev/null 2>&1; then
    "${DNF[@]}" install fedora-workstation-repositories -y
  fi

  configure_kr_mirrorlists

  # Enable third party repositories
  "${SUDO[@]}" fedora-third-party enable

# Enable COPRs
{{ range .packages.linux.fedora.coprs -}}
"${DNF[@]}" copr enable {{ . | quote }} -y
{{ end -}}

  # Install RPM Fusion (free + nonfree) — skip the network install when both
  # release packages are already present. fedora-cisco-openh264 is enabled
  # unconditionally (setopt is idempotent) so steam deps resolve.
  if ! rpm -q rpmfusion-free-release rpmfusion-nonfree-release >/dev/null 2>&1; then
    "${DNF[@]}" install -y \
      "https://mirrors.rpmfusion.org/free/fedora/rpmfusion-free-release-$(rpm -E %fedora).noarch.rpm" \
      "https://mirrors.rpmfusion.org/nonfree/fedora/rpmfusion-nonfree-release-$(rpm -E %fedora).noarch.rpm"
  fi
  "${DNF[@]}" config-manager setopt fedora-cisco-openh264.enabled=1

  # fedora-third-party may have created/enabled RPM Fusion repositories above.
  # Reconcile the NVIDIA package ownership before the main install transaction.
  configure_nvidia_repo_policy

  # Add the NVIDIA CUDA + container-toolkit repositories only on NVIDIA hosts;
  # the driver/container packages are appended to the install set under the same
  # HAS_NVIDIA gate.
  if [[ "${HAS_NVIDIA}" -eq 1 ]]; then
    setup_nvidia_repos
  else
    printf 'install-fedora.sh: no NVIDIA GPU detected; skipping CUDA repo and drivers.\n'
  fi

# Import GPG keys
{{ range .packages.linux.fedora.keys -}}
"${SUDO[@]}" rpm --import {{ . | quote }}
{{ end -}}

{{ range .packages.linux.fedora.dnfRepos }}
"${SUDO[@]}" tee /etc/yum.repos.d/{{ .id }}.repo >/dev/null <<'EOF'
{{ .content -}}
EOF
{{ end -}}

{{ range .packages.linux.fedora.repoFiles -}}
"${DNF[@]}" config-manager addrepo --from-repofile {{ . | quote }} --overwrite
{{ end -}}

  # Refresh metadata now that new repos exist (some, e.g. 1Password, are needed
  # to resolve dependencies of the packages below).
  "${DNF[@]}" makecache -y
}

# Configure repositories (setup_fedora_repos), then install the dnf groups +
# packages. Short-circuits when every named package is already present (rpm -q is
# a local rpmdb lookup; a missing package only lengthens the list, never wrongly
# skips an install). The dnf groups are re-ensured only on the install path; an
# all-present check treats them as satisfied, since their members are not removed
# in normal use.
install_fedora_packages() {
  local -a all_packages=("${core_packages[@]}" "${packages[@]}")
  local -a missing=()
  local pkg
  for pkg in "${all_packages[@]}"; do
    rpm -q "${pkg}" >/dev/null 2>&1 || missing+=("${pkg}")
  done
  if [[ "${#missing[@]}" -eq 0 ]]; then
    printf 'install-fedora.sh: all %d dnf packages already installed; skipping repo setup and install.\n' \
      "${#all_packages[@]}"
    return 0
  fi
  printf 'install-fedora.sh: %d of %d dnf packages missing; configuring repositories and installing.\n' \
    "${#missing[@]}" "${#all_packages[@]}"

  setup_fedora_repos

  "${DNF[@]}" install -y "${core_packages[@]}"
  "${DNF[@]}" group install -y "${dnf_groups[@]}"
  "${DNF[@]}" install -y "${packages[@]}"
}

# RPMs installed directly from a vendor URL (no repo). For each entry: skip when
# already installed — or, for an entry pinning a `version` in the data, when the
# installed rpm VERSION already matches the pin, so bumping the pin re-runs
# `dnf install` as an in-place upgrade (mirrors the Ubuntu installer's
# install_direct_debs). Then import its GPG key(s) and install the URL matching
# the host architecture. Runs after install_fedora_packages so the
# repos/metadata needed for dependency resolution already exist.
install_direct_rpms() {
  local host_arch
  host_arch="$(uname -m)"
{{ range .packages.linux.fedora.directRpms -}}
{{- $pin := get . "version" }}
  if {{ if $pin }}[[ "$(rpm -q --qf '%{VERSION}' {{ .id | quote }} 2>/dev/null || true)" == {{ $pin | quote }} ]]{{ else }}rpm -q {{ .id | quote }} >/dev/null 2>&1{{ end }}; then
    printf 'install-fedora.sh: %s already {{ if $pin }}at pinned version {{ $pin }}{{ else }}installed{{ end }}; skipping.\n' {{ .id | quote }}
  else
{{ if hasKey . "keys" }}{{ range .keys -}}
    "${SUDO[@]}" rpm --import {{ . | quote }}
{{ end }}{{ end -}}
    case "${host_arch}" in
{{ range $arch, $url := .rpms -}}
    {{ $arch }}) "${DNF[@]}" install -y {{ $url | quote }} ;;
{{ end -}}
    *) printf 'install-fedora.sh: no %s rpm for host arch %s; skipping.\n' {{ .id | quote }} "${host_arch}" >&2 ;;
    esac
  fi
{{ end -}}
}

# Flatpak apps from Flathub (system-wide). flatpak install is idempotent, so
# re-runs are safe.
install_flatpak_packages() {
  if [[ "${#flatpaks[@]}" -eq 0 ]]; then
    return 0
  fi

  if ! rpm -q flatpak >/dev/null 2>&1; then
    "${DNF[@]}" install flatpak -y
  fi

  # Ensure the Flathub remote exists system-wide (--if-not-exists is a no-op when
  # already present). Canonical URL per https://flathub.org/setup/Fedora.
  "${SUDO[@]}" flatpak remote-add --if-not-exists --system flathub \
    https://dl.flathub.org/repo/flathub.flatpakrepo

  "${SUDO[@]}" flatpak install --system -y --noninteractive flathub "${flatpaks[@]}"
}

# Global dotnet tools. `dotnet tool install` errors when a tool is already present
# (which would abort under set -e), so install only the ones missing from
# `dotnet tool list -g` — keeping this idempotent across run_onchange re-runs.
install_dotnet_tools() {
  if [[ "${#dotnet_tools[@]}" -eq 0 ]]; then
    return 0
  fi
  if ! command -v dotnet >/dev/null 2>&1; then
    printf 'install-fedora.sh: dotnet not found; skipping global dotnet tools.\n' >&2
    return 0
  fi

  local installed tool
  installed="$(dotnet tool list -g 2>/dev/null || true)"
  for tool in "${dotnet_tools[@]}"; do
    if printf '%s\n' "${installed}" | awk '{print $1}' | grep -ixqF "${tool}"; then
      continue
    fi
    dotnet tool install -g "${tool}"
  done
}

# NVIDIA post-install setup: emit the CDI spec so containers can use the GPU and
# let SELinux allow it. The driver itself installs as part of the main dnf
# transaction (kmod-nvidia-latest-dkms in the HAS_NVIDIA package set), so — unlike
# the Ubuntu install_nvidia_support, which drives the whole driver install — this
# one only does the container-toolkit follow-up. It keeps the name and the
# post-package slot for symmetry with that script. `nvidia-ctk cdi generate` can
# fail on first boot before the freshly built driver module is loaded, so a
# failure here is tolerated (|| true); it regenerates cleanly once the module is
# up — same rationale, and now the same tolerance, as Ubuntu.
install_nvidia_support() {
  if [[ "${HAS_NVIDIA}" -ne 1 ]]; then
    return 0
  fi
  if ! command -v nvidia-ctk >/dev/null 2>&1; then
    printf 'install-fedora.sh: nvidia-ctk not installed; skipping CDI setup.\n' >&2
    return 0
  fi
  "${SUDO[@]}" nvidia-ctk cdi generate --output=/etc/cdi/nvidia.yaml || true
  "${SUDO[@]}" setsebool -P container_use_devices on
}

# Generate the DKMS MOK signing keypair if missing. This ONE keypair is the
# trust anchor for every out-of-tree module signed on this host:
#   - kmod-nvidia-latest-dkms's postinst signs each NVIDIA .ko with it
#     (the DKMS default when a key exists at /var/lib/dkms/mok.{pub,key})
#   - sign_virtualbox_modules() and the /etc/kernel/install.d/50-vbox-sign.install
#     hook sign Oracle's non-DKMS vbox modules with it too
# So one mokutil enrollment covers both stacks — no per-package MOK. Idempotent.
# (Fedora's /var/lib/dkms MOK is the counterpart of Ubuntu's shim-signed MOK at
# /var/lib/shim-signed/mok/; the mechanisms differ per distro, so the enrollment
# functions do not share code.)
#
# On a Fedora host that installs VirtualBox WITHOUT NVIDIA, no DKMS build ever
# fires, so dkms's own /usr/lib/dkms/mok_signing_setup (called from the DKMS
# postinst) never runs and the key file never appears. We call that script
# ourselves when present, and fall back to `openssl req` when it isn't — either
# path lands the pair at the paths mokutil enrollment reads below.
ensure_dkms_mok_generated() {
  [[ -d /sys/firmware/efi ]] || return 0
  mokutil --sb-state 2>/dev/null | grep -q 'SecureBoot enabled' || return 0

  local mok_pub=/var/lib/dkms/mok.pub
  local mok_key=/var/lib/dkms/mok.key
  if "${SUDO[@]}" test -f "${mok_pub}" && "${SUDO[@]}" test -f "${mok_key}"; then
    return 0
  fi

  if [[ -x /usr/lib/dkms/mok_signing_setup ]]; then
    "${SUDO[@]}" /usr/lib/dkms/mok_signing_setup
    return 0
  fi

  # Fallback: mint the pair directly. DER cert + PEM key at DKMS-standard
  # paths, RSA 2048, 100-year validity (the kernel checks signature integrity
  # not cert expiry, so a long-expiring cert saves a re-enrollment reboot),
  # self-describing subject so it stands out in `mokutil --list-enrolled`.
  "${SUDO[@]}" mkdir -p /var/lib/dkms
  "${SUDO[@]}" openssl req -new -x509 -newkey rsa:2048 \
    -keyout "${mok_key}" -outform DER -out "${mok_pub}" \
    -nodes -days 36500 \
    -subj '/CN=DKMS module signing key (chezmoi-managed)/'
  "${SUDO[@]}" chmod 600 "${mok_key}"
}

# Sign the VirtualBox modules for the running kernel so they load under Secure
# Boot. Oracle's Fedora RPM does NOT use DKMS or akmods — its postinst runs
# /sbin/vboxconfig which builds `vbox*.ko` unsigned — so we do the signing
# manually here (whereas NVIDIA's kmod-nvidia-latest-dkms signs itself during
# its own postinst). We reuse the DKMS MOK for the shared-trust-anchor reason
# ensure_dkms_mok_generated documents above.
#
# Runs unconditionally (no HAS_NVIDIA-style gate) — VirtualBox is a base
# package on both distros. Kernel UPDATES re-invoke this loop via the
# /etc/kernel/install.d/50-vbox-sign.install hook (shipped by
# system/linux/etc/, Fedora-gated in .chezmoidata/system.yaml). The hook
# duplicates the sign-file loop rather than sourcing this template — it must
# run outside a chezmoi apply, on every new kernel install.
sign_virtualbox_modules() {
  rpm -q VirtualBox-7.2 >/dev/null 2>&1 || return 0

  ensure_dkms_mok_generated

  local mok_pub=/var/lib/dkms/mok.pub
  local mok_key=/var/lib/dkms/mok.key
  if ! "${SUDO[@]}" test -f "${mok_pub}" || ! "${SUDO[@]}" test -f "${mok_key}"; then
    return 0  # Secure Boot off or MOK generation skipped — unsigned modules load fine
  fi

  # /sbin/vboxconfig is Oracle's build+load entry point; idempotent, and a
  # no-op when the modules are already built for the running kernel. Run it
  # first so a fresh apply after `dnf update kernel` (with no reboot yet) still
  # has vbox*.ko built for `uname -r` to sign.
  if [[ -x /sbin/vboxconfig ]]; then
    "${SUDO[@]}" /sbin/vboxconfig >/dev/null 2>&1 || true
  fi

  local kernel_ver sign_file module_dir
  kernel_ver="$(uname -r)"
  sign_file="/usr/src/kernels/${kernel_ver}/scripts/sign-file"
  if [[ ! -x "${sign_file}" ]]; then
    printf 'install-fedora.sh: %s not found; cannot sign vbox modules. kernel-devel-matched should have installed it — check that its version matches the running kernel.\n' "${sign_file}" >&2
    return 0
  fi

  module_dir="$(dirname "$(modinfo -n vboxdrv 2>/dev/null || true)")"
  if [[ -z "${module_dir}" || "${module_dir}" == "." || ! -d "${module_dir}" ]]; then
    printf 'install-fedora.sh: vbox modules not built for kernel %s; skipping signing (vboxconfig above may have failed silently).\n' "${kernel_ver}" >&2
    return 0
  fi

  local mod modfile
  for mod in vboxdrv vboxnetflt vboxnetadp vboxpci; do
    modfile="${module_dir}/${mod}.ko"
    [[ -f "${modfile}" ]] || continue
    "${SUDO[@]}" "${sign_file}" sha256 "${mok_key}" "${mok_pub}" "${modfile}" 2>/dev/null || true
  done
}

# Enroll the DKMS MOK signing key at /var/lib/dkms/mok.pub when booted with
# Secure Boot — it covers both NVIDIA's DKMS-signed modules AND the VirtualBox
# modules sign_virtualbox_modules signs against the same key. Kept in its own
# function (rather than folded into enable_services, as it once was) so that
# function only enables units, mirroring the Ubuntu installer where MOK
# enrollment lives in dedicated functions. Runs after sign_virtualbox_modules,
# which (via ensure_dkms_mok_generated) seeds the key when VirtualBox is present.
#
# Skipped unless booted via UEFI with Secure Boot on — otherwise unsigned modules
# load fine and `mokutil --import` would queue a pointless MOK Manager prompt on
# next boot. The key is DER-encoded. `mokutil --test-key` confusingly exits 1
# when the key IS enrolled, so grep its stdout for "is already enrolled"; a
# pending request is matched against `mokutil --list-new` by SHA1 fingerprint so
# re-runs between import and reboot don't re-prompt. Approved keys are batched
# into one `mokutil --import` so the user enters the one-time password once.
enroll_dkms_mok() {
  if [[ ! -d /sys/firmware/efi ]]; then
    printf 'install-fedora.sh: not booted via UEFI; skipping MOK import.\n'
  elif ! mokutil --sb-state 2>/dev/null | grep -q 'SecureBoot enabled'; then
    printf 'install-fedora.sh: Secure Boot disabled; skipping MOK import.\n'
  else
    local -a certs=() to_import=()
    local cert fp
    if "${SUDO[@]}" test -f /var/lib/dkms/mok.pub; then
      certs+=(/var/lib/dkms/mok.pub)
    fi
    if [[ ${#certs[@]} -eq 0 ]]; then
      printf 'install-fedora.sh: no DKMS MOK key found; skipping MOK import (sign_virtualbox_modules should have seeded one if VirtualBox is installed).\n'
    else
      for cert in "${certs[@]}"; do
        if "${SUDO[@]}" mokutil --test-key "${cert}" 2>/dev/null | grep -q 'is already enrolled'; then
          printf 'install-fedora.sh: %s already enrolled; skipping.\n' "${cert}"
          continue
        fi
        fp="$("${SUDO[@]}" openssl x509 -in "${cert}" -inform DER -noout -fingerprint -sha1 2>/dev/null | sed 's/.*=//')"
        if [[ -n "${fp}" ]] && mokutil --list-new 2>/dev/null | grep -qi "${fp}"; then
          printf 'install-fedora.sh: %s already queued for enrollment on next boot; skipping.\n' "${cert}"
          continue
        fi
        to_import+=("${cert}")
      done
      if [[ ${#to_import[@]} -gt 0 ]]; then
        "${SUDO[@]}" mokutil --import "${to_import[@]}"
        printf 'install-fedora.sh: MOK enrollment queued. At next boot choose "Enroll MOK" in the MokManager menu and enter the one-time password entered above; NVIDIA and VirtualBox modules stay unloadable until then.\n' >&2
      else
        printf 'install-fedora.sh: DKMS MOK key already enrolled or queued.\n'
      fi
    fi
  fi
}

# Enable a systemd unit only when its unit file exists, so a host missing an
# optional package (e.g. nvidia-persistenced without the NVIDIA driver) is
# skipped rather than failing under set -e. The second argument selects "now"
# (enable --now) or "later" (enable only). Mirrors the Ubuntu installer.
enable_unit() {
  local svc="$1" when="${2:-now}"
  systemctl list-unit-files "${svc}.service" 2>/dev/null | grep -q "${svc}" || return 0
  if [[ "${when}" == later ]]; then
    "${SUDO[@]}" systemctl enable "${svc}" 2>/dev/null || true
  else
    "${SUDO[@]}" systemctl enable --now "${svc}" 2>/dev/null || true
  fi
}

# Enable the system services this machine depends on.
enable_services() {
  enable_unit keyd
  enable_unit tailscaled

  # NVIDIA persistence daemon only on NVIDIA hosts (same HAS_NVIDIA gate as the
  # driver install); it only needs to be up once the driver is loaded, so enable
  # it for next boot rather than starting it now.
  if [[ "${HAS_NVIDIA}" -eq 1 ]]; then
    enable_unit nvidia-persistenced later
  fi

  # Time synchronization — unmask before enabling (some images ship it masked).
  "${SUDO[@]}" systemctl unmask systemd-timesyncd 2>/dev/null || true
  enable_unit systemd-timesyncd
}

# Use the hardware clock as UTC and enable NTP synchronisation. Guarded so a
# systemd-less environment is skipped cleanly (parallel to the Ubuntu installer).
configure_time() {
  command -v timedatectl >/dev/null 2>&1 || return 0
  "${SUDO[@]}" timedatectl set-local-rtc 0 2>/dev/null || true
  "${SUDO[@]}" timedatectl set-ntp true 2>/dev/null || true
}

# Add the user to the device/virtualization groups and allocate rootless-Podman
# subordinate id ranges. Group changes only take effect on next login.
configure_user_groups() {
  local target_user grp
  target_user="${SUDO_USER:-$USER}"
  local -a groups=(keyd vboxusers)

  # Add the user to each device/virtualization group only when it exists.
  for grp in "${groups[@]}"; do
    if getent group "${grp}" >/dev/null 2>&1; then
      "${SUDO[@]}" usermod -aG "${grp}" "${target_user}" 2>/dev/null || true
    fi
  done

  # Drop any stale docker group membership (rootless Podman is used instead).
  if getent group docker >/dev/null 2>&1; then
    "${SUDO[@]}" gpasswd -d "${target_user}" docker 2>/dev/null || true
  fi

  # Allocate subordinate UID/GID ranges for rootless Podman user namespaces.
  # usermod --add-subuids fails if a range already exists, so only add when the
  # user has no entry yet.
  grep -q "^${target_user}:" /etc/subuid 2>/dev/null || "${SUDO[@]}" usermod --add-subuids 100000-165535 "${target_user}" 2>/dev/null || true
  grep -q "^${target_user}:" /etc/subgid 2>/dev/null || "${SUDO[@]}" usermod --add-subgids 100000-165535 "${target_user}" 2>/dev/null || true

  # Notify when the current shell is missing a just-added group; silent on re-runs
  # after re-login.
  if ! id -nG | grep -qw keyd || ! id -nG | grep -qw vboxusers; then
    printf '\n'
    printf 'NOTE: Added "%s" to groups: keyd, vboxusers\n' "${target_user}"
    printf '      Log out and back in (or reboot) for group membership to take effect.\n'
  fi
}

# Reconcile existing hosts before install_fedora_packages can return through its
# all-packages-present fast path. Fresh hosts run this again after RPM Fusion is
# installed inside setup_fedora_repos.
configure_nvidia_repo_policy
install_fedora_packages
install_nvidia_support
install_direct_rpms
install_flatpak_packages
install_dotnet_tools
configure_time
# Sign Oracle's non-DKMS vbox modules and enroll the DKMS MOK BEFORE
# enable_services. sign_virtualbox_modules seeds the MOK (via
# ensure_dkms_mok_generated) that enroll_dkms_mok then imports. Both are no-ops
# when VirtualBox isn't installed or Secure Boot is off; safe on every host.
sign_virtualbox_modules
enroll_dkms_mok
enable_services
configure_user_groups

{{ end -}}
