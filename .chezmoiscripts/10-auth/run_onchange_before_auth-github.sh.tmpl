{{ if ne .chezmoi.os "windows" -}}
#!/usr/bin/env bash

set -euo pipefail

# `gh` may come from dnf/apt or from .chezmoiexternals/vcs.toml (~/.local/bin).
# Fall back to ~/.local/bin when it is not already on PATH (this pre-hook can run
# under a non-login shell) so the login resolves instead of aborting the apply.
case ":$PATH:" in
  *":$HOME/.local/bin:"*) ;;
  *) PATH="$PATH:$HOME/.local/bin" ;;
esac
export PATH

if ! command -v gh >/dev/null 2>&1; then
  printf 'auth-github: `gh` not on PATH or in ~/.local/bin; skipping token login.\n' >&2
  exit 0
fi

env -u GITHUB_TOKEN gh auth login --hostname github.com --git-protocol https --with-token <<EOF
{{ onepasswordRead "op://Private/GitHub/PAT" }}
EOF

{{ end -}}
