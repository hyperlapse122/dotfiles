{{ if eq (printf "%s-%s" .chezmoi.os .chezmoi.osRelease.id) "linux-ubuntu" -}}
#!/usr/bin/env bash
# .chezmoiscripts/linux/run_once_after_teardown-ubuntu-plymouth-bgrt.sh.tmpl
#
# One-shot TEARDOWN that undoes the former `run_after_ubuntu-plymouth-bgrt`
# script. That script pointed the `default.plymouth` update-alternatives link at
# the `bgrt` theme and rebuilt the initramfs; a `bgrt`/spinner splash is known to
# swallow the early-boot LUKS passphrase prompt on Ubuntu (Launchpad #1864586),
# leaving an encrypted host unable to unlock at boot. All Plymouth customization
# has been removed from this repo, so this reverts `default.plymouth` back to
# Ubuntu's automatic (distro-default) choice and rebuilds the initramfs,
# restoring the stock boot splash and its working LUKS passphrase prompt.
#
# run_once: executes a single time per machine. On a host that never ran the old
# bgrt script this is a harmless no-op. Every step is guarded and idempotent, and
# the initramfs is rebuilt only when something actually changed.

set -euo pipefail
export LC_ALL=C
BGRT=/usr/share/plymouth/themes/bgrt/bgrt.plymouth

command -v update-alternatives >/dev/null 2>&1 || { echo "plymouth-teardown: no update-alternatives; skip"; exit 0; }

# SUDO + non-interactive skip (mutating the alternatives db needs root).
if [[ "$EUID" -eq 0 ]]; then SUDO=(); else SUDO=(sudo)
  if [[ ! -t 0 ]] && ! sudo -n true 2>/dev/null; then echo "plymouth-teardown: no sudo; skip"; exit 0; fi
fi

# Nothing to revert if default.plymouth isn't a managed alternative at all.
"${SUDO[@]}" update-alternatives --query default.plymouth >/dev/null 2>&1 \
  || { echo "plymouth-teardown: default.plymouth not managed; skip"; exit 0; }

changed=false

# The old script INJECTED a bgrt alternative (only when bgrt wasn't already
# registered). If bgrt is present AND another theme remains, drop that entry so
# the distro's own theme registration wins under --auto. Guard on >1 alternative
# so we never remove the sole theme (which would leave a bare text splash).
mapfile -t alts < <("${SUDO[@]}" update-alternatives --list default.plymouth 2>/dev/null || true)
if (( ${#alts[@]} > 1 )) && printf '%s\n' "${alts[@]}" | grep -qx "$BGRT"; then
  "${SUDO[@]}" update-alternatives --remove default.plymouth "$BGRT" && changed=true
fi

# Undo the manual `--set` the old script performed: return to automatic mode so
# the distribution's highest-priority (default) theme is selected again.
status="$("${SUDO[@]}" update-alternatives --query default.plymouth 2>/dev/null | awk '/^Status:/{print $2}')"
if [[ "$status" == "manual" ]]; then
  "${SUDO[@]}" update-alternatives --auto default.plymouth && changed=true
fi

# Rebuild the initramfs only when the selection actually changed.
if [[ "$changed" == true ]] && command -v update-initramfs >/dev/null 2>&1; then
  "${SUDO[@]}" update-initramfs -u
  echo "plymouth-teardown: reverted default.plymouth to the distro default + rebuilt initramfs"
else
  echo "plymouth-teardown: already stock; no-op"
fi
{{ end -}}
