{{ if and (eq .chezmoi.os "linux") (or (eq .chezmoi.osRelease.id "fedora") (eq .chezmoi.osRelease.id "ubuntu")) -}}
{{-   $luksPassphrase := "" -}}
{{-   if hasKey . "luksPassphrase" }}{{ $luksPassphrase = .luksPassphrase }}{{ end -}}
{{ $sourceDir := .chezmoi.sourceDir -}}
#!/usr/bin/env bash
# .chezmoiscripts/linux/run_onchange_after_luks-tpm2.sh.tmpl
#
# Wrapper — Fedora + Ubuntu — that enrolls this host's LUKS devices for TPM2
# auto-unlock on `chezmoi apply`, by driving the deployed
# ~/.local/bin/setup-luks-tpm2-unlock.sh non-interactively. Both distros use the
# same dracut + systemd-cryptenroll backend, so this wrapper is backend-neutral.
#
# PASSPHRASE via chezmoi's promptString: chezmoi asks for the existing LUKS
# passphrase at apply time and it reaches the enrollment tool through the
# SETUP_LUKS_TPM2_PASSPHRASE environment variable (the tool reads it from env
# ONLY, never argv, and clears it immediately). Leave the prompt blank to skip
# enrollment for this apply — e.g. once the disk is already enrolled. Enrollment
# is also idempotent: a device that already carries a systemd-tpm2 token is
# skipped even when a passphrase is given.
#
# onchange trigger: the fingerprint block below embeds a sha256 of the deployed
# enrollment tool (executable_setup-luks-tpm2-unlock.sh.tmpl and its inlined
# .setup-luks-tpm2-unlock_dracut.sh backend), so chezmoi re-runs this wrapper
# whenever the enrollment logic changes. The prompted LUKS passphrase is NOT part
# of the fingerprint — only the tool's source is hashed; note that entering a
# passphrase does render it into this script's body (base64), which itself
# changes the onchange hash, so the first apply that supplies a passphrase does
# fire enrollment. NOTE the behavior change from the former run_after: a run
# skipped for a blank passphrase, a not-yet-deployed tool, an absent TPM, or
# missing sudo is now recorded as "done" and is NOT retried on the next apply
# unless the fingerprint changes — re-run enrollment with `chezmoi apply --force`
# (entering the passphrase) or by invoking the tool directly. Enrollment stays a
# cheap idempotent no-op once every device is enrolled.
#
# SECURITY NOTES (inherent to the chezmoi-prompt approach, chosen deliberately):
#   * promptString does NOT mask input, so the passphrase is echoed on screen as
#     you type it during an interactive `chezmoi apply`.
#   * When a passphrase is entered it is rendered (base64-wrapped only for shell
#     safety, NOT secrecy) into this script's transient run-script file, which
#     chezmoi writes mode-0700 and deletes after execution. Avoid
#     `chezmoi apply --verbose` / `--dry-run` with a real passphrase, as those
#     print rendered script contents.
#   * Non-interactive applies (CI, agents, piped) get promptString's empty
#     default and take the skip path below — no passphrase is ever rendered.
set -euo pipefail
export LC_ALL=C

# enrollment tool content fingerprint — chezmoi hashes this rendered script to
# decide whether to re-run; embedding the tool's (and its dracut backend's)
# sha256 forces a re-run when the enrollment logic changes. The prompted
# passphrase is never part of this block. `include . | sha256sum` hashes file
# CONTENT; `(stat .).isDir` skips directories. Comment-only; never executed.
{{ range (glob (joinPath $sourceDir "dot_local/bin/executable_setup-luks-tpm2-unlock.sh.tmpl")) -}}
{{ if not (stat .).isDir -}}
#   {{ . | trimPrefix $sourceDir | trimPrefix "/" }}  {{ include . | sha256sum }}
{{ end -}}
{{ end -}}
{{ range (glob (joinPath $sourceDir "dot_local/bin/.setup-luks-tpm2-unlock_dracut.sh")) -}}
{{ if not (stat .).isDir -}}
#   {{ . | trimPrefix $sourceDir | trimPrefix "/" }}  {{ include . | sha256sum }}
{{ end -}}
{{ end }}
{{ if $luksPassphrase -}}
tool="${HOME}/.local/bin/setup-luks-tpm2-unlock.sh"

# Soft-skip (exit 0) on any unmet precondition; run_after retries next apply.
[[ -x "$tool" ]] || { echo "luks-tpm2: $tool not deployed yet; will retry next apply"; exit 0; }

# TPM2 present? (kernel device node — backend-neutral)
if [[ ! -e /sys/class/tpm/tpm0 && ! -e /dev/tpmrm0 ]]; then
  echo "luks-tpm2: no TPM2 device on this host; skipping"; exit 0
fi

# Any crypto_LUKS block device to enroll?
if ! lsblk -rno FSTYPE 2>/dev/null | grep -qx 'crypto_LUKS'; then
  echo "luks-tpm2: no LUKS devices; skipping"; exit 0
fi

# Enrollment needs root. A non-empty passphrase only ever comes from an
# interactive promptString, so a terminal is present and the tool can prompt for
# sudo itself — we only need sudo to exist here.
if [[ "$EUID" -ne 0 ]] && ! command -v sudo >/dev/null 2>&1; then
  echo "luks-tpm2: not root and sudo unavailable; will retry next apply"; exit 0
fi

# Hand the prompted passphrase to the tool via env (never argv). base64 keeps any
# shell-special characters in the passphrase from breaking the assignment; the
# tool reads $SETUP_LUKS_TPM2_PASSPHRASE, clears it, and enrolls every
# not-yet-enrolled LUKS device for TPM2 unlock.
SETUP_LUKS_TPM2_PASSPHRASE="$(printf '%s' {{ $luksPassphrase | b64enc | quote }} | base64 -d)" "$tool"
{{ else -}}
echo "luks-tpm2: no passphrase entered; skipping TPM2 enrollment this apply."
{{ end -}}
{{ end -}}
