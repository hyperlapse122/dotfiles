{{ if eq (printf "%s-%s" .chezmoi.os .chezmoi.osRelease.id) "linux-ubuntu" -}}
#!/usr/bin/env bash
# .chezmoiscripts/linux/run_after_ubuntu-luks-passphrase-prompt.sh.tmpl
#
# Keep the early-boot LUKS passphrase prompt VISIBLE on an encrypted Ubuntu host.
#
# On a LUKS-encrypted root, the initramfs `cryptsetup` prompt is drawn over the
# framebuffer that Plymouth's `splash` has taken over. Ubuntu's stock `bgrt`
# (and other spinner) themes never transition to a password dialog, so the
# prompt is invisible: the machine sits on a blank/logo splash, accepts no
# passphrase, and never unlocks root (Launchpad #1864586). The companion
# `run_after_ubuntu-plymouth-teardown` script only UNDOES a manual `bgrt`
# override this repo used to `--set`; when `bgrt` is also the distro's automatic
# default (stock Ubuntu) it is deliberately left native, so the prompt stays
# swallowed. Making the generic HWE kernel the default boot entry (Intel stack)
# can expose this on a host that previously booted the lowlatency kernel fine.
#
# FIX: drop the `splash` boot argument via an /etc/default/grub.d drop-in so
# Plymouth does not grab the console during early boot and the `cryptsetup`
# passphrase prompt renders as text. `quiet` is kept (it only hides kernel log
# spam and does not affect the prompt). This is the canonical Ubuntu workaround
# for #1864586 and never touches the passphrase keyslot itself.
#
# SCOPE — strictly an ENCRYPTED-Ubuntu concern:
#   * acts only when the running system actually has a crypto_LUKS device; a
#     host with no encrypted volume is left completely untouched (no splash
#     change), and if encryption is later removed the drop-in is cleaned up;
#   * writes ONLY our own `99-*.cfg` drop-in — it never edits /etc/default/grub
#     or any file this repo does not own, and it rewrites GRUB_CMDLINE_LINUX_DEFAULT
#     purely by stripping the `splash` token (every other boot arg is preserved).
#
# run_after (deliberately NOT run_once): reruns on every apply so a run skipped
# for lack of sudo is retried on a later apply instead of being cached as "done"
# — a run_once skip would strand a still-broken encrypted host forever. It is a
# cheap no-op once the drop-in is in place.

set -euo pipefail
export LC_ALL=C

DROPIN=/etc/default/grub.d/99-luks-visible-passphrase.cfg
DROPIN_DIR=/etc/default/grub.d

command -v lsblk >/dev/null 2>&1 || { echo "luks-passphrase-prompt: no lsblk; skip"; exit 0; }

# SUDO + non-interactive skip (writing under /etc + running update-grub needs
# root). A skip here is safe: run_after retries on the next apply.
if [[ "$EUID" -eq 0 ]]; then SUDO=(); else SUDO=(sudo)
  if [[ ! -t 0 ]] && ! sudo -n true 2>/dev/null; then echo "luks-passphrase-prompt: no sudo; will retry next apply"; exit 0; fi
fi

# Is any block device LUKS-encrypted? (lsblk needs no root for FSTYPE.)
has_luks=false
if lsblk -rno FSTYPE 2>/dev/null | grep -qx 'crypto_LUKS'; then
  has_luks=true
fi

regen_grub() {
  if command -v update-grub >/dev/null 2>&1; then
    "${SUDO[@]}" update-grub
  else
    "${SUDO[@]}" grub-mkconfig -o /boot/grub/grub.cfg
  fi
}

# No encrypted volume: this host has nothing to fix. If a previous apply (from
# when it WAS encrypted) left our drop-in behind, remove it and regenerate grub
# so the stock `splash` behaviour is restored; otherwise do nothing.
if [[ "$has_luks" != true ]]; then
  if "${SUDO[@]}" test -e "$DROPIN"; then
    "${SUDO[@]}" rm -f "$DROPIN"
    regen_grub
    echo "luks-passphrase-prompt: no LUKS device; removed stale $DROPIN and regenerated grub"
  else
    echo "luks-passphrase-prompt: no LUKS device; nothing to do"
  fi
  exit 0
fi

# Desired drop-in: strip `splash` from GRUB_CMDLINE_LINUX_DEFAULT. Sourced by
# grub-mkconfig AFTER /etc/default/grub (and any lower-numbered drop-in), so it
# operates on the fully-assembled value; the space-padded sed removes the token
# wherever it sits and re-trims. Idempotent even if `splash` is already absent.
read -r -d '' DESIRED <<'EOF' || true
# Managed by chezmoi - keep the early-boot LUKS passphrase prompt visible.
# A bgrt/spinner Plymouth splash can hide the cryptsetup passphrase prompt on an
# encrypted host (Launchpad #1864586), leaving it unable to unlock and boot.
# Drop the `splash` boot arg so the prompt renders on the console. `quiet` stays.
GRUB_CMDLINE_LINUX_DEFAULT="$(echo " ${GRUB_CMDLINE_LINUX_DEFAULT} " | sed -e 's/ splash / /g' -e 's/^ *//' -e 's/ *$//')"
EOF

current="$("${SUDO[@]}" cat "$DROPIN" 2>/dev/null || true)"
if [[ "$current" == "$DESIRED" ]]; then
  echo "luks-passphrase-prompt: $DROPIN already current; leaving untouched"
  exit 0
fi

"${SUDO[@]}" install -d -m 0755 "$DROPIN_DIR"
printf '%s\n' "$DESIRED" | "${SUDO[@]}" tee "$DROPIN" >/dev/null
"${SUDO[@]}" chmod 0644 "$DROPIN"
regen_grub
echo "luks-passphrase-prompt: wrote $DROPIN (dropped 'splash' for a visible LUKS prompt) + regenerated grub"
{{ end -}}
