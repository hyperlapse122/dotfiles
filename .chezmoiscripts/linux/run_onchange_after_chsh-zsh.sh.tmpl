{{ if eq .chezmoi.os "linux" -}}
#!/usr/bin/env bash
# .chezmoiscripts/linux/run_onchange_after_chsh-zsh.sh.tmpl
#
# Set the invoking user's login shell to zsh. The login shell lives in the
# /etc/passwd field, which chezmoi (a $HOME manager) cannot own, so this ships
# as a `run_onchange_after_` script — the chezmoi equivalent of a post-install
# shell step.
#
# Idempotent: the current login shell is read from /etc/passwd (via getent)
# first. If it is already a zsh, the script prints a notice and exits 0 WITHOUT
# touching sudo — so the steady-state re-run (this file re-runs whenever its
# rendered content changes) is a silent no-op that never prompts for a password.
#
# Soft-skips (exit 0, never aborts `chezmoi apply`) when:
#   - zsh is not installed (nothing to switch to; install zsh, then re-run)
#   - chsh is not available (Fedora ships it in util-linux-user)
#   - not root, stdin is not a TTY, and sudo has no cached credentials — a
#     non-interactive apply (CI, an agent, a piped run) can't answer a sudo
#     prompt. NOTE: chezmoi records a clean exit-0 skip as a successful run, so
#     the script will NOT re-run on the next apply until its content changes —
#     re-run it by hand on an interactive terminal with `chezmoi apply --force`.
#
# sudo: rewriting the /etc/passwd shell field needs root. The script body runs
# as the user (so $USER is the real invoking user), and only the privileged
# `chsh`/`tee` calls are prefixed with sudo; when already root (e.g. a chroot
# bootstrap) sudo is dropped.
#
# /etc/shells: a login shell should be registered there (getusershell()-based
# tooling and display managers consult it). The zsh rpm registers it already;
# on a host where it is missing we append the resolved path (guarded,
# idempotent) so the registry stays correct.
#
# Single-platform (Linux only) by design — gated on `.chezmoi.os == "linux"`.
# macOS already defaults to zsh and Windows has no /etc/passwd login shell, so
# there is nothing equivalent to do on either; no .ps1 counterpart per the
# script-parity exception in ../AGENTS.md.

set -euo pipefail

# 1. Nothing to switch to if zsh isn't installed.
if ! command -v zsh >/dev/null 2>&1; then
  printf 'chsh-zsh: zsh not installed; skipping (install zsh, then re-run).\n' >&2
  exit 0
fi
zsh_bin="$(command -v zsh)"

# 2. Already a zsh login shell? Bail before touching sudo so the steady-state
#    re-run is a silent no-op. Match on basename so /bin/zsh vs /usr/bin/zsh
#    (Fedora's /bin -> /usr/bin symlink) does not cause needless churn.
current_shell="$(getent passwd "$USER" 2>/dev/null | awk -F: '{ print $7 }')" || true
if [[ "${current_shell##*/}" == "zsh" ]]; then
  printf 'chsh-zsh: login shell already zsh (%s); nothing to do.\n' "$current_shell"
  exit 0
fi

# 3. chsh is what actually rewrites the /etc/passwd shell field.
if ! command -v chsh >/dev/null 2>&1; then
  printf 'chsh-zsh: chsh not found (Fedora: install util-linux-user); skipping.\n' >&2
  exit 0
fi

# 4. Privilege: prefix privileged calls with sudo unless we are already root.
if [[ "${EUID}" -eq 0 ]]; then
  SUDO=()
else
  SUDO=(sudo)

  # Skip cleanly when we would have to prompt for a password but can't.
  # `[[ -t 0 ]]` is true only when stdin is a TTY (interactive `chezmoi apply`);
  # `sudo -n true` succeeds with cached or password-less sudo. Only when both
  # fail do we give up — otherwise a non-interactive apply would hang/fail.
  if [[ ! -t 0 ]] && ! sudo -n true 2>/dev/null; then
    printf 'chsh-zsh: skipped (non-interactive shell, no cached sudo credentials).\n'
    printf '  Re-run on an interactive terminal with sudo available:\n'
    printf '    chezmoi apply --force\n'
    exit 0
  fi
fi

# 5. chsh only accepts a shell listed in /etc/shells for non-root callers, and
#    a login shell belongs there regardless. Register the resolved zsh path if
#    the package did not already (idempotent: append only when missing).
if [[ -f /etc/shells ]] && ! grep -qxF "$zsh_bin" /etc/shells; then
  printf 'chsh-zsh: registering %s in /etc/shells\n' "$zsh_bin"
  printf '%s\n' "$zsh_bin" | "${SUDO[@]}" tee -a /etc/shells >/dev/null
fi

# 6. Switch the login shell.
printf 'chsh-zsh: setting login shell for %s to %s\n' "$USER" "$zsh_bin"
"${SUDO[@]}" chsh -s "$zsh_bin" "$USER"

printf 'chsh-zsh: done. Log out and back in for the new login shell to take effect.\n'
{{ end -}}