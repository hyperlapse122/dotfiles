{{ if eq .chezmoi.os "linux" -}}
#!/usr/bin/env bash
# .chezmoiscripts/linux/run_after_import-wifi-1password.sh.tmpl
#
# run_after_: executes on every `chezmoi apply` (no onchange fingerprint to
# maintain), so Wi-Fi networks newly added to 1Password are imported into
# NetworkManager on the next apply. The real logic lives in the deployed
# ~/.local/bin/import-wifi-1password command — kept there (not inlined here) so
# it is also runnable by hand and supports --dry-run; this wrapper only invokes
# it in apply context.
#
# Secrets never enter this rendered template: the command reads Wi-Fi passwords
# from `op` at RUNTIME. A `run_onchange_` gate would instead have to embed or
# hash the passwords into the rendered script to detect changes, leaking them
# into `chezmoi diff`/state — so this is deliberately an unconditional
# `run_after_` that re-reads 1Password live each apply.
#
# Linux-only: NetworkManager is Linux-only (this file is gated + carries no .sh
# on non-Linux). Container-skipped: the root .chezmoiignore drops
# .chezmoiscripts/linux/*.sh inside a real (non-toolbox) container, where there
# is no NetworkManager to import into.
#
# Soft-skip (like install-dotagents-skills): this must NEVER fail apply. A
# missing command, or any nonzero exit from it (op not signed in, NetworkManager
# down, no sudo, a network that failed to import), is logged and swallowed so the
# rest of the apply continues.

set -euo pipefail

cmd="{{ .chezmoi.homeDir }}/.local/bin/import-wifi-1password"
if [[ ! -x "$cmd" ]]; then
  echo "import-wifi-1password: skipped (command not deployed to ~/.local/bin yet)" >&2
  exit 0
fi

# --from-apply: quieter output and treats "not applicable here" conditions (op
# not signed in, NetworkManager not running, no non-interactive sudo) as a clean
# skip. The `|| echo` additionally swallows any hard error so a single bad
# network cannot abort the apply.
if ! "$cmd" --from-apply; then
  echo "import-wifi-1password: skipped (import reported issues; continuing apply)" >&2
fi
exit 0
{{ end -}}
