{{ if eq (printf "%s-%s" .chezmoi.os .chezmoi.osRelease.id) "linux-ubuntu" -}}
#!/usr/bin/env bash
set -euo pipefail
# Write /etc/sddm.conf.d/90-breeze.conf (lexically overrides Kubuntu's
# /etc/sddm.conf.d/20-kubuntu.conf which sets a Kubuntu-branded theme).
# Written by this SCRIPT, NOT added to the shared system/linux/etc tree
# (that tree deploys to Fedora too and would regress it).

# Guard: skip if sddm is not installed.
dpkg-query -W -f='${db:Status-Abbrev}' sddm 2>/dev/null | grep -q '^ii' \
  || { echo "sddm absent; skip"; exit 0; }

# Guard: skip if the breeze SDDM theme files are absent (ships in sddm-theme-breeze,
# installed by the ubuntu apt provisioner). Forcing Current=breeze without the
# theme installed would yield a broken login screen.
[[ -f /usr/share/sddm/themes/breeze/theme.conf ]] \
  || { echo "sddm breeze theme absent (comes from installer); skip"; exit 0; }

dst=/etc/sddm.conf.d/90-breeze.conf
want=$'[Theme]\nCurrent=breeze'

# Idempotency: no-op if the file already has the desired content.
[[ -f "$dst" && "$(cat "$dst" 2>/dev/null)" == "$want" ]] && { echo "sddm breeze drop-in current; no-op"; exit 0; }

# SUDO + non-interactive skip
if [[ "$EUID" -eq 0 ]]; then SUDO=(); else SUDO=(sudo)
  if [[ ! -t 0 ]] && ! sudo -n true 2>/dev/null; then echo "no sudo; skip"; exit 0; fi
fi

# Write the drop-in via stdin (no temp file needed; install -D creates parent dir).
printf '[Theme]\nCurrent=breeze\n' | "${SUDO[@]}" install -D -m 0644 /dev/stdin "$dst"
echo "sddm login theme forced to breeze via $dst"
{{ end -}}
