{{ if eq (printf "%s-%s" .chezmoi.os .chezmoi.osRelease.id) "linux-ubuntu" -}}
#!/usr/bin/env bash
# .chezmoiscripts/linux/run_onchange_after_ubuntu-plymouth-teardown.sh.tmpl
#
# TEARDOWN that undoes the former `run_after_ubuntu-plymouth-bgrt` script, which
# `--set` the `default.plymouth` update-alternatives link to the `bgrt` theme
# (manual mode) and rebuilt the initramfs. A `bgrt`/spinner splash can swallow
# the early-boot LUKS passphrase prompt on Ubuntu (Launchpad #1864586), leaving
# an encrypted host unable to unlock. All Plymouth customization has been removed
# from this repo, so this returns `default.plymouth` to automatic (distro-default)
# selection and rebuilds every kernel's initramfs, restoring the stock splash and
# its working LUKS prompt.
#
# onchange, no external dependency: this teardown has no dependency file to
# fingerprint, so its onchange trigger is its own rendered content — chezmoi
# re-runs it only when this script changes. NOTE the behavior change from the
# former run_after: a run skipped for lack of sudo is now recorded as "done" and
# is NOT retried on the next apply unless this script's content changes — on a
# host where the revert was skipped for missing sudo, complete it with
# `chezmoi apply --force` (or run the update-alternatives revert by hand). It is
# a cheap no-op once reverted. (It remains NOT run_once — a run_once skip could
# never re-fire at all, even on a content change.)
#
# SCOPE — only ever undoes OUR change, never native/user state:
#   * acts only when `bgrt` is the CURRENTLY SELECTED theme in MANUAL mode (the
#     exact state the old `--set` produced); any other selection, the distro's
#     automatic default, or a user/admin's own manual pick of another theme is
#     left untouched;
#   * only runs `--auto` (undo the manual `--set`) — it NEVER `--remove`s the
#     bgrt alternative, since it cannot prove whether this repo or the distro/
#     admin registered it, and unregistering package-owned state is out of scope.

set -euo pipefail
export LC_ALL=C
BGRT=/usr/share/plymouth/themes/bgrt/bgrt.plymouth

command -v update-alternatives >/dev/null 2>&1 || { echo "plymouth-teardown: no update-alternatives; skip"; exit 0; }

# SUDO + non-interactive skip (querying/mutating the alternatives db needs root).
# A skip here is safe: run_after retries on the next apply.
if [[ "$EUID" -eq 0 ]]; then SUDO=(); else SUDO=(sudo)
  if [[ ! -t 0 ]] && ! sudo -n true 2>/dev/null; then echo "plymouth-teardown: no sudo; will retry next apply"; exit 0; fi
fi

# Read the current selection + mode in one query.
query="$("${SUDO[@]}" update-alternatives --query default.plymouth 2>/dev/null || true)"
current="$(awk '/^Value:/{print $2; exit}' <<<"$query")"
status="$(awk '/^Status:/{print $2; exit}' <<<"$query")"

# Only bgrt-selected-in-manual-mode is the state the removed override produced.
# Anything else — an unmanaged link, the distro's automatic default, or a user's
# own manual choice of some other theme — is left exactly as-is.
if [[ "$current" != "$BGRT" ]]; then
  echo "plymouth-teardown: default.plymouth is not bgrt (native/other); leaving untouched"
  exit 0
fi
if [[ "$status" != "manual" ]]; then
  echo "plymouth-teardown: bgrt is the automatic default here; leaving native"
  exit 0
fi

# Undo the manual `--set`: return to automatic mode so the distro's default theme
# wins again.
"${SUDO[@]}" update-alternatives --auto default.plymouth
new="$("${SUDO[@]}" update-alternatives --query default.plymouth 2>/dev/null | awk '/^Value:/{print $2; exit}')"

if [[ "$new" == "$BGRT" ]]; then
  # bgrt is also the automatic winner (it is the distro default, or the only
  # registered theme). Nothing else to safely revert to; the value is unchanged,
  # so no initramfs rebuild is needed. Warn in case the LUKS prompt is affected.
  echo "plymouth-teardown: bgrt remains the automatic default after --auto (nothing else to revert to)."
  echo "  If this host still fails to prompt for the LUKS passphrase at boot, pick another"
  echo "  theme manually: sudo update-alternatives --config default.plymouth"
  exit 0
fi

# The selection actually moved off bgrt. Rebuild EVERY kernel's initramfs (not
# just the newest) so fallback kernels the old script may have baked the bgrt
# splash into also get the revert.
if command -v update-initramfs >/dev/null 2>&1; then
  "${SUDO[@]}" update-initramfs -u -k all
fi
echo "plymouth-teardown: reverted default.plymouth ($BGRT -> $new) + rebuilt initramfs"
{{ end -}}
