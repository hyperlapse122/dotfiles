{{ if eq (printf "%s-%s" .chezmoi.os .chezmoi.osRelease.id) "linux-ubuntu" -}}
#!/usr/bin/env bash
# .chezmoiscripts/linux/run_after_ubuntu-plymouth-breeze.sh.tmpl
#
# De-brands the Ubuntu (Studio) boot splash to the upstream Breeze plymouth
# theme. Ubuntu selects the plymouth theme via the `default.plymouth`
# update-alternatives link -- NOT Fedora's plymouthd.conf `Theme=` key
# (install-system-config skips plymouthd.conf on Ubuntu) -- so this script owns
# the Ubuntu side. The Fedora side is baked into the initramfs directly by
# install-system-config.
#
# Config-override only: nothing is purged; we just point the alternative at the
# breeze theme (which ships in plymouth-theme-breeze, pulled by the KDE base)
# and rebuild the initramfs. run_after re-runs every apply, but every step is
# guarded and idempotent, so a host already on breeze is a cheap no-op.

set -euo pipefail
export LC_ALL=C
BREEZE=/usr/share/plymouth/themes/breeze/breeze.plymouth
NAME=/usr/share/plymouth/themes/default.plymouth   # update-alternatives "name" link

command -v update-alternatives >/dev/null 2>&1 || { echo "plymouth-breeze: no update-alternatives; skip"; exit 0; }
command -v update-initramfs   >/dev/null 2>&1 || { echo "plymouth-breeze: no update-initramfs; skip"; exit 0; }
# breeze.plymouth ships in plymouth-theme-breeze (KDE base); skip if absent.
[[ -e "$BREEZE" ]] || { echo "plymouth-breeze: breeze plymouth theme absent; skip"; exit 0; }

# SUDO + non-interactive skip (querying/setting the alternatives db needs root).
if [[ "$EUID" -eq 0 ]]; then SUDO=(); else SUDO=(sudo)
  if [[ ! -t 0 ]] && ! sudo -n true 2>/dev/null; then echo "plymouth-breeze: no sudo; skip"; exit 0; fi
fi

# Idempotency: if default.plymouth already resolves to breeze, do NOTHING
# (crucially, do NOT rebuild the initramfs).
current="$("${SUDO[@]}" update-alternatives --query default.plymouth 2>/dev/null | awk '/^Value:/{print $2}')"
[[ "$current" == "$BREEZE" ]] && { echo "plymouth-breeze: already breeze; no-op"; exit 0; }

# plymouth-theme-breeze's postinst does not always register breeze as a
# default.plymouth candidate, so register-if-absent, then select it.
if ! "${SUDO[@]}" update-alternatives --list default.plymouth 2>/dev/null | grep -qx "$BREEZE"; then
  "${SUDO[@]}" update-alternatives --install "$NAME" default.plymouth "$BREEZE" 100
fi
"${SUDO[@]}" update-alternatives --set default.plymouth "$BREEZE"

# Rebuild the initramfs so the boot splash actually changes.
"${SUDO[@]}" update-initramfs -u
echo "plymouth-breeze: boot splash reverted to upstream breeze (update-alternatives + initramfs rebuild)"
{{ end -}}
