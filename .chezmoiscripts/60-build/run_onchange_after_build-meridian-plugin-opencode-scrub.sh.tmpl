{{ if ne .chezmoi.os "windows" -}}
{{- $release := gitHubLatestRelease "rynfar/meridian-plugin-opencode-scrub" -}}
{{- $tag := $release.TagName | toString -}}
{{- if not (regexMatch "^meridian-plugin-opencode-scrub-v[0-9]+\\.[0-9]+\\.[0-9]+(-[0-9A-Za-z.-]+)?$" $tag) -}}
  {{- fail (printf "meridian-plugin-opencode-scrub: latest GitHub release tag %q is not meridian-plugin-opencode-scrub-v<semver>" $tag) -}}
{{- end -}}
{{- $version := trimPrefix "meridian-plugin-opencode-scrub-v" $tag -}}
{{- $commit := $release.TargetCommitish | toString -}}
{{- if not (regexMatch "^[0-9a-f]{40}$" $commit) -}}
  {{- fail (printf "meridian-plugin-opencode-scrub: release %s target %q is not a 40-character commit sha" $tag $commit) -}}
{{- end -}}
#!/usr/bin/env bash
# .chezmoiscripts/60-build/run_onchange_after_build-meridian-plugin-opencode-scrub.sh.tmpl
#
# Builds @rynfar/meridian-plugin-opencode-scrub from the exact GitHub release
# source archive fetched by .chezmoiexternals/ai-agents.toml, then atomically
# links its compiled entry point into ~/.config/meridian/plugins/. Meridian
# auto-discovers top-level *.js files there, so plugins.json remains live/user-
# owned and does not become a chezmoi target.
#
# The external is source-only: GitHub publishes no binary release asset, while
# the NPM tarball already contains dist/ and omits src/. npm ci honors upstream's
# package-lock.json; lifecycle scripts stay disabled during dependency install,
# and only the explicit build command is allowed to run.
#
# onchange trigger: the rendered release tag + immutable target commit are the
# only inputs outside this script. A new release changes the rendered body and
# re-runs the build; there is deliberately no source-tree fingerprint block.
#
# Failure is hard: the existing plugin link is untouched until install, build,
# and module validation succeed, so chezmoi retries instead of recording a
# missing billing scrubber as done. Reload failure only warns because the built
# artifact will be discovered on the next Meridian start.
#
# POSIX-only and container-kept, matching OpenCode + Meridian.

set -euo pipefail

# release: {{ $tag }} @ {{ $commit }}
TAG={{ $tag | quote }}
VERSION={{ $version | quote }}
COMMIT={{ $commit | quote }}
INSTALL_DIR="${MERIDIAN_OPENCODE_SCRUB_INSTALL_DIR:-$HOME/.local/share/meridian/plugins/opencode-scrub}"
PLUGIN_DIR="${MERIDIAN_OPENCODE_SCRUB_PLUGIN_DIR:-$HOME/.config/meridian/plugins}"
source_dir="$INSTALL_DIR/versions/$VERSION"
dist="$source_dir/dist/index.js"
plugin_link="$PLUGIN_DIR/opencode-scrub.js"

if [ ! -d "$source_dir" ]; then
  printf 'meridian-plugin-opencode-scrub: release source directory missing: %s\n' "$source_dir" >&2
  exit 1
fi
for required in package.json package-lock.json; do
  if [ ! -f "$source_dir/$required" ]; then
    printf 'meridian-plugin-opencode-scrub: release source missing %s: %s\n' "$required" "$source_dir" >&2
    exit 1
  fi
done

if command -v mise >/dev/null 2>&1; then
  MISE=(mise)
elif [ -x "$HOME/.local/bin/mise" ]; then
  MISE=("$HOME/.local/bin/mise")
else
  printf 'meridian-plugin-opencode-scrub: mise not found; cannot build release %s\n' "$TAG" >&2
  exit 1
fi

NPM=("${MISE[@]}" --no-config exec node@latest -- npm)
NODE=("${MISE[@]}" --no-config exec node@latest -- node)
if ! "${NPM[@]}" --version >/dev/null 2>&1; then
  printf 'meridian-plugin-opencode-scrub: npm is unavailable through mise node@latest\n' >&2
  exit 1
fi

"${NODE[@]}" --input-type=module - "$source_dir/package.json" "$VERSION" <<'NODE'
import { readFile } from "node:fs/promises"

const [packagePath, expectedVersion] = process.argv.slice(2)
const pkg = JSON.parse(await readFile(packagePath, "utf8"))
if (pkg.name !== "@rynfar/meridian-plugin-opencode-scrub") {
  throw new Error(`unexpected package name: ${String(pkg.name)}`)
}
if (pkg.version !== expectedVersion) {
  throw new Error(`package version mismatch: expected ${expectedVersion}, got ${String(pkg.version)}`)
}
NODE

rm -rf "$source_dir/dist"
(
  cd "$source_dir"
  "${NPM[@]}" ci --ignore-scripts --no-audit --no-fund
  "${NPM[@]}" --ignore-scripts run build
)

if [ ! -s "$dist" ]; then
  printf 'meridian-plugin-opencode-scrub: build produced no dist/index.js for %s\n' "$TAG" >&2
  exit 1
fi

# Import before promotion and enforce the safety-critical adapter scope.
"${NODE[@]}" --input-type=module - "$dist" <<'NODE'
import { pathToFileURL } from "node:url"

const module = await import(pathToFileURL(process.argv[2]).href)
const plugin = module.default
if (plugin?.name !== "opencode-scrub") {
  throw new Error(`unexpected plugin name: ${String(plugin?.name)}`)
}
if (!Array.isArray(plugin.adapters) || plugin.adapters.length !== 1 || plugin.adapters[0] !== "opencode") {
  throw new Error(`unexpected adapter scope: ${JSON.stringify(plugin?.adapters)}`)
}
if (typeof plugin.onRequest !== "function") {
  throw new Error("plugin has no onRequest transform")
}
NODE

mkdir -p "$PLUGIN_DIR"
if [ -e "$plugin_link" ] && [ ! -L "$plugin_link" ]; then
  printf 'meridian-plugin-opencode-scrub: refusing to replace non-symlink path: %s\n' "$plugin_link" >&2
  exit 1
fi

tmp_link="$PLUGIN_DIR/.opencode-scrub.$$.tmp"
cleanup() {
  rm -f "$tmp_link"
}
trap cleanup EXIT
rm -f "$tmp_link"
ln -s "$dist" "$tmp_link"
"${NODE[@]}" - "$tmp_link" "$plugin_link" <<'NODE'
const fs = require("node:fs")
const [temporary, destination] = process.argv.slice(2)
fs.renameSync(temporary, destination)
NODE
trap - EXIT

if [ -d "$INSTALL_DIR/versions" ]; then
  for directory in "$INSTALL_DIR/versions"/*; do
    [ -d "$directory" ] || continue
    if [ "$directory" != "$source_dir" ]; then
      rm -rf "$directory"
    fi
  done
fi

printf 'meridian-plugin-opencode-scrub: built and linked %s (%s)\n' "$VERSION" "$COMMIT"

# HTTP 200 does not prove an individual plugin loaded; Meridian reports that in
# plugins[]. Validate opencode-scrub's active status before claiming success.
reload_url="${MERIDIAN_OPENCODE_SCRUB_RELOAD_URL-http://127.0.0.1:3456/plugins/reload}"
reload_response="$INSTALL_DIR/.opencode-scrub-reload.$$.json"
reload_state=unavailable
cleanup_reload() {
  rm -f "$reload_response"
}
trap cleanup_reload EXIT
if [ -n "$reload_url" ] && command -v curl >/dev/null 2>&1 \
  && curl -fsS --max-time 5 -X POST "$reload_url" -o "$reload_response" 2>/dev/null; then
  reload_state=inactive
  if "${NODE[@]}" --input-type=module - "$reload_response" <<'NODE'
import { readFile } from "node:fs/promises"

let payload
try {
  payload = JSON.parse(await readFile(process.argv[2], "utf8"))
} catch (error) {
  console.error(`meridian-plugin-opencode-scrub: invalid reload response: ${String(error)}`)
  process.exit(1)
}
const plugin = Array.isArray(payload.plugins)
  ? payload.plugins.find((candidate) => candidate?.name === "opencode-scrub")
  : undefined
if (payload.success !== true || plugin?.status !== "active") {
  const detail = plugin
    ? `${String(plugin.status)}${plugin.error ? `: ${String(plugin.error)}` : ""}`
    : "not listed"
  console.error(`meridian-plugin-opencode-scrub: reload left opencode-scrub ${detail}`)
  process.exit(1)
}
NODE
  then
    reload_state=active
  fi
fi
cleanup_reload
trap - EXIT

case "$reload_state" in
  active)
    printf 'meridian-plugin-opencode-scrub: reloaded Meridian plugins (opencode-scrub active)\n'
    ;;
  inactive)
    printf 'meridian-plugin-opencode-scrub: Meridian reloaded but opencode-scrub is inactive; inspect the diagnostic above or the /plugins UI\n' >&2
    ;;
  *)
    printf 'meridian-plugin-opencode-scrub: Meridian reload unavailable; the plugin will load on the next service restart\n' >&2
    ;;
esac
{{ end -}}
