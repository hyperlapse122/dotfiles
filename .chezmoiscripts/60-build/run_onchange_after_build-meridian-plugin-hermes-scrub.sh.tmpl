{{ if ne .chezmoi.os "windows" -}}
{{- $commit := output "sh" "-c" "git ls-remote https://github.com/rynfar/meridian-plugin-hermes-scrub.git refs/heads/main 2>/dev/null || true" | regexFind "^[0-9a-f]{40}" -}}
{{- if not (regexMatch "^[0-9a-f]{40}$" $commit) -}}
  {{- fail "meridian-plugin-hermes-scrub: could not resolve refs/heads/main to a 40-character commit sha" -}}
{{- end -}}
#!/usr/bin/env bash
# .chezmoiscripts/60-build/run_onchange_after_build-meridian-plugin-hermes-scrub.sh.tmpl
#
# Builds @rynfar/meridian-plugin-hermes-scrub from the exact main-branch commit
# archive fetched by .chezmoiexternals/ai-agents.toml, then atomically links its
# compiled entry point into ~/.config/meridian/plugins/. Meridian auto-discovers
# top-level *.js files there, so plugins.json remains live/user-owned.
#
# Upstream currently publishes no GitHub release or tag. The template therefore
# resolves refs/heads/main to an immutable commit for both the external URL and
# this run_onchange trigger. A new main commit changes the rendered script and
# re-runs the build. This is rolling/unsettled by design until upstream starts a
# release train; there is deliberately no source-tree fingerprint block.
#
# npm ci honors upstream's package-lock.json with lifecycle scripts disabled;
# only the explicit build command runs. Failure is hard and the existing live
# link remains untouched until install, build, and module validation succeed.
#
# Hermes traffic has no stable adapter identity, so this plugin is intentionally
# content-scoped across ALL adapters. Validation rejects any adapters restriction.
# POSIX-only and container-kept, matching Hermes + Meridian CLI use.

set -euo pipefail

# main ref: {{ $commit }}
COMMIT={{ $commit | quote }}
INSTALL_DIR="${MERIDIAN_HERMES_SCRUB_INSTALL_DIR:-$HOME/.local/share/meridian/plugins/hermes-scrub}"
PLUGIN_DIR="${MERIDIAN_HERMES_SCRUB_PLUGIN_DIR:-$HOME/.config/meridian/plugins}"
source_dir="$INSTALL_DIR/versions/$COMMIT"
dist="$source_dir/dist/index.js"
plugin_link="$PLUGIN_DIR/hermes-scrub.js"

if [ ! -d "$source_dir" ]; then
  printf 'meridian-plugin-hermes-scrub: source directory missing for main@%s: %s\n' "$COMMIT" "$source_dir" >&2
  exit 1
fi
for required in package.json package-lock.json; do
  if [ ! -f "$source_dir/$required" ]; then
    printf 'meridian-plugin-hermes-scrub: source missing %s: %s\n' "$required" "$source_dir" >&2
    exit 1
  fi
done

if command -v mise >/dev/null 2>&1; then
  MISE=(mise)
elif [ -x "$HOME/.local/bin/mise" ]; then
  MISE=("$HOME/.local/bin/mise")
else
  printf 'meridian-plugin-hermes-scrub: mise not found; cannot build main@%s\n' "$COMMIT" >&2
  exit 1
fi

NPM=("${MISE[@]}" --no-config exec node@latest -- npm)
NODE=("${MISE[@]}" --no-config exec node@latest -- node)
if ! "${NPM[@]}" --version >/dev/null 2>&1; then
  printf 'meridian-plugin-hermes-scrub: npm is unavailable through mise node@latest\n' >&2
  exit 1
fi

# Validate package identity and capture its own semver for diagnostics. The
# commit, not this mutable package version, owns the source directory/trigger.
VERSION=$("${NODE[@]}" --input-type=module - "$source_dir/package.json" <<'NODE'
import { readFile } from "node:fs/promises"

const pkg = JSON.parse(await readFile(process.argv[2], "utf8"))
if (pkg.name !== "@rynfar/meridian-plugin-hermes-scrub") {
  throw new Error(`unexpected package name: ${String(pkg.name)}`)
}
if (typeof pkg.version !== "string" || !/^[0-9]+\.[0-9]+\.[0-9]+(?:-[0-9A-Za-z.-]+)?$/.test(pkg.version)) {
  throw new Error(`invalid package version: ${String(pkg.version)}`)
}
process.stdout.write(pkg.version)
NODE
)

rm -rf "$source_dir/dist"
(
  cd "$source_dir"
  "${NPM[@]}" ci --ignore-scripts --no-audit --no-fund
  "${NPM[@]}" --ignore-scripts run build
)

if [ ! -s "$dist" ]; then
  printf 'meridian-plugin-hermes-scrub: build produced no dist/index.js for main@%s\n' "$COMMIT" >&2
  exit 1
fi

# Import before promotion. No adapters property is load-bearing: Hermes sends no
# distinguishing header and can arrive through any fallback adapter.
"${NODE[@]}" --input-type=module - "$dist" <<'NODE'
import { pathToFileURL } from "node:url"

const module = await import(pathToFileURL(process.argv[2]).href)
const plugin = module.default
if (plugin?.name !== "hermes-scrub") {
  throw new Error(`unexpected plugin name: ${String(plugin?.name)}`)
}
if (plugin.adapters !== undefined) {
  throw new Error(`unexpected adapter restriction: ${JSON.stringify(plugin.adapters)}`)
}
if (typeof plugin.onRequest !== "function") {
  throw new Error("plugin has no onRequest transform")
}
NODE

mkdir -p "$PLUGIN_DIR"
if [ -e "$plugin_link" ] && [ ! -L "$plugin_link" ]; then
  printf 'meridian-plugin-hermes-scrub: refusing to replace non-symlink path: %s\n' "$plugin_link" >&2
  exit 1
fi

tmp_link="$PLUGIN_DIR/.hermes-scrub.$$.tmp"
cleanup() {
  rm -f "$tmp_link"
}
trap cleanup EXIT
rm -f "$tmp_link"
ln -s "$dist" "$tmp_link"
"${NODE[@]}" - "$tmp_link" "$plugin_link" <<'NODE'
const fs = require("node:fs")
const [temporary, destination] = process.argv.slice(2)
fs.renameSync(temporary, destination)
NODE
trap - EXIT

if [ -d "$INSTALL_DIR/versions" ]; then
  for directory in "$INSTALL_DIR/versions"/*; do
    [ -d "$directory" ] || continue
    if [ "$directory" != "$source_dir" ]; then
      rm -rf "$directory"
    fi
  done
fi

printf 'meridian-plugin-hermes-scrub: built and linked %s (main@%s)\n' "$VERSION" "$COMMIT"

# HTTP 200 does not prove an individual plugin loaded; validate hermes-scrub's
# active status from Meridian's plugins[] reload response.
reload_url="${MERIDIAN_HERMES_SCRUB_RELOAD_URL-http://127.0.0.1:3456/plugins/reload}"
reload_response="$INSTALL_DIR/.hermes-scrub-reload.$$.json"
reload_state=unavailable
cleanup_reload() {
  rm -f "$reload_response"
}
trap cleanup_reload EXIT
if [ -n "$reload_url" ] && command -v curl >/dev/null 2>&1 \
  && curl -fsS --max-time 5 -X POST "$reload_url" -o "$reload_response" 2>/dev/null; then
  reload_state=inactive
  if "${NODE[@]}" --input-type=module - "$reload_response" <<'NODE'
import { readFile } from "node:fs/promises"

let payload
try {
  payload = JSON.parse(await readFile(process.argv[2], "utf8"))
} catch (error) {
  console.error(`meridian-plugin-hermes-scrub: invalid reload response: ${String(error)}`)
  process.exit(1)
}
const plugin = Array.isArray(payload.plugins)
  ? payload.plugins.find((candidate) => candidate?.name === "hermes-scrub")
  : undefined
if (payload.success !== true || plugin?.status !== "active") {
  const detail = plugin
    ? `${String(plugin.status)}${plugin.error ? `: ${String(plugin.error)}` : ""}`
    : "not listed"
  console.error(`meridian-plugin-hermes-scrub: reload left hermes-scrub ${detail}`)
  process.exit(1)
}
NODE
  then
    reload_state=active
  fi
fi
cleanup_reload
trap - EXIT

case "$reload_state" in
  active)
    printf 'meridian-plugin-hermes-scrub: reloaded Meridian plugins (hermes-scrub active)\n'
    ;;
  inactive)
    printf 'meridian-plugin-hermes-scrub: Meridian reloaded but hermes-scrub is inactive; inspect the diagnostic above or the /plugins UI\n' >&2
    ;;
  *)
    printf 'meridian-plugin-hermes-scrub: Meridian reload unavailable; the plugin will load on the next service restart\n' >&2
    ;;
esac
{{ end -}}
