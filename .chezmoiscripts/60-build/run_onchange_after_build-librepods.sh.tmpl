{{ if eq .chezmoi.os "linux" -}}
{{ $sha := output "git" "ls-remote" "https://github.com/librepods-org/librepods.git" "refs/heads/linux/rust" | regexFind "^[0-9a-f]{40}" -}}
#!/usr/bin/env bash
# .chezmoiscripts/60-build/run_onchange_after_build-librepods.sh.tmpl
#
# Builds LibrePods (AirPods control for Linux) from upstream source and
# `cargo install`s it into ~/.local/bin, installs its launcher assets, then
# enables the systemd --user unit that autostarts it into the tray. Structured
# exactly like the sibling build-mxm4-haptic script (same cargo resolution, same
# user-bus probe, same soft-skip discipline) — the only real difference is WHERE
# the source comes from.
#
# Why build from source instead of installing a release:
#   The Linux app is a Rust rewrite that lives ONLY on the upstream `linux/rust`
#   branch, in the `linux-rust/` subdirectory — it is NOT on `main` (which still
#   carries the legacy Qt app). Upstream's README calls that branch's CI build
#   the "Nightly (recommended)", and a nightly is nothing but a GitHub Actions
#   ARTIFACT: it needs an authenticated API call to download and it EXPIRES after
#   90 days. An artifact URL is therefore not a durable install source, so we
#   compile the branch head ourselves.
#
# Linux-only (the template gates on .chezmoi.os == "linux"; there is deliberately
# no darwin branch, unlike build-mxm4-haptic): the app talks BlueZ over D-Bus and
# drives a StatusNotifierItem tray (ksni), both Linux desktop concepts.
#
# onchange trigger: THERE IS NO fingerprint.tmpl BLOCK HERE — deliberately, and
# not an oversight. That partial hashes files in the chezmoi SOURCE dir, and
# this script has none: the entire input is a remote git branch. What we hash
# instead is upstream itself. The `output` template function runs
# `git ls-remote` at render time and the resolved branch-head sha is rendered
# into the "nightly ref" comment below, so a new upstream commit changes this
# script's rendered content and chezmoi re-runs the build. That comment IS the
# trigger; it is never executed. (Rolling ref = unsettled by design: a bad
# upstream commit reaches this host on the next apply. Same trade-off the
# release-tracking dotagents skills make.)
#
# Empty-sha guard: `git ls-remote` needs the network. When it fails (offline,
# DNS, upstream down) `regexFind` yields an EMPTY string and $SHA below is "" —
# we soft-skip rather than clone/checkout garbage, and the next apply with a
# working network re-renders a real sha (a changed script body), which re-runs
# the build.
#
# Build dependencies: pkg-config + libdbus-1 + libpulse headers, declared in
# .chezmoidata/packages.yaml (ubuntu: libdbus-1-dev/libpulse-dev; fedora:
# dbus-devel/pulseaudio-libs-devel) and installed by the distro provisioners in
# the BEFORE phase, so a normal apply has them by the time this runs. A missing
# one is not probed for here — it surfaces as a cargo build failure, which
# soft-skips like every other failure path.
#
# Toolchain: prefers mise-managed `rust@latest` (chezmoi runs scripts under a
# non-interactive shell with no mise shell-activation, so we invoke it
# explicitly), falls back to a system `cargo`, and soft-skips the build when
# neither is present. `--root "$HOME/.local"` installs alongside the rest of
# ~/.local/bin (already on PATH); `--locked` honors the Cargo.lock upstream
# tracks; `--force` makes re-runs idempotent (cargo rebuilds only on a source
# change).
#
# Exits 0 on every failure path (no sha, no git, clone/fetch failure, no
# toolchain, build failure, no user bus) so a non-interactive `chezmoi apply`
# never aborts on it.

set -euo pipefail

# nightly ref: linux/rust @ {{ $sha }}
#
# ^^ Rendered by `git ls-remote` at source-state read time (see the header).
# This line is the onchange trigger and is ALSO the sha we check out below.
SHA="{{ $sha }}"
REPO="https://github.com/librepods-org/librepods.git"
# The checkout is throwaway build input, not a project — it belongs in the cache
# dir, NOT under ~/src (which is the aoe/garden-managed project layout) and not
# in the chezmoi source dir (it would be an untracked tree inside the repo).
SRC_DIR="${XDG_CACHE_HOME:-$HOME/.cache}/librepods-src"

if [ -z "$SHA" ]; then
  echo "librepods: could not resolve the linux/rust branch head (offline? ls-remote failed); skipping build" >&2
  exit 0
fi

if ! command -v git >/dev/null 2>&1; then
  echo "librepods: git not found; skipping build" >&2
  exit 0
fi

# Clone once, then advance in place on every later run. --filter=blob:none keeps
# the clone lean (blobs are fetched on demand) and --no-tags skips the tag
# refs we never resolve against.
if [ ! -d "$SRC_DIR/.git" ]; then
  if ! git clone --filter=blob:none --no-tags "$REPO" "$SRC_DIR"; then
    echo "librepods: git clone failed; skipping build" >&2
    exit 0
  fi
fi

# Fetch the exact sha the template resolved, so the build is reproducible for a
# given rendered script even if the branch moves between render and run. GitHub
# allows fetching a reachable commit directly; if a server (or a proxy/mirror)
# refuses that, fall back to fetching the branch ref and taking its head — one
# apply may then build a commit newer than the one in the trigger comment, which
# is harmless (the next render just picks that sha up).
if ! git -C "$SRC_DIR" fetch --depth 1 origin "$SHA" 2>/dev/null; then
  echo "librepods: by-sha fetch refused; falling back to fetching refs/heads/linux/rust" >&2
  if ! git -C "$SRC_DIR" fetch --depth 1 origin "refs/heads/linux/rust"; then
    echo "librepods: git fetch failed (offline?); skipping build" >&2
    exit 0
  fi
fi

# Detached HEAD: this tree is build input, never a working checkout — nobody
# commits here, so there is no branch to keep.
if ! git -C "$SRC_DIR" checkout --detach FETCH_HEAD 2>/dev/null; then
  echo "librepods: checkout of the fetched commit failed; skipping build" >&2
  exit 0
fi

# Resolve a cargo invocation as an array — identical to build-mxm4-haptic:
# mise-managed rust@latest is the supported primary, a system cargo is the
# fallback, an empty array means no toolchain (soft-skip, but still continue to
# the service section so an already-installed binary keeps its unit wiring).
if command -v mise >/dev/null 2>&1; then
  CARGO=(mise exec rust@latest -- cargo)
elif command -v cargo >/dev/null 2>&1; then
  CARGO=(cargo)
else
  CARGO=()
fi

if [ "${#CARGO[@]}" -eq 0 ]; then
  echo "librepods: no cargo toolchain (mise or system); skipping build, continuing to service setup" >&2
else
  # The crate lives in the linux-rust/ subdirectory (package name: librepods),
  # so --path points there, not at the repo root. A build failure here is the
  # usual symptom of a missing pkg-config/libdbus-1/libpulse header (see the
  # header) — we report and continue rather than abort the apply.
  if "${CARGO[@]}" install --root "$HOME/.local" --locked --force --path "$SRC_DIR/linux-rust"; then
    echo "librepods: built + installed librepods into ~/.local/bin"

    # Launcher assets. chezmoi cannot manage these — they are upstream files
    # that only exist after the clone above — so we install them by hand into
    # the XDG user dirs. The .desktop entry carries Exec=librepods and
    # Icon=me.kavishdevar.librepods, so the icon has to land under that name in
    # the hicolor theme for the tray/launcher to resolve it. `install -D`
    # creates the parent dirs; both are plain data, hence 0644.
    if [ -f "$SRC_DIR/linux-rust/assets/me.kavishdevar.librepods.desktop" ]; then
      install -D -m 644 \
        "$SRC_DIR/linux-rust/assets/me.kavishdevar.librepods.desktop" \
        "$HOME/.local/share/applications/me.kavishdevar.librepods.desktop" \
        || echo "librepods: failed to install the .desktop entry; continuing" >&2
    fi
    if [ -f "$SRC_DIR/linux-rust/assets/icon.png" ]; then
      install -D -m 644 \
        "$SRC_DIR/linux-rust/assets/icon.png" \
        "$HOME/.local/share/icons/hicolor/256x256/apps/me.kavishdevar.librepods.png" \
        || echo "librepods: failed to install the icon; continuing" >&2
      # Refresh the hicolor cache so the new icon is picked up without a
      # relogin. Optional tooling (absent on a minimal install) and a stale
      # cache is cosmetic, so a missing binary or a failed run is a soft-skip.
      if command -v gtk-update-icon-cache >/dev/null 2>&1; then
        gtk-update-icon-cache -q -t -f "$HOME/.local/share/icons/hicolor" 2>/dev/null || true
      fi
    fi
  else
    echo "librepods: cargo install failed (missing libdbus-1/libpulse/pkg-config headers?); continuing to service setup" >&2
  fi
fi

# systemd --user. Same shape as build-mxm4-haptic: `daemon-reload` doubles as the
# user-bus reachability probe (it fails with no session bus —
# agent/CI/chroot/SSH-without-linger), in which case we soft-skip (exit 0) with a
# hint. daemon-reload also makes systemd notice the unit file the file phase just
# applied (dot_config/systemd/user/librepods.service).
if systemctl --user daemon-reload >/dev/null 2>&1; then
  # NO --now: plain `enable` only wires the WantedBy symlink, so systemd starts
  # librepods.service when graphical-session.target comes up — matching the
  # unit's [Install]. Starting a tray GUI here would be wrong anyway: this script
  # can run long before (or entirely without) a graphical session.
  systemctl --user enable librepods.service >/dev/null 2>&1 || true
  echo "librepods: service enabled (librepods.service)"

  # Restart only if it is ALREADY running, so a rebuilt binary is picked up
  # immediately on a live session — without spuriously starting the tray app
  # outside one (a fresh install starts it at the next login instead).
  if systemctl --user is-active --quiet librepods.service 2>/dev/null; then
    systemctl --user restart librepods.service 2>/dev/null || true
    echo "librepods: restarted librepods.service (picked up rebuilt binary)"
  fi
else
  echo "librepods: skipping enable (no user session bus); enable manually once logged in: systemctl --user enable librepods.service" >&2
fi

exit 0
{{ end -}}
