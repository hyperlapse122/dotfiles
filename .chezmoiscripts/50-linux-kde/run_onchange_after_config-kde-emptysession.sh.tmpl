{{ if eq .chezmoi.os "linux" -}}
#!/usr/bin/env bash
# .chezmoiscripts/kde/run_onchange_after_config-kde-emptysession.sh.tmpl
#
# Always start with an empty desktop session (never restore the previous one):
#   [General] loginMode = emptySession
#
# Applies on next login (ksmserver reads this at session start).

set -euo pipefail

{{ includeTemplate "kde-guard.sh.tmpl" (dict "ctx" . "name" "config-kde-emptysession.sh") -}}

configure_emptysession() {
  printf 'config-kde-emptysession.sh: forcing empty session on login...\n'

  if ! command -v kwriteconfig6 >/dev/null 2>&1; then
    printf '  kwriteconfig6 not found, skipping.\n'
    return 0
  fi

  kwriteconfig6 --file ksmserverrc --group General \
    --key loginMode emptySession
  printf '  set [General] loginMode = emptySession\n'
}

configure_emptysession
{{ end -}}
