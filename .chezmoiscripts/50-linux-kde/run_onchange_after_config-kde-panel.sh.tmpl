{{ if eq .chezmoi.os "linux" -}}
#!/usr/bin/env bash
# .chezmoiscripts/kde/run_onchange_after_config-kde-panel.sh.tmpl
#
# Sets the task manager grouping strategy on every panel-level
# org.kde.plasma.icontasks / org.kde.plasma.taskmanager applet:
#   groupingStrategy = kde.panel.groupingStrategy
# (TasksModel::GroupDisabled = 0, "Do not group" — the shipped value.)
#
# The strategy is DATA, not script: .chezmoidata/kde.yaml `kde.panel` is the
# single source of truth (see its header) — edit the yaml, not this file. The
# applet-discovery loop and the two plugin ids it matches on are structure and
# stay.
#
# CAVEAT: ~/.config/plasma-org.kde.plasma.desktop-appletsrc is owned by a
# running plasmashell. Edits are safest before plasmashell first starts or
# after restarting it; otherwise the live process may overwrite the change.
# The write is idempotent so re-running is safe.
#
# onchange, no fingerprint block needed: the rendered GROUPING_STRATEGY below is
# part of this script's content, so a kde.yaml edit re-triggers it (the same
# reason config-gnome-mouse carries none).
#
# Applies after restarting plasmashell or logging out/in.

set -euo pipefail

{{ includeTemplate "kde-guard.sh.tmpl" (dict "ctx" . "name" "config-kde-panel.sh") -}}

GROUPING_STRATEGY={{ .kde.panel.groupingStrategy }}

configure_panel() {
  printf 'config-kde-panel.sh: setting task manager groupingStrategy=%s...\n' \
    "$GROUPING_STRATEGY"

  if ! command -v kwriteconfig6 >/dev/null 2>&1 || ! command -v kreadconfig6 >/dev/null 2>&1; then
    printf '  kwriteconfig6/kreadconfig6 not found, skipping.\n'
    return 0
  fi

  local file="$HOME/.config/plasma-org.kde.plasma.desktop-appletsrc"
  if [[ ! -f "$file" ]]; then
    printf '  %s not found (no Plasma session has ever started?), skipping.\n' "$file"
    return 0
  fi

  local count=0
  local containment applet plugin
  while IFS=':' read -r containment applet; do
    plugin="$(kreadconfig6 --file "$file" \
      --group Containments --group "$containment" \
      --group Applets --group "$applet" \
      --key plugin)"
    case "$plugin" in
      org.kde.plasma.icontasks|org.kde.plasma.taskmanager) ;;
      *) continue ;;
    esac
    kwriteconfig6 --file "$file" \
      --group Containments --group "$containment" \
      --group Applets --group "$applet" \
      --group Configuration --group General \
      --key groupingStrategy "$GROUPING_STRATEGY"
    printf '  set [Containments/%s/Applets/%s] (%s) groupingStrategy = %s\n' \
      "$containment" "$applet" "$plugin" "$GROUPING_STRATEGY"
    count=$((count + 1))
  done < <(grep -oE '^\[Containments\]\[[0-9]+\]\[Applets\]\[[0-9]+\]$' "$file" \
            | sed -E 's/^\[Containments\]\[([0-9]+)\]\[Applets\]\[([0-9]+)\]$/\1:\2/')

  if [[ "$count" -eq 0 ]]; then
    printf '  no icontasks/taskmanager applet found in panel config, skipping.\n'
    return 0
  fi

  printf '  configured %d task manager applet(s).\n' "$count"
}

configure_panel
{{ end -}}
