{{ if ne .chezmoi.os "windows" -}}

{{- $ctx := . -}}
{{- $cePlugin := "" -}}
{{- range .agents.opencode.plugins -}}
{{-   if and (eq .install "localArchive") (eq .versionSource "compoundEngineeringRelease") -}}
{{-     $cePlugin = . -}}
{{-   end -}}
{{- end -}}
{{- if $cePlugin -}}
{{- $ceRef := includeTemplate "compound-engineering-ref.tmpl" $ctx -}}
{{- $ceVersion := printf "v%s" (trimPrefix "compound-engineering-v" $ceRef) -}}

#!/usr/bin/env bash
# .chezmoiscripts/00-tools/run_onchange_after_compound-engineering.sh.tmpl
#
# Prunes older extracted versions under ~/<externalPath>/, keeping only the
# release currently pinned by .chezmoidata/agents.yaml (agents.opencode.plugins
# entry with install=localArchive + versionSource=compoundEngineeringRelease).
# Chezmoi's exact=true only cleans within ONE target path, so sibling version
# directories under the same parent accumulate without this — same shape as the
# claude/codex/pi/codegraph linker scripts in this directory.
#
# There is no ~/.local/bin symlink to repoint here: every agent (OpenCode,
# Claude Code, Codex, pi) references the FULLY-RENDERED versioned path in its
# own config, so a version bump propagates through chezmoi's own file phase
# (opencode.json re-render) and the sibling generic
# .chezmoiscripts/70-agents/run_onchange_after_install-agent-plugins
# script (Claude/Codex marketplace re-registration at the new path; pi via its
# own git: source).
#
# onchange trigger: the rendered $CE_VERSION below IS the trigger — a new
# upstream compound-engineering-* release changes this script's content and
# re-runs the prune after the file phase has extracted the new version.

set -euo pipefail

BASE_DIR="$HOME/{{ $cePlugin.externalPath }}"
CURRENT="$BASE_DIR/{{ $ceVersion }}"

# The file phase must have extracted the current version already; if not, do
# nothing rather than nuking the whole tree. Same defensive skip as the
# install-agent-plugins sibling.
[ -d "$CURRENT" ] || exit 0

for d in "$BASE_DIR"/*; do
  [ -d "$d" ] || continue
  [ "$d" = "$CURRENT" ] && continue
  rm -rf -- "$d" || true
done

{{ end -}}
{{ end -}}
