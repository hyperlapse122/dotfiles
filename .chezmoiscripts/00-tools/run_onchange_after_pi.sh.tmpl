{{ if ne .chezmoi.os "windows" -}}

{{- $tag := (gitHubLatestRelease "earendil-works/pi").TagName | toString -}}

#!/usr/bin/env bash
# .chezmoiscripts/00-tools/run_onchange_after_pi.sh.tmpl
#
# Links pi to ~/.local/bin and prunes older versions.
# pi ships a whole DIRECTORY distribution, not a lone binary: the executable
# resolves its own sibling package.json / theme/ / export-html/ / node_modules/
# / photon_rs_bg.wasm at runtime (a detached copy reports version 0.0.0), so
# .chezmoiexternals/ai-agents.toml extracts the tree per version and this script
# symlinks ~/.local/bin/pi at the in-tree executable — a symlink resolves fine.
#
# onchange trigger: the latest release tag is rendered into the script body
# below, so a new upstream release changes the rendered content and re-runs
# the re-link + prune.

set -euo pipefail

INSTALL_DIR="${PI_INSTALL_DIR:-$HOME/.local/share/pi}"
BIN_DIR="${PI_BIN_DIR:-$HOME/.local/bin}"

dest="$INSTALL_DIR/versions/{{ $tag }}"
ln -sf "$dest/pi" "$BIN_DIR/pi"
ln -sfn "$dest" "$INSTALL_DIR/current"

# Prune older versions ("current" lives in $INSTALL_DIR, not inside versions/,
# so it is out of this loop by construction).
pruned=0
if [ -d "$INSTALL_DIR/versions" ]; then
  for d in "$INSTALL_DIR/versions"/*; do
    [ -d "$d" ] || continue
    if [ "$d" != "$dest" ]; then
      if rm -rf "$d"; then
        pruned=$((pruned + 1))
      fi
    fi
  done
fi
# if [ "$pruned" -gt 0 ]; then
