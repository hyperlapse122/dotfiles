{{ if ne .chezmoi.os "windows" -}}

{{- $claudeCodeBaseUrl := "https://downloads.claude.ai/claude-code-releases" -}}
{{- $latestReleaseId := output "curl" "-fsSL" (printf "%s/latest" $claudeCodeBaseUrl) | toString -}}

#!/usr/bin/env bash
# .chezmoiscripts/00-tools/run_onchange_after_claude.sh.tmpl
#
# Links latest claude to ~/.local/bin and prunes older versions.
#
# onchange trigger: the latest release id is rendered into the script body
# below, so a new upstream release changes the rendered content and re-runs
# the re-link + prune. (The former run_after_onchange_* name was parsed by
# chezmoi as a plain run_after_ — every apply — because the attribute order
# is run_[once_|onchange_][before_|after_].)

set -euo pipefail

INSTALL_DIR="${CLAUDE_INSTALL_DIR:-$HOME/.local/share/claude}"
BIN_DIR="${CLAUDE_BIN_DIR:-$HOME/.local/bin}"

dest="$INSTALL_DIR/versions/{{ $latestReleaseId }}"
ln -sf "$dest" "$BIN_DIR/claude"

# Prune older versions
pruned=0
if [ -d "$INSTALL_DIR/versions" ]; then
  for d in "$INSTALL_DIR/versions"/*; do
    [ -f "$d" ] || continue
    if [ "$d" != "$dest" ]; then
      if rm -rf "$d"; then
        pruned=$((pruned + 1))
      fi
    fi
  done
fi
# if [ "$pruned" -gt 0 ]; then
#   echo "Removed    $pruned older version(s)"
# fi

{{ end -}}