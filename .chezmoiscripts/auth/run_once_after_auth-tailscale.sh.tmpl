{{ if ne .chezmoi.os "windows" -}}
#!/usr/bin/env bash

set -euo pipefail

{{ if eq .chezmoi.os "darwin" -}}
SUDO=()
{{ else if eq .chezmoi.os "linux" -}}
if [[ "${EUID}" -eq 0 ]]; then
  SUDO=()
elif command -v sudo >/dev/null 2>&1; then
  SUDO=(sudo)
else
  printf 'auth-tailscale.sh: requires root or sudo to run tailscale up.\n' >&2
  exit 1
fi
{{ end -}}

{{ if eq .chezmoi.os "linux" -}}
"${SUDO[@]}" systemctl enable --now tailscaled.service
{{ end -}}

"${SUDO[@]}" tailscale up --operator "$USER" --accept-routes --accept-dns --accept-risk=all --auth-key={{- onepasswordRead "op://Private/Tailscale/Auth Key" | quote -}} || echo "Auth Failed"

{{ end -}}