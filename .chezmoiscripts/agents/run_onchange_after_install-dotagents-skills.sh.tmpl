{{ if or (eq .chezmoi.os "linux") (eq .chezmoi.os "darwin") -}}
{{ $sourceDir := .chezmoi.sourceDir -}}
#!/usr/bin/env bash
# .chezmoiscripts/agents/run_onchange_after_install-dotagents-skills.sh.tmpl
#
# run_onchange_after_: chezmoi hashes this rendered script and re-runs it only
# when the hash changes. The agents.toml fingerprint below embeds the sha256 of
# the deployed agents config source, so `dotagents --user install` re-runs
# whenever that config changes (an agent added, a skill/MCP declaration edited,
# a trust-allowlist tweak, or a remote-skill @ref bumped by the weekly
# update-agent-skills workflow) rather than on every apply. Note the tradeoff
# vs the former run_after_: a plain re-apply no longer re-runs install, so
# newer remote-skill releases (settled by minimum_release_age) are pulled only
# when agents.toml changes or the weekly workflow bumps a ref.
# Soft-skip: this script must never fail apply; missing tools, offline fetches,
# trust rejection, or install errors all exit 0 after a diagnostic message.
# Container-kept: intentionally not excluded from containers; it soft-skips when
# mise/node/git are absent instead of bootstrapping anything.

# agents.toml content fingerprint — chezmoi hashes this rendered script to
# decide whether to re-run it, so embedding the sha256 of the deployed agents
# config template here forces a re-run whenever it changes. `include` hashes the
# raw source bytes (never renders it), so no `op` secret resolution is triggered.
# Comment-only; never executed.
{{ range (glob (joinPath $sourceDir "dot_agents/private_readonly_agents.toml.tmpl")) -}}
{{ if not (stat .).isDir -}}
#   {{ . | trimPrefix $sourceDir | trimPrefix "/" }} {{ include . | sha256sum }}
{{ end -}}
{{ end }}
set -euo pipefail

skip() { exit 0; }

if ! command -v mise >/dev/null 2>&1; then
  echo "install-dotagents-skills: skipped (mise not installed)" >&2
  skip
fi

if ! command -v git >/dev/null 2>&1; then
  echo "install-dotagents-skills: skipped (git not installed)" >&2
  skip
fi

# First-apply fix: `dotagents --user install` iterates agents.toml's
# `agents = ["claude", "codex"]` and drops a `skills` symlink into each agent's
# config dir (~/.claude/skills, ~/.codex/skills) via ensureSkillsSymlink, which
# does NOT create the parent. On a fresh machine ~/.codex is provided by the
# codex external, but nothing creates ~/.claude until Claude Code is first run —
# so the symlink fails with ENOENT and the whole install exits non-zero, which
# the soft-skip below then swallows, leaving skills/MCPs unconfigured on the very
# first apply. Pre-create the agent config dirs so the initial apply provisions
# fully; mkdir -p is idempotent and harmless if the dirs already exist.
mkdir -p "$HOME/.claude" "$HOME/.codex" || true

set +e
install_output="$(mise --no-env --no-hooks exec -y npm:@sentry/dotagents@latest node -- dotagents --user install 2>&1)"
install_rc=$?
set -e
if [[ $install_rc -ne 0 ]]; then
  reason="${install_output//$'\n'/; }"
  echo "install-dotagents-skills: skipped (install failed: ${reason})" >&2
  skip
fi
{{ end -}}
