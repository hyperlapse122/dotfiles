{{ if eq (printf "%s-%s" .chezmoi.os .chezmoi.osRelease.id) "linux-ubuntu" -}}
#!/usr/bin/env bash
# .chezmoiscripts/linux-kde/run_onchange_after_config-kde-autotheme.sh.tmpl
#
# Ubuntu Studio only. Moves the desktop OFF Ubuntu Studio's custom Global Theme
# and onto Plasma's default Breeze theme, with automatic day/night switching
# (Plasma 6.5+):
#   [KDE] LookAndFeelPackage       = org.kde.breezedark.desktop  (initial theme)
#   [KDE] DefaultLightLookAndFeel  = org.kde.breeze.desktop       (daytime theme)
#   [KDE] DefaultDarkLookAndFeel   = org.kde.breezedark.desktop   (night theme)
#   [KDE] AutomaticLookAndFeel     = true
#
# This is the Ubuntu counterpart to config-kde-darkmode (which is Fedora-only):
# Fedora pins Breeze Dark, Ubuntu Studio auto-switches Breeze Dark <-> Light.
#
# Priority-1 behaviour is automatic Breeze Dark + Breeze Light switching, timed
# off the Night Light schedule. On Plasma < 6.5 the auto-switch keys are unknown
# and silently ignored, so the LookAndFeelPackage pin alone leaves the desktop on
# Breeze Dark -- the priority-2 fallback -- without any extra handling here.
#
# Applies after re-login.

set -euo pipefail

if ! command -v plasmashell >/dev/null 2>&1; then
  printf 'config-kde-autotheme.sh: plasmashell not found (non-KDE system), skipping.\n'
  exit 0
fi

configure_autotheme() {
  printf 'config-kde-autotheme.sh: switching to Breeze with automatic day/night global theme...\n'

  if ! command -v kwriteconfig6 >/dev/null 2>&1; then
    printf '  kwriteconfig6 not found, skipping.\n'
    return 0
  fi

  kwriteconfig6 --file kdeglobals --group KDE \
    --key LookAndFeelPackage org.kde.breezedark.desktop
  printf '  set [KDE] LookAndFeelPackage      = org.kde.breezedark.desktop\n'

  kwriteconfig6 --file kdeglobals --group KDE \
    --key DefaultLightLookAndFeel org.kde.breeze.desktop
  printf '  set [KDE] DefaultLightLookAndFeel = org.kde.breeze.desktop\n'

  kwriteconfig6 --file kdeglobals --group KDE \
    --key DefaultDarkLookAndFeel org.kde.breezedark.desktop
  printf '  set [KDE] DefaultDarkLookAndFeel  = org.kde.breezedark.desktop\n'

  kwriteconfig6 --file kdeglobals --group KDE \
    --key AutomaticLookAndFeel --type bool true
  printf '  set [KDE] AutomaticLookAndFeel    = true\n'
}

configure_autotheme
{{ end -}}
