{{ if ne .chezmoi.os "windows" -}}
#!/usr/bin/env bash
# Provisions the age identity that decrypts `encrypted_` source files (the
# ~/src garden project registry). MUST stay `run_once_before_`: chezmoi
# decrypts encrypted targets during the file phase, so the identity has to
# exist before it. The identity is a 1Password document ("chezmoi age key" in
# the Private vault); the recipient (public half) lives in .chezmoi.toml.tmpl.
# run_once_ state is content-hashed, so rotating the key in 1Password changes
# the rendered script and re-runs the import.

set -euo pipefail

mkdir -p "$HOME/.config/chezmoi"
umask 077
cat > "$HOME/.config/chezmoi/key.txt" <<'AGE_IDENTITY_EOF'
{{ onepasswordDocument "a47ivjj34cnn3zfl5577l6bsh4" }}
AGE_IDENTITY_EOF
{{ end -}}
