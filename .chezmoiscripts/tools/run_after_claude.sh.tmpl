{{ if ne .chezmoi.os "windows" -}}

{{- $claudeCodeBaseUrl := "https://downloads.claude.ai/claude-code-releases" -}}
{{- $latestReleaseId := output "curl" "-fsSL" (printf "%s/latest" $claudeCodeBaseUrl) | toString -}}

#!/usr/bin/env bash
# Links latest claude to ~/.local/bin

set -euo pipefail

INSTALL_DIR="${CLAUDE_INSTALL_DIR:-$HOME/.local/share/claude}"
BIN_DIR="${CLAUDE_BIN_DIR:-$HOME/.local/bin}"

dest="$INSTALL_DIR/versions/{{ $latestReleaseId }}"
ln -sf "$dest" "$BIN_DIR/claude"

# Prune older versions
pruned=0
if [ -d "$INSTALL_DIR/versions" ]; then
  for d in "$INSTALL_DIR/versions"/*; do
    [ -f "$d" ] || continue
    if [ "$d" != "$dest" ]; then
      if rm -rf "$d"; then
        pruned=$((pruned + 1))
      fi
    fi
  done
fi
# if [ "$pruned" -gt 0 ]; then
#   echo "Removed    $pruned older version(s)"
# fi

{{ end -}}