{{ if eq .chezmoi.os "linux" -}}
#!/usr/bin/env bash
# .chezmoiscripts/50-linux-gnome/run_onchange_after_config-gnome-1password-shortcut.sh.tmpl
#
# GNOME hosts (Fedora Workstation, Ubuntu Desktop 26.04). Brings the 1Password
# Quick Access global shortcut to PARITY with the KDE target, which gets it
# declaratively from the desktop action in
# ~/.local/share/applications/1password.desktop:
#
#   [Desktop Action QuickAccess]
#   Exec=/usr/bin/1password --quick-access %U
#   X-KDE-Shortcuts=Ctrl+Shift+Space
#
# GNOME ignores X-KDE-Shortcuts entirely, so the same chord has to be registered
# as a GNOME custom keybinding instead:
#
#   org.gnome.settings-daemon.plugins.media-keys custom-keybindings += <path>
#     <path> name    = gnome.shortcuts.onePassword.name
#     <path> command = gnome.shortcuts.onePassword.command
#     <path> binding = gnome.shortcuts.onePassword.binding
#
# The triple is DATA, not script: .chezmoidata/gnome.yaml
# `gnome.shortcuts.onePassword` is the single source of truth (see its header) —
# edit the yaml, not this file. The dconf PATH below stays here: it is the
# keybinding's IDENTITY, not a setting value.
#
# The keybinding lives at a DEDICATED, descriptive dconf path
# (.../custom-keybindings/1password-quickaccess/) instead of a customN slot, so
# it can never clobber a customN shortcut the user (or gnome-control-center's UI)
# allocated, and it is self-identifying/idempotent — gnome-settings-daemon
# activates it and the Settings UI displays it regardless of the path segment
# name. The command drops the %U desktop-entry field code (only meaningful to a
# .desktop launcher; a raw gsettings command is g_spawn'd directly).
#
# GNOME normally stays on stock defaults here; mirroring this one KDE-defined
# shortcut is a deliberate, user-requested exception, scoped to a single custom
# keybinding — no other shell/keyboard changes.
#
# onchange, no fingerprint block needed: the shortcut triple RENDERS INTO
# NAME/COMMAND/BINDING below, so a gnome.yaml edit changes this script's own
# content and re-triggers it (the same reason config-gnome-mouse carries no
# fingerprint — a data hash would only add re-runs on comment-only yaml edits).
# Editing BINDING or COMMAND also changes the $SIG the stamp records, so such an
# edit re-asserts the new value (parity with a change to the KDE X-KDE-Shortcuts
# line); while $SIG is unchanged the stamp makes this a no-op, so a shortcut the
# user later re-binds or deletes in Settings is NOT fought.
#
# SESSION-DEPENDENT + user-respecting (same spirit as config-gnome-inputmethod /
# config-gnome-fonts): gsettings writes go through dconf-service on the session
# D-Bus, so on a headless / TTY / first-boot apply this exits 0 WITHOUT stamping.
# NOTE the onchange trade-off: that skipped run is recorded as done and will NOT
# re-run on the next apply just because a live GNOME session appeared — the
# shortcut lands on the next content change (an edit here) or a manual
# `chezmoi apply --force`.

set -euo pipefail

NAME="{{ .gnome.shortcuts.onePassword.name }}"
COMMAND="{{ .gnome.shortcuts.onePassword.command }}"
BINDING="{{ .gnome.shortcuts.onePassword.binding }}"

# Dedicated, collision-safe dconf path for our keybinding (not a customN slot).
KEYPATH="/org/gnome/settings-daemon/plugins/media-keys/custom-keybindings/1password-quickaccess/"
SCHEMA="org.gnome.settings-daemon.plugins.media-keys.custom-keybinding:${KEYPATH}"

STAMP="${XDG_STATE_HOME:-$HOME/.local/state}/chezmoi/gnome-1password-shortcut"

# Signature of the exact shortcut this script wants applied. Bumping BINDING or
# COMMAND changes it, so the stamp no longer matches and the shortcut is
# re-asserted; while it matches, a shortcut the user later changed is left be.
SIG="binding=${BINDING} command=${COMMAND}"

{{ includeTemplate "gnome-guard.sh.tmpl" (dict "ctx" . "name" "config-gnome-1password-shortcut") -}}

# Already applied this exact signature once -> respect the user's current binding.
if [[ -f "$STAMP" ]] && [[ "$(cat "$STAMP" 2>/dev/null || true)" == "$SIG" ]]; then
  echo "config-gnome-1password-shortcut: shortcut already ensured ($SIG); leaving current binding alone"
  exit 0
fi

# --- Live session / tooling guards (any absent condition => safe exit 0) ---
if [[ -z "${DBUS_SESSION_BUS_ADDRESS:-}" && ! -S "${XDG_RUNTIME_DIR:-/nonexistent}/bus" ]]; then
  echo "config-gnome-1password-shortcut: no D-Bus session bus; skip (retries next apply)"
  exit 0
fi
command -v gsettings >/dev/null 2>&1 \
  || { echo "config-gnome-1password-shortcut: gsettings absent; skip"; exit 0; }
# /usr/bin/python3, NOT bare python3 (mise may shadow it): GVariant text for an
# `as` array is valid Python literal syntax, so the merge below parses with
# ast.literal_eval instead of hand-rolled string munging.
[[ -x /usr/bin/python3 ]] \
  || { echo "config-gnome-1password-shortcut: /usr/bin/python3 absent; skip"; exit 0; }
# Binding a chord to a missing binary would leave a dead shortcut, so wait for
# the package (installed in this same apply) instead — mirrors
# config-gnome-inputmethod waiting on ibus-hangul. The binary is the first word
# of $COMMAND (1Password ships /usr/bin/1password via the `1password` system
# package); deriving it keeps the path out of this script as a second literal.
COMMAND_BIN="${COMMAND%% *}"
if [[ ! -x "$COMMAND_BIN" ]]; then
  echo "config-gnome-1password-shortcut: $COMMAND_BIN not installed; skip (retries next apply)"
  exit 0
fi

if ! current="$(gsettings get org.gnome.settings-daemon.plugins.media-keys custom-keybindings 2>/dev/null)"; then
  echo "config-gnome-1password-shortcut: cannot read custom-keybindings; skip"
  exit 0
fi

# Merge $KEYPATH into the existing `as` list. Output protocol: PRESENT (already
# listed), PARSE_ERROR (unexpected GVariant text — leave the list untouched), or
# the new list in GVariant text form (Python's repr of a list of str is valid
# GVariant `as` text).
merged="$(/usr/bin/python3 - "$current" "$KEYPATH" <<'PYEOF'
import ast
import sys

raw = sys.argv[1].strip()
path = sys.argv[2]
# An empty typed array prints as "@as []"; strip the type annotation so
# ast.literal_eval handles both the empty and populated forms.
if raw.startswith("@as"):
    raw = raw[len("@as"):].strip()
try:
    paths = list(ast.literal_eval(raw))
except (SyntaxError, ValueError):
    print("PARSE_ERROR")
    sys.exit(0)

if path in paths:
    print("PRESENT")
else:
    paths.append(path)
    print(repr(paths))
PYEOF
)"

if [[ "$merged" == "PARSE_ERROR" ]]; then
  echo "config-gnome-1password-shortcut: unexpected custom-keybindings format (${current}); leaving untouched" >&2
  exit 0
fi

# Define the keybinding at its dedicated path (re-asserts name/command/binding
# even when the path is already listed, so a SIG bump takes effect).
gsettings set "$SCHEMA" name    "$NAME"
gsettings set "$SCHEMA" command "$COMMAND"
gsettings set "$SCHEMA" binding "$BINDING"

# Register the path in the custom-keybindings list only if it is not already there.
if [[ "$merged" == "PRESENT" ]]; then
  echo "config-gnome-1password-shortcut: $KEYPATH already in custom-keybindings"
else
  gsettings set org.gnome.settings-daemon.plugins.media-keys custom-keybindings "$merged"
  echo "config-gnome-1password-shortcut: registered $KEYPATH -> $merged"
fi

echo "config-gnome-1password-shortcut: $BINDING -> $COMMAND"

# Stamp only after the desired state is confirmed reached, so any skip path above
# retries on a later apply.
mkdir -p "$(dirname "$STAMP")"
printf '%s' "$SIG" > "$STAMP"
exit 0
{{ end -}}
