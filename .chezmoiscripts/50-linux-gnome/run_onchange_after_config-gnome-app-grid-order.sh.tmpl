{{ if eq .chezmoi.os "linux" -}}
#!/usr/bin/env bash
# .chezmoiscripts/50-linux-gnome/run_onchange_after_config-gnome-app-grid-order.sh.tmpl
#
# GNOME hosts (Fedora Workstation, Ubuntu Desktop 26.04). Sorts the Application
# launcher (app grid / "Show Applications") icons alphabetically by clearing the
# custom layout:
#
#   org.gnome.shell app-picker-layout = []   (empty -> GNOME auto-sorts by name)
#
# GNOME Shell stores the user's hand-arranged app-grid pages/positions in
# app-picker-layout; while it is non-empty the grid keeps that manual order.
# When it is EMPTY, GNOME lays the grid out itself and sorts entries by their
# display name using LOCALE collation (g_utf8_collate) — under a Korean locale
# that collation IS 가나다순, so clearing the key gives an alphabetical (가나다)
# app grid with no Korean-specific handling needed; under any other locale it
# is that locale's A→Z order. Only the launcher order is touched; nothing else
# about the grid, folders, or favorites is changed.
#
# The INTENT is DATA, not script: .chezmoidata/gnome.yaml
# `gnome.appGrid.sortAlphabetically` is the single source of truth (see its
# header) — set it to false there to leave the launcher on the host's own order,
# and this script no-ops. It is an intent flag rather than a value because there
# is no "sort" key in GNOME to write: an EMPTY app-picker-layout is what makes
# the shell sort the grid itself, so the action is a `reset`, and that semantic
# (plus the once-only stamp below) is exactly why this stays a script.
#
# GNOME normally stays on stock defaults here; this is a deliberate,
# user-approved exception to that policy (alongside fonts, the GDM
# password-only greeter, the mouse accel profile, the terminal palette, the
# input source, and the 1Password shortcut).
#
# ONE-SHOT + user-respecting (same pattern as config-gnome-inputmethod): the
# grid order is a per-user setting, so this clears the layout exactly once
# (tracked by a per-user stamp) and never again — if the user later drags icons
# into a custom arrangement (which re-populates app-picker-layout), we do NOT
# keep wiping it back to alphabetical on every apply.
#
# onchange, no fingerprint block needed: the intent flag RENDERS INTO
# SORT_ALPHABETICALLY below, so a gnome.yaml edit changes this script's own
# content and re-triggers it (the same reason config-gnome-mouse carries no
# fingerprint — a data hash would only add re-runs on comment-only yaml edits).
# Live-session
# only: gsettings writes go through dconf-service on the session D-Bus, so on a
# headless/TTY/first-boot apply this exits 0 WITHOUT stamping. NOTE the onchange
# behavior: that skipped run is recorded as done and will NOT re-run on the next
# apply just because a live GNOME session appeared — the layout is cleared on
# the next content change or a manual `chezmoi apply --force`. Once the stamp
# exists the script is a no-op regardless.

set -euo pipefail

SORT_ALPHABETICALLY={{ .gnome.appGrid.sortAlphabetically | ternary 1 0 }}

STAMP="${XDG_STATE_HOME:-$HOME/.local/state}/chezmoi/gnome-app-grid-order-alphabetical"

{{ includeTemplate "gnome-guard.sh.tmpl" (dict "ctx" . "name" "config-gnome-app-grid-order") -}}

# Opted out in .chezmoidata/gnome.yaml -> leave the launcher order alone entirely
# (no stamp either: flipping the flag back to true must still be able to apply).
if [[ "$SORT_ALPHABETICALLY" -ne 1 ]]; then
  echo "config-gnome-app-grid-order: gnome.appGrid.sortAlphabetically is false; leaving app-picker-layout alone"
  exit 0
fi

# Already ensured once -> respect the user's current grid arrangement, do nothing.
if [[ -f "$STAMP" ]]; then
  echo "config-gnome-app-grid-order: already applied once ($STAMP); leaving app-picker-layout alone"
  exit 0
fi

# --- Live session / tooling guards (any absent condition => safe exit 0) ---
if [[ -z "${DBUS_SESSION_BUS_ADDRESS:-}" && ! -S "${XDG_RUNTIME_DIR:-/nonexistent}/bus" ]]; then
  echo "config-gnome-app-grid-order: no D-Bus session bus; skip (retries next apply)"
  exit 0
fi
command -v gsettings >/dev/null 2>&1 \
  || { echo "config-gnome-app-grid-order: gsettings absent; skip"; exit 0; }
# The key lives in the org.gnome.shell schema (shipped with GNOME Shell); guard
# on its presence so a stripped host without the schema/key skips cleanly
# instead of erroring on the write.
if ! gsettings list-keys org.gnome.shell 2>/dev/null | grep -qx 'app-picker-layout'; then
  echo "config-gnome-app-grid-order: org.gnome.shell app-picker-layout absent; skip"
  exit 0
fi

# Clear the custom layout -> GNOME re-sorts the grid alphabetically (locale
# collation). reset restores the schema default (an empty array), which is
# exactly the alphabetical trigger.
gsettings reset org.gnome.shell app-picker-layout
echo "config-gnome-app-grid-order: cleared org.gnome.shell app-picker-layout -> app grid sorted alphabetically (가나다순 under a Korean locale)"

# Stamp only after the desired state is confirmed reached, so any skip path
# above retries on a later apply.
mkdir -p "$(dirname "$STAMP")"
touch "$STAMP"
exit 0
{{ end -}}
