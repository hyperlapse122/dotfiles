{{ if eq .chezmoi.os "linux" -}}
#!/usr/bin/env bash
# .chezmoiscripts/50-linux-gnome/run_onchange_after_config-gnome-mouse.sh.tmpl
#
# GNOME hosts (Fedora Workstation, Ubuntu Desktop 26.04). Sets the pointer
# acceleration profile:
#
#   org.gnome.desktop.peripherals.mouse accel-profile = '<profile>'
#
# The profile is DATA, not script: .chezmoidata/gnome.yaml
# `gnome.mouse.accelProfile` is the single source of truth (see its header for
# the value reference) — edit the yaml, not this file. The value renders into
# this script's body, so a data edit re-triggers this run_onchange_ script
# automatically.
#
# WHY flat (the shipped value): the MX Master mice used here are high-DPI;
# libinput's default adaptive profile layers a speed-dependent software
# acceleration curve on top, which makes pointer travel unpredictable and hard
# to build muscle memory against. The flat profile is a constant 1:1 mapping
# (sensitivity comes from the mouse's own DPI, no curve surprises) — the
# common recommendation for high-DPI mice. ONLY accel-profile is touched:
# speed and every other pointer key stay on GNOME defaults.
#
# GNOME normally stays on stock defaults here; this is a deliberate,
# user-approved THIRD exception to that policy (after fonts and the GDM
# password-only greeter).
#
# VALUE-SIGNATURE stamp + user-respecting (same pattern as
# config-gnome-fonts): the per-user stamp records the exact profile value this
# script last applied. While the stamp matches, the script is a no-op — a user
# who later switches the profile in Settings is never fought on subsequent
# applies. Changing gnome.yaml changes the signature, so the new value is
# re-asserted exactly once. (Stamps written by the former one-shot version of
# this script are empty, which never matches a signature — such hosts
# re-assert the data value once when this version first runs.)
#
# onchange, no external fingerprint block needed: the rendered profile value
# IS part of this script's content, so a gnome.yaml edit re-triggers it. Live-
# session only: gsettings writes go through dconf-service on the session
# D-Bus, so on a headless/TTY/first-boot apply this exits 0 WITHOUT stamping;
# note that onchange records that skipped run as done and will NOT re-run on
# the next apply just because a live GNOME session appeared — the profile
# lands on the next content change or a manual `chezmoi apply --force`. Once
# the stamp matches the signature the script is a no-op regardless.

set -euo pipefail

ACCEL_PROFILE="{{ .gnome.mouse.accelProfile }}"
STAMP="${XDG_STATE_HOME:-$HOME/.local/state}/chezmoi/gnome-mouse-accel-profile"

# Signature of the exact profile this script wants applied. While the stamp
# holds it, the user's later manual Settings changes are left be; a gnome.yaml
# edit changes it, so the new value is re-asserted exactly once.
SIG="accel-profile=${ACCEL_PROFILE}"

{{ includeTemplate "gnome-guard.sh.tmpl" (dict "ctx" . "name" "config-gnome-mouse") -}}

# Already applied this exact profile once -> respect the user's current one.
if [[ -f "$STAMP" ]] && [[ "$(cat "$STAMP" 2>/dev/null || true)" == "$SIG" ]]; then
  echo "config-gnome-mouse: already ensured ($SIG); leaving accel-profile alone"
  exit 0
fi

# --- Live session / tooling guards (any absent condition => safe exit 0) ---
if [[ -z "${DBUS_SESSION_BUS_ADDRESS:-}" && ! -S "${XDG_RUNTIME_DIR:-/nonexistent}/bus" ]]; then
  echo "config-gnome-mouse: no D-Bus session bus; skip"
  exit 0
fi
command -v gsettings >/dev/null 2>&1 \
  || { echo "config-gnome-mouse: gsettings absent; skip"; exit 0; }

gsettings set org.gnome.desktop.peripherals.mouse accel-profile "'${ACCEL_PROFILE}'"
echo "config-gnome-mouse: org.gnome.desktop.peripherals.mouse accel-profile = '${ACCEL_PROFILE}'"

# Stamp only after the desired state is confirmed reached, so any skip path
# above retries on a later apply.
mkdir -p "$(dirname "$STAMP")"
printf '%s' "$SIG" > "$STAMP"
exit 0
{{ end -}}
