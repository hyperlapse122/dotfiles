{{ if eq .chezmoi.os "linux" -}}
{{ $sourceDir := .chezmoi.sourceDir -}}
#!/usr/bin/env bash
# .chezmoiscripts/30-linux/run_onchange_after_install-system-10-files.sh.tmpl
#
# Installs root-owned config from system/linux/etc/**/* into /etc/* using
# `sudo install -D -m <mode>`, removes orphaned /etc paths this repo used to
# ship, and reloads exactly what it installed (systemd units, udev rules,
# sysctl drop-ins, Ubuntu locale generation, the gdm dconf db). chezmoi
# manages $HOME and cannot own root-owned /etc targets, so this ships as a
# script rather than managed files.
#
# MANIFEST-DRIVEN: per-path install modes, host gates, source checks, and the
# removed-path list all live in .chezmoidata/system.yaml (single source of
# truth, like packages.yaml) — edit the data, not this script. The manifest
# is rendered into the bash arrays below, so a manifest edit re-triggers this
# run_onchange_ script automatically.
#
# FACT-DRIVEN GATES: a manifest `gate:` names a host fact from the registry
# (.chezmoidata/facts.yaml), and gate_ok() is a pure lookup into the FACT_*
# variables — this script probes the host for NOTHING any more. That is what
# retired the `sudo dmidecode -t system` grep (the thinkpad fact reads the same
# two DMI fields from world-readable /sys/class/dmi/id/, no elevation) and the
# `dpkg -s ubuntustudio-default-settings` test (which exits 0 for a
# removed-but-not-purged package; the fact stats the dpkg .md5sums marker).
# Every gate name is validated against the registry at render time below, so an
# unknown one aborts the whole chezmoi command instead of silently resolving
# false.
#
# This is part 1/3 of the split install-system set (10-files → 20-host →
# 30-network, ordered by filename). Splitting keeps re-run scope tight: a
# tracked /etc file edit re-runs THIS script only — it no longer restarts
# NetworkManager/tailscaled (30-network) or re-masks services (20-host) the
# way the old monolithic install-system-config did.
#
# onchange trigger: the fingerprint block below embeds a sha256 of every
# tracked system/linux/etc file (the rendered manifest covers itself), so
# chezmoi re-runs this script whenever any of them is added, removed, or
# modified. Re-running is cheap and idempotent regardless.
#
# Skip behaviour: soft-skips (exit 0) on headless/server installs and when
# sudo would have to prompt but can't — see the shared guards inlined below
# (.chezmoitemplates/headless-guard.sh.tmpl, sudo-skip-guard.sh.tmpl).

set -euo pipefail

{{ includeTemplate "headless-guard.sh.tmpl" (dict "ctx" . "name" "install-system-files") }}
# The FACT_* variables gate_ok() reads below are assigned by the headless guard
# just above: it inlines .chezmoitemplates/facts-sh.tmpl (the guard needs the
# headless fact itself, and every script that guards on it therefore gets the
# whole set). Do NOT add a second `includeTemplate "facts-sh.tmpl"` here — the
# assignment block would render twice.

# system/linux/etc content fingerprint — chezmoi hashes this rendered script
# to decide whether to re-run it, so embedding every tracked file's sha256
# here forces a re-run on any add/remove/edit. Comment-only; never executed.
{{- includeTemplate "fingerprint.tmpl" (dict "sourceDir" $sourceDir "globs" (list "system/linux/etc/**")) }}
SRC_ROOT="{{ $sourceDir }}/system/linux"

{{ includeTemplate "sudo-skip-guard.sh.tmpl" "install-system-files" }}
# Detect distro at runtime for the distro-scoped branches below.
os_id="$(. /etc/os-release 2>/dev/null && printf '%s' "${ID:-}")" || os_id=""

# Discover files at runtime so adding system/linux/etc/... config does not
# require editing this script; a non-default mode or a host gate is a
# .chezmoidata/system.yaml overrides entry.
shopt -s globstar nullglob

# --- Manifest (rendered from .chezmoidata/system.yaml) ----------------------
# Parallel arrays: a file's path relative to system/linux/ is glob-matched
# against override_patterns (first match wins); unmatched files install at
# mode 0644, ungated.
override_patterns=()
override_modes=()
override_gates=()
override_checks=()
{{ range .system.linux.overrides -}}
override_patterns+=({{ .path | quote }})
override_modes+=({{ get . "mode" | default "644" | quote }})
override_gates+=({{ get . "gate" | default "" | quote }})
override_checks+=({{ get . "check" | default "" | quote }})
{{ end }}
{{- /* The unknown-gate abort — at RENDER time now, not at runtime. Every `gate:`
   in the manifest names a fact, and facts-validate.tmpl fails the whole chezmoi
   command on a name the registry does not declare (listing the valid ones), on a
   registry name with no probe behind it, and on a form that does not match the
   fact's type. Its contract is CALLER PASSES THE NAMES, so collect them from the
   same manifest the arrays above render from. It emits nothing on success, which
   is why it can sit in the middle of a bash script. */ -}}
{{- $gates := list -}}
{{- range .system.linux.overrides -}}
{{-   $gate := get . "gate" | default "" -}}
{{-   if ne $gate "" -}}
{{-     $gates = append $gates $gate -}}
{{-   end -}}
{{- end -}}
{{- includeTemplate "facts-validate.tmpl" (dict "ctx" . "source" ".chezmoidata/system.yaml (gate:)" "gates" $gates) -}}
# Fail loud on a manifest typo before touching anything. Gate names are checked
# at render time (facts-validate.tmpl, above); `check:` is not a fact, so its
# small closed set stays a runtime case.
for check in "${override_checks[@]}"; do
  case "$check" in
    ''|visudo) ;;
    *) printf 'install-system-files: unknown check "%s" in .chezmoidata/system.yaml; aborting.\n' "$check" >&2; exit 1 ;;
  esac
done

# Gate resolution — a pure LOOKUP into the FACT_* variables, not a probe. Every
# `gate:` in the manifest is a fact name (.chezmoidata/facts.yaml), the values
# were resolved once for this chezmoi command, and facts-validate.tmpl proved at
# render time that each name is declared. Nothing in this function may touch the
# host: put a new condition in the registry, never here.
gate_ok() {
  case "$1" in
    '') return 0 ;;
    thinkpad) [[ "$FACT_THINKPAD" == 1 ]] ;;
    # VMs only. Deliberately NOT the registry's `virt` fact, which is true for a
    # container as well: this gate grants password-less sudo (etc/sudoers.d/*),
    # and NOPASSWD must not follow a $HOME-bind-mounting distrobox. Never swap
    # the two facts here.
    vm) [[ "$FACT_VM" == 1 ]] ;;
    # No FORCE_UBUNTU_STUDIO here, and none in facts-sh.tmpl either — the
    # override is installer-only. Honouring it would install the realtime-limits
    # drop-in (@audio rtprio 95, memlock unlimited) on a plain Ubuntu Desktop.
    ubuntuStudio) [[ "$FACT_UBUNTU_STUDIO" == 1 ]] ;;
    sddmBreeze) [[ "$FACT_SDDM_BREEZE" == 1 ]] ;;
    gdm) [[ "$FACT_GDM" == 1 ]] ;;
    # The polkit-1 stack this gates @includes common-auth, so it only fits a
    # Debian-style PAM tree — Fedora's rpm-owned polkit-1 includes system-auth.
    # The fact carries BOTH halves (pam_fprintd.so present AND common-auth
    # present); a module-presence test alone would overwrite Fedora's file with a
    # stack referencing a file it does not have, breaking every polkit prompt.
    fprintdPam) [[ "$FACT_FPRINTD_PAM" == 1 ]] ;;
    # Unreachable — facts-validate.tmpl aborts the render on an unknown gate. Kept
    # because an unmatched bash `case` returns 0, i.e. it would silently GRANT the
    # install: the one direction no gate here may ever fail in.
    *) printf 'install-system-files: unknown gate "%s" reached gate_ok; aborting.\n' "$1" >&2; exit 1 ;;
  esac
}
gate_reason() {
  case "$1" in
    thinkpad) printf 'not a ThinkPad system' ;;
    vm) printf 'not a VM' ;;
    ubuntuStudio) printf 'ubuntu-studio-only (realtime audio limits)' ;;
    sddmBreeze) printf 'breeze sddm theme absent' ;;
    gdm) printf 'gdm not installed' ;;
    fprintdPam) printf 'no pam_fprintd module or non-Debian PAM stack' ;;
    *) printf 'gate %s failed' "$1" ;;
  esac
}

# --- Install system/linux/etc/** into /etc/** -------------------------------
count=0
skipped=0
# Set below when a file under etc/bluetooth/ is actually about to change on this
# host; consumed by the bluetoothd restart in the reload section. See the long
# comment there for why this is change-gated instead of dir-gated like the rest.
bluetooth_changed=false
for src in "$SRC_ROOT"/etc/**; do
  [[ -f "$src" ]] || continue

  rel="${src#"$SRC_ROOT"/}"
  dst="/$rel"

  mode=644
  gate=
  check=
  for i in "${!override_patterns[@]}"; do
    # shellcheck disable=SC2254 # manifest entries are deliberate glob patterns
    case "$rel" in
      ${override_patterns[$i]})
        mode="${override_modes[$i]}"
        gate="${override_gates[$i]}"
        check="${override_checks[$i]}"
        break
        ;;
    esac
  done

  # Source checks run on EVERY host, even when the gate skips the install,
  # so contributors catch broken files on machines that never deploy them
  # (a broken sudoers drop-in can break sudo globally on the host).
  if [[ "$check" == visudo ]]; then
    if ! visudo -c -f "$src" >/dev/null; then
      printf '  !! %s: visudo syntax check failed; aborting\n' "$dst" >&2
      exit 1
    fi
  fi

  if ! gate_ok "$gate"; then
    printf '  -- %s (skipped: %s)\n' "$dst" "$(gate_reason "$gate")"
    skipped=$((skipped + 1))
    continue
  fi

  # Note whether THIS install actually changes a /etc/bluetooth/ file, so the
  # reload section can restart bluetoothd only when it has to. `cmp -s` against
  # the deployed copy is the whole test: a missing $dst is "changed" (cmp exits
  # non-zero), an identical $dst is not. Checked before the install, since after
  # it the two files are identical by construction.
  if [[ "$rel" == etc/bluetooth/* ]] && ! cmp -s "$src" "$dst"; then
    bluetooth_changed=true
  fi

  printf '  -> %s (mode %s)\n' "$dst" "$mode"
  "${SUDO[@]}" install -D -m "$mode" "$src" "$dst"
  count=$((count + 1))
done

printf 'install-system-files: %d installed, %d skipped\n' "$count" "$skipped"

# Same fact as the thinkpad `gate:` above, so the module is force-loaded exactly
# on the hosts that just received its modprobe.d/modules-load.d config.
if [[ "$FACT_THINKPAD" == 1 ]]; then
  printf '  -> modprobe thinkpad_acpi\n'
  "${SUDO[@]}" modprobe thinkpad_acpi
else
  printf '  -- thinkpad_acpi: skipped (not a ThinkPad system)\n'
fi

# On Ubuntu, the LANG/LC_* values in /etc/locale.conf (installed above, and read
# by systemd-localed on every distro) only take effect once the referenced locale
# is compiled: Fedora ships ko_KR.UTF-8 precompiled via glibc-langpack-ko, but
# Ubuntu generates locales on demand from the `locales` package. Drive locale-gen
# and update-locale straight from the installed /etc/locale.conf so this stays in
# lockstep with that single source of truth, plus the extra_locales baseline
# below — generated but never selected as a LANG/LC_* default.
if [[ "$os_id" == ubuntu && -f /etc/locale.conf ]] \
  && command -v locale-gen >/dev/null 2>&1 \
  && command -v update-locale >/dev/null 2>&1; then
  locale_vars=()
  while IFS='=' read -r locale_key locale_value; do
    [[ "$locale_key" =~ ^[A-Z][A-Z_]*$ ]] || continue
    locale_value="${locale_value%\"}"
    locale_value="${locale_value#\"}"
    [[ -n "$locale_value" ]] || continue
    locale_vars+=("${locale_key}=${locale_value}")
  done < /etc/locale.conf

  # Extra locales to GENERATE beyond the locale.conf selection (never handed to
  # update-locale, so LANG/LC_* stay whatever locale.conf picks): en_US.UTF-8 is
  # the baseline many tools assume exists. Fedora needs no counterpart —
  # glibc-langpack-en is effectively always installed there.
  extra_locales=(en_US.UTF-8)

  if [[ ${#locale_vars[@]} -gt 0 ]]; then
    mapfile -t locale_values < <(
      {
        printf '%s\n' "${locale_vars[@]}" | cut -d= -f2
        printf '%s\n' "${extra_locales[@]}"
      } | sort -u
    )
    printf '  -> locale-gen %s\n' "${locale_values[*]}"
    "${SUDO[@]}" locale-gen "${locale_values[@]}"
    printf '  -> update-locale %s\n' "${locale_vars[*]}"
    "${SUDO[@]}" update-locale "${locale_vars[@]}"
  fi
fi

# --- Remove orphaned /etc paths (rendered from system.yaml `removed`) -------
REMOVED_ETC_PATHS=()
REMOVED_ETC_DISTROS=()
{{ range .system.linux.removed -}}
REMOVED_ETC_PATHS+=({{ .path | quote }})
REMOVED_ETC_DISTROS+=({{ get . "distro" | default "" | quote }})
{{ end }}
removed_eligible=0
removed_cleaned=0
for i in "${!REMOVED_ETC_PATHS[@]}"; do
  dst="${REMOVED_ETC_PATHS[$i]}"
  distro="${REMOVED_ETC_DISTROS[$i]}"
  # A distro-scoped entry was only ever deployed on that distro: never delete
  # a native or user-created file at the same path elsewhere.
  [[ -z "$distro" || "$distro" == "$os_id" ]] || continue
  removed_eligible=$((removed_eligible + 1))
  if [[ -e "$dst" || -L "$dst" ]]; then
    printf '  -> removing %s (listed in system.yaml removed)\n' "$dst"
    "${SUDO[@]}" rm -f "$dst"
    removed_cleaned=$((removed_cleaned + 1))
  fi
done
if [[ "$removed_eligible" -eq 0 ]]; then
  printf '  -- removed paths: none listed (nothing to clean)\n'
elif [[ "$removed_cleaned" -eq 0 ]]; then
  printf '  -- removed paths: %d entries, all already absent\n' "$removed_eligible"
else
  printf '  -- removed paths: cleaned %d of %d listed path(s)\n' "$removed_cleaned" "$removed_eligible"
fi

# --- Reload what was installed above ----------------------------------------
# Reload systemd when system/linux/etc/systemd/system/ ships any unit files so
# systemd notices the newly-installed units. Harmless no-op when the directory
# exists but ships no units.
if [[ -d "$SRC_ROOT/etc/systemd/system" ]]; then
  "${SUDO[@]}" systemctl daemon-reload
fi

# Reload udev rules so freshly-installed rules under /etc/udev/rules.d/ take
# effect without a reboot. `udevadm control --reload` re-reads the rules
# database; it does not retrigger events for existing devices (`udevadm
# trigger` would, and is intentionally omitted to avoid disrupting connected
# hardware on every run).
if [[ -d "$SRC_ROOT/etc/udev/rules.d" ]]; then
  printf '  -> udevadm control --reload\n'
  "${SUDO[@]}" udevadm control --reload
fi

# Apply sysctl settings so freshly-installed drop-ins under /etc/sysctl.d/
# (e.g. 99-tailscale.conf) take effect without a reboot. `sysctl --system`
# re-reads /etc/sysctl.conf and every conf.d/ drop-in in the documented load
# order (see sysctl.d(5)), which is the same path systemd-sysctl.service runs
# at boot — so runtime state matches what a reboot would produce.
if [[ -d "$SRC_ROOT/etc/sysctl.d" ]]; then
  printf '  -> sysctl --system\n'
  "${SUDO[@]}" sysctl --system >/dev/null
fi

# Compile /etc/dconf/db/gdm.d into the binary db the GDM greeter reads
# (system-db:gdm in the /etc/dconf/profile/gdm override installed above).
# `dconf update` only rewrites databases whose source dir changed, so this is
# a cheap no-op on re-runs. Re-check the gdm gate: on KDE hosts the gdm.d
# files were skipped above, so there is nothing to compile.
if [[ -d "$SRC_ROOT/etc/dconf/db/gdm.d" ]] && gate_ok gdm \
  && command -v dconf >/dev/null 2>&1; then
  printf '  -> dconf update\n'
  "${SUDO[@]}" dconf update
fi

# Restart bluetoothd so a changed /etc/bluetooth/main.conf takes effect — it is
# read ONCE at startup and has no reload path (no SIGHUP handler, no drop-in
# dir), so an edited DeviceID/ControllerMode is otherwise inert until reboot.
#
# CHANGE-gated, deliberately NOT dir-gated like every reload above. The others
# (`daemon-reload`, `udevadm control --reload`, `sysctl --system`) are cheap and
# side-effect-free, so gating them on "does this source dir exist" is fine even
# though that fires them on EVERY run of this script — i.e. whenever ANY tracked
# /etc file changes. A bluetoothd restart is not cheap: it drops every live
# Bluetooth connection (mouse, keyboard, headphones) mid-session. So it fires
# only when the install loop above saw an etc/bluetooth/ file genuinely differ
# from what was already deployed.
#
# AirPods must be RE-PAIRED after a DeviceID change: they cache the host's DID
# from pairing, so a restart alone will not surface the spoofed-vendor features.
if [[ "$bluetooth_changed" == true ]] \
  && command -v systemctl >/dev/null 2>&1 \
  && systemctl cat bluetooth.service >/dev/null 2>&1; then
  printf '  -> systemctl restart bluetooth (etc/bluetooth changed; re-pair AirPods after a DeviceID change)\n'
  "${SUDO[@]}" systemctl restart bluetooth
fi
{{ end -}}
