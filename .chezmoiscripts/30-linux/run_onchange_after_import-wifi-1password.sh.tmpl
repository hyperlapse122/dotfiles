{{ if eq .chezmoi.os "linux" -}}
{{ $sourceDir := .chezmoi.sourceDir -}}
#!/usr/bin/env bash
# .chezmoiscripts/30-linux/run_onchange_after_import-wifi-1password.sh.tmpl
#
# onchange trigger: the fingerprint block below embeds a sha256 of the deployed
# ~/.local/bin/import-wifi-1password command's SOURCE, so chezmoi re-runs this
# wrapper whenever that command changes. The real logic lives in that command —
# kept there (not inlined here) so it is also runnable by hand and supports
# --dry-run; this wrapper only invokes it in apply context.
#
# Secrets never enter this rendered template OR its fingerprint: the command
# reads Wi-Fi passwords from `op` at RUNTIME, and the fingerprint hashes the
# command's CODE (which contains no secrets), never the passwords — so nothing
# sensitive lands in `chezmoi diff`/state. NOTE the behavior change from the
# former unconditional run_after: because this now runs only on a fingerprint
# change rather than every apply, a Wi-Fi network newly added to 1Password is
# NOT auto-imported on the next apply — import it by running
# `import-wifi-1password` by hand (or `chezmoi apply --force`).
#
# Linux-only: NetworkManager is Linux-only (this file is gated + carries no .sh
# on non-Linux). Container-skipped: the root .chezmoiignore drops
# .chezmoiscripts/30-linux/*.sh inside a real (non-toolbox) container, where there
# is no NetworkManager to import into.
#
# Soft-skip (like install-dotagents-skills): this must NEVER fail apply. A
# missing command, or any nonzero exit from it (op not signed in, NetworkManager
# down, no sudo, a network that failed to import), is logged and swallowed so the
# rest of the apply continues.

set -euo pipefail

# import-wifi command content fingerprint — chezmoi hashes this rendered script
# to decide whether to re-run; embedding the command's sha256 forces a re-run
# when its code changes. Only the command's CODE is hashed, never any secret.
# `include . | sha256sum` hashes file CONTENT; `(stat .).isDir` skips dirs.
# Comment-only; never executed.
{{- includeTemplate "fingerprint.tmpl" (dict "sourceDir" $sourceDir "globs" (list "dot_local/bin/executable_import-wifi-1password")) }}
cmd="{{ .chezmoi.homeDir }}/.local/bin/import-wifi-1password"
if [[ ! -x "$cmd" ]]; then
  echo "import-wifi-1password: skipped (command not deployed to ~/.local/bin yet)" >&2
  exit 0
fi

# --from-apply: quieter output and treats "not applicable here" conditions (op
# not usable, NetworkManager not running, no active polkit session) as a clean
# skip. The `|| echo` additionally swallows any hard error so a single bad
# network cannot abort the apply.
if ! "$cmd" --from-apply; then
  echo "import-wifi-1password: skipped (import reported issues; continuing apply)" >&2
fi
exit 0
{{ end -}}
