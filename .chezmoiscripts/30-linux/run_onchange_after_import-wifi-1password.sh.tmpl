{{ if eq .chezmoi.os "linux" -}}
{{ $sourceDir := .chezmoi.sourceDir -}}
#!/usr/bin/env bash
# .chezmoiscripts/30-linux/run_onchange_after_import-wifi-1password.sh.tmpl
#
# onchange trigger: the fingerprint block below embeds a sha256 of the deployed
# ~/.local/bin/import-wifi-1password command's SOURCE (.tmpl) AND of
# .chezmoidata/networking.yaml, so chezmoi re-runs this wrapper whenever the
# tool's code OR the declared network list changes. The tool bakes
# networking.yaml in at render time, so a data-only edit does NOT change the
# tool's raw .tmpl text — which is why networking.yaml is fingerprinted alongside
# it (the config-solaar pattern). The real logic lives in that command — kept
# there (not inlined here) so it is also runnable by hand and supports --dry-run;
# this wrapper only invokes it in apply context.
#
# Secrets never enter this rendered template OR its fingerprint: networking.yaml
# holds op:// REFERENCES (resolved to real PSKs only inside the private_ 0700
# tool at render time), and the fingerprint hashes those raw refs, never the
# passwords — so nothing sensitive lands in `chezmoi diff`/state. TWO behavior
# notes: (1) this runs only on a fingerprint change, not every apply; (2)
# rotating a PSK's VALUE in 1Password alone does NOT change networking.yaml's
# raw ref, so it does NOT re-trigger — after a rotation, re-run
# `import-wifi-1password` by hand (or `chezmoi apply --force`).
#
# Linux-only: NetworkManager is Linux-only (this file is gated + carries no .sh
# on non-Linux). Container-skipped: the root .chezmoiignore drops
# .chezmoiscripts/30-linux/*.sh inside a real (non-toolbox) container, where there
# is no NetworkManager to import into.
#
# Soft-skip (like install-dotagents-skills): this must NEVER fail apply. A
# missing command, or any nonzero exit from it (NetworkManager down, a network
# that failed to create), is logged and swallowed so the rest of the apply
# continues.

set -euo pipefail

# import-wifi fingerprint — chezmoi hashes this rendered script to decide whether
# to re-run; embedding the sha256 of the tool's .tmpl source AND of
# .chezmoidata/networking.yaml forces a re-run when the tool's code or the
# network list changes. Only RAW source is hashed (networking.yaml's op:// refs,
# not the resolved passwords), so no secret enters the fingerprint.
# `include . | sha256sum` hashes file CONTENT; `(stat .).isDir` skips dirs.
# Comment-only; never executed.
{{- includeTemplate "fingerprint.tmpl" (dict "sourceDir" $sourceDir "globs" (list "dot_local/bin/private_executable_import-wifi-1password.tmpl" ".chezmoidata/networking.yaml")) }}
cmd="{{ .chezmoi.homeDir }}/.local/bin/import-wifi-1password"
if [[ ! -x "$cmd" ]]; then
  echo "import-wifi-1password: skipped (command not deployed to ~/.local/bin yet)" >&2
  exit 0
fi

# --from-apply: quieter output and treats "not applicable here" conditions (op
# not usable, NetworkManager not running, no active polkit session) as a clean
# skip. The `|| echo` additionally swallows any hard error so a single bad
# network cannot abort the apply.
if ! "$cmd" --from-apply; then
  echo "import-wifi-1password: skipped (import reported issues; continuing apply)" >&2
fi
exit 0
{{ end -}}
