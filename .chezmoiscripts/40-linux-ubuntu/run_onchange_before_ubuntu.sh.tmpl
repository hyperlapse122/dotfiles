{{- /* Validate this distro's `gates:` map against the fact registry. Emits
   nothing, and deliberately sits OUTSIDE the OS gate below: a typo in
   packages.yaml's ubuntu gates must abort the apply on EVERY host, not only on
   the one distro whose installer body renders. `values` hands the partial the
   gate expressions; the keys are the package-group names, which it has no
   opinion about. */ -}}
{{- includeTemplate "facts-validate.tmpl" (dict
      "ctx"    .
      "source" ".chezmoidata/packages.yaml (packages.linux.ubuntu.gates)"
      "gates"  (values .packages.linux.ubuntu.gates)) -}}
{{ if eq (printf "%s-%s" .chezmoi.os .chezmoi.osRelease.id) "linux-ubuntu" -}}
{{- $mokPassword := "" -}}
{{- if and (hasKey . "mokPasswordCipher") (ne .mokPasswordCipher "") -}}
{{-   $secretsKey := includeTemplate "config-secrets-key.tmpl" . -}}
{{-   if ne $secretsKey "" }}{{ $mokPassword = decryptAES $secretsKey .mokPasswordCipher }}{{ end -}}
{{- end -}}
#!/usr/bin/env bash

set -euo pipefail

# Consolidated Ubuntu provisioning, adapted from the Fedora run_onchange installer:
# APT repositories, dpkg architecture setup for Steam, apt/flatpak/dotnet
# packages, direct .deb installs, NVIDIA driver + CUDA + container toolkit, the
# Intel graphics stack + HWE kernel (kobuk-team PPA, Intel-GPU-gated), system
# services, and user groups. Serves both Ubuntu flavors — Ubuntu Desktop 26.04
# (GNOME) and Ubuntu Studio 26.04 (KDE Plasma) — with the per-desktop package
# sets (kdePackages/gnomePackages) and the Studio pro-audio stack
# (studioPackages, @audio group) gated on named host facts; packages.yaml's
# `gates:` map says which fact gates which group. Every install path is guarded
# so chezmoi can safely re-run this script when .chezmoidata/packages.yaml
# changes.
#
# The gates are resolved at RENDER time, not at runtime: the fact values are
# baked into this script by facts-sh.tmpl below. That is the point — one probe
# per chezmoi command, one answer everywhere — and it means a host that becomes
# a different host (a GPU added, a desktop swapped) changes this script's
# rendered content, which is exactly what makes run_onchange re-run it.

{{ includeTemplate "facts-sh.tmpl" . }}
{{ includeTemplate "facts-gate.sh.tmpl" . }}
{{- $gates := .packages.linux.ubuntu.gates }}

# Host capabilities — SEEDED FROM packages.yaml's `gates:` map via the shared
# fact_gate() dispatcher (.chezmoitemplates/facts-gate.sh.tmpl), not hand-wired
# to a FACT_* variable here. This script used to carry its own probes (a sysfs
# 0x10de scan for the NVIDIA GPU, a vendor+class sysfs walk for the Intel GPU,
# systemd-detect-virt, a `dpkg -s` Studio marker check, and a pair of
# `command -v` desktop checks), then — once those became registry facts — a
# stage that still hand-picked which FACT_* answered each flag, bypassing
# whatever the map itself said. Now the map drives the flag directly: change
# `gates.kdePackages` from `desktop.kde` to something else and this flag
# follows it, no script edit required. See the file header in
# .chezmoidata/packages.yaml. HAS_INTEL_GPU is seeded from intelPackages' gate
# (intelHweKernel declares the identical `intelGpu` gate in the map, purely so
# the map stays a complete index of every conditional key — it drives no flag
# of its own).
#
# The FORCE_* env vars are NOT facts and layer on top of the map-seeded flag
# HERE, in the installer, never in the shared partial — see the closing note
# in facts.yaml. Each forces its stack on for a GPU-passthrough VM whose card
# the sysfs scan misses, and to exercise the repos + package sets in a
# GPU-less test container.
HAS_NVIDIA=0; fact_gate {{ index $gates "nvidiaPackages" | quote }} && HAS_NVIDIA=1
[[ "${FORCE_NVIDIA:-0}" == 1 ]] && HAS_NVIDIA=1
HAS_INTEL_GPU=0; fact_gate {{ index $gates "intelPackages" | quote }} && HAS_INTEL_GPU=1
[[ "${FORCE_INTEL:-0}" == 1 ]] && HAS_INTEL_GPU=1
IS_UBUNTU_STUDIO=0; fact_gate {{ index $gates "studioPackages" | quote }} && IS_UBUNTU_STUDIO=1
[[ "${FORCE_UBUNTU_STUDIO:-0}" == 1 ]] && IS_UBUNTU_STUDIO=1

# HAS_BARE_METAL is seeded from bareMetalPackages' `!virt` gate — the BARE
# systemd-detect-virt, true for a container as well as a VM. That is
# deliberately not the manifest's `vm` fact (systemd-detect-virt --vm), which
# gates password-less sudo and must stay false in a container. No FORCE_
# counterpart.
HAS_BARE_METAL=0; fact_gate {{ index $gates "bareMetalPackages" | quote }} && HAS_BARE_METAL=1

# The desktop is ONE fact with ONE value (kde | gnome | none), so the two flags
# are mutually exclusive by construction — where the old pair of independent
# `command -v` probes would have set both on a host that happened to carry both
# shells. KDE wins that tie (the precedence facts.yaml declares); `none` (a
# server, a container) installs neither set, as before.
HAS_KDE=0; fact_gate {{ index $gates "kdePackages" | quote }} && HAS_KDE=1
HAS_GNOME=0; fact_gate {{ index $gates "gnomePackages" | quote }} && HAS_GNOME=1

{{ includeTemplate "sudo-require-guard.sh.tmpl" "run_onchange_before_ubuntu.sh" -}}

export DEBIAN_FRONTEND=noninteractive
# Keep apt invocations behind one sudo/env wrapper; the rendered script still
# performs apt-get update and apt-get install operations through this array.
APT=("${SUDO[@]}" env LC_ALL=C DEBIAN_FRONTEND=noninteractive apt-get)

# Secure Boot MOK enrollment password, prompted once by chezmoi at `chezmoi
# init` and stored AES-ENCRYPTED in the config (mokPasswordCipher in
# `.chezmoi.toml.tmpl`, keyed from the user keyring via
# .chezmoitemplates/config-secrets-key.tmpl), decrypted here at render time —
# same mechanism and trade-offs as the LUKS passphrase: unmasked input at init,
# decrypted into this script's transient run-script, so avoid
# `--verbose`/`--dry-run` applies with a real password stored; base64 wraps it
# for shell safety only, NOT secrecy. Blank at init (or an unreachable keyring
# at render time) = skip the NVIDIA stack on a Secure Boot host without an
# enrolled MOK. Used only by install_nvidia_support() below.
MOK_PASSWORD="$(printf '%s' {{ $mokPassword | b64enc | quote }} | base64 -d)"

# Package sets rendered from .chezmoidata/packages.yaml.
core_packages=(
{{ range .packages.linux.ubuntu.corePackages -}}
  {{ . | quote }}
{{ end -}}
)
packages=(
{{ range .packages.linux.ubuntu.packages -}}
  {{ . | quote }}
{{ end -}}
)
if [[ "${HAS_BARE_METAL}" -eq 1 ]]; then
  packages+=(
{{ range .packages.linux.ubuntu.bareMetalPackages -}}
    {{ . | quote }}
{{ end -}}
  )
fi
if [[ "${HAS_KDE}" -eq 1 ]]; then
  packages+=(
{{ range .packages.linux.ubuntu.kdePackages -}}
    {{ . | quote }}
{{ end -}}
  )
fi
if [[ "${HAS_GNOME}" -eq 1 ]]; then
  packages+=(
{{ range .packages.linux.ubuntu.gnomePackages -}}
    {{ . | quote }}
{{ end -}}
  )
fi
if [[ "${IS_UBUNTU_STUDIO}" -eq 1 ]]; then
  packages+=(
{{ range .packages.linux.ubuntu.studioPackages -}}
    {{ . | quote }}
{{ end -}}
  )
fi
nvidia_packages=(
{{ range .packages.linux.ubuntu.nvidiaPackages -}}
  {{ . | quote }}
{{ end -}}
)
intel_packages=(
{{ range .packages.linux.ubuntu.intelPackages -}}
  {{ . | quote }}
{{ end -}}
)
intel_hwe_kernel={{ .packages.linux.ubuntu.intelHweKernel | quote }}
flatpaks=(
{{ range .packages.linux.ubuntu.flatpaks -}}
  {{ . | quote }}
{{ end -}}
)
dotnet_tools=(
{{ range .packages.linux.ubuntu.dotnetTools -}}
  {{ . | quote }}
{{ end -}}
)

setup_apt_repos() {
  # The 1password repo is package-managed, not aptRepos-managed: the 1password
  # deb's postinst writes the deb822 /etc/apt/sources.list.d/1password.sources
  # (Signed-By /usr/share/keyrings/1password-archive-keyring.gpg) and comments
  # out any 1password.list. An earlier revision managed 1password.list here
  # anyway, so the converge loop below kept resurrecting its `deb ` lines with a
  # different signed-by= — two live definitions of one source, which apt rejects
  # wholesale ("Conflicting values set for option Signed-By"), breaking every
  # apt operation on the host. Drop that legacy .list (and its keyring) once the
  # package-managed .sources exists; keep this cleanup ahead of the loop so a
  # broken host heals before the first apt invocation.
  if [[ -f /etc/apt/sources.list.d/1password.sources && -f /etc/apt/sources.list.d/1password.list ]]; then
    "${SUDO[@]}" rm -f /etc/apt/sources.list.d/1password.list /usr/share/keyrings/1password.gpg
  fi

  # Converge each repo's .list to the rendered lines instead of only creating
  # it when missing: a stale definition from an earlier revision (the retired
  # mise.jdx.dev/deb repo written by .install-prerequisites.sh, a line missing
  # its arch= pin) would otherwise survive forever. The keyring is refetched
  # alongside a changed .list, since a repo move can also mean a different
  # signing key (mise.jdx.dev/deb -> the jdxcode PPA did exactly that).
  local repo_lines
{{ range .packages.linux.ubuntu.aptRepos -}}
{{ $repo := . -}}
  # {{ $repo.id }}
  repo_lines="$(printf '%s\n' {{ range $repo.sourcesListLines }}{{ . | quote }} {{ end }})"
  if [[ ! -f /usr/share/keyrings/{{ $repo.id }}.gpg || "$(cat /etc/apt/sources.list.d/{{ $repo.id }}.list 2>/dev/null)" != "${repo_lines}" ]]; then
    curl -fsSL {{ $repo.keyringUrl | quote }} | "${SUDO[@]}" gpg --yes --dearmor -o /usr/share/keyrings/{{ $repo.id }}.gpg
    printf '%s\n' "${repo_lines}" | "${SUDO[@]}" tee /etc/apt/sources.list.d/{{ $repo.id }}.list >/dev/null
  fi
{{ end -}}
}

enable_first_apply_apt_features() {
  # Enable universe, multiverse, and restricted components when the helper exists.
  # On stripped-down containers add-apt-repository can be absent; package install
  # smoke tests still exercise apt resolution without failing this script body.
  if command -v add-apt-repository >/dev/null 2>&1; then
    "${SUDO[@]}" add-apt-repository -y universe multiverse restricted 2>/dev/null || true
  fi

  # Enable i386 for Steam and other 32-bit runtime dependencies.
  "${SUDO[@]}" dpkg --add-architecture i386
}

install_ubuntu_packages() {
  local -a pkgs=("$@")
  local -a to_install=()
  local pkg
  for pkg in "${pkgs[@]}"; do
    dpkg -s "${pkg}" >/dev/null 2>&1 || to_install+=("${pkg}")
  done
  [[ ${#to_install[@]} -eq 0 ]] && return 0
  "${APT[@]}" install -y "${to_install[@]}"
}

# An entry pinning a `version` in the data converges to that exact version —
# bumping the pin re-runs dpkg -i as an in-place upgrade. An unpinned entry
# installs only when the package is absent (right for self-updating packages
# like teamviewer, whose postinst registers its own apt repo).
install_direct_debs() {
  local arch deb_url tmp
{{ range .packages.linux.ubuntu.directDebs -}}
{{- $pin := get . "version" }}
  if {{ if $pin }}[[ "$(dpkg-query -W -f '${Version}' {{ .id | quote }} 2>/dev/null || true)" != {{ $pin | quote }} ]]{{ else }}! dpkg -s {{ .id | quote }} >/dev/null 2>&1{{ end }}; then
    arch="$(dpkg --print-architecture)"
    case "${arch}" in
      amd64) deb_url={{ index . "debs" "x86_64" | quote }} ;;
      arm64) deb_url={{ index . "debs" "aarch64" | quote }} ;;
      *) printf 'run_onchange_before_ubuntu.sh: unsupported arch %s for %s; skipping.\n' "${arch}" {{ .id | quote }} >&2; deb_url='' ;;
    esac
    if [[ -n "${deb_url}" ]]; then
      tmp="$(mktemp --suffix=.deb)"
      curl -fsSL "${deb_url}" -o "${tmp}"
      "${SUDO[@]}" dpkg -i "${tmp}" || true
      rm -f "${tmp}"
      "${APT[@]}" install -f -y || true
    fi
  fi
{{ end -}}
}

install_flatpak_packages() {
  if [[ ${#flatpaks[@]} -eq 0 ]]; then
    return 0
  fi
  if command -v flatpak >/dev/null 2>&1; then
    "${SUDO[@]}" flatpak remote-add --if-not-exists --system flathub \
      https://dl.flathub.org/repo/flathub.flatpakrepo || true
    "${SUDO[@]}" flatpak install --system -y --noninteractive flathub "${flatpaks[@]}" 2>/dev/null || true
  fi
}

install_dotnet_tools() {
  if [[ ${#dotnet_tools[@]} -eq 0 ]]; then
    return 0
  fi
  if command -v dotnet >/dev/null 2>&1; then
    local installed_tools tool
    installed_tools="$(dotnet tool list -g 2>/dev/null || true)"
    for tool in "${dotnet_tools[@]}"; do
      printf '%s\n' "${installed_tools}" | awk '{print $1}' | grep -ixqF "${tool}" \
        || dotnet tool install -g "${tool}" || true
    done
  fi
}

# NVIDIA's cuda-keyring package drops the CUDA archive keyring, its sources.list
# entry, and an apt pin at priority 600 in one maintained step; the
# libnvidia-container apt repo adds the container toolkit. Split out from
# install_nvidia_support so the harness smoke test (FORCE_NVIDIA=1) can exercise
# repo registration and NVIDIA package resolution without the DKMS driver build.
setup_nvidia_repos() {
  if [[ ! -f /usr/share/keyrings/cuda-archive-keyring.gpg ]]; then
    local cuda_keyring
    cuda_keyring="$(mktemp --suffix=.deb)"
    curl -fsSL https://developer.download.nvidia.com/compute/cuda/repos/ubuntu2604/x86_64/cuda-keyring_1.1-1_all.deb -o "${cuda_keyring}"
    "${SUDO[@]}" dpkg -i "${cuda_keyring}"
    rm -f "${cuda_keyring}"
  fi

  # libnvidia-container apt repo for the container toolkit. Its upstream .list
  # ships a plain URL, so sed pins it to the keyring via signed-by; apt expands
  # the literal $(ARCH) token in the URI at fetch time.
  if [[ ! -f /usr/share/keyrings/nvidia-container-toolkit-keyring.gpg ]]; then
    curl -fsSL https://nvidia.github.io/libnvidia-container/gpgkey | "${SUDO[@]}" gpg --dearmor -o /usr/share/keyrings/nvidia-container-toolkit-keyring.gpg
  fi
  if [[ ! -f /etc/apt/sources.list.d/nvidia-container-toolkit.list ]]; then
    curl -fsSL https://nvidia.github.io/libnvidia-container/stable/deb/nvidia-container-toolkit.list \
      | sed 's#deb https://#deb [signed-by=/usr/share/keyrings/nvidia-container-toolkit-keyring.gpg] https://#g' \
      | "${SUDO[@]}" tee /etc/apt/sources.list.d/nvidia-container-toolkit.list >/dev/null
  fi
}

# Ubuntu signs DKMS builds with the shim-signed MOK keypair
# (/var/lib/shim-signed/mok/MOK.priv + MOK.der); the kernel loads them under
# Secure Boot only once that certificate is enrolled through shim. Prepare the
# enrollment BEFORE the driver install so neither the dkms build nor the
# package postinst has to stop and ask:
#   * generate the keypair if missing (update-secureboot-policy --new-key), so
#     dkms signs the NVIDIA modules with it during the package install;
#   * preseed shim-signed's debconf password questions with the chezmoi-prompted
#     MOK password — the dkms postinst runs `update-secureboot-policy
#     --enroll-key`, whose interactive whiptail dialog ("configuring secure
#     boot") would otherwise pose exactly that question mid-install.
prepare_mok_enrollment() {
  local mok_der="$1"
  install_ubuntu_packages mokutil shim-signed
  if [[ ! -f "${mok_der}" ]]; then
    "${SUDO[@]}" update-secureboot-policy --new-key
  fi
  # Blank the questions again on ANY script exit — also when a later install
  # step fails under set -e before finish_mok_enrollment runs — so the one-time
  # secret never outlives this script in debconf's database.
  trap clear_mok_debconf EXIT
  printf '%s\n' \
    "shim-signed shim/secureboot_key password ${MOK_PASSWORD}" \
    "shim-signed shim/secureboot_key_again password ${MOK_PASSWORD}" \
    | "${SUDO[@]}" debconf-set-selections
}

# EXIT-trap counterpart to prepare_mok_enrollment's preseed (|| true keeps the
# trap from rewriting the script's real exit code).
clear_mok_debconf() {
  printf '%s\n' \
    'shim-signed shim/secureboot_key password ' \
    'shim-signed shim/secureboot_key_again password ' \
    | "${SUDO[@]}" debconf-set-selections || true
}

# After the driver install, make sure the MOK certificate actually reached
# shim's enrollment queue: the debconf-preseeded postinst path normally queues
# it, but if it did not (e.g. the postinst enrollment was skipped), import it
# directly with mokutil, feeding the prompted password on stdin (mokutil asks
# for it twice). Idempotent — an already-pending request is matched by SHA1
# certificate fingerprint and left alone. The preseeded debconf password is
# cleared by the EXIT trap prepare_mok_enrollment installed.
finish_mok_enrollment() {
  local mok_der="$1" fingerprint
  if ! "${SUDO[@]}" mokutil --test-key "${mok_der}" 2>/dev/null | grep -q 'is already enrolled'; then
    fingerprint="$("${SUDO[@]}" openssl x509 -inform der -in "${mok_der}" -noout -fingerprint -sha1 | cut -d= -f2)"
    if ! "${SUDO[@]}" mokutil --list-new 2>/dev/null | grep -qiF "${fingerprint}"; then
      printf '%s\n%s\n' "${MOK_PASSWORD}" "${MOK_PASSWORD}" | "${SUDO[@]}" mokutil --import "${mok_der}"
    fi
    printf 'run_onchange_before_ubuntu.sh: MOK enrollment queued. At next boot choose "Enroll MOK" in the MokManager menu and enter the prompted MOK password; the NVIDIA modules stay unloadable until then.\n' >&2
  fi
}

install_nvidia_support() {
  if [[ "${HAS_NVIDIA}" -ne 1 ]]; then
    return 0
  fi

  # cuda-drivers builds its GPU kernel modules with DKMS; under Secure Boot the
  # kernel loads them only when signed by an enrolled MOK. With the shim-signed
  # MOK already enrolled the install just proceeds (dkms signs every build with
  # it). Otherwise a chezmoi-prompted MOK password (see MOK_PASSWORD above)
  # drives the enrollment non-interactively; without one, a Secure Boot host
  # skips the NVIDIA stack entirely (a black screen at boot is worse than no
  # driver) — re-run `chezmoi init` to enter the password, then
  # `chezmoi apply --force`.
  local mok_der=/var/lib/shim-signed/mok/MOK.der
  local mok_enroll=0
  if command -v mokutil >/dev/null 2>&1 && mokutil --sb-state 2>/dev/null | grep -q 'SecureBoot enabled'; then
    if [[ -f "${mok_der}" ]] && "${SUDO[@]}" mokutil --test-key "${mok_der}" 2>/dev/null | grep -q 'is already enrolled'; then
      : # signing key already trusted by shim; nothing to enroll
    elif [[ -n "${MOK_PASSWORD}" && "${#MOK_PASSWORD}" -ge 8 && "${#MOK_PASSWORD}" -le 16 ]]; then
      mok_enroll=1
      prepare_mok_enrollment "${mok_der}"
    elif [[ -n "${MOK_PASSWORD}" ]]; then
      printf 'run_onchange_before_ubuntu.sh: Secure Boot is enabled but the MOK password is outside the 8-16 characters shim-signed'\''s update-secureboot-policy accepts; skipping NVIDIA driver/CUDA install. Re-run `chezmoi init` with a password in that range, then `chezmoi apply --force`.\n' >&2
      return 0
    else
      printf 'run_onchange_before_ubuntu.sh: Secure Boot is enabled and no MOK is enrolled; skipping NVIDIA driver/CUDA install (the DKMS modules would not load). Re-run `chezmoi init` to enter a MOK enrollment password (or enroll a MOK / disable Secure Boot), then `chezmoi apply --force`.\n' >&2
      return 0
    fi
  fi

  setup_nvidia_repos

  "${APT[@]}" update

  # Kernel headers for the running kernel — the DKMS build prerequisite the
  # NVIDIA driver installation guide lists first.
  install_ubuntu_packages "linux-headers-$(uname -r)"

  install_ubuntu_packages "${nvidia_packages[@]}"

  if [[ "${mok_enroll}" -eq 1 ]]; then
    finish_mok_enrollment "${mok_der}"
  fi

  # Emit the CDI spec so podman can inject the GPU. Enumerating the live GPU can
  # fail before the freshly built driver is loaded on first boot, so a failure
  # here is tolerated; it regenerates cleanly once the module is loaded.
  if command -v nvidia-ctk >/dev/null 2>&1; then
    "${SUDO[@]}" nvidia-ctk cdi generate --output=/etc/cdi/nvidia.yaml || true
  fi
}

# kobuk-team/intel-graphics PPA (Canonical's intel-graphics-preview stack).
# Split out from install_intel_support so the harness smoke test (FORCE_INTEL=1)
# can exercise repo registration and Intel package resolution on a GPU-less box.
# Signing key 0C0E6AF955CE463C03FC51574D098D70AFBE5E1F; the launchpad PPA
# publishes for resolute (26.04), matching the other PPA sources lines above.
setup_intel_repos() {
  if [[ ! -f /usr/share/keyrings/kobuk-intel-graphics.gpg ]]; then
    curl -fsSL "https://keyserver.ubuntu.com/pks/lookup?op=get&options=mr&search=0x0C0E6AF955CE463C03FC51574D098D70AFBE5E1F" \
      | "${SUDO[@]}" gpg --dearmor -o /usr/share/keyrings/kobuk-intel-graphics.gpg
  fi
  if [[ ! -f /etc/apt/sources.list.d/kobuk-intel-graphics.list ]]; then
    printf '%s\n' 'deb [signed-by=/usr/share/keyrings/kobuk-intel-graphics.gpg] https://ppa.launchpadcontent.net/kobuk-team/intel-graphics/ubuntu resolute main' \
      | "${SUDO[@]}" tee /etc/apt/sources.list.d/kobuk-intel-graphics.list >/dev/null
  fi
}

install_intel_support() {
  if [[ "${HAS_INTEL_GPU}" -ne 1 ]]; then
    return 0
  fi

  setup_intel_repos
  "${APT[@]}" update

  # Make the generic (HWE) kernel the default boot entry, ahead of the lowlatency
  # flavour ubuntustudio-lowlatency-settings prefers. Written BEFORE the kernel
  # install so its postinst update-grub already emits the HWE entry as default;
  # the 99- prefix outranks the ubuntustudio grub.d drop-in.
  if [[ -d /etc/default/grub.d ]]; then
    printf '%s\n' \
      '# Managed by chezmoi - Intel graphics enablement.' \
      '# Boot the generic (HWE) kernel by default, ahead of the lowlatency flavour' \
      '# ubuntustudio-lowlatency-settings prefers. The 99- prefix outranks it.' \
      'GRUB_FLAVOUR_ORDER="generic"' \
      | "${SUDO[@]}" tee /etc/default/grub.d/99-hwe-generic-default.cfg >/dev/null
  fi

  # Intel graphics stack. Ubuntu installs Recommends by default (as Canonical's
  # setup-intel-graphics.sh relies on), so the idempotent helper suffices here.
  install_ubuntu_packages "${intel_packages[@]}"

  # HWE kernel. --install-recommends pulls the full stack (modules-extra, etc.)
  # per the recipe; its postinst runs update-grub, honouring the drop-in above.
  if ! dpkg -s "${intel_hwe_kernel}" >/dev/null 2>&1; then
    "${APT[@]}" install -y --install-recommends "${intel_hwe_kernel}"
  fi

  # Reflect the default-kernel change even on a re-run where the kernel was
  # already present (no postinst fired to regenerate the GRUB menu).
  if command -v update-grub >/dev/null 2>&1; then
    "${SUDO[@]}" update-grub || true
  fi
}

# Enable a systemd unit only when its unit file exists, so a host missing an
# optional package (libvirt, nvidia) is skipped rather than failing.
# The second argument selects "now" (enable --now) or "later" (enable only).
enable_unit() {
  local svc="$1" when="${2:-now}"
  systemctl list-unit-files "${svc}.service" 2>/dev/null | grep -q "${svc}" || return 0
  if [[ "${when}" == later ]]; then
    "${SUDO[@]}" systemctl enable "${svc}" 2>/dev/null || true
  else
    "${SUDO[@]}" systemctl enable --now "${svc}" 2>/dev/null || true
  fi
}

enable_services() {
  enable_unit keyd
  enable_unit tailscaled
  enable_unit libvirtd

  # NVIDIA persistence daemon only on NVIDIA hosts (same gate as the driver
  # install); it only needs to be up once the driver is loaded, so enable it for
  # next boot rather than starting it now.
  if [[ "${HAS_NVIDIA}" -eq 1 ]]; then
    enable_unit nvidia-persistenced later
  fi

  # systemd-timesyncd ships masked on some Ubuntu images; unmask before enabling.
  "${SUDO[@]}" systemctl unmask systemd-timesyncd 2>/dev/null || true
  enable_unit systemd-timesyncd

}

# Use the hardware clock as UTC and enable NTP synchronisation. Guarded so a
# container or systemd-less environment (harness smoke tests) is skipped cleanly.
configure_time() {
  command -v timedatectl >/dev/null 2>&1 || return 0
  "${SUDO[@]}" timedatectl set-local-rtc 0 2>/dev/null || true
  "${SUDO[@]}" timedatectl set-ntp true 2>/dev/null || true
}

configure_user_groups() {
  local target_user grp
  target_user="${SUDO_USER:-$USER}"
  local -a groups=(keyd libvirt kvm)

  # @audio grants the realtime privileges from the Studio limits.d drop-in
  # (95-ubuntustudio-audio.conf) — Studio-only, like the drop-in itself. The
  # audio group exists on every Ubuntu, so membership (direct device access)
  # is deliberately NOT granted on a plain Desktop install.
  if [[ "${IS_UBUNTU_STUDIO}" -eq 1 ]]; then
    groups+=(audio)
  fi

  # Add user to groups only when they exist.
  for grp in "${groups[@]}"; do
    if getent group "${grp}" >/dev/null 2>&1; then
      "${SUDO[@]}" usermod -aG "${grp}" "${target_user}" 2>/dev/null || true
    fi
  done

  # Subordinate UID/GID ranges for rootless containers.
  grep -q "^${target_user}:" /etc/subuid 2>/dev/null || "${SUDO[@]}" usermod --add-subuids 100000-165535 "${target_user}" 2>/dev/null || true
  grep -q "^${target_user}:" /etc/subgid 2>/dev/null || "${SUDO[@]}" usermod --add-subgids 100000-165535 "${target_user}" 2>/dev/null || true
}

setup_apt_repos
enable_first_apply_apt_features
"${APT[@]}" update
install_ubuntu_packages "${core_packages[@]}"
"${APT[@]}" update
install_ubuntu_packages "${packages[@]}"
install_nvidia_support
install_intel_support
install_direct_debs
install_flatpak_packages
install_dotnet_tools
configure_time
enable_services
configure_user_groups

{{ end -}}
