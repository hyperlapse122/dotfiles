{{ if ne .chezmoi.os "windows" -}}
#!/usr/bin/env bash

set -euo pipefail

# Prefer system `glab`; fall back to ephemeral `mise exec glab@latest`. Error
# if neither is available.
if command -v glab >/dev/null 2>&1; then
  GLAB=(glab)
elif command -v mise >/dev/null 2>&1; then
  GLAB=(mise --no-config --no-env --no-hooks exec glab@latest -- glab)
else
  printf 'auth-glab.sh: glab not found and mise unavailable as fallback.\n' >&2
  exit 1
fi

"${GLAB[@]}" auth login --hostname git.jpi.app --container-registry-domains registry.jpi.app -a git.jpi.app -g https -p https --use-keyring --stdin <<EOF
{{ onepasswordRead "op://Private/ayf4zcy2khkrvdoexfdvbqgzka/PAT" }}
EOF
"${GLAB[@]}" auth login --hostname gitlab.com --container-registry-domains registry.gitlab.com -a gitlab.com -g https -p https --use-keyring --stdin <<EOF
{{ onepasswordRead "op://Private/GitLab/PAT" }}
EOF


{{ end -}}