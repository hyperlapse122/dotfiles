{{- $executableExtension := (replace "linux" "" (replace "darwin" "" (replace "windows" ".exe" .chezmoi.os))) -}}
{{- $scriptExtension := (replace "linux" ".sh" (replace "darwin" ".sh" (replace "windows" ".ps1" .chezmoi.os))) -}}

{{ if ne .chezmoi.os "windows" -}}
# Non-interactive pager for `chezmoi diff` / `apply --verbose`: `less` quits when the
# diff fits one screen (--quit-if-one-screen) and skips the alternate screen
# (--no-init), so short output prints inline instead of trapping in interactive less;
# --RAW-CONTROL-CHARS preserves chezmoi's colored diff. Root keys must precede [edit].
pager = "less"
pagerArgs = ["--quit-if-one-screen", "--no-init", "--RAW-CONTROL-CHARS"]
# Pin chezmoi-managed normal files/directories to 0644/0755 on POSIX hosts,
# independent of a distribution's login umask.
umask = 0o022
{{ end }}
# GPG encryption for `encrypted_` source files (the ~/src garden project
# registry and the secrets cache — kept ciphertext-only in this public repo).
# The recipient below is the PUBLIC key fingerprint (safe to commit); the
# private key is provisioned from 1Password and imported by
# .chezmoiscripts/80-keys/run_once_before_import-gpg-key.sh.tmpl, which runs in
# the before phase so the key exists before the file phase decrypts. Windows
# and containers never decrypt: src/garden.yaml is chezmoiignored there.
encryption = "gpg"
[gpg]
    # Same key as .chezmoidata/user.yaml gpgPubKey (used by chezmoi-secrets-sync and the
    # 80-keys import). Kept as a literal because this config template renders BEFORE
    # .chezmoidata loads; on key rotation, update both.
    recipient = "A7F1956CD1A035A139BC7ABFCC740A29852C0E95"

[edit]
    command = '{{ printf "codium%s" $executableExtension }}'
    args = ["--wait"]

[data]
{{- /* Prompted secrets are stored AES-encrypted (encryptAES + the user-keyring
   key), never plaintext — the rendered chezmoi.toml carries only ciphertext.
   The hasKey guard replicates promptStringOnce (re-init keeps the stored value)
   WITHOUT re-encrypting an already-encrypted value, and — crucially — WITHOUT
   touching the keyring at all on a provisioned host (so a lost keyring entry
   there degrades to the decrypt consumers' skip path, never a fresh wrong key).
   The keyring key is resolved GET-OR-CREATE (config-secrets-key-ensure.tmpl)
   ONLY when a non-blank answer is actually being encrypted: chezmoi renders and
   prompts on this config template BEFORE the read-source-state.pre hook that
   also seeds the key runs, so on a fresh machine's first `chezmoi init` the key
   must be created right here or the prompt would have nothing to encrypt with.
   A non-blank answer with a genuinely unreachable keyring still fails loudly
   rather than silently discarding what was typed; a blank answer (also what
   non-interactive/CI init gets) stores "" and keeps the skip path. Consumers
   decrypt at apply-render time with the read-only config-secrets-key.tmpl. */}}
{{ if and (eq .chezmoi.os "linux") (or (eq .chezmoi.osRelease.id "fedora") (eq .chezmoi.osRelease.id "ubuntu")) -}}
{{-   $luksPassphraseCipher := "" -}}
{{-   if hasKey . "luksPassphraseCipher" -}}
{{-     $luksPassphraseCipher = .luksPassphraseCipher -}}
{{-   else -}}
{{-     $plain := promptString "Existing LUKS passphrase for TPM2 auto-unlock enrollment (leave blank to skip)" "" -}}
{{-     if ne $plain "" -}}
{{-       $secretsKey := includeTemplate "config-secrets-key-ensure.tmpl" . -}}
{{-       if eq $secretsKey "" -}}
{{-         fail "config-secrets key unavailable (user keyring locked or unreachable); re-run `chezmoi init` from a desktop session, or leave the prompt blank to skip" -}}
{{-       end -}}
{{-       $luksPassphraseCipher = encryptAES $secretsKey $plain -}}
{{-     end -}}
{{-   end -}}
    luksPassphraseCipher = {{ $luksPassphraseCipher | quote }}
{{ end -}}
{{ if and (eq .chezmoi.os "linux") (eq .chezmoi.osRelease.id "ubuntu") -}}
{{-   $mokPasswordCipher := "" -}}
{{-   if hasKey . "mokPasswordCipher" -}}
{{-     $mokPasswordCipher = .mokPasswordCipher -}}
{{-   else -}}
{{-     $plain := promptString "MOK enrollment password for Secure Boot NVIDIA DKMS module signing (8-16 chars; leave blank to skip)" "" -}}
{{-     if ne $plain "" -}}
{{-       $secretsKey := includeTemplate "config-secrets-key-ensure.tmpl" . -}}
{{-       if eq $secretsKey "" -}}
{{-         fail "config-secrets key unavailable (user keyring locked or unreachable); re-run `chezmoi init` from a desktop session, or leave the prompt blank to skip" -}}
{{-       end -}}
{{-       $mokPasswordCipher = encryptAES $secretsKey $plain -}}
{{-     end -}}
{{-   end -}}
    mokPasswordCipher = {{ $mokPasswordCipher | quote }}
{{ end }}

[hooks.read-source-state.pre]
    # `script` (not `command`): chezmoi applies the per-extension interpreter to a
    # hook `script`, so a Windows `.ps1` runs via `pwsh`/`powershell -NoLogo -File`
    # (a bare `command` would exec the .ps1 directly, which Windows cannot do). On
    # Linux/macOS the `.sh` has no chezmoi interpreter, so it still execs directly
    # via its shebang + executable bit — identical to the previous `command` form.
    script = '{{ printf ".local/share/chezmoi/.install-prerequisites%s" $scriptExtension }}'
