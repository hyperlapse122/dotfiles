{{- $executableExtension := (replace "linux" "" (replace "darwin" "" (replace "windows" ".exe" .chezmoi.os))) -}}
{{- $scriptExtension := (replace "linux" ".sh" (replace "darwin" ".sh" (replace "windows" ".ps1" .chezmoi.os))) -}}

{{ if ne .chezmoi.os "windows" -}}
# Non-interactive pager for `chezmoi diff` / `apply --verbose`: `less` quits when the
# diff fits one screen (--quit-if-one-screen) and skips the alternate screen
# (--no-init), so short output prints inline instead of trapping in interactive less;
# --RAW-CONTROL-CHARS preserves chezmoi's colored diff. Root keys must precede [edit].
pager = "less"
pagerArgs = ["--quit-if-one-screen", "--no-init", "--RAW-CONTROL-CHARS"]
{{ end }}
[edit]
    command = '{{ printf "codium%s" $executableExtension }}'
    args = ["--wait"]

[hooks.read-source-state.pre]
    # `script` (not `command`): chezmoi applies the per-extension interpreter to a
    # hook `script`, so a Windows `.ps1` runs via `pwsh`/`powershell -NoLogo -File`
    # (a bare `command` would exec the .ps1 directly, which Windows cannot do). On
    # Linux/macOS the `.sh` has no chezmoi interpreter, so it still execs directly
    # via its shebang + executable bit — identical to the previous `command` form.
    script = '{{ printf ".local/share/chezmoi/.install-prerequisites%s" $scriptExtension }}'

