{{ if ne .chezmoi.os "windows" -}}
{{- /* ~/.pi/agent/settings.json — MANAGED PRIVATE-READONLY (0400, owner-read-only), the pi counterpart of
       dot_config/opencode/readonly_opencode.json.tmpl.

       pi LIVE-WROTE this file in its former design (theme, packages,
       lastChangelogVersion) and a read-merge-write script overlaid declared
       defaults. That is gone: this file is now a chezmoi-managed `private_readonly_` 0400 target (owner-read-only),
       so pi CANNOT write it — not theme, not lastChangelogVersion, and not the
       packages array. The trade-off is accepted (and matches opencode's
       contract): pi's runtime writes are blocked, and the actual package
       INSTALLATION — the one side-effect pi can no longer perform itself via
       `pi install` (which writes settings) — is done by
       .chezmoiscripts/70-agents/run_onchange_after_update-pi-extensions, which
       runs `pi update --extensions` (reads the declared list FROM settings,
       updates deps under ~/.pi/agent/npm/, writes nothing) so it never fights
       the readonly file.

       Everything here is data-driven from .chezmoidata/agents.yaml:
         - the whole object is deepCopied from .agents.pi.settings (same key
           names as pi's settings.json schema, INCLUDING `packages` — npm
           sources plus compound-engineering as a native `git:` source, not the
           localArchive path the other agents use), so adding a new key is a
           DATA edit;
         - `lastChangelogVersion` is the installed pi version, resolved inline
           from the SAME earendil-works/pi release .chezmoiexternals/
           ai-agents.toml fetches (so it always matches the pi on disk);
         - `theme` is declared (pi can no longer persist a theme choice, so it
           is fixed here to the documented default).

       Plain JSON, not JSONC — no comments in the rendered file. */ -}}
{{- $d := .agents.pi.settings -}}
{{- /* The GitHub tag carries a leading `v` (v0.80.7) — pi's own version and the
       value pi writes to lastChangelogVersion strip it (0.80.7).
       .chezmoiexternals/ai-agents.toml keeps the `v` for the versioned on-disk
       dir; here we match pi's format. Resolved inline (same release) so no
       shared partial is needed. */ -}}
{{- $piVer := (gitHubLatestRelease "earendil-works/pi").TagName | toString | trimPrefix "v" -}}
{{- $settings := deepCopy $d -}}
{{- $settings = set $settings "lastChangelogVersion" $piVer -}}
{{- /* Resolve any `op://` 1Password reference ANYWHERE in the object — recursive,
       by VALUE not field name — through resolve-op-refs-json.tmpl, the same
       rule dot_config/opencode/readonly_opencode.json.tmpl uses for its
       providers. So a key like `defaultProvider` can stay a plain name while a
       secret (e.g. an inline apiKey) declared as `op://...` in
       .agents.pi.settings is read from 1Password and baked in at render time.
       NOTE the file deploys 0400 (owner-read-only — tighter than opencode.json's
       0444, because `op://` refs may bake secrets here); pi's API keys
       otherwise live in the 0600 ~/.pi/agent/auth.json (config-pi-auth). */ -}}
{{ includeTemplate "resolve-op-refs-json.tmpl" (dict "value" $settings) }}
{{- end }}
