{{- /* ~/.pi/agent/models.json — routes Pi's built-in Anthropic models through
       the managed CLIProxyAPI service on supported workstation hosts.

       The provider override is data-driven from .agents.pi.models. Pi keeps its
       built-in Anthropic model catalog; only the endpoint and non-secret
       compatibility token change. This 0444 target deliberately does not call
       the secret resolver: `agents.pi.models` must contain no `op://` values.
       The root .chezmoiignore excludes it outside Linux/macOS workstations,
       where the service is not provisioned. */ -}}
{{- $f := includeTemplate "facts.tmpl" . | fromYaml -}}
{{- if and (or (eq .chezmoi.os "linux") (eq .chezmoi.os "darwin")) (not $f.container) -}}
{{ .agents.pi.models | toPrettyJson }}
{{- end }}
