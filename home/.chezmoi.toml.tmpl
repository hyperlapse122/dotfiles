# ~/.config/chezmoi/chezmoi.toml — generated by home/.chezmoi.toml.tmpl on `chezmoi init`.
# chezmoi config for h82/dotfiles. Lives under the .chezmoiroot subdir (home/).
# OS: {{ .chezmoi.os }} (linux/darwin/windows — built-in, lowercase; no data section needed).
#
# Windows: .ps1 scripts run via the chezmoi built-in default interpreter
#   `pwsh -NoLogo -File` — so no [interpreters] override is configured here.
# No encryption, no [merge], no [hooks], no [diff] — 1Password handles secrets injection.
# First boot is non-interactive: no promptStringOnce calls that would block a headless run.

[data]
# No machine-specific prompts needed — .chezmoi.os covers OS detection.
