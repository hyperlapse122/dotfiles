{
  "project_panel": {
    "dock": "right"
  },
  "outline_panel": {
    "dock": "right"
  },
  "collaboration_panel": {
    "dock": "right"
  },
  "git_panel": {
    "dock": "right"
  },
  "prettier": {},
  "agent": {
    "play_sound_when_agent_done": "when_hidden",
    "new_thread_location": "new_worktree",
    "dock": "left",
    "default_model": {
      "provider": "copilot_chat",
      "model": "gpt-5-mini",
      "enable_thinking": false,
      "effort": "high"
    },
    "favorite_models": [],
    "model_parameters": []
  },
  "edit_predictions": {
    "provider": "copilot"
  },
  "telemetry": {
    "diagnostics": false,
    "metrics": false
  },
  "base_keymap": "JetBrains",
  "ui_font_size": 16,
  "ui_font_family": "Pretendard",
  "ui_font_fallbacks": ["Pretendard JP"],
  "buffer_font_size": 12,
  "buffer_font_family": "JetBrainsMono Nerd Font",
  "buffer_font_fallbacks": ["D2CodingLigature Nerd Font"],
  "buffer_font_features": {
    "calt": true
  },
  "theme": {
    "mode": "system",
    "light": "One Light",
    "dark": "One Dark"
  },
  "auto_install_extensions": {
    "biome": true,
    "graphql": true,
    "html": true,
    "dockerfile": true,
    "git-firefly": true,
    "toml": true,
    "wakatime": true
  },
  "lsp": {
    "biome": {
      "settings": {
        "require_config_file": true
      }
    },
    "vtsls": {
      "settings": {
        "typescript": { "tsserver": { "maxTsServerMemory": 16184 } },
        "javascript": { "tsserver": { "maxTsServerMemory": 16184 } }
      }
    }
  },
  "autosave": "on_window_change",
  "restore_on_startup": "launchpad",
  "minimap": {
    "show": "auto"
  },
  "agent_servers": {
    "gemini": {
      "type": "registry"
    },
    "codex-acp": {
      "type": "registry"
    },
    "claude-acp": {
      "type": "registry"
    },
    "OpenCode": {
      "type": "custom",
      "command": "opencode",
      "args": ["acp"]
    }
  }
}
