{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": false,
  "lsp": {
    "biome": {
      "command": [
        "mise",
        "exec",
        "-q",
        "npm:@biomejs/biome@latest",
        "--",
        "biome",
        "lsp-proxy"
      ],
      "extensions": [
        ".ts",
        ".tsx",
        ".js",
        ".jsx",
        ".cts",
        ".ctsx",
        ".cjs",
        ".cjsx",
        ".mts",
        ".mtsx",
        ".mjs",
        ".mjsx",
        ".json",
        ".css",
        ".scss",
        ".html",
        ".vue",
        ".svelte",
        ".json",
        ".yaml",
        ".yml"
      ]
    },
    "buf": {
      "command": [
        "mise",
        "exec",
        "-q",
        "npm:@bufbuild/buf@latest",
        "--",
        "buf",
        "lsp",
        "serve"
      ],
      "extensions": [
        ".proto"
      ]
    },
    "typescript": {
      "command": [
        "mise",
        "exec",
        "-q",
        "npm:typescript-language-server@latest",
        "--",
        "typescript-language-server",
        "--stdio"
      ],
      "extensions": [
        ".ts",
        ".tsx",
        ".js",
        ".jsx",
        ".mts",
        ".mtsx",
        ".mjs",
        ".mjsx",
        ".cts",
        ".ctsx",
        ".cjs",
        ".cjsx"
      ],
      "initialization": {
        "preferences": {
          "importModuleSpecifierPreference": "relative"
        }
      }
    }
  },
  "mcp": {
    "figma": {
      "type": "remote",
      "url": "https://mcp.figma.com/mcp"
    }
  },
  "model": "anthropic/claude-opus-4-7",
  "permission": {
    "edit": {
      "**/.env*": "allow",
      "**/.env*.local": "ask"
    },
    "read": {
      "**/.env*": "allow",
      "**/.env*.local": "ask"
    }
  },
  "plugin": [
    "oh-my-openagent@3.17.15",
    "@ex-machina/opencode-anthropic-auth@latest",
    "opencode-gemini-auth@latest"
  ],
  "provider": {},
  "small_model": "anthropic/claude-haiku-4-5"
}
