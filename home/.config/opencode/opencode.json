{
	"$schema": "https://opencode.ai/config.json",
	"autoupdate": false,
	"plugin": [
		"oh-my-openagent@4.2.3",
		"@ex-machina/opencode-anthropic-auth@1.8.1",
		"opencode-gemini-auth@1.4.15"
	],
	"lsp": {
		"biome": {
			"command": [
				"mise",
				"exec",
				"-q",
				"npm:@biomejs/biome@latest",
				"--",
				"biome",
				"lsp-proxy"
			],
			"extensions": [
				".ts",
				".tsx",
				".js",
				".jsx",
				".cts",
				".ctsx",
				".cjs",
				".cjsx",
				".mts",
				".mtsx",
				".mjs",
				".mjsx",
				".json",
				".css",
				".scss",
				".html",
				".vue",
				".svelte",
				".json",
				".yaml",
				".yml"
			]
		},
		"buf": {
			"command": [
				"mise",
				"exec",
				"-q",
				"npm:@bufbuild/buf@latest",
				"--",
				"buf",
				"lsp",
				"serve"
			],
			"extensions": [
				".proto"
			]
		},
		"typescript": {
			"command": [
				"mise",
				"exec",
				"-q",
				"npm:@typescript/native-preview",
				"--",
				"tsgo",
				"--lsp",
				"--stdio"
			],
			"extensions": [
				".ts",
				".tsx",
				".js",
				".jsx",
				".mts",
				".mtsx",
				".mjs",
				".mjsx",
				".cts",
				".ctsx",
				".cjs",
				".cjsx"
			],
			"initialization": {
				"preferences": {
					"importModuleSpecifierPreference": "relative"
				}
			}
		},
		"marksman": {
			"command": [
				"mise",
				"exec",
				"-q",
				"marksman",
				"--",
				"marksman"
			],
			"extensions": [
				".md"
			]
		}
	},
	"mcp": {
		"figma": {
			"type": "remote",
			"enabled": true,
			"url": "https://mcp.figma.com/mcp"
		},
		"context7": {
			"type": "remote",
			"enabled": true,
			"url": "https://mcp.context7.com/mcp",
			"headers": {
				"CONTEXT7_API_KEY": "{file:~/.secrets/context7-api-key}"
			}
		},
		"websearch": {
			"type": "remote",
			"enabled": true,
			"url": "https://mcp.exa.ai/mcp",
			"headers": {
				"x-api-key": "{file:~/.secrets/exa-api-key}"
			}
		}
	},
	"model": "openai/gpt-5.5",
	"permission": {
		"edit": {
			"**/.env*": "allow",
			"**/.env*.local": "ask"
		},
		"read": {
			"**/.env*": "allow",
			"**/.env*.local": "ask",
			"~/.secrets/**": "deny",
			"~/.local/share/opencode/auth*": "deny"
		},
		"bash": {
			"*": "allow",
			"cat ~/.secrets/*": "deny",
			"cat /home/h82/.secrets/*": "deny",
			"cat ~/.local/share/opencode/auth*": "deny",
			"env": "ask",
			"printenv*": "ask"
		}
	},
	"provider": {
		"opencode": {
			"options": {
				"apiKey": "{file:~/.secrets/opencode-api-key}",
			}
		},
		"opencode-go": {
			"options": {
				"apiKey": "{file:~/.secrets/opencode-api-key}",
			}
		},
		"openrouter": {
			"options": {
				"apiKey": "{file:~/.secrets/openrouter-api-key}",
				"headers": {
					"HTTP-Referer": "https://opencode.ai/",
					"X-OpenRouter-Title": "OpenCode",
					"X-OpenRouter-Categories": "cli-agent"
				}
			},
			"models": {
				"openrouter/free": {
					"name": "Free Models Router",
					"cost": {
						"input": 0,
						"output": 0,
						"cache_read": 0,
						"cache_write": 0
					}
				}
			}
		},
		"anthropic": {
			"models": {
				"claude-sonnet-4-6": {
					"limit": {
						"context": 200000,
						"output": 64000,
						"input": 200000
					}
				},
				"claude-opus-4-7": {
					"limit": {
						"context": 200000,
						"output": 128000,
						"input": 200000
					}
				}
			}
		}
	},
	"small_model": "openai/gpt-5.4-mini-fast",
	"server": {
		"hostname": "0.0.0.0"
	}
}