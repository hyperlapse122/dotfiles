{
	"$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-openagent/refs/heads/dev/assets/oh-my-opencode.schema.json",
	"agents": {
		// Model Mapping Reference: https://github.com/code-yeongyu/oh-my-openagent/blob/dev/packages/model-core/src/agent-model-requirements.ts
		"sisyphus": {
			"model": "anthropic/claude-opus-4-8",
			"variant": "max",
			"fallback_models": [
				{
					"model": "openai/gpt-5.5",
					"variant": "medium"
				}
			]
		},
		"hephaestus": {
			"model": "openai/gpt-5.5",
			"variant": "medium"
		},
		"oracle": {
			"model": "openai/gpt-5.5",
			"variant": "high"
		},
		"librarian": {
			"model": "openai/gpt-5.4-mini-fast",
			"fallback_models": []
		},
		"explore": {
			"model": "openai/gpt-5.4-mini-fast",
			"fallback_models": []
		},
		"multimodal-looker": {
			"model": "openai/gpt-5.5",
			"variant": "medium",
			"fallback_models": []
		},
		"prometheus": {
			"model": "anthropic/claude-opus-4-8",
			"variant": "max",
		  "fallback_models": [
				{
					"model": "openai/gpt-5.5",
					"variant": "high"
				}
			]
		},
		"metis": {
			"model": "anthropic/claude-sonnet-4-6",
			"fallback_models": [
				{
					"model": "openai/gpt-5.5",
					"variant": "high"
				}
			]
		},
		"momus": {
			"model": "openai/gpt-5.5",
			"variant": "xhigh"
		},
		"atlas": {
			"model": "anthropic/claude-sonnet-4-6",
		  "fallback_models": [
				{
					"model": "openai/gpt-5.5",
					"variant": "medium"
				}
			]
		},
		"sisyphus-junior": {
			"model": "anthropic/claude-sonnet-4-6",
			"fallback_models": [
				{
					"model": "openai/gpt-5.5",
					"variant": "medium"
				}
			]
		}
	},
	"categories": {
		// Model Mapping Reference: https://github.com/code-yeongyu/oh-my-openagent/blob/dev/packages/model-core/src/category-model-requirements.ts
		"visual-engineering": {
			"model": "anthropic/claude-opus-4-8",
			"variant": "max",
			"fallback_models": [
				{
					"model": "openai/gpt-5.5",
					"variant": "medium"
				}
			]
		},
		"ultrabrain": {
			"model": "openai/gpt-5.5",
			"variant": "xhigh"
		},
		"deep": {
			"model": "openai/gpt-5.5",
			"variant": "medium"
		},
		"artistry": {
			"model": "anthropic/claude-opus-4-8",
			"variant": "max",
			"fallback_models": [
				{
					"model": "openai/gpt-5.5"
				}
			]
		},
		"quick": {
			"model": "openai/gpt-5.4-mini-fast"
		},
		"unspecified-low": {
			"model": "anthropic/claude-sonnet-4-6",
			"fallback_models": [
				{
					"model": "openai/gpt-5.3-codex",
					"variant": "medium"
				}
			]
		},
		"unspecified-high": {
			"model": "anthropic/claude-opus-4-8",
			"variant": "max",
			"fallback_models": [
				{
					"model": "openai/gpt-5.5",
					"variant": "high"
				}
			]
		},
		"writing": {
			"model": "anthropic/claude-sonnet-4-6"
		}
	},
	"disabled_mcps": ["playwright"],
	"disabled_skills": ["playwright"],
	"disabled_hooks": [
		"session-notification",
		"no-sisyphus-gpt",
		"claude-code-hooks"
	],
	"browser_automation_engine": { "provider": "playwright-cli" },
	"git_master": {
		"commit_footer": false,
		"include_co_authored_by": false,
		"git_env_prefix": "GIT_MASTER=1"
	},
	"notification": { "force_enable": true }
}
