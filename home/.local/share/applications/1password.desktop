[Desktop Entry]
Name=1Password
Actions=QuickAccess;
Exec=1password %U
Terminal=false
Type=Application
Icon=1password
StartupWMClass=1Password
Comment=Password manager and secure wallet
MimeType=x-scheme-handler/onepassword;
