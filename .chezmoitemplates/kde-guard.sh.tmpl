{{- /*
kde-guard.sh.tmpl — runtime KDE Plasma host guard.

Desktop detection is keyed on the shell binary the ISO shipped
(plasmashell, stable from first boot): exits 0 on a non-KDE host so the
same script deploys everywhere and self-selects at runtime.

Usage: {{ includeTemplate "kde-guard.sh.tmpl" "my-script-name" }}
*/ -}}
if ! command -v plasmashell >/dev/null 2>&1; then
  printf '%s: plasmashell not found (non-KDE system), skipping.\n' '{{ . }}'
  exit 0
fi
