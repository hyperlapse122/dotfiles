{{- /*
resolve-op-refs-json.tmpl — recursively render data as JSON while resolving
1Password references by VALUE, never by field name.

Input (dict):
  value     required; any map, slice, scalar, or null
  indent    optional; indentation of the value's containing line (default "")

Every string beginning exactly with "op://" is passed to onepasswordRead. Every
other scalar and type is serialized unchanged. Maps and slices recurse, so the
rule applies uniformly to heterogeneous provider options, nested headers, model
definitions, MCP data, and auth data without field-specific branches.

Map keys are emitted in deterministic lexical order.

Usage:
  {{ includeTemplate "resolve-op-refs-json.tmpl" (dict
       "value" .agents.opencode.providers
       "indent" "  ") }}
*/ -}}
{{- if not (kindIs "map" .) -}}
{{-   fail (printf "resolve-op-refs-json.tmpl: expected a dict, got %s" (kindOf .)) -}}
{{- end -}}
{{- if not (hasKey . "value") -}}
{{-   fail "resolve-op-refs-json.tmpl: missing required argument value" -}}
{{- end -}}
{{- $value := .value -}}
{{-   $indent := "" -}}
{{-   if hasKey . "indent" -}}{{- $indent = .indent -}}{{- end -}}
{{-   $childIndent := printf "%s  " $indent -}}
{{-   if kindIs "map" $value -}}
{{-     if eq (len $value) 0 -}}
{}
{{-     else -}}
{{-       $orderedKeys := keys $value | sortAlpha -}}
{
{{-       $last := sub (len $orderedKeys) 1 -}}
{{-       range $index, $key := $orderedKeys }}
{{ $childIndent }}{{ $key | toJson }}: {{ includeTemplate "resolve-op-refs-json.tmpl" (dict "value" (index $value $key) "indent" $childIndent) }}{{ if lt $index $last }},{{ end }}
{{-       end }}
{{ $indent }}}
{{-     end -}}
{{-   else if kindIs "slice" $value -}}
{{-     if eq (len $value) 0 -}}
[]
{{-     else -}}
[
{{-       $last := sub (len $value) 1 -}}
{{-       range $index, $item := $value }}
{{ $childIndent }}{{ includeTemplate "resolve-op-refs-json.tmpl" (dict "value" $item "indent" $childIndent) }}{{ if lt $index $last }},{{ end }}
{{-       end }}
{{ $indent }}]
{{-     end -}}
{{-   else if and (kindIs "string" $value) (hasPrefix "op://" $value) -}}
{{ onepasswordRead $value | toJson }}
{{-   else -}}
{{ $value | toJson }}
{{-   end -}}
