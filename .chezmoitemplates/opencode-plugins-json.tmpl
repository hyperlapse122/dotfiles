{{- /*
opencode-plugins-json.tmpl — resolve the data-driven OpenCode plugin list.

Input (dict):
  ctx     required; root chezmoi context
  target  required; opencode or tui

Each plugin declares its exact package source, installation form, version
resolver, and target-specific suffixes in .chezmoidata/agents.yaml. The output
is a compact JSON array for callers to parse and pretty-print.
*/ -}}
{{- if not (kindIs "map" .) -}}
{{-   fail (printf "opencode-plugins-json.tmpl: expected a dict, got %s" (kindOf .)) -}}
{{- end -}}
{{- if or (not (hasKey . "ctx")) (not (hasKey . "target")) -}}
{{-   fail "opencode-plugins-json.tmpl: ctx and target are required" -}}
{{- end -}}
{{- $ctx := .ctx -}}
{{- $target := .target -}}
{{- $specs := list -}}
{{- range $index, $plugin := $ctx.agents.opencode.plugins -}}
{{-   if not (kindIs "map" $plugin) -}}
{{-     fail (printf "opencode-plugins-json.tmpl: plugins[%d] must be a map" $index) -}}
{{-   end -}}
{{-   range $field := list "package" "install" "versionSource" "targets" -}}
{{-     if not (hasKey $plugin $field) -}}
{{-       fail (printf "opencode-plugins-json.tmpl: plugins[%d] is missing %s" $index $field) -}}
{{-     end -}}
{{-   end -}}
{{- /* source names the GitHub repo and is required only where it is consumed:
   versionSource=latestTag (gitHubLatestTag) and install=localArchive (the
   archive URL rendered by .chezmoiexternals/ai-agents.toml, which reads the
   same plugin entry). An npm package resolved from the registry
   (versionSource=npmLatest) may have no public repo, so source is optional
   there. */ -}}
{{-   if and (or (eq $plugin.versionSource "latestTag") (eq $plugin.install "localArchive")) (not (hasKey $plugin "source")) -}}
{{-     fail (printf "opencode-plugins-json.tmpl: plugins[%d] requires source for versionSource=latestTag or install=localArchive" $index) -}}
{{-   end -}}
{{-   $version := "" -}}
{{-   if eq $plugin.versionSource "latestTag" -}}
{{-     $version = (gitHubLatestTag $plugin.source).Name | trimPrefix "v" -}}
{{-   else if eq $plugin.versionSource "npmLatest" -}}
{{-     $version = output "curl" "-fsSL" (printf "https://registry.npmjs.org/%s/latest" $plugin.package) | fromJson | dig "version" "" -}}
{{-   else if eq $plugin.versionSource "compoundEngineeringRelease" -}}
{{-     $version = includeTemplate "compound-engineering-ref.tmpl" $ctx -}}
{{-   else -}}
{{-     fail (printf "opencode-plugins-json.tmpl: plugins[%d] has unknown versionSource %q" $index $plugin.versionSource) -}}
{{-   end -}}
{{-   $base := "" -}}
{{-   if eq $plugin.install "npm" -}}
{{-     if not (regexMatch "^[0-9]+\\.[0-9]+\\.[0-9]+([-.][0-9A-Za-z.-]+)?$" $version) -}}
{{-       fail (printf "opencode-plugins-json.tmpl: plugins[%d] resolved invalid npm version %q" $index $version) -}}
{{-     end -}}
{{-     $base = printf "%s@%s" $plugin.package $version -}}
{{-   else if eq $plugin.install "localArchive" -}}
{{-     if not (hasKey $plugin "externalPath") -}}
{{-       fail (printf "opencode-plugins-json.tmpl: plugins[%d] requires externalPath for install=localArchive" $index) -}}
{{-     end -}}
{{- /* Chezmoi extracts the release tarball to
   `$HOME/<externalPath>/v<version>/` in .chezmoiexternals/ai-agents.toml and
   .chezmoiscripts/00-tools/run_onchange_after_compound-engineering prunes
   siblings. Every agent then references the same fully-rendered absolute
   path. compoundEngineeringRelease yields tags of the form
   `compound-engineering-v<semver>`; trim the front-half prefix and keep the
   `v` so the on-disk segment matches the release tag's version suffix. */ -}}
{{-     $verSegment := "" -}}
{{-     if eq $plugin.versionSource "compoundEngineeringRelease" -}}
{{-       $verSegment = printf "v%s" (trimPrefix "compound-engineering-v" $version) -}}
{{-     else -}}
{{-       $verSegment = printf "v%s" (trimPrefix "v" $version) -}}
{{-     end -}}
{{-     $base = printf "%s/%s/%s" (trimSuffix "/" $ctx.chezmoi.homeDir) $plugin.externalPath $verSegment -}}
{{-   else -}}
{{-     fail (printf "opencode-plugins-json.tmpl: plugins[%d] has unknown install %q" $index $plugin.install) -}}
{{-   end -}}
{{-   if hasKey $plugin.targets $target -}}
{{-     range $suffix := index $plugin.targets $target -}}
{{-       $specs = append $specs (printf "%s%s" $base $suffix) -}}
{{-     end -}}
{{-   end -}}
{{- end -}}
{{- toJson $specs -}}
