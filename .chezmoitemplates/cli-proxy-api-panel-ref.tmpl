{{- /*
Shared CLIProxyAPI management control-panel release identity.

The panel is a single self-contained management.html asset published as a
release asset (no archive, no checksums sidecar) by router-for-me /
Cli-Proxy-API-Management-Center. This partial resolves, at render time, the
newest release tag, the asset sha256 (from the GitHub REST API asset digest),
the download URL, and an identity string composed of the tag and the digest
prefix — mirroring cli-proxy-api-ref.tmpl so a same-tag asset replacement
becomes a new candidate.

Production callers pass (dict "ctx" .). Deterministic tests may additionally
pass tag and digest to exercise validation without the network.
*/ -}}
{{- $repo := "router-for-me/Cli-Proxy-API-Management-Center" -}}
{{- $assetName := "management.html" -}}

{{- $tag := "" -}}
{{- $sha256 := "" -}}
{{- if hasKey . "tag" -}}
  {{- /* deterministic-test path: tag + digest supplied directly */ -}}
  {{- $tag = .tag | toString -}}
  {{- if hasKey . "digest" -}}{{- $sha256 = .digest | toString -}}{{- end -}}
{{- else -}}
  {{- /* githubLatestRelease authenticates via chezmoi's GITHUB_TOKEN; it
       resolves the tag but does not expose the asset digest field, so the
       digest is read from the REST API asset object separately. */ -}}
  {{- $rel := gitHubLatestRelease $repo -}}
  {{- $tag = $rel.TagName | toString -}}
  {{- $authHeader := "" -}}
  {{- with (env "GITHUB_TOKEN") -}}{{- $authHeader = printf "-H \"Authorization: Bearer %s\" " . -}}{{- end -}}
  {{- $apiJson := output "sh" "-c" (printf "curl -fsSL %shttps://api.github.com/repos/%s/releases/latest" $authHeader $repo) | toString -}}
  {{- $api := $apiJson | fromJson -}}
  {{- $matches := 0 -}}
  {{- range $api.assets -}}
    {{- if eq .name $assetName -}}
      {{- $sha256 = trimPrefix "sha256:" .digest -}}
      {{- $matches = add $matches 1 -}}
    {{- end -}}
  {{- end -}}
  {{- if ne $matches 1 -}}
    {{- fail (printf "cli-proxy-api panel: expected one %s asset, found %d" $assetName $matches) -}}
  {{- end -}}
{{- end -}}

{{- if not (regexMatch "^v[0-9]+\\.[0-9]+\\.[0-9]+$" $tag) -}}
  {{- fail (printf "cli-proxy-api panel: invalid release tag %q" $tag) -}}
{{- end -}}
{{- if not (regexMatch "^[0-9a-f]{64}$" $sha256) -}}
  {{- fail (printf "cli-proxy-api panel: invalid sha256 for %s" $assetName) -}}
{{- end -}}
{{- $version := trimPrefix "v" $tag -}}

{{- dict
  "tag" $tag
  "version" $version
  "asset" $assetName
  "sha256" $sha256
  "url" (printf "https://github.com/%s/releases/download/%s/%s" $repo $tag $assetName)
  "identity" (printf "%s-%s" $tag (substr 0 12 $sha256))
  | toJson -}}
